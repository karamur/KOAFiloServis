@inherits LayoutComponentBase

<div class="d-flex flex-column min-vh-100">
    <main class="flex-grow-1" style="padding-bottom: 70px;">
        @Body
    </main>

    <!-- Bottom Navigation -->
    <nav class="navbar fixed-bottom navbar-light bg-white border-top shadow-sm">
        <div class="container-fluid d-flex justify-content-around py-1">
            <a href="/" class="nav-item text-center text-decoration-none @GetNavItemClass("/")">
                <i class="bi bi-house-fill d-block" style="font-size: 1.25rem;"></i>
                <small>Ana Sayfa</small>
            </a>
            <a href="/seferler" class="nav-item text-center text-decoration-none @GetNavItemClass("/seferler")">
                <i class="bi bi-clock-history d-block" style="font-size: 1.25rem;"></i>
                <small>Seferler</small>
            </a>
            <a href="/masraf" class="nav-item text-center text-decoration-none @GetNavItemClass("/masraf")">
                <i class="bi bi-receipt d-block" style="font-size: 1.25rem;"></i>
                <small>Masraf</small>
            </a>
            <a href="/ayarlar" class="nav-item text-center text-decoration-none @GetNavItemClass("/ayarlar")">
                <i class="bi bi-gear d-block" style="font-size: 1.25rem;"></i>
                <small>Ayarlar</small>
            </a>
        </div>
    </nav>
</div>

@code {
    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private string GetNavItemClass(string href)
    {
        var currentUri = Navigation.ToBaseRelativePath(Navigation.Uri);

        if (string.IsNullOrEmpty(currentUri) && href == "/")
            return "text-primary";

        if (!string.IsNullOrEmpty(currentUri) && href != "/" && currentUri.StartsWith(href.TrimStart('/')))
            return "text-primary";

        return "text-muted";
    }
}
