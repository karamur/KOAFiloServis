@page "/seferler"
@using KOAFiloServis.Mobile.Services
@inject IApiService ApiService
@inject NavigationManager Navigation

<div class="container-fluid p-3">
    <div class="d-flex align-items-center mb-4">
        <button class="btn btn-link text-dark p-0 me-3" @onclick="GeriGit">
            <i class="bi bi-arrow-left fs-4"></i>
        </button>
        <h5 class="mb-0">Sefer Geçmişi</h5>
    </div>

    @if (_yukleniyor)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 text-muted">Yükleniyor...</p>
        </div>
    }
    else if (_seferler.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-truck text-muted" style="font-size: 4rem;"></i>
            <p class="mt-3 text-muted">Henüz sefer kaydınız bulunmuyor.</p>
        </div>
    }
    else
    {
        <!-- Filtre -->
        <div class="card mb-3">
            <div class="card-body p-2">
                <div class="row g-2">
                    <div class="col-6">
                        <select class="form-select form-select-sm" @bind="_filtreAy">
                            <option value="0">Tüm Aylar</option>
                            @for (int i = 1; i <= 12; i++)
                            {
                                <option value="@i">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)</option>
                            }
                        </select>
                    </div>
                    <div class="col-6">
                        <select class="form-select form-select-sm" @bind="_filtreYil">
                            @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 2; y--)
                            {
                                <option value="@y">@y</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Özet Kartları -->
        <div class="row g-2 mb-3">
            <div class="col-4">
                <div class="card text-center">
                    <div class="card-body p-2">
                        <h5 class="mb-0 text-primary">@FiltrelenmisListe.Count</h5>
                        <small class="text-muted">Sefer</small>
                    </div>
                </div>
            </div>
            <div class="col-4">
                <div class="card text-center">
                    <div class="card-body p-2">
                        <h5 class="mb-0 text-success">@ToplamKm.ToString("N0")</h5>
                        <small class="text-muted">KM</small>
                    </div>
                </div>
            </div>
            <div class="col-4">
                <div class="card text-center">
                    <div class="card-body p-2">
                        <h5 class="mb-0 text-info">@ToplamSaat.ToString("N1")</h5>
                        <small class="text-muted">Saat</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sefer Listesi -->
        @foreach (var sefer in FiltrelenmisListe)
        {
            <div class="card mb-2" @onclick="() => SeferDetayaGit(sefer.Id)">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="mb-1">@sefer.GuzergahAdi</h6>
                            <small class="text-muted d-block">
                                <i class="bi bi-car-front me-1"></i> @sefer.AracPlaka
                            </small>
                            <small class="text-muted d-block">
                                <i class="bi bi-calendar me-1"></i> @sefer.BaslangicZamani.ToString("dd MMM yyyy HH:mm")
                            </small>
                        </div>
                        <div class="text-end">
                            @if (sefer.Tamamlandi)
                            {
                                <span class="badge bg-success mb-1">Tamamlandı</span>
                            }
                            else
                            {
                                <span class="badge bg-warning mb-1">Devam Ediyor</span>
                            }
                            @if (sefer.ToplamKm > 0)
                            {
                                <small class="d-block text-muted">@sefer.ToplamKm.ToString("N0") km</small>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private bool _yukleniyor = true;
    private List<SeferOzet> _seferler = new();
    private int _filtreAy = 0;
    private int _filtreYil = DateTime.Now.Year;

    private List<SeferOzet> FiltrelenmisListe => _seferler
        .Where(s => _filtreAy == 0 || s.BaslangicZamani.Month == _filtreAy)
        .Where(s => s.BaslangicZamani.Year == _filtreYil)
        .OrderByDescending(s => s.BaslangicZamani)
        .ToList();

    private decimal ToplamKm => FiltrelenmisListe.Sum(s => s.ToplamKm);
    private decimal ToplamSaat => FiltrelenmisListe.Sum(s => 
        s.BitisZamani.HasValue ? (decimal)(s.BitisZamani.Value - s.BaslangicZamani).TotalHours : 0m);

    protected override async Task OnInitializedAsync()
    {
        await VerileriYukleAsync();
    }

    private async Task VerileriYukleAsync()
    {
        _yukleniyor = true;
        try
        {
            _seferler = await ApiService.SeferGecmisiniGetirAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Sefer geçmişi yükleme hatası: {ex.Message}");
        }
        finally
        {
            _yukleniyor = false;
        }
    }

    private void GeriGit() => Navigation.NavigateTo("/");
    private void SeferDetayaGit(int seferId) => Navigation.NavigateTo($"/sefer/{seferId}");
}
