@page "/"
@using KOAFiloServis.Mobile.Services
@inject IApiService ApiService
@inject NavigationManager Navigation

<div class="container-fluid p-3">
    @if (_yukleniyor)
    {
        <div class="d-flex justify-content-center align-items-center" style="height: 80vh;">
            <div class="text-center">
                <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;"></div>
                <p class="text-muted">Yükleniyor...</p>
                @if (!string.IsNullOrWhiteSpace(_yuklenmeDurumu))
                {
                    <p class="small text-muted mb-3">@_yuklenmeDurumu</p>
                }
                @if (!string.IsNullOrWhiteSpace(_yuklenmeHatasi))
                {
                    <div class="alert alert-warning text-start small">
                        <i class="bi bi-exclamation-triangle me-2"></i>@_yuklenmeHatasi
                    </div>
                    <div class="d-grid gap-2">
                        <button class="btn btn-outline-primary" @onclick="YenidenDeneAsync">
                            <i class="bi bi-arrow-clockwise me-2"></i>Yeniden Dene
                        </button>
                        <button class="btn btn-outline-secondary" @onclick="GiriseSayfasinaGit">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Giriş Ekranına Git
                        </button>
                    </div>
                }
            </div>
        </div>
    }
    else if (_kullanici == null)
    {
        <div class="text-center mt-5">
            <img src="images/logo.png" alt="Logo" class="mb-4" style="max-width: 150px;" />
            <h3 class="mb-4">Filo Servis Mobil</h3>
            <button class="btn btn-primary btn-lg w-100" @onclick="GiriseSayfasinaGit">
                <i class="bi bi-box-arrow-in-right me-2"></i> Giriş Yap
            </button>
        </div>
    }
    else
    {
        <!-- Hoşgeldin Header -->
        <div class="card bg-primary text-white mb-4">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-white text-primary p-3 me-3">
                        <i class="bi bi-person-fill fs-3"></i>
                    </div>
                    <div>
                        <h5 class="mb-0">Hoş geldin, @_kullanici.AdSoyad</h5>
                        <small class="opacity-75">@(_kullanici.Rol ?? "Şoför")</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Aktif Sefer Kartı -->
        @if (_aktifSefer != null)
        {
            <div class="card border-success mb-4">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-truck me-2"></i> Aktif Sefer</span>
                    <span class="badge bg-light text-success">Devam Ediyor</span>
                </div>
                <div class="card-body">
                    <h6>@_aktifSefer.GuzergahAdi</h6>
                    <p class="text-muted mb-2">
                        <i class="bi bi-car-front me-1"></i> @_aktifSefer.AracPlaka
                    </p>
                    <p class="text-muted mb-3">
                        <i class="bi bi-clock me-1"></i> Başlangıç: @_aktifSefer.BaslangicZamani.ToString("HH:mm")
                    </p>
                    <button class="btn btn-danger w-100" @onclick="SeferiBitirSayfasinaGit">
                        <i class="bi bi-stop-circle me-2"></i> Seferi Bitir
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="card mb-4">
                <div class="card-body text-center py-4">
                    <i class="bi bi-truck text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-2 mb-3">Aktif sefer bulunmuyor</p>
                    <button class="btn btn-success" @onclick="YeniSeferSayfasinaGit">
                        <i class="bi bi-play-circle me-2"></i> Yeni Sefer Başlat
                    </button>
                </div>
            </div>
        }

        <!-- Hızlı Aksiyonlar -->
        <h6 class="mb-3 text-muted">Hızlı İşlemler</h6>
        <div class="row g-3 mb-4">
            <div class="col-6">
                <div class="card h-100 text-center" @onclick="MasrafGirisiSayfasinaGit" style="cursor: pointer;">
                    <div class="card-body">
                        <i class="bi bi-receipt text-warning" style="font-size: 2rem;"></i>
                        <p class="mb-0 mt-2">Masraf Girişi</p>
                    </div>
                </div>
            </div>
            <div class="col-6">
                <div class="card h-100 text-center" @onclick="ArizaBildirSayfasinaGit" style="cursor: pointer;">
                    <div class="card-body">
                        <i class="bi bi-exclamation-triangle text-danger" style="font-size: 2rem;"></i>
                        <p class="mb-0 mt-2">Arıza Bildir</p>
                    </div>
                </div>
            </div>
            <div class="col-6">
                <div class="card h-100 text-center" @onclick="SeferGecmisiSayfasinaGit" style="cursor: pointer;">
                    <div class="card-body">
                        <i class="bi bi-clock-history text-info" style="font-size: 2rem;"></i>
                        <p class="mb-0 mt-2">Sefer Geçmişi</p>
                    </div>
                </div>
            </div>
            <div class="col-6">
                <div class="card h-100 text-center" @onclick="AyarlarSayfasinaGit" style="cursor: pointer;">
                    <div class="card-body">
                        <i class="bi bi-gear text-secondary" style="font-size: 2rem;"></i>
                        <p class="mb-0 mt-2">Ayarlar</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Araç Bilgisi -->
        @if (_araclar.Count > 0)
        {
            <h6 class="mb-3 text-muted">Atanan Araçlar</h6>
            @foreach (var arac in _araclar)
            {
                <div class="card mb-2">
                    <div class="card-body d-flex align-items-center">
                        <div class="rounded-circle bg-light p-2 me-3">
                            <i class="bi bi-truck text-primary"></i>
                        </div>
                        <div class="flex-grow-1">
                            <h6 class="mb-0">@arac.Plaka</h6>
                            <small class="text-muted">@arac.Marka @arac.Model</small>
                        </div>
                        <div class="text-end">
                            <small class="text-muted">@(arac.KmDurumu?.ToString("N0") ?? "-") km</small>
                        </div>
                    </div>
                </div>
            }
        }
    }
</div>

@code {
    private bool _yukleniyor = true;
    private bool _ilkYuklemeTamamlandi;
    private string? _yuklenmeDurumu;
    private string? _yuklenmeHatasi;
    private bool _giriseYonlendir;
    private KullaniciBilgisi? _kullanici;
    private SeferOzet? _aktifSefer;
    private List<AracOzet> _araclar = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _ilkYuklemeTamamlandi)
            return;

        _ilkYuklemeTamamlandi = true;
        await VerileriYukleAsync();

        if (_giriseYonlendir)
        {
            Navigation.NavigateTo("/giris", replace: true);
            return;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task VerileriYukleAsync()
    {
        _yukleniyor = true;
        _yuklenmeHatasi = null;
        _yuklenmeDurumu = "Oturum bilgileri kontrol ediliyor...";
        _giriseYonlendir = false;
        _kullanici = null;
        _aktifSefer = null;
        _araclar = new();

        try
        {
            var tokenYuklemeGorevi = ApiService.TokenYukleAsync();
            var tamamlanan = await Task.WhenAny(tokenYuklemeGorevi, Task.Delay(TimeSpan.FromSeconds(10)));

            if (tamamlanan != tokenYuklemeGorevi)
            {
                _yuklenmeHatasi = "Açılış sırasında sunucu veya yerel oturum bilgisi yanıt vermedi. Sunucu adresini kontrol edin.";
                return;
            }

            await tokenYuklemeGorevi;

            if (ApiService.TokenGecerliMi)
            {
                _yuklenmeDurumu = "Kullanıcı bilgileri alınıyor...";
                _kullanici = await ApiService.KullaniciBilgisiGetirAsync();

                if (_kullanici != null)
                {
                    _yuklenmeDurumu = "Sefer ve araç bilgileri yükleniyor...";
                    var seferler = await ApiService.AktifSeferleriGetirAsync();
                    _aktifSefer = seferler.FirstOrDefault();

                    _araclar = await ApiService.SoforAraclariniGetirAsync();
                }
                else
                {
                    await ApiService.CikisYapAsync();
                    _giriseYonlendir = true;
                }
            }
            else
            {
                _giriseYonlendir = true;
            }
        }
        catch (Exception ex)
        {
            _yuklenmeHatasi = $"Veri yükleme hatası: {ex.Message}";
            Console.WriteLine($"Veri yükleme hatası: {ex.Message}");
        }
        finally
        {
            _yukleniyor = false;
        }
    }

    private async Task YenidenDeneAsync()
    {
        await VerileriYukleAsync();
    }

    private void GiriseSayfasinaGit() => Navigation.NavigateTo("/giris");
    private void YeniSeferSayfasinaGit() => Navigation.NavigateTo("/sefer/yeni");
    private void SeferiBitirSayfasinaGit() => Navigation.NavigateTo($"/sefer/{_aktifSefer?.Id}/bitir");
    private void MasrafGirisiSayfasinaGit() => Navigation.NavigateTo("/masraf");
    private void ArizaBildirSayfasinaGit() => Navigation.NavigateTo("/ariza");
    private void SeferGecmisiSayfasinaGit() => Navigation.NavigateTo("/seferler");
    private void AyarlarSayfasinaGit() => Navigation.NavigateTo("/ayarlar");
}
