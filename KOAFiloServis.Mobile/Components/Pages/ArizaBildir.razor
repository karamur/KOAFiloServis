@page "/ariza"
@using KOAFiloServis.Mobile.Services
@inject IApiService ApiService
@inject IKonumService KonumService
@inject NavigationManager Navigation

<div class="container-fluid p-3">
    <div class="d-flex align-items-center mb-4">
        <button class="btn btn-link text-dark p-0 me-3" @onclick="GeriGit">
            <i class="bi bi-arrow-left fs-4"></i>
        </button>
        <h5 class="mb-0">Arıza Bildirimi</h5>
    </div>

    @if (_yukleniyor)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
        </div>
    }
    else
    {
        <EditForm Model="@_model" OnValidSubmit="ArizaBildirAsync">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrEmpty(_hataMesaji))
            {
                <div class="alert alert-danger mb-3">
                    <i class="bi bi-exclamation-circle me-2"></i>
                    @_hataMesaji
                </div>
            }

            @if (_basarili)
            {
                <div class="alert alert-success mb-3">
                    <i class="bi bi-check-circle me-2"></i>
                    Arıza bildirimi başarıyla gönderildi!
                </div>
            }

            <!-- Acil Durum Uyarısı -->
            <div class="alert alert-warning mb-3">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <strong>Acil durumlarda</strong> önce yetkilileri arayın!
            </div>

            <!-- Araç Seçimi -->
            <div class="card mb-3">
                <div class="card-header bg-white">
                    <i class="bi bi-truck me-2 text-primary"></i> Araç
                </div>
                <div class="card-body">
                    <InputSelect @bind-Value="_model.AracId" class="form-select">
                        <option value="0">Araç seçin...</option>
                        @foreach (var arac in _araclar)
                        {
                            <option value="@arac.Id">@arac.Plaka - @arac.Marka @arac.Model</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => _model.AracId)" class="text-danger small" />
                </div>
            </div>

            <!-- Arıza Tipi -->
            <div class="card mb-3">
                <div class="card-header bg-white">
                    <i class="bi bi-tools me-2 text-danger"></i> Arıza Tipi
                </div>
                <div class="card-body">
                    <div class="row g-2">
                        @foreach (var tip in _arizaTipleri)
                        {
                            <div class="col-6">
                                <div class="card @(_model.ArizaTipi == tip.Value ? "border-danger bg-danger bg-opacity-10" : "")" 
                                     @onclick="() => _model.ArizaTipi = tip.Value" style="cursor: pointer;">
                                    <div class="card-body p-2 text-center">
                                        <i class="bi @tip.Icon fs-3 @(_model.ArizaTipi == tip.Value ? "text-danger" : "text-muted")"></i>
                                        <small class="d-block mt-1">@tip.Label</small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    <ValidationMessage For="@(() => _model.ArizaTipi)" class="text-danger small" />
                </div>
            </div>

            <!-- Öncelik Seviyesi -->
            <div class="card mb-3">
                <div class="card-header bg-white">
                    <i class="bi bi-flag me-2 text-warning"></i> Öncelik
                </div>
                <div class="card-body">
                    <div class="btn-group w-100" role="group">
                        @foreach (var oncelik in _oncelikSeviyeleri)
                        {
                            <input type="radio" class="btn-check" id="@oncelik.Value" 
                                   checked="@(_model.OncelikSeviyesi == oncelik.Value)"
                                   @onchange="() => _model.OncelikSeviyesi = oncelik.Value" />
                            <label class="btn @(_model.OncelikSeviyesi == oncelik.Value ? oncelik.ActiveClass : "btn-outline-secondary")" 
                                   for="@oncelik.Value">
                                @oncelik.Label
                            </label>
                        }
                    </div>
                </div>
            </div>

            <!-- Açıklama -->
            <div class="card mb-3">
                <div class="card-header bg-white">
                    <i class="bi bi-chat-text me-2 text-info"></i> Arıza Açıklaması
                </div>
                <div class="card-body">
                    <InputTextArea @bind-Value="_model.Aciklama" class="form-control" rows="4" 
                                   placeholder="Arızayı detaylı olarak açıklayın..." />
                    <ValidationMessage For="@(() => _model.Aciklama)" class="text-danger small" />
                </div>
            </div>

            <!-- Fotoğraflar -->
            <div class="card mb-3">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-camera me-2 text-success"></i> Fotoğraflar</span>
                    <span class="badge bg-secondary">@_model.Fotograflar.Count / 5</span>
                </div>
                <div class="card-body">
                    @if (_model.Fotograflar.Count > 0)
                    {
                        <div class="row g-2 mb-3">
                            @foreach (var (foto, index) in _model.Fotograflar.Select((f, i) => (f, i)))
                            {
                                <div class="col-4">
                                    <div class="position-relative">
                                        <img src="data:image/jpeg;base64,@foto" 
                                             class="img-fluid rounded" style="height: 80px; object-fit: cover; width: 100%;" />
                                        <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0"
                                                style="padding: 0 4px;" @onclick="() => FotoSil(index)">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    @if (_model.Fotograflar.Count < 5)
                    {
                        <div class="d-grid gap-2">
                            <button type="button" class="btn btn-outline-primary btn-sm" @onclick="FotoCekAsync">
                                <i class="bi bi-camera me-1"></i> Fotoğraf Çek
                            </button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="GaleridenSecAsync">
                                <i class="bi bi-image me-1"></i> Galeriden Seç
                            </button>
                        </div>
                    }
                </div>
            </div>

            <!-- Konum -->
            <div class="card mb-4">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-geo-alt me-2 text-danger"></i> Konum</span>
                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="KonumAlAsync">
                        <i class="bi bi-crosshair"></i>
                    </button>
                </div>
                <div class="card-body">
                    @if (_konum != null)
                    {
                        <div class="text-success small">
                            <i class="bi bi-check-circle me-1"></i>
                            @_konum.Enlem.ToString("F5"), @_konum.Boylam.ToString("F5")
                        </div>
                    }
                    else
                    {
                        <div class="text-muted small">
                            Konumunuzu almak için butona tıklayın
                        </div>
                    }
                </div>
            </div>

            <!-- Gönder Butonu -->
            <button type="submit" class="btn btn-danger btn-lg w-100 py-3" disabled="@(_kaydediliyor || !FormGecerliMi)">
                @if (_kaydediliyor)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <span>Gönderiliyor...</span>
                }
                else
                {
                    <i class="bi bi-send me-2"></i>
                    <span>Arıza Bildir</span>
                }
            </button>
        </EditForm>
    }
</div>

@code {
    private ArizaModel _model = new();
    private List<AracOzet> _araclar = new();
    private KonumBilgisi? _konum;
    private string? _hataMesaji;
    private bool _basarili;
    private bool _yukleniyor = true;
    private bool _kaydediliyor;

    private bool FormGecerliMi => _model.AracId > 0 && 
                                   !string.IsNullOrEmpty(_model.ArizaTipi) && 
                                   !string.IsNullOrEmpty(_model.Aciklama);

    private class ArizaModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.Range(1, int.MaxValue, ErrorMessage = "Araç seçin")]
        public int AracId { get; set; }

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Arıza tipi seçin")]
        public string ArizaTipi { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Açıklama girin")]
        [System.ComponentModel.DataAnnotations.MinLength(10, ErrorMessage = "En az 10 karakter girin")]
        public string Aciklama { get; set; } = string.Empty;

        public string OncelikSeviyesi { get; set; } = "Orta";
        public List<string> Fotograflar { get; set; } = new();
    }

    private readonly List<(string Value, string Label, string Icon)> _arizaTipleri = new()
    {
        ("Motor", "Motor", "bi-gear"),
        ("Lastik", "Lastik", "bi-circle"),
        ("Fren", "Fren", "bi-stop-circle"),
        ("Elektrik", "Elektrik", "bi-lightning"),
        ("Kaza", "Kaza", "bi-car-front"),
        ("Diger", "Diğer", "bi-three-dots")
    };

    private readonly List<(string Value, string Label, string ActiveClass)> _oncelikSeviyeleri = new()
    {
        ("Dusuk", "Düşük", "btn-success"),
        ("Orta", "Orta", "btn-warning"),
        ("Yuksek", "Yüksek", "btn-orange text-white"),
        ("Acil", "ACİL", "btn-danger")
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _araclar = await ApiService.SoforAraclariniGetirAsync();
            
            if (_araclar.Count == 1)
            {
                _model.AracId = _araclar[0].Id;
            }

            // Otomatik konum al
            await KonumAlAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Hata: {ex.Message}");
        }
        finally
        {
            _yukleniyor = false;
        }
    }

    private async Task KonumAlAsync()
    {
        try
        {
            _konum = await KonumService.MevcutKonumuAlAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Konum hatası: {ex.Message}");
        }
    }

    private async Task ArizaBildirAsync()
    {
        if (!FormGecerliMi) return;

        _hataMesaji = null;
        _basarili = false;
        _kaydediliyor = true;

        try
        {
            var request = new ArizaBildirimRequest
            {
                AracId = _model.AracId,
                ArizaTipi = _model.ArizaTipi,
                Aciklama = _model.Aciklama,
                OncelikSeviyesi = _model.OncelikSeviyesi,
                Enlem = _konum?.Enlem,
                Boylam = _konum?.Boylam,
                FotografBase64 = _model.Fotograflar.Count > 0 ? _model.Fotograflar : null
            };

            var sonuc = await ApiService.ArizaBildirAsync(request);

            if (sonuc)
            {
                _basarili = true;
                _model = new ArizaModel
                {
                    AracId = _araclar.Count == 1 ? _araclar[0].Id : 0,
                    OncelikSeviyesi = "Orta"
                };
            }
            else
            {
                _hataMesaji = "Arıza bildirimi gönderilemedi.";
            }
        }
        catch (Exception ex)
        {
            _hataMesaji = "Bir hata oluştu.";
            Console.WriteLine($"Hata: {ex.Message}");
        }
        finally
        {
            _kaydediliyor = false;
        }
    }

    private async Task FotoCekAsync()
    {
        if (_model.Fotograflar.Count >= 5) return;

        try
        {
            if (MediaPicker.Default.IsCaptureSupported)
            {
                var photo = await MediaPicker.Default.CapturePhotoAsync();
                if (photo != null)
                {
                    using var stream = await photo.OpenReadAsync();
                    using var memoryStream = new MemoryStream();
                    await stream.CopyToAsync(memoryStream);
                    _model.Fotograflar.Add(Convert.ToBase64String(memoryStream.ToArray()));
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fotoğraf hatası: {ex.Message}");
        }
    }

    private async Task GaleridenSecAsync()
    {
        if (_model.Fotograflar.Count >= 5) return;

        try
        {
            var photos = await MediaPicker.Default.PickPhotosAsync();
            if (photos != null)
            {
                foreach (var photo in photos.Take(5 - _model.Fotograflar.Count))
                {
                    using var stream = await photo.OpenReadAsync();
                    using var memoryStream = new MemoryStream();
                    await stream.CopyToAsync(memoryStream);
                    _model.Fotograflar.Add(Convert.ToBase64String(memoryStream.ToArray()));
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Galeri hatası: {ex.Message}");
        }
    }

    private void FotoSil(int index)
    {
        if (index >= 0 && index < _model.Fotograflar.Count)
        {
            _model.Fotograflar.RemoveAt(index);
        }
    }

    private void GeriGit() => Navigation.NavigateTo("/");
}
