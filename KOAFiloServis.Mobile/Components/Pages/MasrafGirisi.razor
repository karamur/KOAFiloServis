@page "/masraf"
@using KOAFiloServis.Mobile.Services
@inject IApiService ApiService
@inject IKonumService KonumService
@inject NavigationManager Navigation

<div class="container-fluid p-3">
    <div class="d-flex align-items-center mb-4">
        <button class="btn btn-link text-dark p-0 me-3" @onclick="GeriGit">
            <i class="bi bi-arrow-left fs-4"></i>
        </button>
        <h5 class="mb-0">Masraf Girişi</h5>
    </div>

    @if (_yukleniyor)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 text-muted">Yükleniyor...</p>
        </div>
    }
    else
    {
        <EditForm Model="@_model" OnValidSubmit="MasrafKaydetAsync">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrEmpty(_hataMesaji))
            {
                <div class="alert alert-danger mb-3">
                    <i class="bi bi-exclamation-circle me-2"></i>
                    @_hataMesaji
                </div>
            }

            @if (_basarili)
            {
                <div class="alert alert-success mb-3">
                    <i class="bi bi-check-circle me-2"></i>
                    Masraf başarıyla kaydedildi!
                </div>
            }

            <!-- Araç Seçimi -->
            <div class="card mb-3">
                <div class="card-header bg-white">
                    <i class="bi bi-truck me-2 text-primary"></i> Araç
                </div>
                <div class="card-body">
                    <InputSelect @bind-Value="_model.AracId" class="form-select">
                        <option value="0">Araç seçin...</option>
                        @foreach (var arac in _araclar)
                        {
                            <option value="@arac.Id">@arac.Plaka - @arac.Marka @arac.Model</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => _model.AracId)" class="text-danger small" />
                </div>
            </div>

            <!-- Masraf Kalemi -->
            <div class="card mb-3">
                <div class="card-header bg-white">
                    <i class="bi bi-tag me-2 text-success"></i> Masraf Türü
                </div>
                <div class="card-body">
                    <div class="row g-2">
                        @foreach (var kalem in _masrafKalemleri)
                        {
                            <div class="col-4">
                                <div class="card text-center @(_model.MasrafKalemiId == kalem.Id ? "border-primary bg-light" : "")" 
                                     @onclick="() => _model.MasrafKalemiId = kalem.Id" style="cursor: pointer;">
                                    <div class="card-body p-2">
                                        <i class="bi @(kalem.Ikon ?? "bi-receipt") fs-4 text-primary"></i>
                                        <small class="d-block mt-1">@kalem.Ad</small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    <ValidationMessage For="@(() => _model.MasrafKalemiId)" class="text-danger small" />
                </div>
            </div>

            <!-- Tutar -->
            <div class="card mb-3">
                <div class="card-header bg-white">
                    <i class="bi bi-currency-lira me-2 text-warning"></i> Tutar
                </div>
                <div class="card-body">
                    <div class="input-group">
                        <span class="input-group-text">₺</span>
                        <InputNumber @bind-Value="_model.Tutar" class="form-control" placeholder="0.00" />
                    </div>
                    <ValidationMessage For="@(() => _model.Tutar)" class="text-danger small" />
                </div>
            </div>

            <!-- Tarih -->
            <div class="card mb-3">
                <div class="card-header bg-white">
                    <i class="bi bi-calendar me-2 text-info"></i> Tarih
                </div>
                <div class="card-body">
                    <InputDate @bind-Value="_model.Tarih" class="form-control" />
                </div>
            </div>

            <!-- KM Durumu -->
            <div class="card mb-3">
                <div class="card-header bg-white">
                    <i class="bi bi-speedometer me-2 text-secondary"></i> Kilometre (Opsiyonel)
                </div>
                <div class="card-body">
                    <InputNumber @bind-Value="_model.KmDurumu" class="form-control" placeholder="Araç KM durumu" />
                </div>
            </div>

            <!-- Açıklama -->
            <div class="card mb-3">
                <div class="card-header bg-white">
                    <i class="bi bi-sticky me-2 text-muted"></i> Açıklama (Opsiyonel)
                </div>
                <div class="card-body">
                    <InputTextArea @bind-Value="_model.Aciklama" class="form-control" rows="2" 
                                   placeholder="Masraf açıklaması..." />
                </div>
            </div>

            <!-- Fiş Fotoğrafı -->
            <div class="card mb-4">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-camera me-2 text-danger"></i> Fiş Fotoğrafı</span>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(_model.FisGorseliBase64))
                    {
                        <div class="position-relative">
                            <img src="data:image/jpeg;base64,@_model.FisGorseliBase64" 
                                 class="img-fluid rounded" style="max-height: 200px;" />
                            <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 m-1"
                                    @onclick="FotoSil">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="d-grid gap-2">
                            <button type="button" class="btn btn-outline-primary" @onclick="FotoCekAsync">
                                <i class="bi bi-camera me-2"></i> Fotoğraf Çek
                            </button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="GaleridenSecAsync">
                                <i class="bi bi-image me-2"></i> Galeriden Seç
                            </button>
                        </div>
                    }
                </div>
            </div>

            <!-- Kaydet Butonu -->
            <button type="submit" class="btn btn-primary btn-lg w-100 py-3" disabled="@(_kaydediliyor || !FormGecerliMi)">
                @if (_kaydediliyor)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <span>Kaydediliyor...</span>
                }
                else
                {
                    <i class="bi bi-check-circle me-2"></i>
                    <span>Masrafı Kaydet</span>
                }
            </button>
        </EditForm>
    }
</div>

@code {
    private MasrafModel _model = new();
    private List<AracOzet> _araclar = new();
    private List<MasrafKalemiOzet> _masrafKalemleri = new();
    private string? _hataMesaji;
    private bool _basarili;
    private bool _yukleniyor = true;
    private bool _kaydediliyor;

    private bool FormGecerliMi => _model.AracId > 0 && _model.MasrafKalemiId > 0 && _model.Tutar > 0;

    private class MasrafModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.Range(1, int.MaxValue, ErrorMessage = "Araç seçin")]
        public int AracId { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.Range(1, int.MaxValue, ErrorMessage = "Masraf türü seçin")]
        public int MasrafKalemiId { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.Range(0.01, double.MaxValue, ErrorMessage = "Geçerli bir tutar girin")]
        public decimal Tutar { get; set; }

        public DateTime Tarih { get; set; } = DateTime.Today;
        public int? KmDurumu { get; set; }
        public string? Aciklama { get; set; }
        public string? FisGorseliBase64 { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _araclar = await ApiService.SoforAraclariniGetirAsync();
            _masrafKalemleri = await ApiService.MasrafKalemleriGetirAsync();

            // Eğer masraf kalemleri boşsa varsayılan değerler
            if (_masrafKalemleri.Count == 0)
            {
                _masrafKalemleri = new List<MasrafKalemiOzet>
                {
                    new() { Id = 1, Ad = "Yakıt", Ikon = "bi-fuel-pump" },
                    new() { Id = 2, Ad = "Yol Ücreti", Ikon = "bi-signpost" },
                    new() { Id = 3, Ad = "Park", Ikon = "bi-p-circle" },
                    new() { Id = 4, Ad = "Yıkama", Ikon = "bi-droplet" },
                    new() { Id = 5, Ad = "Bakım", Ikon = "bi-wrench" },
                    new() { Id = 6, Ad = "Diğer", Ikon = "bi-three-dots" }
                };
            }

            if (_araclar.Count == 1)
            {
                _model.AracId = _araclar[0].Id;
            }
        }
        catch (Exception ex)
        {
            _hataMesaji = "Veriler yüklenirken hata oluştu.";
            Console.WriteLine($"Hata: {ex.Message}");
        }
        finally
        {
            _yukleniyor = false;
        }
    }

    private async Task MasrafKaydetAsync()
    {
        if (!FormGecerliMi) return;

        _hataMesaji = null;
        _basarili = false;
        _kaydediliyor = true;

        try
        {
            // Konum al
            var konum = await KonumService.MevcutKonumuAlAsync();

            var request = new MasrafKayitRequest
            {
                AracId = _model.AracId,
                MasrafKalemiId = _model.MasrafKalemiId,
                Tutar = _model.Tutar,
                Tarih = _model.Tarih,
                Aciklama = _model.Aciklama,
                KmDurumu = _model.KmDurumu,
                Enlem = konum?.Enlem,
                Boylam = konum?.Boylam,
                FisGorseliBase64 = _model.FisGorseliBase64
            };

            var sonuc = await ApiService.MasrafKaydetAsync(request);

            if (sonuc)
            {
                _basarili = true;
                // Formu sıfırla
                _model = new MasrafModel
                {
                    AracId = _araclar.Count == 1 ? _araclar[0].Id : 0,
                    Tarih = DateTime.Today
                };
            }
            else
            {
                _hataMesaji = "Masraf kaydedilemedi. Lütfen tekrar deneyin.";
            }
        }
        catch (Exception ex)
        {
            _hataMesaji = "Bir hata oluştu. Lütfen tekrar deneyin.";
            Console.WriteLine($"Masraf kayıt hatası: {ex.Message}");
        }
        finally
        {
            _kaydediliyor = false;
        }
    }

    private async Task FotoCekAsync()
    {
        try
        {
            if (MediaPicker.Default.IsCaptureSupported)
            {
                var photo = await MediaPicker.Default.CapturePhotoAsync();
                if (photo != null)
                {
                    using var stream = await photo.OpenReadAsync();
                    using var memoryStream = new MemoryStream();
                    await stream.CopyToAsync(memoryStream);
                    _model.FisGorseliBase64 = Convert.ToBase64String(memoryStream.ToArray());
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fotoğraf çekme hatası: {ex.Message}");
        }
    }

    private async Task GaleridenSecAsync()
    {
        try
        {
            var photos = await MediaPicker.Default.PickPhotosAsync();
            var photo = photos?.FirstOrDefault();
            if (photo != null)
            {
                using var stream = await photo.OpenReadAsync();
                using var memoryStream = new MemoryStream();
                await stream.CopyToAsync(memoryStream);
                _model.FisGorseliBase64 = Convert.ToBase64String(memoryStream.ToArray());
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Galeri seçim hatası: {ex.Message}");
        }
    }

    private void FotoSil()
    {
        _model.FisGorseliBase64 = null;
    }

    private void GeriGit() => Navigation.NavigateTo("/");
}
