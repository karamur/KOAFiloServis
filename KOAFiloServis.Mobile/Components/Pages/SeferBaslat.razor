@page "/sefer/yeni"
@using KOAFiloServis.Mobile.Services
@inject IApiService ApiService
@inject IKonumService KonumService
@inject NavigationManager Navigation

<div class="container-fluid p-3">
    <div class="d-flex align-items-center mb-4">
        <button class="btn btn-link text-dark p-0 me-3" @onclick="GeriGit">
            <i class="bi bi-arrow-left fs-4"></i>
        </button>
        <h5 class="mb-0">Yeni Sefer Başlat</h5>
    </div>

    @if (_yukleniyor)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 text-muted">Yükleniyor...</p>
        </div>
    }
    else
    {
        <EditForm Model="@_model" OnValidSubmit="SeferBaslatAsync">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrEmpty(_hataMesaji))
            {
                <div class="alert alert-danger mb-3">
                    <i class="bi bi-exclamation-circle me-2"></i>
                    @_hataMesaji
                </div>
            }

            <!-- Araç Seçimi -->
            <div class="card mb-3">
                <div class="card-header bg-white">
                    <i class="bi bi-truck me-2 text-primary"></i> Araç Seçimi
                </div>
                <div class="card-body">
                    @if (_araclar.Count == 0)
                    {
                        <p class="text-muted mb-0">Size atanmış araç bulunamadı.</p>
                    }
                    else
                    {
                        <div class="row g-2">
                            @foreach (var arac in _araclar)
                            {
                                <div class="col-12">
                                    <div class="card @(_model.AracId == arac.Id ? "border-primary bg-light" : "")" 
                                         @onclick="() => AracSec(arac)" style="cursor: pointer;">
                                        <div class="card-body p-2 d-flex align-items-center">
                                            <div class="form-check mb-0">
                                                <input type="radio" class="form-check-input" 
                                                       checked="@(_model.AracId == arac.Id)" 
                                                       @onchange="() => AracSec(arac)" />
                                            </div>
                                            <div class="ms-2 flex-grow-1">
                                                <strong>@arac.Plaka</strong>
                                                <small class="text-muted d-block">@arac.Marka @arac.Model</small>
                                            </div>
                                            <small class="text-muted">@(arac.KmDurumu?.ToString("N0") ?? "-") km</small>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Güzergah Seçimi -->
            <div class="card mb-3">
                <div class="card-header bg-white">
                    <i class="bi bi-signpost me-2 text-success"></i> Güzergah
                </div>
                <div class="card-body">
                    <InputSelect @bind-Value="_model.GuzergahId" class="form-select">
                        <option value="0">Güzergah seçin...</option>
                        @foreach (var guzergah in _guzergahlar)
                        {
                            <option value="@guzergah.Id">@guzergah.Ad</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => _model.GuzergahId)" class="text-danger small" />
                </div>
            </div>

            <!-- KM Durumu -->
            <div class="card mb-3">
                <div class="card-header bg-white">
                    <i class="bi bi-speedometer me-2 text-warning"></i> Kilometre
                </div>
                <div class="card-body">
                    <InputNumber @bind-Value="_model.BaslangicKm" class="form-control" placeholder="Başlangıç KM" />
                    <small class="text-muted">Araç kilometre durumunu girin</small>
                    <ValidationMessage For="@(() => _model.BaslangicKm)" class="text-danger small" />
                </div>
            </div>

            <!-- Konum Bilgisi -->
            <div class="card mb-3">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-geo-alt me-2 text-danger"></i> Konum</span>
                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="KonumAlAsync">
                        <i class="bi bi-crosshair me-1"></i> Konumu Al
                    </button>
                </div>
                <div class="card-body">
                    @if (_konum != null)
                    {
                        <div class="d-flex align-items-center text-success">
                            <i class="bi bi-check-circle me-2"></i>
                            <span>Konum alındı: @_konum.Enlem.ToString("F5"), @_konum.Boylam.ToString("F5")</span>
                        </div>
                    }
                    else if (_konumHatasi != null)
                    {
                        <div class="text-danger">
                            <i class="bi bi-exclamation-circle me-2"></i>
                            @_konumHatasi
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">
                            <i class="bi bi-info-circle me-2"></i>
                            Başlangıç konumu için butona tıklayın
                        </div>
                    }
                </div>
            </div>

            <!-- Notlar -->
            <div class="card mb-4">
                <div class="card-header bg-white">
                    <i class="bi bi-sticky me-2 text-info"></i> Notlar (Opsiyonel)
                </div>
                <div class="card-body">
                    <InputTextArea @bind-Value="_model.Notlar" class="form-control" rows="2" 
                                   placeholder="Sefer ile ilgili not ekleyin..." />
                </div>
            </div>

            <!-- Başlat Butonu -->
            <button type="submit" class="btn btn-success btn-lg w-100 py-3" disabled="@(_kaydediliyor || !FormGecerliMi)">
                @if (_kaydediliyor)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <span>Başlatılıyor...</span>
                }
                else
                {
                    <i class="bi bi-play-circle me-2"></i>
                    <span>Seferi Başlat</span>
                }
            </button>
        </EditForm>
    }
</div>

@code {
    private SeferBaslatModel _model = new();
    private List<AracOzet> _araclar = new();
    private List<GuzergahOzet> _guzergahlar = new();
    private KonumBilgisi? _konum;
    private string? _konumHatasi;
    private string? _hataMesaji;
    private bool _yukleniyor = true;
    private bool _kaydediliyor;

    private bool FormGecerliMi => _model.AracId > 0 && _model.GuzergahId > 0 && _model.BaslangicKm > 0;

    private class SeferBaslatModel
    {
        public int AracId { get; set; }

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Güzergah seçin")]
        [System.ComponentModel.DataAnnotations.Range(1, int.MaxValue, ErrorMessage = "Güzergah seçin")]
        public int GuzergahId { get; set; }

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Başlangıç KM girin")]
        [System.ComponentModel.DataAnnotations.Range(1, 9999999, ErrorMessage = "Geçerli bir KM değeri girin")]
        public int BaslangicKm { get; set; }

        public string? Notlar { get; set; }
    }

    private class GuzergahOzet
    {
        public int Id { get; set; }
        public string Ad { get; set; } = string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Araçları yükle
            _araclar = await ApiService.SoforAraclariniGetirAsync();
            
            if (_araclar.Count == 1)
            {
                AracSec(_araclar[0]);
            }

            // Güzergahları yükle (TODO: API'den alınacak)
            _guzergahlar = new List<GuzergahOzet>
            {
                new() { Id = 1, Ad = "İstanbul - Ankara" },
                new() { Id = 2, Ad = "İstanbul - İzmir" },
                new() { Id = 3, Ad = "Ankara - Konya" }
            };
        }
        catch (Exception ex)
        {
            _hataMesaji = "Veriler yüklenirken hata oluştu.";
            Console.WriteLine($"Hata: {ex.Message}");
        }
        finally
        {
            _yukleniyor = false;
        }
    }

    private void AracSec(AracOzet arac)
    {
        _model.AracId = arac.Id;
        if (arac.KmDurumu.HasValue && _model.BaslangicKm == 0)
        {
            _model.BaslangicKm = arac.KmDurumu.Value;
        }
    }

    private async Task KonumAlAsync()
    {
        _konumHatasi = null;
        
        try
        {
            _konum = await KonumService.MevcutKonumuAlAsync();
            
            if (_konum == null)
            {
                var izinVar = await KonumService.KonumIzniIsteAsync();
                if (!izinVar)
                {
                    _konumHatasi = "Konum izni verilmedi. Ayarlardan izin verin.";
                }
                else
                {
                    _konumHatasi = "Konum alınamadı. GPS'in açık olduğundan emin olun.";
                }
            }
        }
        catch (Exception ex)
        {
            _konumHatasi = "Konum alınırken hata oluştu.";
            Console.WriteLine($"Konum hatası: {ex.Message}");
        }
    }

    private async Task SeferBaslatAsync()
    {
        if (!FormGecerliMi) return;

        _hataMesaji = null;
        _kaydediliyor = true;

        try
        {
            var request = new SeferBaslatRequest
            {
                AracId = _model.AracId,
                GuzergahId = _model.GuzergahId,
                BaslangicKm = _model.BaslangicKm,
                BaslangicEnlem = _konum?.Enlem,
                BaslangicBoylam = _konum?.Boylam,
                Notlar = _model.Notlar
            };

            var sonuc = await ApiService.SeferBaslatAsync(request);
            
            if (sonuc != null)
            {
                // Konum takibini başlat
                await KonumService.TakipBaslatAsync();
                
                Navigation.NavigateTo("/", replace: true);
            }
            else
            {
                _hataMesaji = "Sefer başlatılamadı. Lütfen tekrar deneyin.";
            }
        }
        catch (Exception ex)
        {
            _hataMesaji = "Bir hata oluştu. Lütfen tekrar deneyin.";
            Console.WriteLine($"Sefer başlatma hatası: {ex.Message}");
        }
        finally
        {
            _kaydediliyor = false;
        }
    }

    private void GeriGit() => Navigation.NavigateTo("/");
}
