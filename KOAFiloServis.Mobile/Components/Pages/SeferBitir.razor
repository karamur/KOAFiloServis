@page "/sefer/{SeferId:int}/bitir"
@using KOAFiloServis.Mobile.Services
@inject IApiService ApiService
@inject IKonumService KonumService
@inject NavigationManager Navigation

<div class="container-fluid p-3">
    <div class="d-flex align-items-center mb-4">
        <button class="btn btn-link text-dark p-0 me-3" @onclick="GeriGit">
            <i class="bi bi-arrow-left fs-4"></i>
        </button>
        <h5 class="mb-0">Seferi Bitir</h5>
    </div>

    @if (_yukleniyor)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 text-muted">Yükleniyor...</p>
        </div>
    }
    else if (_sefer == null)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Sefer bilgisi bulunamadı.
        </div>
    }
    else
    {
        <!-- Sefer Bilgileri -->
        <div class="card mb-3 border-primary">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-truck me-2"></i> Aktif Sefer Bilgileri
            </div>
            <div class="card-body">
                <p class="mb-2"><strong>Güzergah:</strong> @_sefer.GuzergahAdi</p>
                <p class="mb-2"><strong>Araç:</strong> @_sefer.AracPlaka</p>
                <p class="mb-2"><strong>Başlangıç:</strong> @_sefer.BaslangicZamani.ToString("dd MMM yyyy HH:mm")</p>
                <p class="mb-0"><strong>Süre:</strong> @SureyiHesapla()</p>
            </div>
        </div>

        <EditForm Model="@_model" OnValidSubmit="SeferiBitirAsync">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrEmpty(_hataMesaji))
            {
                <div class="alert alert-danger mb-3">
                    <i class="bi bi-exclamation-circle me-2"></i>
                    @_hataMesaji
                </div>
            }

            <!-- Bitiş KM -->
            <div class="card mb-3">
                <div class="card-header bg-white">
                    <i class="bi bi-speedometer me-2 text-warning"></i> Bitiş Kilometresi
                </div>
                <div class="card-body">
                    <InputNumber @bind-Value="_model.BitisKm" class="form-control" placeholder="Bitiş KM" />
                    <small class="text-muted">Başlangıç KM: @_sefer.BaslangicKm?.ToString("N0")</small>
                    <ValidationMessage For="@(() => _model.BitisKm)" class="text-danger small" />
                    
                    @if (_model.BitisKm > 0 && _sefer.BaslangicKm.HasValue)
                    {
                        var fark = _model.BitisKm - _sefer.BaslangicKm.Value;
                        <div class="mt-2 text-info">
                            <i class="bi bi-arrow-right me-1"></i>
                            Toplam: <strong>@fark.ToString("N0") km</strong>
                        </div>
                    }
                </div>
            </div>

            <!-- Konum Bilgisi -->
            <div class="card mb-3">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-geo-alt me-2 text-danger"></i> Bitiş Konumu</span>
                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="KonumAlAsync">
                        <i class="bi bi-crosshair me-1"></i> Konumu Al
                    </button>
                </div>
                <div class="card-body">
                    @if (_konum != null)
                    {
                        <div class="d-flex align-items-center text-success">
                            <i class="bi bi-check-circle me-2"></i>
                            <span>Konum alındı: @_konum.Enlem.ToString("F5"), @_konum.Boylam.ToString("F5")</span>
                        </div>
                    }
                    else if (_konumHatasi != null)
                    {
                        <div class="text-danger">
                            <i class="bi bi-exclamation-circle me-2"></i>
                            @_konumHatasi
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">
                            <i class="bi bi-info-circle me-2"></i>
                            Bitiş konumu için butona tıklayın
                        </div>
                    }
                </div>
            </div>

            <!-- Notlar -->
            <div class="card mb-4">
                <div class="card-header bg-white">
                    <i class="bi bi-sticky me-2 text-info"></i> Notlar (Opsiyonel)
                </div>
                <div class="card-body">
                    <InputTextArea @bind-Value="_model.Notlar" class="form-control" rows="2" 
                                   placeholder="Sefer ile ilgili not ekleyin..." />
                </div>
            </div>

            <!-- Bitir Butonu -->
            <button type="submit" class="btn btn-danger btn-lg w-100 py-3" disabled="@(_kaydediliyor || !FormGecerliMi)">
                @if (_kaydediliyor)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <span>Kaydediliyor...</span>
                }
                else
                {
                    <i class="bi bi-stop-circle me-2"></i>
                    <span>Seferi Bitir</span>
                }
            </button>
        </EditForm>
    }
</div>

@code {
    [Parameter]
    public int SeferId { get; set; }

    private bool _yukleniyor = true;
    private bool _kaydediliyor;
    private string? _hataMesaji;
    private string? _konumHatasi;
    private SeferOzet? _sefer;
    private KonumBilgisi? _konum;
    private SeferBitirModel _model = new();

    private bool FormGecerliMi => _model.BitisKm > 0 && 
                                   (_sefer?.BaslangicKm == null || _model.BitisKm >= _sefer.BaslangicKm);

    protected override async Task OnInitializedAsync()
    {
        await VerileriYukleAsync();
    }

    private async Task VerileriYukleAsync()
    {
        _yukleniyor = true;
        try
        {
            _sefer = await ApiService.SeferGetirAsync(SeferId);
            if (_sefer != null && _sefer.BaslangicKm.HasValue)
            {
                _model.BitisKm = _sefer.BaslangicKm.Value;
            }
        }
        catch (Exception ex)
        {
            _hataMesaji = "Sefer bilgisi yüklenemedi: " + ex.Message;
        }
        finally
        {
            _yukleniyor = false;
        }
    }

    private async Task KonumAlAsync()
    {
        _konumHatasi = null;
        try
        {
            _konum = await KonumService.MevcutKonumuAlAsync();
            if (_konum == null)
            {
                _konumHatasi = "Konum alınamadı. Konum izinlerini kontrol edin.";
            }
        }
        catch (Exception ex)
        {
            _konumHatasi = "Konum hatası: " + ex.Message;
        }
    }

    private async Task SeferiBitirAsync()
    {
        if (_kaydediliyor || !FormGecerliMi) return;

        _kaydediliyor = true;
        _hataMesaji = null;

        try
        {
            _model.SeferId = SeferId;
            _model.BitisEnlem = _konum?.Enlem;
            _model.BitisBoylam = _konum?.Boylam;

            var sonuc = await ApiService.SeferBitirAsync(_model);
            if (sonuc)
            {
                Navigation.NavigateTo("/", forceLoad: true);
            }
            else
            {
                _hataMesaji = "Sefer bitirilemedi. Lütfen tekrar deneyin.";
            }
        }
        catch (Exception ex)
        {
            _hataMesaji = "Hata: " + ex.Message;
        }
        finally
        {
            _kaydediliyor = false;
        }
    }

    private string SureyiHesapla()
    {
        if (_sefer == null) return "-";
        var sure = DateTime.Now - _sefer.BaslangicZamani;
        if (sure.TotalHours >= 1)
            return $"{(int)sure.TotalHours} saat {sure.Minutes} dk";
        return $"{sure.Minutes} dakika";
    }

    private void GeriGit() => Navigation.NavigateTo("/");

    public class SeferBitirModel
    {
        public int SeferId { get; set; }
        public decimal BitisKm { get; set; }
        public double? BitisEnlem { get; set; }
        public double? BitisBoylam { get; set; }
        public string? Notlar { get; set; }
    }
}
