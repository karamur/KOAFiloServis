{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=crmfilo;Username=postgres;Password=CrmFilo2026!"
  },
  "DatabaseProvider": "PostgreSQL",
  "Application": {
    "Name": "CRM Filo Servis",
    "Version": "1.0.0",
    "Environment": "Production"
  },
  "AdminPanel": {
    "Enabled": true,
    "RequireAuth": true,
    "AllowedIPs": ["127.0.0.1", "::1", "192.168.0.0/16", "10.0.0.0/8"],
    "SessionTimeout": 30,
    "MaxLoginAttempts": 5,
    "LockoutDuration": 15
  },
  "Redis": {
    "Enabled": true,
    "ConnectionString": "localhost:6379",
    "InstanceName": "CRMFilo_",
    "DefaultExpiration": 3600
  },
  "Security": {
    "EnableSensitiveDataLogging": false,
    "RequireLicense": true,
    "JwtSecret": "YOUR_SUPER_SECRET_KEY_CHANGE_THIS_IN_PRODUCTION_2026",
    "TokenExpiration": 60,
    "RefreshTokenExpiration": 1440
  },
  "Licensing": {
    "Mode": "File",
    "LicensePath": "license.key",
    "CheckInterval": 3600,
    "GracePeriodDays": 7
  },
  "Backup": {
    "Enabled": true,
    "Schedule": "0 2 * * *",
    "Path": "backups/",
    "RetentionDays": 30,
    "IncludeLogs": false,
    "Compression": true
  },
  "Email": {
    "Enabled": false,
    "SmtpHost": "smtp.example.com",
    "SmtpPort": 587,
    "UseSsl": true,
    "Username": "",
    "Password": "",
    "FromAddress": "noreply@crmfiloservis.com",
    "FromName": "CRM Filo Servis"
  },
  "Monitoring": {
    "EnableMetrics": true,
    "MetricsPath": "/metrics",
    "EnableHealthChecks": true,
    "HealthCheckPath": "/health"
  },
  "RateLimiting": {
    "Enabled": true,
    "PermitLimit": 100,
    "Window": 60,
    "QueueLimit": 10
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000", "https://www.crmfiloservis.com"],
    "AllowCredentials": true
  },
  "Features": {
    "MultiTenant": false,
    "ApiEnabled": true,
    "WebhooksEnabled": false,
    "AuditLogEnabled": true
  }
}
