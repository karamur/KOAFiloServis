    private List<FaturaAIKalem> GetYeniGuzergahKalemler()
    {
        if (analizSonuc == null) return [];
        return analizSonuc.Kalemler
            .Where(k => k.GuzergahEslesme != null && k.GuzergahEslesme.YeniGuzergahOlusturulacak && !k.GuzergahEslesme.GuzergahMevcut)
            .ToList();
    }

