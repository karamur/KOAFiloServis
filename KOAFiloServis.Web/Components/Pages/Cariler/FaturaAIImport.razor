        }
    }

    private async Task Adim3Gec()
    {
        if (analizSonuc == null) return;

        yukleniyor = true;
        yukleniyorMesaj = "AI kalem sınıflandırması yapılıyor...";
        StateHasChanged();

        try
        {
            // Kalem sınıflandırması AI tarafından zaten yapıldı, ek analiz gerekirse burada
            aktifAdim = 3;
        }
        finally
        {
            yukleniyor = false;
        }
    }

    private async Task Adim4Gec()
    {
        if (analizSonuc == null) return;

        yukleniyor = true;
        yukleniyorMesaj = "Fatura ve ilişkili kayıtlar oluşturuluyor...";
        StateHasChanged();

        try
        {
            kaydetSonuc = await AiImportService.KaydetAsync(analizSonuc, null);
            aktifAdim = 4;
        }
        catch (Exception ex)
        {
            kaydetSonuc = new FaturaAIKaydetSonuc
            {
                Basarili = false,
                Mesaj = $"Hata: {ex.Message}"
            };
            aktifAdim = 4;
        }
        finally
        {
            yukleniyor = false;
        }
    }

    private void YeniImport()
    {
        aktifAdim = 1;
        analizSonuc = null;
        kaydetSonuc = null;
        hataMesaji = null;
        farkliCariSec = false;
        mevcutCariSec = false;
    }

    private void KalemTipiDegisti(FaturaAIKalem kalem)
    {
        kalem.KullaniciDuzeltti = true;
        // Alt tipi sıfırla
        kalem.KullaniciAltTipi = null;
    }

    private void GuzergahSecildi(FaturaAIKalem kalem, ChangeEventArgs e)
    {
        if (kalem.GuzergahEslesme == null) return;
        var val = e.Value?.ToString();

        if (val == "yeni" || string.IsNullOrEmpty(val))
        {
            kalem.GuzergahEslesme.GuzergahMevcut = false;
            kalem.GuzergahEslesme.YeniGuzergahOlusturulacak = true;
            return;
        }

        if (int.TryParse(val, out var guzergahId))
        {
            var benzer = kalem.GuzergahEslesme.BenzerGuzergahlar.FirstOrDefault(b => b.GuzergahId == guzergahId);
            if (benzer != null)
            {
                kalem.GuzergahEslesme.GuzergahMevcut = true;
                kalem.GuzergahEslesme.MevcutGuzergahId = benzer.GuzergahId;
                kalem.GuzergahEslesme.MevcutGuzergahAdi = benzer.GuzergahAdi;
                kalem.GuzergahEslesme.MevcutGuzergahKodu = benzer.GuzergahKodu;
                kalem.GuzergahEslesme.MevcutBirimFiyat = benzer.BirimFiyat;
                kalem.GuzergahEslesme.YeniGuzergahOlusturulacak = false;
            }
        }
    }

    private void StokSecildi(FaturaAIKalem kalem, ChangeEventArgs e)
    {
        if (kalem.StokEslesme == null) return;

        if (int.TryParse(e.Value?.ToString(), out var stokId))
        {
            var benzer = kalem.StokEslesme.BenzerStoklar.FirstOrDefault(b => b.StokId == stokId);
            if (benzer != null)
            {
                kalem.StokEslesme.StokMevcut = true;
                kalem.StokEslesme.MevcutStokId = benzer.StokId;
                kalem.StokEslesme.MevcutStokKodu = benzer.StokKodu;
                kalem.StokEslesme.MevcutStokAdi = benzer.StokAdi;
                kalem.StokEslesme.MevcutFiyat = benzer.Fiyat;
            }
        }
    }

