@page "/tedarikci-servis/personel"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@inject ISoforService SoforService
@inject ITasimaTedarikciService TasimaTedarikciService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Tedarikçi Personel Listesi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-people me-2"></i>Tedarikçi Personel Listesi</h3>
        <button class="btn btn-outline-secondary" @onclick='() => Navigation.NavigateTo("/personel-tasima/tedarikciler")'>
            <i class="bi bi-truck me-1"></i>Tedarikçi Yönetimi
        </button>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body bg-light">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small">Ara (Ad, Kod, Telefon)</label>
                    <input class="form-control form-control-sm" @bind="arama" @bind:event="oninput" placeholder="Arama..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Tedarikçi</label>
                    <select class="form-select form-select-sm" @bind="seciliTedarikciId">
                        <option value="0">Tümü</option>
                        @foreach (var t in tedarikciler)
                        {
                            <option value="@t.Id">@t.Unvan</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Görev</label>
                    <select class="form-select form-select-sm" @bind="secilenGorev">
                        <option value="">Tüm Görevler</option>
                        @foreach (PersonelGorev gorev in Enum.GetValues(typeof(PersonelGorev)))
                        {
                            <option value="@gorev">@GetGorevAdi(gorev)</option>
                        }
                    </select>
                </div>
                <div class="col-md-4 d-flex justify-content-between align-items-end gap-2">
                    <div class="btn-group btn-group-sm" role="group" aria-label="Durum filtresi">
                        <button type="button" class="btn @(secilenAktifDurum == "" ? "btn-secondary" : "btn-outline-secondary")" @onclick='() => secilenAktifDurum = ""'>Tümü</button>
                        <button type="button" class="btn @(secilenAktifDurum == "aktif" ? "btn-success" : "btn-outline-success")" @onclick='() => secilenAktifDurum = "aktif"'>Aktif</button>
                        <button type="button" class="btn @(secilenAktifDurum == "pasif" ? "btn-danger" : "btn-outline-danger")" @onclick='() => secilenAktifDurum = "pasif"'>Pasif</button>
                    </div>
                    <button class="btn btn-sm btn-primary" @onclick='() => Navigation.NavigateTo("/personel")'>
                        <i class="bi bi-grid me-1"></i>Tüm Personel Sayfası
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (yukleniyor)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else if (!FiltreliPersonel.Any())
    {
        <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>Kayıt bulunamadı.</div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0 align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Kod</th>
                                <th>Ad Soyad</th>
                                <th>Görev</th>
                                <th>Firma</th>
                                <th>Telefon</th>
                                <th>İşe Başlama</th>
                                <th>İşten Çıkış</th>
                                <th class="text-end">Maaş</th>
                                <th>Tedarikçi</th>
                                <th>Cari</th>
                                <th>Durum</th>
                                <th class="text-end">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in FiltreliPersonel)
                            {
                                <tr>
                                    <td><strong>@p.SoforKodu</strong></td>
                                    <td>@p.TamAd</td>
                                    <td>
                                        <span class="badge @GetGorevBadgeClass(p.Gorev)">@GetGorevAdi(p.Gorev)</span>
                                    </td>
                                    <td>@(p.Firma?.FirmaAdi ?? "-")</td>
                                    <td>@(p.Telefon ?? "-")</td>
                                    <td>@p.IseBaslamaTarihi?.ToString("dd.MM.yyyy")</td>
                                    <td>@p.IstenAyrilmaTarihi?.ToString("dd.MM.yyyy")</td>
                                    <td class="text-end">@p.NetMaas.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("tr-TR"))</td>
                                    <td><span class="badge bg-info text-dark">@GetTedarikciEtiket(p.TasimaTedarikciId)</span></td>
                                    <td><small class="text-muted">@GetTedarikciCariEtiket(p.TasimaTedarikciId)</small></td>
                                    <td>
                                        <span class="badge @(p.Aktif ? "bg-success" : "bg-danger")">@(p.Aktif ? "Aktif" : "Pasif")</span>
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary" @onclick='() => Navigation.NavigateTo($"/personel/{p.Id}")'>
                                            <i class="bi bi-pencil-square me-1"></i>Düzenle
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool yukleniyor = true;
    private string arama = string.Empty;
    private int seciliTedarikciId;
    private string secilenAktifDurum = string.Empty;
    private PersonelGorev? secilenGorev;
    private List<Sofor> personeller = new();
    private List<TasimaTedarikci> tedarikciler = new();

    private IEnumerable<Sofor> FiltreliPersonel => personeller
        .Where(p => p.TasimaTedarikciId.HasValue)
        .Where(p => seciliTedarikciId == 0 || p.TasimaTedarikciId == seciliTedarikciId)
        .Where(p => !secilenGorev.HasValue || p.Gorev == secilenGorev.Value)
        .Where(p => secilenAktifDurum == "" || (secilenAktifDurum == "aktif" ? p.Aktif : !p.Aktif))
        .Where(p => string.IsNullOrWhiteSpace(arama)
            || (p.SoforKodu?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false)
            || (p.Ad?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false)
            || (p.Soyad?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false)
            || (p.Telefon?.Contains(arama, StringComparison.OrdinalIgnoreCase) ?? false)
            || GetTedarikciUnvan(p.TasimaTedarikciId).Contains(arama, StringComparison.OrdinalIgnoreCase))
        .OrderBy(p => p.Ad)
        .ThenBy(p => p.Soyad);

    protected override async Task OnInitializedAsync()
    {
        tedarikciler = await TasimaTedarikciService.GetAllAsync(sadeceAktif: false);
        personeller = await SoforService.GetAllAsync();
        yukleniyor = false;
    }

    private string GetTedarikciUnvan(int? id)
    {
        if (!id.HasValue) return "-";
        return tedarikciler.FirstOrDefault(t => t.Id == id.Value)?.Unvan ?? "-";
    }

    private string GetTedarikciEtiket(int? id)
    {
        if (!id.HasValue) return "-";
        var t = tedarikciler.FirstOrDefault(x => x.Id == id.Value);
        if (t is null) return "-";
        return string.IsNullOrWhiteSpace(t.TedarikciKodu) ? t.Unvan : $"{t.TedarikciKodu} - {t.Unvan}";
    }

    private string GetTedarikciCariEtiket(int? id)
    {
        if (!id.HasValue) return "-";
        var t = tedarikciler.FirstOrDefault(x => x.Id == id.Value);
        if (t?.Cari is null) return "-";
        return string.IsNullOrWhiteSpace(t.Cari.CariKodu) ? t.Cari.Unvan : $"{t.Cari.CariKodu} - {t.Cari.Unvan}";
    }

    private static string GetGorevAdi(PersonelGorev gorev)
    {
        return gorev switch
        {
            PersonelGorev.Sofor => "Şoför",
            PersonelGorev.OfisCalisani => "Ofis Çalışanı",
            PersonelGorev.Yonetici => "Yönetici",
            PersonelGorev.Muhasebe => "Muhasebe",
            PersonelGorev.Teknik => "Teknik",
            PersonelGorev.Diger => "Diğer",
            _ => gorev.ToString()
        };
    }

    private static string GetGorevBadgeClass(PersonelGorev gorev)
    {
        return gorev switch
        {
            PersonelGorev.Sofor => "bg-primary",
            PersonelGorev.OfisCalisani => "bg-info",
            PersonelGorev.Yonetici => "bg-danger",
            PersonelGorev.Muhasebe => "bg-success",
            PersonelGorev.Teknik => "bg-warning text-dark",
            _ => "bg-secondary"
        };
    }
}
