@page "/filo/servis-puantaj"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using KOAFiloServis.Web.Services.Interfaces
@inject IFiloKomisyonService FiloService
@inject IGuzergahService GuzergahService
@inject IFirmaService FirmaService
@inject IAracService AracService
@inject ISoforService SoforService
@inject IToastService ToastService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Servis Puantaj</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-calendar-check me-2"></i>Servis Puantaj</h3>
        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="EslestirmeModalAc">
                <i class="bi bi-link-45deg me-1"></i>Eşleştirme Yönet
            </button>
            <button class="btn btn-success" @onclick="TopluPuantajOlustur" disabled="@(!eslestirmeler.Any())">
                <i class="bi bi-calendar-plus me-1"></i>Ay Puantajı Oluştur
            </button>
            <button class="btn btn-outline-secondary" @onclick="YenileAsync">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
    </div>

    <!-- Filtreler -->
    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small mb-1">Firma</label>
                    <select class="form-select form-select-sm" @bind="filtreFirmaId" @bind:after="YenileAsync">
                        <option value="0">Tüm Firmalar</option>
                        @foreach (var firma in firmalar)
                        {
                            <option value="@firma.Id">@firma.FirmaAdi</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Yıl</label>
                    <select class="form-select form-select-sm" @bind="filtreYil" @bind:after="YenileAsync">
                        @for (int y = DateTime.Today.Year; y >= DateTime.Today.Year - 2; y--)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Ay</label>
                    <select class="form-select form-select-sm" @bind="filtreAy" @bind:after="YenileAsync">
                        @for (int a = 1; a <= 12; a++)
                        {
                            <option value="@a">@GetAyAdi(a)</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-1">Güzergah</label>
                    <select class="form-select form-select-sm" @bind="filtreGuzergahId" @bind:after="FiltreleListeyi">
                        <option value="0">Tüm Güzergahlar</option>
                        @foreach (var g in guzergahlar)
                        {
                            <option value="@g.Id">@g.GuzergahAdi</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary btn-sm w-100" @onclick="YenileAsync">
                        <i class="bi bi-search me-1"></i>Filtrele
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabs -->
    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <button class="nav-link @(aktifTab == "eslestirme" ? "active" : "")" @onclick='() => TabDegistir("eslestirme")'>
                <i class="bi bi-link me-1"></i>Eşleştirmeler
                <span class="badge bg-primary ms-1">@eslestirmeler.Count</span>
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(aktifTab == "puantaj" ? "active" : "")" @onclick='() => TabDegistir("puantaj")'>
                <i class="bi bi-table me-1"></i>Puantaj Tablosu
            </button>
        </li>
    </ul>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
        </div>
    }
    else if (aktifTab == "eslestirme")
    {
        <!-- Eşleştirme Listesi -->
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Güzergah</th>
                                <th>Firma</th>
                                <th>Sefer</th>
                                <th>Araç</th>
                                <th>Şoför</th>
                                <th class="text-end">Kurum Ücret</th>
                                <th class="text-end">Taşeron Ücret</th>
                                <th class="text-center">Durum</th>
                                <th class="text-center">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!eslestirmeler.Any())
                            {
                                <tr>
                                    <td colspan="9" class="text-center text-muted py-4">
                                        <i class="bi bi-inbox display-6 d-block mb-2"></i>
                                        Henüz eşleştirme yok. "Eşleştirme Yönet" butonuna tıklayın.
                                    </td>
                                </tr>
                            }
                            @foreach (var e in filtrelenmisEslestirmeler)
                            {
                                <tr>
                                    <td>
                                        <strong>@e.Guzergah?.GuzergahAdi</strong>
                                        <br/><small class="text-muted">@e.Guzergah?.GuzergahKodu</small>
                                    </td>
                                    <td>@e.KurumFirma?.FirmaAdi</td>
                                    <td>
                                        <span class="badge @GetSeferBadge(e.ServisTuru)">@GetSeferAdi(e.ServisTuru)</span>
                                    </td>
                                    <td>
                                        <i class="bi bi-truck me-1"></i>@e.Arac?.AktifPlaka
                                        <br/><small class="text-muted">@e.Arac?.Marka @e.Arac?.Model</small>
                                    </td>
                                    <td>
                                        <i class="bi bi-person me-1"></i>@e.Sofor?.TamAd
                                    </td>
                                    <td class="text-end text-success"><strong>@FormatPara(e.KurumaKesilecekUcret)</strong></td>
                                    <td class="text-end text-danger">@FormatPara(e.TaseronaOdenenUcret)</td>
                                    <td class="text-center">
                                        <span class="badge @(e.IsActive ? "bg-success" : "bg-secondary")">
                                            @(e.IsActive ? "Aktif" : "Pasif")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary" @onclick="() => EslestirmeDuzenle(e)" title="Düzenle">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-outline-danger" @onclick="() => EslestirmeSil(e)" title="Sil">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Puantaj Tablosu -->
        <div class="card">
            <div class="card-header bg-light py-2">
                <div class="d-flex justify-content-between align-items-center">
                    <span><strong>@GetAyAdi(filtreAy) @filtreYil</strong> Puantaj Tablosu</span>
                    <div class="btn-group btn-group-sm">
                        <button class="btn btn-outline-success" @onclick="PuantajKaydet" disabled="@(!puantajDegisiklikVar)">
                            <i class="bi bi-save me-1"></i>Kaydet
                        </button>
                        <button class="btn btn-outline-primary" @onclick="PuantajExcelExport">
                            <i class="bi bi-file-excel me-1"></i>Excel
                        </button>
                    </div>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive" style="max-height: 60vh;">
                    <table class="table table-sm table-bordered mb-0" style="font-size: 0.75rem;">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th class="sticky-start" style="min-width: 200px; position: sticky; left: 0; background: #f8f9fa; z-index: 10;">
                                    Güzergah / Araç / Şoför
                                </th>
                                @for (int gun = 1; gun <= AyGunSayisi; gun++)
                                {
                                    var tarih = new DateTime(filtreYil, filtreAy, gun);
                                    var haftaSonu = tarih.DayOfWeek == DayOfWeek.Saturday || tarih.DayOfWeek == DayOfWeek.Sunday;
                                    <th class="text-center @(haftaSonu ? "table-warning" : "")" style="min-width: 35px;">
                                        @gun
                                        <br/><small>@GetGunKisa(tarih)</small>
                                    </th>
                                }
                                <th class="text-center" style="min-width: 60px;">Toplam</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var eslestirme in filtrelenmisEslestirmeler.Where(e => e.IsActive))
                            {
                                var eslestirmePuantajlari = puantajlar.Where(p => p.FiloGuzergahEslestirmeId == eslestirme.Id).ToList();
                                var toplamGun = eslestirmePuantajlari.Sum(p => p.PuantajCarpani);

                                <tr>
                                    <td class="sticky-start" style="position: sticky; left: 0; background: white; z-index: 5;">
                                        <strong>@eslestirme.Guzergah?.GuzergahAdi</strong><br/>
                                        <small class="text-muted">
                                            <i class="bi bi-truck"></i> @eslestirme.Arac?.AktifPlaka
                                            <i class="bi bi-person ms-2"></i> @eslestirme.Sofor?.TamAd
                                        </small>
                                    </td>
                                    @for (int gun = 1; gun <= AyGunSayisi; gun++)
                                    {
                                        var tarih = new DateTime(filtreYil, filtreAy, gun);
                                        var puantaj = eslestirmePuantajlari.FirstOrDefault(p => p.Tarih.Date == tarih.Date);
                                        var haftaSonu = tarih.DayOfWeek == DayOfWeek.Saturday || tarih.DayOfWeek == DayOfWeek.Sunday;

                                        <td class="text-center p-0 @(haftaSonu ? "table-warning" : "")" 
                                            style="cursor: pointer;"
                                            @onclick="() => PuantajHucreClick(eslestirme, tarih, puantaj)">
                                            @if (puantaj != null)
                                            {
                                                <span class="badge @GetDurumBadge(puantaj.Durum)" style="font-size: 0.65rem;">
                                                    @GetDurumKisa(puantaj.Durum)
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                    }
                                    <td class="text-center fw-bold">@toplamGun.ToString("0.#")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-light py-2">
                <div class="row text-center small">
                    <div class="col">
                        <span class="badge bg-success">G</span> Gitti
                    </div>
                    <div class="col">
                        <span class="badge bg-warning text-dark">Y</span> Yarım
                    </div>
                    <div class="col">
                        <span class="badge bg-danger">X</span> Gitmedi
                    </div>
                    <div class="col">
                        <span class="badge bg-info">İ</span> İzinli
                    </div>
                    <div class="col">
                        <span class="badge bg-secondary">T</span> Taksi
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Eşleştirme Modal -->
@if (showEslestirmeModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-link-45deg me-2"></i>
                        @(editEslestirme.Id == 0 ? "Yeni Eşleştirme" : "Eşleştirme Düzenle")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Firma (Kurum) *</label>
                            <select class="form-select" @bind="editEslestirme.KurumFirmaId">
                                <option value="0">-- Seçin --</option>
                                @foreach (var f in firmalar)
                                {
                                    <option value="@f.Id">@f.FirmaAdi</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Güzergah *</label>
                            <select class="form-select" @bind="editEslestirme.GuzergahId">
                                <option value="0">-- Seçin --</option>
                                @foreach (var g in guzergahlar.Where(x => editEslestirme.KurumFirmaId == 0 || x.FirmaId == editEslestirme.KurumFirmaId))
                                {
                                    <option value="@g.Id">@g.GuzergahAdi (@g.GuzergahKodu)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Araç *</label>
                            <select class="form-select" @bind="editEslestirme.AracId">
                                <option value="0">-- Seçin --</option>
                                @foreach (var a in araclar)
                                {
                                    <option value="@a.Id">@a.AktifPlaka - @a.Marka @a.Model</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Şoför *</label>
                            <select class="form-select" @bind="editEslestirme.SoforId">
                                <option value="0">-- Seçin --</option>
                                @foreach (var s in soforler)
                                {
                                    <option value="@s.Id">@s.TamAd</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Sefer Türü</label>
                            <select class="form-select" @bind="editEslestirme.ServisTuru">
                                <option value="@ServisTuru.SabahAksam">Sabah-Akşam</option>
                                <option value="@ServisTuru.Sabah">Sabah</option>
                                <option value="@ServisTuru.Aksam">Akşam</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Kurum Ücreti</label>
                            <div class="input-group">
                                <input type="number" class="form-control" @bind="editEslestirme.KurumaKesilecekUcret" step="0.01" />
                                <span class="input-group-text">?</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Taşeron Ücreti</label>
                            <div class="input-group">
                                <input type="number" class="form-control" @bind="editEslestirme.TaseronaOdenenUcret" step="0.01" />
                                <span class="input-group-text">?</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="eslestirmeAktif" @bind="editEslestirme.IsActive" />
                                <label class="form-check-label" for="eslestirmeAktif">Aktif</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="EslestirmeKaydet">
                        <i class="bi bi-check me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Puantaj Düzenleme Modal -->
@if (showPuantajModal && editPuantaj != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-calendar-check me-2"></i>
                        Puantaj Düzenle - @editPuantaj.Tarih.ToString("dd.MM.yyyy")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showPuantajModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-light py-2">
                        <strong>@puantajEslestirme?.Guzergah?.GuzergahAdi</strong><br/>
                        <small>
                            <i class="bi bi-truck"></i> @puantajEslestirme?.Arac?.AktifPlaka
                            <i class="bi bi-person ms-2"></i> @puantajEslestirme?.Sofor?.TamAd
                        </small>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Durum</label>
                            <select class="form-select" @bind="editPuantaj.Durum">
                                <option value="@OperasyonDurumu.Gitti">Gitti</option>
                                <option value="@OperasyonDurumu.Gitmedi_Mazeretli">Gitmedi (Mazeretli)</option>
                                <option value="@OperasyonDurumu.Gitmedi_Mazeretsiz">Gitmedi (Mazeretsiz)</option>
                                <option value="@OperasyonDurumu.Taksiyle_Gidildi">Taksiyle Gidildi</option>
                                <option value="@OperasyonDurumu.Arizalandi_YoldaKaldi">Arızalandı</option>
                                <option value="@OperasyonDurumu.Iptal_KurumTarafindan">İptal (Kurum)</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Çarpan</label>
                            <input type="number" class="form-control" @bind="editPuantaj.PuantajCarpani" step="0.5" min="0" max="2" />
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" @bind="editPuantaj.TaksiKullanildiMi" />
                                <label class="form-check-label">Taksi Kullanıldı</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showPuantajModal = false">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="PuantajGuncelle">
                        <i class="bi bi-check me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Firma> firmalar = new();
    private List<Guzergah> guzergahlar = new();
    private List<Arac> araclar = new();
    private List<Sofor> soforler = new();
    private List<FiloGuzergahEslestirme> eslestirmeler = new();
    private List<FiloGuzergahEslestirme> filtrelenmisEslestirmeler = new();
    private List<FiloGunlukPuantaj> puantajlar = new();

    private bool isLoading = true;
    private string aktifTab = "eslestirme";

    // Filtreler
    private int filtreFirmaId = 0;
    private int filtreYil = DateTime.Today.Year;
    private int filtreAy = DateTime.Today.Month;
    private int filtreGuzergahId = 0;

    // Modal
    private bool showEslestirmeModal = false;
    private FiloGuzergahEslestirme editEslestirme = new();

    private bool showPuantajModal = false;
    private FiloGunlukPuantaj? editPuantaj;
    private FiloGuzergahEslestirme? puantajEslestirme;

    private bool puantajDegisiklikVar = false;

    private int AyGunSayisi => DateTime.DaysInMonth(filtreYil, filtreAy);

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAllAsync();
        araclar = await AracService.GetAllAsync();
        soforler = await SoforService.GetAllAsync();
        guzergahlar = await GuzergahService.GetActiveAsync();
        await YenileAsync();
    }

    private async Task YenileAsync()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            int? firmaIdParam = filtreFirmaId > 0 ? filtreFirmaId : null;
            eslestirmeler = await FiloService.GetEslestirmelerAsync(firmaIdParam);

            if (aktifTab == "puantaj")
            {
                var baslangic = new DateTime(filtreYil, filtreAy, 1);
                var bitis = baslangic.AddMonths(1).AddDays(-1);
                puantajlar = await FiloService.GetPuantajlarByTarihAraligiAsync(firmaIdParam, baslangic, bitis);
            }

            FiltreleListeyi();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void FiltreleListeyi()
    {
        var query = eslestirmeler.AsEnumerable();

        if (filtreFirmaId > 0)
            query = query.Where(e => e.KurumFirmaId == filtreFirmaId);

        if (filtreGuzergahId > 0)
            query = query.Where(e => e.GuzergahId == filtreGuzergahId);

        filtrelenmisEslestirmeler = query.OrderBy(e => e.Guzergah?.GuzergahAdi).ToList();
    }

    private void TabDegistir(string tab)
    {
        aktifTab = tab;
        _ = YenileAsync();
    }

    private void EslestirmeModalAc()
    {
        editEslestirme = new FiloGuzergahEslestirme
        {
            FirmaId = 1, // Default firma
            IsActive = true,
            ServisTuru = ServisTuru.SabahAksam
        };
        showEslestirmeModal = true;
    }

    private void EslestirmeDuzenle(FiloGuzergahEslestirme e)
    {
        editEslestirme = new FiloGuzergahEslestirme
        {
            Id = e.Id,
            FirmaId = e.FirmaId,
            KurumFirmaId = e.KurumFirmaId,
            GuzergahId = e.GuzergahId,
            AracId = e.AracId,
            SoforId = e.SoforId,
            ServisTuru = e.ServisTuru,
            KurumaKesilecekUcret = e.KurumaKesilecekUcret,
            TaseronaOdenenUcret = e.TaseronaOdenenUcret,
            IsActive = e.IsActive
        };
        showEslestirmeModal = true;
    }

    private async Task EslestirmeKaydet()
    {
        if (editEslestirme.KurumFirmaId == 0 || editEslestirme.GuzergahId == 0 ||
            editEslestirme.AracId == 0 || editEslestirme.SoforId == 0)
        {
            ToastService.ShowWarning("Lütfen tüm alanları doldurun.");
            return;
        }

        try
        {
            if (editEslestirme.Id == 0)
            {
                editEslestirme.FirmaId = 1; // Default
                await FiloService.CreateEslestirmeAsync(editEslestirme);
                ToastService.ShowSuccess("Eşleştirme oluşturuldu.");
            }
            else
            {
                await FiloService.UpdateEslestirmeAsync(editEslestirme);
                ToastService.ShowSuccess("Eşleştirme güncellendi.");
            }

            showEslestirmeModal = false;
            await YenileAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private async Task EslestirmeSil(FiloGuzergahEslestirme e)
    {
        var onay = await JS.InvokeAsync<bool>("confirm", $"'{e.Guzergah?.GuzergahAdi}' eşleştirmesi silinecek. Emin misiniz?");
        if (!onay) return;

        try
        {
            await FiloService.DeleteEslestirmeAsync(e.Id);
            ToastService.ShowSuccess("Eşleştirme silindi.");
            await YenileAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private async Task TopluPuantajOlustur()
    {
        if (filtreFirmaId == 0)
        {
            ToastService.ShowWarning("Toplu puantaj oluşturmak için lütfen bir firma seçin.");
            return;
        }

        var onay = await JS.InvokeAsync<bool>("confirm", $"{GetAyAdi(filtreAy)} {filtreYil} için tüm eşleştirmelere puantaj kaydı oluşturulacak. Devam?");
        if (!onay) return;

        try
        {
            await FiloService.TopluPuantajUretAsync(filtreFirmaId, filtreYil, filtreAy);
            ToastService.ShowSuccess("Puantaj kayıtları oluşturuldu.");
            aktifTab = "puantaj";
            await YenileAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private void PuantajHucreClick(FiloGuzergahEslestirme eslestirme, DateTime tarih, FiloGunlukPuantaj? puantaj)
    {
        puantajEslestirme = eslestirme;

        if (puantaj != null)
        {
            editPuantaj = new FiloGunlukPuantaj
            {
                Id = puantaj.Id,
                Tarih = puantaj.Tarih,
                Durum = puantaj.Durum,
                PuantajCarpani = puantaj.PuantajCarpani,
                TaksiKullanildiMi = puantaj.TaksiKullanildiMi
            };
        }
        else
        {
            editPuantaj = new FiloGunlukPuantaj
            {
                Tarih = tarih,
                FiloGuzergahEslestirmeId = eslestirme.Id,
                KurumFirmaId = eslestirme.KurumFirmaId,
                GuzergahId = eslestirme.GuzergahId,
                AracId = eslestirme.AracId,
                SoforId = eslestirme.SoforId,
                FirmaId = eslestirme.FirmaId,
                Durum = OperasyonDurumu.Gitti,
                PuantajCarpani = 1
            };
        }

        showPuantajModal = true;
    }

    private async Task PuantajGuncelle()
    {
        if (editPuantaj == null) return;

        try
        {
            // Duruma göre çarpanı otomatik ayarla
            editPuantaj.PuantajCarpani = editPuantaj.Durum switch
            {
                OperasyonDurumu.Gitti => 1,
                OperasyonDurumu.Gitmedi_Mazeretli => 0,
                OperasyonDurumu.Gitmedi_Mazeretsiz => 0,
                OperasyonDurumu.Taksiyle_Gidildi => 1,
                OperasyonDurumu.Arizalandi_YoldaKaldi => 0.5m,
                OperasyonDurumu.Iptal_KurumTarafindan => 0,
                _ => editPuantaj.PuantajCarpani
            };

            if (editPuantaj.Id == 0)
            {
                await FiloService.CreatePuantajAsync(editPuantaj);
            }
            else
            {
                await FiloService.UpdateGunlukPuantajAsync(editPuantaj);
            }

            ToastService.ShowSuccess("Puantaj güncellendi.");
            showPuantajModal = false;
            await YenileAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private async Task PuantajKaydet()
    {
        ToastService.ShowSuccess("Puantaj kaydedildi.");
        puantajDegisiklikVar = false;
    }

    private async Task PuantajExcelExport()
    {
        if (!filtrelenmisEslestirmeler.Any(e => e.IsActive))
        {
            ToastService.ShowWarning("Disa aktarilacak veri bulunamadi.");
            return;
        }

        try
        {
            // Baslik satiri: Guzergah/Arac/Sofor + 1-31 gunler + Toplam
            var headers = new List<string> { "Guzergah / Arac / Sofor" };
            for (int gun = 1; gun <= AyGunSayisi; gun++)
            {
                var tarih = new DateTime(filtreYil, filtreAy, gun);
                headers.Add($"{gun} ({GetGunKisa(tarih)})");
            }
            headers.Add("Toplam");

            // Veri satirlari
            var rows = new List<object[]>();
            foreach (var eslestirme in filtrelenmisEslestirmeler.Where(e => e.IsActive))
            {
                var eslestirmePuantajlari = puantajlar.Where(p => p.FiloGuzergahEslestirmeId == eslestirme.Id).ToList();
                var row = new List<object>();

                // Ilk sutun: Guzergah bilgisi
                row.Add($"{eslestirme.Guzergah?.GuzergahAdi} | {eslestirme.Arac?.AktifPlaka} | {eslestirme.Sofor?.TamAd}");

                // Gunluk puantajlar
                decimal toplam = 0;
                for (int gun = 1; gun <= AyGunSayisi; gun++)
                {
                    var tarih = new DateTime(filtreYil, filtreAy, gun);
                    var puantaj = eslestirmePuantajlari.FirstOrDefault(p => p.Tarih.Date == tarih.Date);
                    if (puantaj != null)
                    {
                        row.Add(GetDurumKisa(puantaj.Durum));
                        toplam += puantaj.PuantajCarpani;
                    }
                    else
                    {
                        row.Add("-");
                    }
                }
                row.Add(toplam);
                rows.Add(row.ToArray());
            }

            // Excel olustur
            using var workbook = new ClosedXML.Excel.XLWorkbook();
            var worksheet = workbook.Worksheets.Add($"Puantaj {GetAyAdi(filtreAy)} {filtreYil}");

            // Basliklari yaz
            for (int i = 0; i < headers.Count; i++)
            {
                worksheet.Cell(1, i + 1).Value = headers[i];
                worksheet.Cell(1, i + 1).Style.Font.Bold = true;
                worksheet.Cell(1, i + 1).Style.Fill.BackgroundColor = ClosedXML.Excel.XLColor.LightBlue;
            }

            // Verileri yaz
            for (int r = 0; r < rows.Count; r++)
            {
                for (int c = 0; c < rows[r].Length; c++)
                {
                    worksheet.Cell(r + 2, c + 1).Value = rows[r][c]?.ToString() ?? "";
                }
            }

            worksheet.Columns().AdjustToContents();

            using var stream = new System.IO.MemoryStream();
            workbook.SaveAs(stream);
            var base64 = Convert.ToBase64String(stream.ToArray());

            var fileName = $"Puantaj_{GetAyAdi(filtreAy)}_{filtreYil}.xlsx";
            await JS.InvokeVoidAsync("downloadFileFromBase64", fileName, base64);

            ToastService.ShowSuccess("Excel dosyasi indirildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Excel export hatasi: {ex.Message}");
        }
    }

    private void ModalKapat()
    {
        showEslestirmeModal = false;
        showPuantajModal = false;
    }

    // Helper Methods
    private string GetAyAdi(int ay) => new DateTime(2024, ay, 1).ToString("MMMM", new System.Globalization.CultureInfo("tr-TR"));
    private string GetGunKisa(DateTime tarih) => tarih.ToString("ddd", new System.Globalization.CultureInfo("tr-TR")).Substring(0, 2);
    private string FormatPara(decimal t) => t.ToString("N2", new System.Globalization.CultureInfo("tr-TR")) + " ?";

    private string GetSeferAdi(ServisTuru t) => t switch
    {
        ServisTuru.SabahAksam => "S-A",
        ServisTuru.Sabah => "Sabah",
        ServisTuru.Aksam => "Akşam",
        _ => t.ToString()
    };

    private string GetSeferBadge(ServisTuru t) => t switch
    {
        ServisTuru.SabahAksam => "bg-primary",
        ServisTuru.Sabah => "bg-info",
        ServisTuru.Aksam => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private string GetDurumKisa(OperasyonDurumu d) => d switch
    {
        OperasyonDurumu.Gitti => "G",
        OperasyonDurumu.Gitmedi_Mazeretli => "M",
        OperasyonDurumu.Gitmedi_Mazeretsiz => "X",
        OperasyonDurumu.Taksiyle_Gidildi => "T",
        OperasyonDurumu.Arizalandi_YoldaKaldi => "A",
        OperasyonDurumu.Iptal_KurumTarafindan => "İ",
        _ => "?"
    };

    private string GetDurumBadge(OperasyonDurumu d) => d switch
    {
        OperasyonDurumu.Gitti => "bg-success",
        OperasyonDurumu.Gitmedi_Mazeretli => "bg-warning text-dark",
        OperasyonDurumu.Gitmedi_Mazeretsiz => "bg-danger",
        OperasyonDurumu.Taksiyle_Gidildi => "bg-info",
        OperasyonDurumu.Arizalandi_YoldaKaldi => "bg-warning",
        OperasyonDurumu.Iptal_KurumTarafindan => "bg-secondary",
        _ => "bg-light text-dark"
    };
}
