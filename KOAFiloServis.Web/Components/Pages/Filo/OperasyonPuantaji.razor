@page "/filo/operasyon-puantaj"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services.Interfaces
@using KOAFiloServis.Web.Services
@inject IFiloKomisyonService FiloKomisyonService
@inject IFirmaService FirmaService
@inject IToastService ToastService
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer

<PageTitle>Aylık Operasyon Puantajı</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0"><i class="bi bi-calendar2-range me-2 text-danger"></i>Aylık Operasyon Puantajı</h3>
            <small class="text-muted">Ay boyunca çalışılan araçların günlük devamsızlık ve hakediş tablosu</small>
        </div>
        <div>
            <button class="btn btn-outline-primary me-2" @onclick="TopluPuantajOlustur" disabled="@isGenerating">
                @if (isGenerating)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                }
                else
                {
                    <i class="bi bi-magic me-1"></i>
                }
                Bu Ay İçin Puantaj Üret
            </button>
            <button class="btn btn-success" @onclick="Kaydet" disabled="@isSaving">
                @if (isSaving)
                {
                     <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                }
                else
                {
                     <i class="bi bi-save me-1"></i>
                }
                Değişiklikleri Kaydet
            </button>
        </div>
    </div>

    <!-- Filtreler -->
    <div class="card shadow-sm mb-3">
        <div class="card-body py-2 bg-light">
            <div class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small mb-1 fw-bold">Yıl</label>
                    <select class="form-select form-select-sm" @bind="secilenYil">
                        @for (int i = DateTime.Today.Year - 1; i <= DateTime.Today.Year; i++)
                        {
                            <option value="@i">@i</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1 fw-bold">Ay</label>
                    <select class="form-select form-select-sm" @bind="secilenAy">
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m">@m.ToString("D2")</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-1 fw-bold">Kurum / Müşteri Filtresi</label>
                    <select class="form-select form-select-sm" @bind="secilenKurumId">
                        <option value="0">Tümü</option>
                        @foreach(var k in kurumlar)
                        {
                            <option value="@k.Id">@k.Unvan</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-1 fw-bold">Araç Filtresi</label>
                    <select class="form-select form-select-sm" @bind="secilenAracId">
                        <option value="0">Tümü</option>
                        @foreach(var a in araclar)
                        {
                            <option value="@a.Id">@(a.AktifPlaka ?? a.AktifPlakaKaydi?.Plaka ?? a.SaseNo)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-secondary btn-sm w-100" @onclick="Yenile"><i class="bi bi-search me-1"></i>Listele</button>
                </div>
            </div>
        </div>
    </div>

    <!-- PUANTAJ TABLOSU (EXCEL GÖRÜNÜMÜ) -->
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Veriler yükleniyor...</p>
        </div>
    }
    else if (!puantajGruplu.Any())
    {
        <div class="alert alert-info py-4 text-center">
            Puantaj kaydı bulunamadı. Lütfen sağ üstten <strong>Bu Ay İçin Puantaj Üret</strong> butonuna tıklayarak şablondaki eşleşmeleri bu aya aktarın.
        </div>
    }
    else
    {
        var gunSayisi = DateTime.DaysInMonth(secilenYil, secilenAy);

        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive" style="max-height: 65vh; overflow-y: auto;">
                    <table class="table table-bordered table-hover table-sm text-center mb-0 align-middle" style="font-size: 0.85rem;">
                        <thead class="table-dark" style="position: sticky; top: 0; z-index: 3;">
                            <tr>
                                <th class="align-middle text-start" style="min-width: 150px; position: sticky; left: 0; z-index: 4; background-color: #212529;">Müşteri / Kurum</th>
                                <th class="align-middle text-start" style="min-width: 130px; position: sticky; left: 150px; z-index: 4; background-color: #212529;">Güzergah</th>
                                <th class="align-middle text-start" style="min-width: 110px; position: sticky; left: 280px; z-index: 4; background-color: #212529;">Araç Plaka</th>

                                @for(int gun = 1; gun <= gunSayisi; gun++)
                                {
                                    var date = new DateTime(secilenYil, secilenAy, gun);
                                    var isWeekend = date.DayOfWeek == DayOfWeek.Sunday || date.DayOfWeek == DayOfWeek.Saturday;
                                    <th style="width: 40px; @(isWeekend ? "background-color: #c79595; color: white;" : "")">
                                        @gun<br/><small style="font-size:10px;">@date.ToString("ddd").Substring(0,2)</small>
                                    </th>
                                }
                                <th class="align-middle bg-primary text-white" style="min-width: 70px;">Top. Gün</th>
                                <th class="align-middle bg-success text-white" style="min-width: 90px;">Kurum Hakediş</th>
                                <th class="align-middle bg-danger text-white" style="min-width: 90px;">Araç Hakediş</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var grup in puantajGruplu)
                            {
                                // Her satır bir Araç/Güzergah eşleştirmesini temsil eder.
                                var eId = grup.Key; // Eşleşme Şablon Id'si
                                var liste = grup.Value;
                                var ilkS = liste.FirstOrDefault();
                                if(ilkS == null) continue;

                                var toplamGun = liste.Sum(x => x.PuantajCarpani);
                                var kurumHak = liste.Sum(x => x.TahakkukEdenKurumUcreti);
                                var taseronHak = liste.Sum(x => x.TahakkukEdenTaseronUcreti);

                                <tr>
                                    <td class="text-start fw-bold" style="position: sticky; left: 0; background-color: #f8f9fa; z-index: 1;" title="@ilkS.KurumFirma?.FirmaAdi">
                                        <div class="text-truncate" style="max-width: 140px;">@ilkS.KurumFirma?.FirmaAdi</div>
                                    </td>
                                    <td class="text-start text-muted" style="position: sticky; left: 150px; background-color: #f8f9fa; z-index: 1;" title="@ilkS.Guzergah?.GuzergahAdi">
                                        <div class="text-truncate" style="max-width: 120px;">@ilkS.Guzergah?.GuzergahAdi</div>
                                    </td>
                                    <td class="text-start text-primary fw-bold" style="position: sticky; left: 280px; background-color: #f8f9fa; z-index: 1;">
                                        @(ilkS.Arac?.AktifPlaka ?? ilkS.Arac?.AktifPlakaKaydi?.Plaka) <br/>
                                        <small class="text-muted fw-normal">@ilkS.Sofor?.TamAd</small>
                                    </td>

                                    @for(int gun = 1; gun <= gunSayisi; gun++)
                                    {
                                        var pCell = liste.FirstOrDefault(x => x.Tarih.Day == gun);
                                        var date = new DateTime(secilenYil, secilenAy, gun);
                                        var isWk = date.DayOfWeek == DayOfWeek.Sunday || date.DayOfWeek == DayOfWeek.Saturday;

                                        var bgColor = isWk ? "#fdf2f2" : "transparent";
                                        var textColor = "black";
                                        var cellText = "1";

                                        if (pCell != null)
                                        {
                                            if (pCell.Durum == OperasyonDurumu.Gitti) { cellText = "X"; textColor = "green"; }
                                            else if (pCell.Durum == OperasyonDurumu.Gitmedi_Mazeretli) { cellText = "R"; textColor = "orange"; }
                                            else if (pCell.Durum == OperasyonDurumu.Gitmedi_Mazeretsiz) { cellText = "D"; textColor = "red"; }
                                            else if (pCell.Durum == OperasyonDurumu.Taksiyle_Gidildi) { cellText = "T"; textColor = "purple"; }
                                            else if (pCell.Durum == OperasyonDurumu.Arizalandi_YoldaKaldi) { cellText = "A"; textColor = "darkred"; }
                                            else { cellText = "-"; }
                                        }
                                        else
                                        {
                                            cellText = "";
                                        }

                                        <td class="p-0 align-middle" style="background-color: @bgColor; cursor: pointer;" title="Tıklayarak Güncelle" @onclick="() => HucreDuzenleModalAc(pCell)">
                                            @if(pCell != null && pCell.TaksiKullanildiMi)
                                            {
                                                <div style="position: relative;">
                                                    <span style="font-weight: bold; color: @textColor; font-size: 14px;">@cellText</span>
                                                    <i class="bi bi-taxi-front-fill text-warning" style="position: absolute; top: -5px; right: 2px; font-size: 9px;" title="Taksi Gidildi"></i>
                                                </div>
                                            }
                                            else
                                            {
                                                <span style="font-weight: bold; color: @textColor; font-size: 14px;">@cellText</span>
                                            }
                                        </td>
                                    }

                                    <td class="fw-bold text-primary">@Math.Round(toplamGun, 1)</td>
                                    <td class="text-success fw-bold text-end pe-2">@kurumHak.ToString("N0")</td>
                                    <td class="text-danger fw-bold text-end pe-2">@taseronHak.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light fw-bold">
                            <tr>
                                <td colspan="3" class="text-end" style="position: sticky; left: 280px; z-index: 1;">GENEL TOPLAM :</td>
                                <td colspan="@gunSayisi"></td>
                                <td></td>
                                <td class="text-success text-end pe-2">@puantajHam.Sum(x => x.TahakkukEdenKurumUcreti).ToString("N0") TL</td>
                                <td class="text-danger text-end pe-2">@puantajHam.Sum(x => x.TahakkukEdenTaseronUcreti).ToString("N0") TL</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                <div class="card-footer bg-white p-2 text-center text-muted small">
                    <span class="badge bg-success me-1">X</span> Gitti
                    <span class="badge bg-warning text-dark ms-2 me-1">R</span> İzinli/Tatil
                    <span class="badge bg-danger ms-2 me-1">D</span> Devamsız
                                        <span class="badge bg-purple ms-2 me-1" style="background-color: purple;">T</span> Taksi Tutuldu (Araç bozuldu vs.)
                    <span class="badge ms-2 me-1" style="background-color: darkred;">A</span> Arıza Yaptı
                                        <span class="badge bg-secondary ms-2 me-1">İ</span> Kurum İptali
                </div>
            </div>
        </div>
    }
</div>

@if (isCellModalOpen && currentCell != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Günlük Puantaj Düzenle : @currentCell.Tarih.ToString("dd.MM.yyyy")</h5>
                    <button type="button" class="btn-close" @onclick="() => isCellModalOpen = false"></button>
                </div>
                <div class="modal-body">
                    @if (currentCell.Arac != null)
                    {
                        <div class="alert @GetSahiplikAlertClass(currentCell.Arac.SahiplikTipi) py-2">
                            <strong>@GetSahiplikText(currentCell.Arac.SahiplikTipi)</strong> kuralı: @GetSahiplikAciklama(currentCell.Arac.SahiplikTipi)
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Çalışma Durumu</label>
                        <select class="form-select text-dark fw-bold" @bind="currentCell.Durum" @bind:after="AutoFixPuantaj">
                            <option value="1">Gitti (Tam Gün)</option>
                            <option value="2">Mazeretli / Tatil</option>
                            <option value="3">Mazeretsiz Devamsızlık</option>
                            <option value="4">Taksi İle Gidildi (Araç Bozuk)</option>
                            <option value="5">Arızalandı / Yolda Kaldı</option>
                            <option value="6">Kurum Tarafından İptal</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Günlük Çarpan (1 = Tam, 0 = Yok, 0.5 = Yarım)</label>
                        <input type="number" step="0.5" class="form-control" @bind="currentCell.PuantajCarpani" @bind:after="AutoFixPuantaj" />
                    </div>
                    <hr />
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label text-success">Fatura Edilecek ₺</label>
                            <input type="number" step="0.01" class="form-control text-success fw-bold" @bind="currentCell.TahakkukEdenKurumUcreti" />
                        </div>
                        <div class="col-6">
                            <label class="form-label text-danger">Taşerona Ödenecek ₺</label>
                            <input type="number" step="0.01" class="form-control text-danger fw-bold" @bind="currentCell.TahakkukEdenTaseronUcreti" disabled="@(!CurrentCellKomisyonMu())" />
                            @if (!CurrentCellKomisyonMu())
                            {
                                <small class="text-muted">Özmal ve kiralık araçlarda bu alan otomatik `0` olarak tutulur.</small>
                            }
                        </div>
                    </div>
                    @if (currentCell.Durum == OperasyonDurumu.Taksiyle_Gidildi)
                    {
                        <div class="alert alert-warning py-2 mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" @bind="currentCell.TaksiKullanildiMi" id="flexCheckTaksi">
                                <label class="form-check-label" for="flexCheckTaksi">Taksi Kullanıldı</label>
                            </div>
                            @if(currentCell.TaksiKullanildiMi)
                            {
                                <input type="number" class="form-control form-control-sm mt-2 mb-1" placeholder="Taksi Tutar ₺" @bind="currentCell.TaksiFisTutari" />
                                <input type="text" class="form-control form-control-sm" placeholder="Taksi Fişi Açıklama (Belge No vb.)" @bind="currentCell.TaksiFisAciklama" />
                            }
                        </div>
                    }
                    @if (currentCell.Durum == OperasyonDurumu.Arizalandi_YoldaKaldi)
                    {
                        <div class="mb-3">
                            <label class="form-label text-danger"><i class="bi bi-wrench me-1"></i>Arıza Nedeni</label>
                            <input type="text" class="form-control border-danger" @bind="currentCell.ArizaAciklamasi" placeholder="Motor arızası, lastik patladı vb." />
                        </div>
                    }
                    <div class="mb-0">
                        <label class="form-label">Özel Not</label>
                        <input type="text" class="form-control" @bind="currentCell.Notlar" placeholder="Örn: Müdür geç geldiği için..." />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => isCellModalOpen = false">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int secilenYil = DateTime.Today.Year;
    private int secilenAy = DateTime.Today.Month;
    private int secilenKurumId = 0;
    private int secilenAracId = 0;

    private int aktifFirmaId;
    private bool isLoading = true;
    private bool isGenerating = false;
    private bool isSaving = false;

    // Lookuplar
    private List<Cari> kurumlar = new();
    private List<Arac> araclar = new();

    // Veri Modeli
    private List<FiloGunlukPuantaj> puantajHam = new();
    private Dictionary<int, List<FiloGunlukPuantaj>> puantajGruplu = new();

    // Hucre Duzenleme
    private bool isCellModalOpen = false;
    private FiloGunlukPuantaj? currentCell;

    protected override async Task OnInitializedAsync()
    {
        aktifFirmaId = FirmaService.GetAktifFirma().FirmaId;
        kurumlar = await FiloKomisyonService.GetKurumlarAsync(aktifFirmaId);
        araclar = await FiloKomisyonService.GetAraclarAsync(aktifFirmaId);
        await Yenile();
    }

    private async Task TopluPuantajOlustur()
    {
        if (isGenerating) return;
        isGenerating = true;
        try
        {
            await FiloKomisyonService.TopluPuantajUretAsync(aktifFirmaId, secilenYil, secilenAy);
            ToastService.ShowSuccess("Bu aya ait eksik şablon günleri tarandı ve eksikler oluşturuldu!");
            await Yenile();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Puantaj üretilirken hata oluştu: " + ex.Message);
        }
        finally
        {
            isGenerating = false;
        }
    }

    private async Task Yenile()
    {
        isLoading = true;
        try
        {
            var baslangic = new DateTime(secilenYil, secilenAy, 1);
            var bitis = baslangic.AddMonths(1).AddDays(-1);

            puantajHam = await FiloKomisyonService.GetPuantajlarByTarihAraligiAsync(
                aktifFirmaId, 
                baslangic, 
                bitis, 
                secilenKurumId > 0 ? secilenKurumId : null, 
                secilenAracId > 0 ? secilenAracId : null);

            // Eşleştirme Şablon Id'sine göre veya Müşteri+Güzergah+Araç combinasyonuna göre grupla
            puantajGruplu = puantajHam
                .Where(p => p.FiloGuzergahEslestirmeId.HasValue) // Şimdilik sadece şablondan gelenleri grupla
                .GroupBy(p => p.FiloGuzergahEslestirmeId ?? 0)
                .ToDictionary(g => g.Key, g => g.ToList());
        }
        catch (Exception)
        {
            ToastService.ShowError("Veriler alınırken hata...");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void HucreDuzenleModalAc(FiloGunlukPuantaj? mevcutSecim)
    {
        if (mevcutSecim == null) return;
        currentCell = mevcutSecim;
        AutoFixPuantaj();
        isCellModalOpen = true;
    }

    private void AutoFixPuantaj()
    {
        // Dropdowndan mazeretsiz devamsızlık seçilirse çarpanı sıfırla, giderleri sıfırla vs
        if (currentCell == null) return;

        if (currentCell.Durum == OperasyonDurumu.Gitmedi_Mazeretsiz || currentCell.Durum == OperasyonDurumu.Gitmedi_Mazeretli)
        {
            currentCell.PuantajCarpani = 0m;
            currentCell.TahakkukEdenKurumUcreti = 0m;
            currentCell.TahakkukEdenTaseronUcreti = 0m;
        }
        else if (currentCell.Durum == OperasyonDurumu.Gitti)
        {
            currentCell.PuantajCarpani = 1.0m;
            // Şablondan asıl fiyatını geri ezecekseniz DB'den sorgu lazım ama şimdilik manuel girmelerine izin verdik menüde.
        }
    }

    private async Task Kaydet()
    {
        if (isSaving) return;
        isSaving = true;

        try
        {
            // Sadece form üzerinden açılıp referansı değişen veya editi alınmış objeler aslında puantajHam içindeki ile aynı reference olduğu için toplu save yapılabilir.
            // Entity Framework change tracker yakalıyor mu diye tek tek update fonk çağırıyoruz
            foreach(var item in puantajHam)
            {
                await FiloKomisyonService.UpdateGunlukPuantajAsync(item);
            }
            ToastService.ShowSuccess("Günlük operasyon kayıtları başarıyla saklandı!");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Kayıt veritabanına işlenirken hata: " + ex.Message);
        }
        finally
        {
            isSaving = false;
        }
    }

    private bool CurrentCellKomisyonMu() => currentCell?.Arac?.SahiplikTipi == AracSahiplikTipi.Komisyon;

    private static string GetSahiplikText(AracSahiplikTipi sahiplikTipi) => sahiplikTipi switch
    {
        AracSahiplikTipi.Ozmal => "Özmal",
        AracSahiplikTipi.Kiralik => "Kiralık",
        AracSahiplikTipi.Komisyon => "Komisyon",
        _ => "Diğer"
    };

    private static string GetSahiplikBadge(AracSahiplikTipi sahiplikTipi) => sahiplikTipi switch
    {
        AracSahiplikTipi.Ozmal => "bg-success",
        AracSahiplikTipi.Kiralik => "bg-warning text-dark",
        AracSahiplikTipi.Komisyon => "bg-info text-dark",
        _ => "bg-secondary"
    };

    private static string GetSahiplikAlertClass(AracSahiplikTipi sahiplikTipi) => sahiplikTipi switch
    {
        AracSahiplikTipi.Ozmal => "alert-success",
        AracSahiplikTipi.Kiralik => "alert-warning",
        AracSahiplikTipi.Komisyon => "alert-info",
        _ => "alert-secondary"
    };

    private static string GetSahiplikAciklama(AracSahiplikTipi sahiplikTipi) => sahiplikTipi switch
    {
        AracSahiplikTipi.Ozmal => "Plaka, şoför ve araç firmaya aittir. Araç hakedişi oluşmaz.",
        AracSahiplikTipi.Kiralik => "Plaka kiralık yapıdadır ancak operasyon firma tarafından yönetilir. Araç hakedişi otomatik sıfırlanır.",
        AracSahiplikTipi.Komisyon => "Plaka, şoför, araç ve masraflar komisyoncuya aittir. Araç hakedişi aktif olarak kullanılır.",
        _ => "Ek kural tanımlanmamış."
    };
}
