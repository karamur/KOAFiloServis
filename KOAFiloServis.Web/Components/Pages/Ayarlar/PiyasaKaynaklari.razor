@page "/ayarlar/piyasa-kaynaklari"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using System.Text.Json
@inject IPiyasaKaynakService KaynakService
@inject IToastService ToastService
@rendermode InteractiveServer

<PageTitle>Piyasa Ara�t�rma Kaynaklar�</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-1"><i class="bi bi-globe me-2"></i>Piyasa Ara�t�rma Kaynaklar�</h3>
            <small class="text-muted">Ara� piyasa ara�t�rmas�nda kullan�lacak web sitelerini y�netin</small>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="VarsayilanlariYukle" disabled="@isLoading">
                <i class="bi bi-arrow-clockwise me-1"></i>Varsay�lanlar� Y�kle
            </button>
            <button class="btn btn-primary" @onclick="YeniKaynakEkle">
                <i class="bi bi-plus-lg me-1"></i>Yeni Kaynak Ekle
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2">Y�kleniyor...</p>
        </div>
    }
    else
    {
        <!-- Kaynak Tipleri Tabs -->
        <ul class="nav nav-tabs mb-4">
            <li class="nav-item">
                <button class="nav-link @(activeTab == "tumu" ? "active" : "")" @onclick='() => activeTab = "tumu"'>
                    <i class="bi bi-list me-1"></i>T�m� <span class="badge bg-secondary ms-1">@kaynaklar.Count</span>
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(activeTab == "Genel" ? "active" : "")" @onclick='() => activeTab = "Genel"'>
                    <i class="bi bi-globe me-1"></i>Genel <span class="badge bg-primary ms-1">@kaynaklar.Count(x => x.KaynakTipi == "Genel")</span>
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(activeTab == "YetkiliBayi" ? "active" : "")" @onclick='() => activeTab = "YetkiliBayi"'>
                    <i class="bi bi-building me-1"></i>Yetkili Bayi <span class="badge bg-success ms-1">@kaynaklar.Count(x => x.KaynakTipi == "YetkiliBayi")</span>
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(activeTab == "Galeri" ? "active" : "")" @onclick='() => activeTab = "Galeri"'>
                    <i class="bi bi-shop me-1"></i>Galeri <span class="badge bg-info ms-1">@kaynaklar.Count(x => x.KaynakTipi == "Galeri")</span>
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(activeTab == "Sifir" ? "active" : "")" @onclick='() => activeTab = "Sifir"'>
                    <i class="bi bi-car-front me-1"></i>S�f�r Ara� <span class="badge bg-warning text-dark ms-1">@kaynaklar.Count(x => x.KaynakTipi == "Sifir")</span>
                </button>
            </li>
        </ul>

        <!-- Kaynaklar Listesi -->
        <div class="row g-3">
            @foreach (var kaynak in FiltrelenenKaynaklar)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm @(kaynak.Aktif ? "" : "bg-light")">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge @GetKaynakTipiBadge(kaynak.KaynakTipi)">@kaynak.KaynakTipi</span>
                                <span class="badge bg-secondary">S�ra: @kaynak.Sira</span>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" checked="@kaynak.Aktif" 
                                       @onchange="() => AktiflikDegistir(kaynak)" />
                            </div>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title d-flex align-items-center gap-2">
                                <img src="https://www.google.com/s2/favicons?domain=@(new Uri(kaynak.BaseUrl).Host)&sz=32" 
                                     alt="" class="rounded" style="width: 24px; height: 24px;"
                                     onerror="this.style.display='none'" />
                                @kaynak.Ad
                            </h5>
                            <p class="card-text mb-2">
                                <a href="@kaynak.BaseUrl" target="_blank" class="text-decoration-none">
                                    <i class="bi bi-link-45deg me-1"></i>@kaynak.BaseUrl
                                </a>
                            </p>
                            @if (!string.IsNullOrEmpty(kaynak.DesteklenenMarkalar))
                            {
                                <p class="card-text mb-2">
                                    <small class="text-muted">
                                        <i class="bi bi-car-front me-1"></i>Markalar: @kaynak.DesteklenenMarkalar
                                    </small>
                                </p>
                            }
                            <p class="card-text">
                                <small class="text-muted">
                                    <i class="bi bi-code-slash me-1"></i>Kod: <code>@kaynak.Kod</code>
                                </small>
                            </p>
                        </div>
                        <div class="card-footer bg-transparent d-flex justify-content-between">
                            <small class="text-muted">
                                @if (kaynak.GuncellemeTarihi.HasValue)
                                {
                                    <span>G�ncelleme: @kaynak.GuncellemeTarihi.Value.ToString("dd.MM.yyyy")</span>
                                }
                                else
                                {
                                    <span>Ekleme: @kaynak.OlusturmaTarihi.ToString("dd.MM.yyyy")</span>
                                }
                            </small>
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-outline-primary" @onclick="() => KaynakDuzenle(kaynak)" title="D�zenle">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-outline-danger" @onclick="() => KaynakSil(kaynak)" title="Sil">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!FiltrelenenKaynaklar.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox display-1"></i>
                <p class="mt-2">Bu kategoride kaynak bulunamad�.</p>
            </div>
        }
    }
</div>

