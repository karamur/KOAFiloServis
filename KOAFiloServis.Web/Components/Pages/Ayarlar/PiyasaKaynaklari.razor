<!-- Silme Onay Modal -->
@if (showDeleteModal && deletingKaynak != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Kayna�� Sil</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <p><strong>@deletingKaynak.Ad</strong> kayna��n� silmek istedi�inize emin misiniz?</p>
                    <p class="text-muted mb-0">Bu i�lem geri al�namaz.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showDeleteModal = false">�ptal</button>
                    <button type="button" class="btn btn-danger" @onclick="SilmeOnayla">
                        <i class="bi bi-trash me-1"></i>Sil
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<PiyasaKaynak> kaynaklar = new();
    private PiyasaKaynak editingKaynak = new();
    private PiyasaKaynakSelector editingSelector = new();
    private PiyasaKaynak? deletingKaynak;

    private bool isLoading = true;
    private bool isSaving = false;
    private bool showModal = false;
    private bool showDeleteModal = false;
    private string activeTab = "tumu";
    private string? errorMessage;

    private List<PiyasaKaynak> FiltrelenenKaynaklar => activeTab == "tumu" 
        ? kaynaklar 
        : kaynaklar.Where(x => x.KaynakTipi == activeTab).ToList();

    protected override async Task OnInitializedAsync()
    {
        await KaynaklariYukle();
        
        // E�er kaynak yoksa otomatik olarak varsay�lanlar� y�kle
        if (!kaynaklar.Any())
        {
            await VarsayilanlariYukle();
        }
    }

    private async Task KaynaklariYukle()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            kaynaklar = await KaynakService.GetAllAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Kaynaklar y�klenemedi: {ex.Message}";
            ToastService.ShowError(errorMessage);
            kaynaklar = new List<PiyasaKaynak>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task VarsayilanlariYukle()
    {
        try
        {
            await KaynakService.SeedDefaultKaynaklarAsync();
            await KaynaklariYukle();
            ToastService.ShowSuccess("Varsay�lan kaynaklar y�klendi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private void YeniKaynakEkle()
    {
        editingKaynak = new PiyasaKaynak { Aktif = true, Sira = kaynaklar.Count + 1 };
        editingSelector = new PiyasaKaynakSelector();
        showModal = true;
    }

    private void KaynakDuzenle(PiyasaKaynak kaynak)
    {
        editingKaynak = new PiyasaKaynak
        {
            Id = kaynak.Id,
            Ad = kaynak.Ad,
            Kod = kaynak.Kod,
            BaseUrl = kaynak.BaseUrl,
            AramaUrl = kaynak.AramaUrl,
            KaynakTipi = kaynak.KaynakTipi,
            DesteklenenMarkalar = kaynak.DesteklenenMarkalar,
            Sira = kaynak.Sira,
            Aktif = kaynak.Aktif,
            Selectors = kaynak.Selectors
        };

        // Selector'lar� parse et
        if (!string.IsNullOrEmpty(kaynak.Selectors))
        {
            try
            {
                editingSelector = JsonSerializer.Deserialize<PiyasaKaynakSelector>(kaynak.Selectors) ?? new();
            }
            catch
            {
                editingSelector = new PiyasaKaynakSelector();
            }
        }
        else
        {
            editingSelector = new PiyasaKaynakSelector();
        }

        showModal = true;
    }

    private async Task KaynakKaydet()
    {
        if (string.IsNullOrWhiteSpace(editingKaynak.Ad))
        {
            ToastService.ShowWarning("Kaynak ad� gerekli.");
            return;
        }
        if (string.IsNullOrWhiteSpace(editingKaynak.Kod))
        {
            ToastService.ShowWarning("Kod gerekli.");
            return;
        }
        if (string.IsNullOrWhiteSpace(editingKaynak.BaseUrl))
        {
            ToastService.ShowWarning("URL gerekli.");
            return;
        }

        // Kod kontrol�
        if (await KaynakService.KodVarMiAsync(editingKaynak.Kod, editingKaynak.Id == 0 ? null : editingKaynak.Id))
        {
            ToastService.ShowWarning("Bu kod zaten kullan�l�yor.");
            return;
        }

        isSaving = true;
        try
        {
            // Selector'lar� JSON'a �evir
            editingKaynak.Selectors = JsonSerializer.Serialize(editingSelector);

            if (editingKaynak.Id == 0)
            {
                await KaynakService.CreateAsync(editingKaynak);
                ToastService.ShowSuccess("Kaynak eklendi.");
            }
            else
            {
                await KaynakService.UpdateAsync(editingKaynak);
                ToastService.ShowSuccess("Kaynak g�ncellendi.");
            }

            await KaynaklariYukle();
            showModal = false;
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void KaynakSil(PiyasaKaynak kaynak)
    {
        deletingKaynak = kaynak;
        showDeleteModal = true;
    }

    private async Task SilmeOnayla()
    {
        if (deletingKaynak == null) return;

        try
        {
            await KaynakService.DeleteAsync(deletingKaynak.Id);
            await KaynaklariYukle();
            ToastService.ShowSuccess("Kaynak silindi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            showDeleteModal = false;
            deletingKaynak = null;
        }
    }

    private async Task AktiflikDegistir(PiyasaKaynak kaynak)
    {
        kaynak.Aktif = !kaynak.Aktif;
        await KaynakService.UpdateAsync(kaynak);
        ToastService.ShowInfo(kaynak.Aktif ? $"{kaynak.Ad} aktifle�tirildi." : $"{kaynak.Ad} devre d��� b�rak�ld�.");
    }

    private void ModalKapat()
    {
        showModal = false;
        editingKaynak = new();
        editingSelector = new();
    }

    private string GetKaynakTipiBadge(string tip) => tip switch
    {
        "Genel" => "bg-primary",
        "YetkiliBayi" => "bg-success",
        "Galeri" => "bg-info",
        "Sifir" => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}
