@page "/ayarlar/sirketler"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using KOAFiloServis.Web.Services.Interfaces
@inject ITenantService TenantService
@inject IToastService ToastService
@rendermode InteractiveServer

<PageTitle>Şirket Yönetimi (Multi-Tenant)</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3><i class="bi bi-buildings me-2"></i>Şirket Yönetimi</h3>
            <small class="text-muted">Multi-tenant (çoklu şirket) yapılandırması</small>
        </div>
        @if (TenantService.IsSuperAdmin)
        {
            <button class="btn btn-primary" @onclick="YeniSirketAc">
                <i class="bi bi-plus-lg me-1"></i>Yeni Şirket
            </button>
        }
    </div>

    @if (!TenantService.IsSuperAdmin)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Bu sayfaya yalnızca Super Admin rolündeki kullanıcılar erişebilir.
        </div>
    }
    else if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Şirketler yükleniyor...</p>
        </div>
    }
    else
    {
        <!-- İstatistik Kartları -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h6 class="card-subtitle mb-1 opacity-75">Toplam Şirket</h6>
                                <h2 class="mb-0">@sirketler.Count</h2>
                            </div>
                            <i class="bi bi-buildings fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h6 class="card-subtitle mb-1 opacity-75">Aktif Şirket</h6>
                                <h2 class="mb-0">@sirketler.Count(s => s.Aktif)</h2>
                            </div>
                            <i class="bi bi-check-circle fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h6 class="card-subtitle mb-1 opacity-75">Toplam Kullanıcı</h6>
                                <h2 class="mb-0">@sirketler.Sum(s => s.Kullanicilar?.Count ?? 0)</h2>
                            </div>
                            <i class="bi bi-people fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-dark">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h6 class="card-subtitle mb-1 opacity-75">Mevcut Şirket</h6>
                                <h6 class="mb-0">@(TenantService.CurrentSirket?.KisaAd ?? "Tümü")</h6>
                            </div>
                            <i class="bi bi-building-check fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Şirket Listesi -->
        <div class="row g-3">
            @foreach (var sirket in sirketler)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 @(sirket.Id == TenantService.CurrentSirketId ? "border-primary border-2" : "")">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <div>
                                <span class="badge bg-secondary me-1">@sirket.SirketKodu</span>
                                <strong>@(sirket.KisaAd ?? sirket.Unvan)</strong>
                                @if (sirket.Id == TenantService.CurrentSirketId)
                                {
                                    <span class="badge bg-primary ms-1">Aktif</span>
                                }
                            </div>
                            <span class="badge @(sirket.Aktif ? "bg-success" : "bg-danger")">
                                @(sirket.Aktif ? "Açık" : "Kapalı")
                            </span>
                        </div>
                        <div class="card-body">
                            <table class="table table-sm table-borderless mb-0">
                                <tr>
                                    <th width="90"><i class="bi bi-building me-1"></i>Unvan:</th>
                                    <td class="text-truncate" style="max-width: 200px;" title="@sirket.Unvan">@sirket.Unvan</td>
                                </tr>
                                @if (!string.IsNullOrEmpty(sirket.VergiNo))
                                {
                                    <tr>
                                        <th><i class="bi bi-hash me-1"></i>VKN:</th>
                                        <td>@sirket.VergiNo</td>
                                    </tr>
                                }
                                @if (!string.IsNullOrEmpty(sirket.VergiDairesi))
                                {
                                    <tr>
                                        <th><i class="bi bi-geo-alt me-1"></i>V.D.:</th>
                                        <td>@sirket.VergiDairesi</td>
                                    </tr>
                                }
                                @if (!string.IsNullOrEmpty(sirket.Telefon))
                                {
                                    <tr>
                                        <th><i class="bi bi-telephone me-1"></i>Tel:</th>
                                        <td>@sirket.Telefon</td>
                                    </tr>
                                }
                                @if (!string.IsNullOrEmpty(sirket.Email))
                                {
                                    <tr>
                                        <th><i class="bi bi-envelope me-1"></i>Email:</th>
                                        <td class="text-truncate" style="max-width: 150px;">@sirket.Email</td>
                                    </tr>
                                }
                                <tr>
                                    <th><i class="bi bi-people me-1"></i>Kullanıcı:</th>
                                    <td>
                                        <span class="badge bg-info">@(sirket.Kullanicilar?.Count ?? 0) / @sirket.MaxKullaniciSayisi</span>
                                    </td>
                                </tr>
                                <tr>
                                    <th><i class="bi bi-currency-exchange me-1"></i>Birim:</th>
                                    <td>@sirket.ParaBirimi</td>
                                </tr>
                            </table>
                        </div>
                        <div class="card-footer bg-transparent">
                            <div class="btn-group btn-group-sm w-100">
                                @if (sirket.Id != TenantService.CurrentSirketId && sirket.Aktif)
                                {
                                    <button class="btn btn-outline-success" @onclick="() => SirketSecAsync(sirket.Id)">
                                        <i class="bi bi-box-arrow-in-right me-1"></i>Geçiş Yap
                                    </button>
                                }
                                <button class="btn btn-outline-primary" @onclick="() => SirketDuzenle(sirket)">
                                    <i class="bi bi-pencil me-1"></i>Düzenle
                                </button>
                                <button class="btn btn-outline-danger" @onclick="() => SirketSilAsync(sirket)"
                                        disabled="@((sirket.Kullanicilar?.Any() ?? false) || sirket.Id == TenantService.CurrentSirketId)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (!sirketler.Any())
            {
                <div class="col-12">
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        Henüz şirket tanımlanmamış. "Yeni Şirket" butonuyla ilk şirketi oluşturun.
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Şirket Modal -->
@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-building me-2"></i>
                        @(isEditing ? "Şirket Düzenle" : "Yeni Şirket")
                    </h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="sirketForm" OnValidSubmit="SirketKaydetAsync">
                        <DataAnnotationsValidator />
                        
                        <div class="row g-3">
                            <!-- Şirket Kodu -->
                            <div class="col-md-4">
                                <label class="form-label">Şirket Kodu *</label>
                                <InputText @bind-Value="sirketForm.SirketKodu" class="form-control text-uppercase"
                                           placeholder="KOA" maxlength="20" disabled="@isEditing" />
                                <small class="text-muted">Benzersiz kısa kod (değiştirilemez)</small>
                            </div>

                            <!-- Unvan -->
                            <div class="col-md-8">
                                <label class="form-label">Ticari Unvan *</label>
                                <InputText @bind-Value="sirketForm.Unvan" class="form-control"
                                           placeholder="Örn: ABC Lojistik A.Ş." />
                            </div>

                            <!-- Kısa Ad -->
                            <div class="col-md-4">
                                <label class="form-label">Kısa Ad</label>
                                <InputText @bind-Value="sirketForm.KisaAd" class="form-control"
                                           placeholder="ABC Lojistik" />
                            </div>

                            <!-- Vergi No -->
                            <div class="col-md-4">
                                <label class="form-label">Vergi No</label>
                                <InputText @bind-Value="sirketForm.VergiNo" class="form-control"
                                           placeholder="1234567890" maxlength="11" />
                            </div>

                            <!-- Vergi Dairesi -->
                            <div class="col-md-4">
                                <label class="form-label">Vergi Dairesi</label>
                                <InputText @bind-Value="sirketForm.VergiDairesi" class="form-control"
                                           placeholder="Merkez V.D." />
                            </div>

                            <!-- Adres -->
                            <div class="col-12">
                                <label class="form-label">Adres</label>
                                <InputTextArea @bind-Value="sirketForm.Adres" class="form-control" rows="2"
                                               placeholder="Merkez ofis adresi" />
                            </div>

                            <!-- İl / İlçe -->
                            <div class="col-md-6">
                                <label class="form-label">İl</label>
                                <InputText @bind-Value="sirketForm.Il" class="form-control" placeholder="İstanbul" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">İlçe</label>
                                <InputText @bind-Value="sirketForm.Ilce" class="form-control" placeholder="Kadıköy" />
                            </div>

                            <!-- Telefon / Email -->
                            <div class="col-md-6">
                                <label class="form-label">Telefon</label>
                                <InputText @bind-Value="sirketForm.Telefon" class="form-control"
                                           placeholder="0212 123 45 67" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">E-posta</label>
                                <InputText @bind-Value="sirketForm.Email" class="form-control" type="email"
                                           placeholder="info@firma.com" />
                            </div>

                            <!-- Web Sitesi -->
                            <div class="col-md-6">
                                <label class="form-label">Web Sitesi</label>
                                <InputText @bind-Value="sirketForm.WebSitesi" class="form-control"
                                           placeholder="https://www.firma.com" />
                            </div>

                            <!-- Para Birimi -->
                            <div class="col-md-3">
                                <label class="form-label">Para Birimi</label>
                                <InputSelect @bind-Value="sirketForm.ParaBirimi" class="form-select">
                                    <option value="TRY">TRY - Türk Lirası</option>
                                    <option value="USD">USD - Amerikan Doları</option>
                                    <option value="EUR">EUR - Euro</option>
                                </InputSelect>
                            </div>

                            <!-- Max Kullanıcı -->
                            <div class="col-md-3">
                                <label class="form-label">Max Kullanıcı</label>
                                <InputNumber @bind-Value="sirketForm.MaxKullaniciSayisi" class="form-control" min="1" />
                            </div>

                            @if (isEditing)
                            {
                                <!-- Aktif -->
                                <div class="col-md-6">
                                    <div class="form-check form-switch mt-4">
                                        <InputCheckbox @bind-Value="sirketForm.Aktif" class="form-check-input" id="aktifSwitch" />
                                        <label class="form-check-label" for="aktifSwitch">Şirket Aktif</label>
                                    </div>
                                </div>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger mt-3 mb-0">
                                <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
                            </div>
                        }
                    </EditForm>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="SirketKaydetAsync" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Sirket> sirketler = [];
    private bool isLoading = true;
    private bool showModal;
    private bool isEditing;
    private bool isSaving;
    private string? errorMessage;

    private SirketFormModel sirketForm = new();
    private int? editingSirketId;

    protected override async Task OnInitializedAsync()
    {
        await LoadSirketlerAsync();
    }

    private async Task LoadSirketlerAsync()
    {
        try
        {
            isLoading = true;
            sirketler = await TenantService.GetAllSirketlerAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Şirketler yüklenemedi: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void YeniSirketAc()
    {
        sirketForm = new SirketFormModel
        {
            ParaBirimi = "TRY",
            MaxKullaniciSayisi = 5,
            Aktif = true
        };
        isEditing = false;
        editingSirketId = null;
        errorMessage = null;
        showModal = true;
    }

    private void SirketDuzenle(Sirket sirket)
    {
        sirketForm = new SirketFormModel
        {
            SirketKodu = sirket.SirketKodu,
            Unvan = sirket.Unvan,
            KisaAd = sirket.KisaAd,
            VergiDairesi = sirket.VergiDairesi,
            VergiNo = sirket.VergiNo,
            Adres = sirket.Adres,
            Il = sirket.Il,
            Ilce = sirket.Ilce,
            Telefon = sirket.Telefon,
            Email = sirket.Email,
            WebSitesi = sirket.WebSitesi,
            ParaBirimi = sirket.ParaBirimi,
            MaxKullaniciSayisi = sirket.MaxKullaniciSayisi,
            Aktif = sirket.Aktif
        };
        isEditing = true;
        editingSirketId = sirket.Id;
        errorMessage = null;
        showModal = true;
    }

    private async Task SirketKaydetAsync()
    {
        if (string.IsNullOrWhiteSpace(sirketForm.SirketKodu) || string.IsNullOrWhiteSpace(sirketForm.Unvan))
        {
            errorMessage = "Şirket kodu ve unvan zorunludur.";
            return;
        }

        try
        {
            isSaving = true;
            errorMessage = null;

            if (isEditing && editingSirketId.HasValue)
            {
                var updateModel = new SirketGuncelleModel
                {
                    Id = editingSirketId.Value,
                    Unvan = sirketForm.Unvan,
                    KisaAd = sirketForm.KisaAd,
                    VergiDairesi = sirketForm.VergiDairesi,
                    VergiNo = sirketForm.VergiNo,
                    Adres = sirketForm.Adres,
                    Il = sirketForm.Il,
                    Ilce = sirketForm.Ilce,
                    Telefon = sirketForm.Telefon,
                    Email = sirketForm.Email,
                    WebSitesi = sirketForm.WebSitesi,
                    ParaBirimi = sirketForm.ParaBirimi,
                    MaxKullaniciSayisi = sirketForm.MaxKullaniciSayisi,
                    Aktif = sirketForm.Aktif
                };

                await TenantService.UpdateSirketAsync(updateModel);
                ToastService.ShowSuccess("Şirket güncellendi.");
            }
            else
            {
                var createModel = new SirketOlusturModel
                {
                    SirketKodu = sirketForm.SirketKodu.ToUpperInvariant(),
                    Unvan = sirketForm.Unvan,
                    KisaAd = sirketForm.KisaAd,
                    VergiDairesi = sirketForm.VergiDairesi,
                    VergiNo = sirketForm.VergiNo,
                    Adres = sirketForm.Adres,
                    Il = sirketForm.Il,
                    Ilce = sirketForm.Ilce,
                    Telefon = sirketForm.Telefon,
                    Email = sirketForm.Email,
                    WebSitesi = sirketForm.WebSitesi,
                    ParaBirimi = sirketForm.ParaBirimi,
                    MaxKullaniciSayisi = sirketForm.MaxKullaniciSayisi
                };

                await TenantService.CreateSirketAsync(createModel);
                ToastService.ShowSuccess("Yeni şirket oluşturuldu.");
            }

            showModal = false;
            await LoadSirketlerAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task SirketSecAsync(int sirketId)
    {
        try
        {
            await TenantService.SetCurrentSirketAsync(sirketId);
            ToastService.ShowSuccess("Şirket değiştirildi.");
            await LoadSirketlerAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Şirket değiştirilemedi: {ex.Message}");
        }
    }

    private async Task SirketSilAsync(Sirket sirket)
    {
        try
        {
            await TenantService.DeleteSirketAsync(sirket.Id);
            ToastService.ShowSuccess($"'{sirket.SirketKodu}' şirketi silindi.");
            await LoadSirketlerAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Şirket silinemedi: {ex.Message}");
        }
    }

    private void ModalKapat()
    {
        showModal = false;
        errorMessage = null;
    }

    // Form Model
    private class SirketFormModel
    {
        public string SirketKodu { get; set; } = "";
        public string Unvan { get; set; } = "";
        public string? KisaAd { get; set; }
        public string? VergiDairesi { get; set; }
        public string? VergiNo { get; set; }
        public string? Adres { get; set; }
        public string? Il { get; set; }
        public string? Ilce { get; set; }
        public string? Telefon { get; set; }
        public string? Email { get; set; }
        public string? WebSitesi { get; set; }
        public string ParaBirimi { get; set; } = "TRY";
        public int MaxKullaniciSayisi { get; set; } = 5;
        public bool Aktif { get; set; } = true;
    }
}
