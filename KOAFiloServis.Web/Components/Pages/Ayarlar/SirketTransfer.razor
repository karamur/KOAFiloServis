@page "/ayarlar/sirket-transfer"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@inject ITenantService TenantService
@inject NavigationManager Navigation
@attribute [Authorize(Roles = "Admin,SuperAdmin")]

<PageTitle>Şirketler Arası Transfer</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h3><i class="bi bi-arrow-left-right me-2"></i>Şirketler Arası Transfer</h3>
            <p class="text-muted">Veri (Cari, Araç, Şoför vb.) başka şirkete transfer edin</p>
        </div>
    </div>

    @if (!TenantService.IsSuperAdmin)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Bu sayfaya erişim için SuperAdmin yetkisi gereklidir.
        </div>
    }
    else
    {
        <!-- Transfer Formu -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-send me-2"></i>Yeni Transfer</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <!-- Entity Türü -->
                    <div class="col-md-3">
                        <label class="form-label">Veri Türü</label>
                        <select class="form-select" @bind="secilenEntityTuru" @bind:after="EntityTuruDegisti">
                            <option value="">-- Seçiniz --</option>
                            @foreach (var tur in TransferEntityTurleri.Tumu)
                            {
                                <option value="@tur">@TransferEntityTurleri.GetDisplayName(tur)</option>
                            }
                        </select>
                    </div>

                    <!-- Kaynak Şirket -->
                    <div class="col-md-3">
                        <label class="form-label">Kaynak Şirket</label>
                        <select class="form-select" @bind="kaynakSirketId" @bind:after="KaynakSirketDegisti">
                            <option value="0">-- Tüm Şirketler --</option>
                            @foreach (var sirket in sirketler)
                            {
                                <option value="@sirket.Id">@sirket.KisaAd (@sirket.SirketKodu)</option>
                            }
                        </select>
                    </div>

                    <!-- Hedef Şirket -->
                    <div class="col-md-3">
                        <label class="form-label">Hedef Şirket</label>
                        <select class="form-select" @bind="hedefSirketId">
                            <option value="0">-- Seçiniz --</option>
                            @foreach (var sirket in sirketler.Where(s => s.Id != kaynakSirketId))
                            {
                                <option value="@sirket.Id">@sirket.KisaAd (@sirket.SirketKodu)</option>
                            }
                        </select>
                    </div>

                    <!-- İlişkili Veriler -->
                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" @bind="iliskiliVerileriTransferEt" id="iliskiliCheck">
                            <label class="form-check-label" for="iliskiliCheck">
                                İlişkili verileri de transfer et
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Transfer Notu -->
                <div class="row g-3 mt-2">
                    <div class="col-12">
                        <label class="form-label">Not (Opsiyonel)</label>
                        <input type="text" class="form-control" @bind="transferNotu" placeholder="Transfer sebebi veya açıklama...">
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(secilenEntityTuru))
        {
            <!-- Entity Listesi -->
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-list-check me-2"></i>
                        @TransferEntityTurleri.GetDisplayName(secilenEntityTuru) Listesi
                    </h5>
                    <div>
                        <button class="btn btn-outline-primary btn-sm me-2" @onclick="TumunuSec">
                            <i class="bi bi-check-all me-1"></i>Tümünü Seç
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="SecimiTemizle">
                            <i class="bi bi-x-lg me-1"></i>Seçimi Temizle
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    @if (yukleniyor)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Yükleniyor...</span>
                            </div>
                        </div>
                    }
                    else if (entityOzetleri.Count == 0)
                    {
                        <div class="alert alert-info mb-0">
                            <i class="bi bi-info-circle me-2"></i>
                            Bu kriterlere uygun veri bulunamadı.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                            <table class="table table-hover table-sm">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th style="width: 40px;">
                                            <input class="form-check-input" type="checkbox" 
                                                   checked="@tumunuSecildi" 
                                                   @onchange="TumSecimDegistir">
                                        </th>
                                        <th>Açıklama</th>
                                        <th>Mevcut Şirket</th>
                                        <th>İlişkili Veri</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ozet in entityOzetleri)
                                    {
                                        <tr class="@(secilenEntityIdler.Contains(ozet.Id) ? "table-primary" : "")">
                                            <td>
                                                <input class="form-check-input" type="checkbox" 
                                                       checked="@secilenEntityIdler.Contains(ozet.Id)"
                                                       @onchange="() => EntitySecimDegistir(ozet.Id)">
                                            </td>
                                            <td>@ozet.Aciklama</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(ozet.MevcutSirketAdi))
                                                {
                                                    <span class="badge bg-secondary">@ozet.MevcutSirketAdi</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Şirket atanmamış</span>
                                                }
                                            </td>
                                            <td>
                                                @if (ozet.IliskiliEntitySayisi > 0)
                                                {
                                                    <span class="badge bg-info">@ozet.IliskiliEntitySayisi kayıt</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="text-muted">
                                <strong>@secilenEntityIdler.Count</strong> / @entityOzetleri.Count kayıt seçildi
                            </span>
                            <button class="btn btn-primary" 
                                    @onclick="TransferEt"
                                    disabled="@(secilenEntityIdler.Count == 0 || hedefSirketId == 0 || transferEdiliyor)">
                                @if (transferEdiliyor)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                    <span>Transfer Ediliyor...</span>
                                }
                                else
                                {
                                    <i class="bi bi-arrow-right-circle me-1"></i>
                                    <span>Transfer Et (@secilenEntityIdler.Count kayıt)</span>
                                }
                            </button>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Transfer Sonucu -->
        @if (transferSonucu != null)
        {
            <div class="card mb-4 @(transferSonucu.Basarili ? "border-success" : "border-danger")">
                <div class="card-header @(transferSonucu.Basarili ? "bg-success text-white" : "bg-danger text-white")">
                    <h5 class="mb-0">
                        <i class="bi @(transferSonucu.Basarili ? "bi-check-circle" : "bi-x-circle") me-2"></i>
                        Transfer Sonucu
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="text-center p-3 bg-light rounded">
                                <h3 class="text-success mb-0">@transferSonucu.TransferEdilenSayisi</h3>
                                <small class="text-muted">Başarılı Transfer</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="text-center p-3 bg-light rounded">
                                <h3 class="text-danger mb-0">@transferSonucu.BasarisizSayisi</h3>
                                <small class="text-muted">Başarısız</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="text-center p-3 bg-light rounded">
                                <h3 class="text-info mb-0">@transferSonucu.IliskiliEntitySayisi</h3>
                                <small class="text-muted">İlişkili Kayıt</small>
                            </div>
                        </div>
                    </div>

                    @if (transferSonucu.Hatalar.Count > 0)
                    {
                        <div class="alert alert-danger mt-3 mb-0">
                            <strong>Hatalar:</strong>
                            <ul class="mb-0 mt-2">
                                @foreach (var hata in transferSonucu.Hatalar)
                                {
                                    <li>@hata</li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Transfer Geçmişi -->
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Transfer Geçmişi</h5>
                <button class="btn btn-outline-primary btn-sm" @onclick="TransferLoglariniYukle">
                    <i class="bi bi-arrow-clockwise me-1"></i>Yenile
                </button>
            </div>
            <div class="card-body">
                @if (transferLoglari.Count == 0)
                {
                    <div class="alert alert-info mb-0">
                        <i class="bi bi-info-circle me-2"></i>
                        Henüz transfer işlemi yapılmamış.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>Tarih</th>
                                    <th>Tür</th>
                                    <th>Açıklama</th>
                                    <th>Kaynak</th>
                                    <th>Hedef</th>
                                    <th>Durum</th>
                                    <th>Kullanıcı</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in transferLoglari.Take(50))
                                {
                                    <tr>
                                        <td>@log.TransferTarihi.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>
                                            <span class="badge bg-primary">
                                                @TransferEntityTurleri.GetDisplayName(log.EntityTuru)
                                            </span>
                                        </td>
                                        <td>@log.EntityAciklama</td>
                                        <td>@(log.KaynakSirket?.KisaAd ?? "-")</td>
                                        <td>@(log.HedefSirket?.KisaAd ?? "-")</td>
                                        <td>
                                            @switch (log.Durum)
                                            {
                                                case TransferDurum.Basarili:
                                                    <span class="badge bg-success">Başarılı</span>
                                                    break;
                                                case TransferDurum.Basarisiz:
                                                    <span class="badge bg-danger" title="@log.HataMesaji">Başarısız</span>
                                                    break;
                                                case TransferDurum.KismiBasarili:
                                                    <span class="badge bg-warning">Kısmi</span>
                                                    break;
                                            }
                                        </td>
                                        <td>@(log.Kullanici?.AdSoyad ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private List<Sirket> sirketler = new();
    private List<TransferEntityOzet> entityOzetleri = new();
    private List<SirketTransferLog> transferLoglari = new();
    private HashSet<int> secilenEntityIdler = new();

    private string secilenEntityTuru = "";
    private int kaynakSirketId;
    private int hedefSirketId;
    private bool iliskiliVerileriTransferEt;
    private string transferNotu = "";

    private bool yukleniyor;
    private bool transferEdiliyor;
    private bool tumunuSecildi => entityOzetleri.Count > 0 && secilenEntityIdler.Count == entityOzetleri.Count;

    private SirketTransferResult? transferSonucu;

    protected override async Task OnInitializedAsync()
    {
        if (TenantService.IsSuperAdmin)
        {
            sirketler = await TenantService.GetAllSirketlerAsync();
            await TransferLoglariniYukle();
        }
    }

    private async Task EntityTuruDegisti()
    {
        secilenEntityIdler.Clear();
        transferSonucu = null;
        await EntityListesiniYukle();
    }

    private async Task KaynakSirketDegisti()
    {
        secilenEntityIdler.Clear();
        await EntityListesiniYukle();
    }

    private async Task EntityListesiniYukle()
    {
        if (string.IsNullOrEmpty(secilenEntityTuru)) return;

        yukleniyor = true;
        StateHasChanged();

        try
        {
            // Tüm entity'lerin ID'lerini al
            var tumIdler = await GetEntityIdlerAsync();
            
            // Önizleme bilgilerini al
            entityOzetleri = await TenantService.GetTransferOnizlemeAsync(secilenEntityTuru, tumIdler);

            // Kaynak şirket filtresi
            if (kaynakSirketId > 0)
            {
                entityOzetleri = entityOzetleri.Where(e => e.MevcutSirketId == kaynakSirketId).ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Entity listesi yüklenemedi: {ex.Message}");
        }
        finally
        {
            yukleniyor = false;
        }
    }

    private async Task<List<int>> GetEntityIdlerAsync()
    {
        // Bu metod gerçek implementasyonda ilgili servisleri çağırmalı
        // Şimdilik basit bir örnek:
        return entityOzetleri.Select(e => e.Id).ToList();
    }

    private void TumunuSec()
    {
        secilenEntityIdler = entityOzetleri.Select(e => e.Id).ToHashSet();
    }

    private void SecimiTemizle()
    {
        secilenEntityIdler.Clear();
    }

    private void TumSecimDegistir(ChangeEventArgs e)
    {
        if ((bool?)e.Value == true)
        {
            TumunuSec();
        }
        else
        {
            SecimiTemizle();
        }
    }

    private void EntitySecimDegistir(int id)
    {
        if (secilenEntityIdler.Contains(id))
        {
            secilenEntityIdler.Remove(id);
        }
        else
        {
            secilenEntityIdler.Add(id);
        }
    }

    private async Task TransferEt()
    {
        if (secilenEntityIdler.Count == 0 || hedefSirketId == 0) return;

        transferEdiliyor = true;
        transferSonucu = null;
        StateHasChanged();

        try
        {
            var request = new SirketTransferRequest
            {
                EntityTuru = secilenEntityTuru,
                EntityIdler = secilenEntityIdler.ToList(),
                HedefSirketId = hedefSirketId,
                IliskiliVerileriTransferEt = iliskiliVerileriTransferEt,
                Notlar = transferNotu
            };

            transferSonucu = await TenantService.TransferAsync(request);

            // Başarılı transfer sonrası listeyi yenile
            if (transferSonucu.Basarili)
            {
                secilenEntityIdler.Clear();
                await EntityListesiniYukle();
                await TransferLoglariniYukle();
            }
        }
        catch (Exception ex)
        {
            transferSonucu = new SirketTransferResult
            {
                Basarili = false,
                Hatalar = { ex.Message }
            };
        }
        finally
        {
            transferEdiliyor = false;
        }
    }

    private async Task TransferLoglariniYukle()
    {
        try
        {
            transferLoglari = await TenantService.GetTransferLoglariAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Transfer logları yüklenemedi: {ex.Message}");
        }
    }
}
