@page "/personel/maas-hareketleri"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using ClosedXML.Excel
@inject IPersonelMaasIzinService PersonelService
@inject ISoforService SoforService
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Maaş Hareket Listesi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-clock-history me-2"></i>Maaş Hareket Listesi</h3>
        <div class="d-flex gap-2">
            <button class="btn btn-success" @onclick="ExcelExport" disabled="@(!hareketler.Any())">
                <i class="bi bi-file-earmark-excel me-1"></i>Excel
            </button>
        </div>
    </div>

    <!-- Filtreler -->
    <div class="card mb-4">
        <div class="card-body py-3">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-bold">Personel</label>
                    <select class="form-select form-select-sm" @bind="secilenSoforId" @bind:after="Filtrele">
                        <option value="0">-- Tüm Personel --</option>
                        @foreach (var sofor in soforler)
                        {
                            <option value="@sofor.Id">@sofor.TamAd</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold">Yıl</label>
                    <select class="form-select form-select-sm" @bind="secilenYil" @bind:after="Filtrele">
                        <option value="0">-- Tüm Yıllar --</option>
                        @for (int y = DateTime.Today.Year; y >= DateTime.Today.Year - 5; y--)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold">Ay</label>
                    <select class="form-select form-select-sm" @bind="secilenAy" @bind:after="Filtrele">
                        <option value="0">-- Tüm Aylar --</option>
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m">@(new DateTime(2024, m, 1).ToString("MMMM"))</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold">Ödeme Durumu</label>
                    <select class="form-select form-select-sm" @bind="secilenDurum" @bind:after="Filtrele">
                        <option value="-1">-- Tümü --</option>
                        <option value="0">Bekliyor</option>
                        <option value="1">Ödendi</option>
                        <option value="2">Kısmi Ödendi</option>
                        <option value="3">İptal Edildi</option>
                    </select>
                </div>
                <div class="col-md-3 text-end">
                    <span class="badge bg-secondary fs-6">@filtrelenmisHareketler.Count kayıt</span>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <!-- Özet Kartları -->
        @if (filtrelenmisHareketler.Any())
        {
            <div class="row mb-4">
                <div class="col-md-3">
                    <div class="card bg-primary text-white">
                        <div class="card-body text-center py-2">
                            <h6 class="mb-0">Toplam Kayıt</h6>
                            <h4 class="mb-0">@filtrelenmisHareketler.Count</h4>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-success text-white">
                        <div class="card-body text-center py-2">
                            <h6 class="mb-0">Toplam Ödenen</h6>
                            <h5 class="mb-0">@filtrelenmisHareketler.Where(h => h.OdemeDurum == MaasOdemeDurum.Odendi).Sum(h => h.OdenecekTutar).ToString("N0") ₺</h5>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-warning text-dark">
                        <div class="card-body text-center py-2">
                            <h6 class="mb-0">Bekleyen</h6>
                            <h5 class="mb-0">@filtrelenmisHareketler.Where(h => h.OdemeDurum == MaasOdemeDurum.Bekliyor).Sum(h => h.OdenecekTutar).ToString("N0") ₺</h5>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-info text-white">
                        <div class="card-body text-center py-2">
                            <h6 class="mb-0">Genel Toplam</h6>
                            <h5 class="mb-0">@filtrelenmisHareketler.Sum(h => h.OdenecekTutar).ToString("N0") ₺</h5>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Hareket Tablosu -->
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:40px">#</th>
                                <th>Personel</th>
                                <th class="text-center">Dönem</th>
                                <th class="text-end">Brüt Maaş</th>
                                <th class="text-end">Net Maaş</th>
                                <th class="text-end">Eklemeler</th>
                                <th class="text-end">Kesintiler</th>
                                <th class="text-end">Ödenecek</th>
                                <th class="text-center">Çalışma</th>
                                <th class="text-center">Durum</th>
                                <th class="text-center">Ödeme Tarihi</th>
                                <th class="text-center">Detay</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int sira = 0; }
                            @foreach (var h in filtrelenmisHareketler)
                            {
                                sira++;
                                <tr class="@(h.OdemeDurum == MaasOdemeDurum.IptalEdildi ? "table-secondary text-muted" : "")">
                                    <td class="text-muted">@sira</td>
                                    <td><strong>@(h.Sofor != null ? h.Sofor.TamAd : "-")</strong></td>
                                    <td class="text-center">
                                        <span class="badge bg-light text-dark">@(new DateTime(h.Yil, h.Ay, 1).ToString("MMMM yyyy"))</span>
                                    </td>
                                    <td class="text-end">@h.BrutMaas.ToString("N0") ₺</td>
                                    <td class="text-end">@h.NetMaas.ToString("N0") ₺</td>
                                    <td class="text-end text-success">
                                        @if (h.ToplamEklemeler > 0)
                                        {
                                            <span>+@h.ToplamEklemeler.ToString("N0") ₺</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-end text-danger">
                                        @if (h.ToplamKesintiler > 0)
                                        {
                                            <span>-@h.ToplamKesintiler.ToString("N0") ₺</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-end"><strong>@h.OdenecekTutar.ToString("N0") ₺</strong></td>
                                    <td class="text-center">
                                        <small>@h.CalismaGunu gün</small>
                                        @if (h.IzinliGun > 0)
                                        {
                                            <br /><small class="text-warning">@h.IzinliGun izin</small>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @switch (h.OdemeDurum)
                                        {
                                            case MaasOdemeDurum.Odendi:
                                                <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Ödendi</span>
                                                break;
                                            case MaasOdemeDurum.Bekliyor:
                                                <span class="badge bg-warning text-dark"><i class="bi bi-clock me-1"></i>Bekliyor</span>
                                                break;
                                            case MaasOdemeDurum.KismiOdendi:
                                                <span class="badge bg-info"><i class="bi bi-cash me-1"></i>Kısmi</span>
                                                break;
                                            case MaasOdemeDurum.IptalEdildi:
                                                <span class="badge bg-secondary"><i class="bi bi-x-circle me-1"></i>İptal</span>
                                                break;
                                        }
                                    </td>
                                    <td class="text-center">
                                        <small>@(h.OdemeTarihi.HasValue ? h.OdemeTarihi.Value.ToString("dd.MM.yyyy") : "-")</small>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-outline-primary btn-sm" @onclick="() => DetayGoster(h)" title="Detay">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        @if (filtrelenmisHareketler.Any())
                        {
                            <tfoot class="table-light fw-bold">
                                <tr>
                                    <td colspan="3" class="text-end">TOPLAM:</td>
                                    <td class="text-end">@filtrelenmisHareketler.Sum(h => h.BrutMaas).ToString("N0") ₺</td>
                                    <td class="text-end">@filtrelenmisHareketler.Sum(h => h.NetMaas).ToString("N0") ₺</td>
                                    <td class="text-end text-success">+@filtrelenmisHareketler.Sum(h => h.ToplamEklemeler).ToString("N0") ₺</td>
                                    <td class="text-end text-danger">-@filtrelenmisHareketler.Sum(h => h.ToplamKesintiler).ToString("N0") ₺</td>
                                    <td class="text-end">@filtrelenmisHareketler.Sum(h => h.OdenecekTutar).ToString("N0") ₺</td>
                                    <td colspan="4"></td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>
                @if (!filtrelenmisHareketler.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-inbox fs-1"></i>
                        <p class="mt-2">Kayıt bulunamadı</p>
                    </div>
                }
            </div>
        </div>

        <!-- Personel Bazlı Özet -->
        @if (secilenSoforId == 0 && filtrelenmisHareketler.Any())
        {
            <div class="card mt-4">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-bar-chart me-2"></i>Personel Bazlı Özet</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Personel</th>
                                    <th class="text-center">Kayıt Sayısı</th>
                                    <th class="text-end">Toplam Brüt</th>
                                    <th class="text-end">Toplam Net</th>
                                    <th class="text-end">Toplam Ödenecek</th>
                                    <th class="text-center">Ödenen</th>
                                    <th class="text-center">Bekleyen</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var g in personelOzetleri)
                                {
                                    <tr>
                                        <td><strong>@g.AdSoyad</strong></td>
                                        <td class="text-center">@g.KayitSayisi</td>
                                        <td class="text-end">@g.ToplamBrut.ToString("N0") ₺</td>
                                        <td class="text-end">@g.ToplamNet.ToString("N0") ₺</td>
                                        <td class="text-end"><strong>@g.ToplamOdenecek.ToString("N0") ₺</strong></td>
                                        <td class="text-center"><span class="badge bg-success">@g.OdenenSayisi</span></td>
                                        <td class="text-center">
                                            @if (g.BekleyenSayisi > 0)
                                            {
                                                <span class="badge bg-warning text-dark">@g.BekleyenSayisi</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-light text-muted">0</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
</div>

<!-- Detay Modal -->
@if (detayMaas != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-receipt me-2"></i>Maaş Detayı - @(detayMaas.Sofor != null ? detayMaas.Sofor.TamAd : "-")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="DetayKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body py-2">
                                    <h6 class="text-primary mb-2">Dönem Bilgisi</h6>
                                    <table class="table table-sm table-borderless mb-0">
                                        <tr>
                                            <td class="text-muted">Dönem:</td>
                                            <td class="text-end fw-bold">@(new DateTime(detayMaas.Yil, detayMaas.Ay, 1).ToString("MMMM yyyy"))</td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted">Çalışma Günü:</td>
                                            <td class="text-end">@detayMaas.CalismaGunu gün</td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted">İzinli Gün:</td>
                                            <td class="text-end">@detayMaas.IzinliGun gün</td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted">Raporlu Gün:</td>
                                            <td class="text-end">@detayMaas.RaporluGun gün</td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted">Devamsızlık:</td>
                                            <td class="text-end">@detayMaas.DevamsizlikGun gün</td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body py-2">
                                    <h6 class="text-primary mb-2">Ödeme Bilgisi</h6>
                                    <table class="table table-sm table-borderless mb-0">
                                        <tr>
                                            <td class="text-muted">Durum:</td>
                                            <td class="text-end">
                                                @switch (detayMaas.OdemeDurum)
                                                {
                                                    case MaasOdemeDurum.Odendi:
                                                        <span class="badge bg-success">Ödendi</span>
                                                        break;
                                                    case MaasOdemeDurum.Bekliyor:
                                                        <span class="badge bg-warning text-dark">Bekliyor</span>
                                                        break;
                                                    case MaasOdemeDurum.KismiOdendi:
                                                        <span class="badge bg-info">Kısmi</span>
                                                        break;
                                                    case MaasOdemeDurum.IptalEdildi:
                                                        <span class="badge bg-secondary">İptal</span>
                                                        break;
                                                }
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted">Ödeme Tarihi:</td>
                                            <td class="text-end">@(detayMaas.OdemeTarihi.HasValue ? detayMaas.OdemeTarihi.Value.ToString("dd.MM.yyyy") : "-")</td>
                                        </tr>
                                        @if (!string.IsNullOrEmpty(detayMaas.OdemeAciklama))
                                        {
                                            <tr>
                                                <td class="text-muted">Açıklama:</td>
                                                <td class="text-end">@detayMaas.OdemeAciklama</td>
                                            </tr>
                                        }
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="card border-primary">
                                <div class="card-header bg-primary text-white py-1">
                                    <small class="fw-bold">Maaş Bilgileri</small>
                                </div>
                                <div class="card-body py-2">
                                    <table class="table table-sm table-borderless mb-0">
                                        <tr>
                                            <td>Brüt Maaş:</td>
                                            <td class="text-end fw-bold">@detayMaas.BrutMaas.ToString("N2") ₺</td>
                                        </tr>
                                        <tr>
                                            <td>Net Maaş:</td>
                                            <td class="text-end fw-bold">@detayMaas.NetMaas.ToString("N2") ₺</td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-success">
                                <div class="card-header bg-success text-white py-1">
                                    <small class="fw-bold">Ek Ödemeler (@detayMaas.ToplamEklemeler.ToString("N2") ₺)</small>
                                </div>
                                <div class="card-body py-2">
                                    <table class="table table-sm table-borderless mb-0">
                                        @if (detayMaas.Prim > 0) { <tr><td>Prim:</td><td class="text-end">@detayMaas.Prim.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.Ikramiye > 0) { <tr><td>İkramiye:</td><td class="text-end">@detayMaas.Ikramiye.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.Yemek > 0) { <tr><td>Yemek:</td><td class="text-end">@detayMaas.Yemek.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.Yol > 0) { <tr><td>Yol:</td><td class="text-end">@detayMaas.Yol.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.Mesai > 0) { <tr><td>Mesai:</td><td class="text-end">@detayMaas.Mesai.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.DigerEklemeler > 0) { <tr><td>Diğer:</td><td class="text-end">@detayMaas.DigerEklemeler.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.ToplamEklemeler == 0) { <tr><td colspan="2" class="text-center text-muted">-</td></tr> }
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-danger">
                                <div class="card-header bg-danger text-white py-1">
                                    <small class="fw-bold">Kesintiler (@detayMaas.ToplamKesintiler.ToString("N2") ₺)</small>
                                </div>
                                <div class="card-body py-2">
                                    <table class="table table-sm table-borderless mb-0">
                                        @if (detayMaas.SGKIsciPayi > 0) { <tr><td>SGK İşçi:</td><td class="text-end">@detayMaas.SGKIsciPayi.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.GelirVergisi > 0) { <tr><td>Gelir V.:</td><td class="text-end">@detayMaas.GelirVergisi.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.DamgaVergisi > 0) { <tr><td>Damga V.:</td><td class="text-end">@detayMaas.DamgaVergisi.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.IssizlikPrimi > 0) { <tr><td>İşsizlik:</td><td class="text-end">@detayMaas.IssizlikPrimi.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.Avans > 0) { <tr><td>Avans:</td><td class="text-end">@detayMaas.Avans.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.IcraTakibi > 0) { <tr><td>İcra:</td><td class="text-end">@detayMaas.IcraTakibi.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.DigerKesintiler > 0) { <tr><td>Diğer:</td><td class="text-end">@detayMaas.DigerKesintiler.ToString("N2") ₺</td></tr> }
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-primary mt-3 mb-0 text-center">
                        <h5 class="mb-0">Ödenecek Tutar: <strong>@detayMaas.OdenecekTutar.ToString("N2") ₺</strong></h5>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="DetayKapat">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Bildirim Toast -->
@if (!string.IsNullOrEmpty(bildirimMesaj))
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999;">
        <div class="toast show" role="alert">
            <div class="toast-header @(bildirimBasarili ? "bg-success" : "bg-danger") text-white">
                <i class="bi @(bildirimBasarili ? "bi-check-circle" : "bi-exclamation-circle") me-2"></i>
                <strong class="me-auto">@(bildirimBasarili ? "Başarılı" : "Hata")</strong>
                <button type="button" class="btn-close btn-close-white" @onclick="() => bildirimMesaj = null"></button>
            </div>
            <div class="toast-body">
                @bildirimMesaj
            </div>
        </div>
    </div>
}

@code {
    private List<Sofor> soforler = new();
    private List<PersonelMaas> hareketler = new();
    private List<PersonelMaas> filtrelenmisHareketler = new();
    private List<PersonelBazliOzet> personelOzetleri = new();
    private PersonelMaas? detayMaas;
    private bool isLoading = false;

    // Filtreler
    private int secilenSoforId = 0;
    private int secilenYil = 0;
    private int secilenAy = 0;
    private int secilenDurum = -1;

    // Bildirim
    private string? bildirimMesaj;
    private bool bildirimBasarili;
    private System.Threading.Timer? bildirimTimer;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            soforler = await SoforService.GetActiveAsync();
            secilenYil = DateTime.Today.Year;
            await VeriYukle();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task VeriYukle()
    {
        // Tüm maaş kayıtlarını yükle
        var tumKayitlar = new List<PersonelMaas>();

        if (secilenSoforId > 0)
        {
            tumKayitlar = await PersonelService.GetSoforMaasGecmisiAsync(secilenSoforId);
        }
        else if (secilenYil > 0 && secilenAy > 0)
        {
            tumKayitlar = await PersonelService.GetMaaslarAsync(secilenYil, secilenAy);
        }
        else if (secilenYil > 0)
        {
            // Yıl seçili ama ay seçili değilse tüm ayları yükle
            for (int ay = 1; ay <= 12; ay++)
            {
                var aylikKayitlar = await PersonelService.GetMaaslarAsync(secilenYil, ay);
                tumKayitlar.AddRange(aylikKayitlar);
            }
        }
        else
        {
            // Hiçbir filtre yoksa mevcut yılın tüm kayıtlarını göster
            for (int ay = 1; ay <= 12; ay++)
            {
                var aylikKayitlar = await PersonelService.GetMaaslarAsync(DateTime.Today.Year, ay);
                tumKayitlar.AddRange(aylikKayitlar);
            }
        }

        hareketler = tumKayitlar
            .OrderByDescending(h => h.Yil)
            .ThenByDescending(h => h.Ay)
            .ThenBy(h => h.Sofor != null ? h.Sofor.TamAd : "")
            .ToList();

        UygulaFiltre();
    }

    private async Task Filtrele()
    {
        isLoading = true;
        try
        {
            await VeriYukle();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void UygulaFiltre()
    {
        var sonuc = hareketler.AsEnumerable();

        if (secilenDurum >= 0)
        {
            var durum = (MaasOdemeDurum)secilenDurum;
            sonuc = sonuc.Where(h => h.OdemeDurum == durum);
        }

        filtrelenmisHareketler = sonuc.ToList();
        HesaplaPersonelOzetleri();
    }

    private void HesaplaPersonelOzetleri()
    {
        personelOzetleri = filtrelenmisHareketler
            .GroupBy(h => h.SoforId)
            .Select(g => new PersonelBazliOzet
            {
                SoforId = g.Key,
                AdSoyad = g.First().Sofor != null ? g.First().Sofor.TamAd : "-",
                KayitSayisi = g.Count(),
                ToplamBrut = g.Sum(h => h.BrutMaas),
                ToplamNet = g.Sum(h => h.NetMaas),
                ToplamOdenecek = g.Sum(h => h.OdenecekTutar),
                OdenenSayisi = g.Count(h => h.OdemeDurum == MaasOdemeDurum.Odendi),
                BekleyenSayisi = g.Count(h => h.OdemeDurum == MaasOdemeDurum.Bekliyor)
            })
            .OrderBy(o => o.AdSoyad)
            .ToList();
    }

    private void DetayGoster(PersonelMaas maas)
    {
        detayMaas = maas;
    }

    private void DetayKapat()
    {
        detayMaas = null;
    }

    private async Task ExcelExport()
    {
        try
        {
            using var workbook = new XLWorkbook();
            var ws = workbook.Worksheets.Add("Maaş Hareketleri");

            // Başlık
            ws.Cell(1, 1).Value = "Maaş Hareket Listesi";
            ws.Range(1, 1, 1, 12).Merge().Style.Font.Bold = true;
            ws.Cell(1, 1).Style.Font.FontSize = 14;

            // Filtre bilgisi
            var filtreBilgi = "Filtre: ";
            if (secilenYil > 0) filtreBilgi += $"Yıl: {secilenYil} ";
            if (secilenAy > 0) filtreBilgi += $"Ay: {new DateTime(2024, secilenAy, 1):MMMM} ";
            if (secilenSoforId > 0)
            {
                var sofor = soforler.FirstOrDefault(s => s.Id == secilenSoforId);
                if (sofor != null) filtreBilgi += $"Personel: {sofor.TamAd} ";
            }
            ws.Cell(2, 1).Value = filtreBilgi;
            ws.Range(2, 1, 2, 12).Merge();

            // Kolonlar
            var basliklar = new[] { "Personel", "Dönem", "Brüt Maaş", "Net Maaş", "Prim", "İkramiye", "Yemek", "Yol", "Mesai", "Kesintiler", "Ödenecek", "Durum", "Ödeme Tarihi" };
            for (int i = 0; i < basliklar.Length; i++)
            {
                ws.Cell(4, i + 1).Value = basliklar[i];
                ws.Cell(4, i + 1).Style.Font.Bold = true;
                ws.Cell(4, i + 1).Style.Fill.BackgroundColor = XLColor.LightGray;
            }

            // Veriler
            int satir = 5;
            foreach (var h in filtrelenmisHareketler)
            {
                ws.Cell(satir, 1).Value = h.Sofor != null ? h.Sofor.TamAd : "-";
                ws.Cell(satir, 2).Value = new DateTime(h.Yil, h.Ay, 1).ToString("MMMM yyyy");
                ws.Cell(satir, 3).Value = h.BrutMaas;
                ws.Cell(satir, 4).Value = h.NetMaas;
                ws.Cell(satir, 5).Value = h.Prim;
                ws.Cell(satir, 6).Value = h.Ikramiye;
                ws.Cell(satir, 7).Value = h.Yemek;
                ws.Cell(satir, 8).Value = h.Yol;
                ws.Cell(satir, 9).Value = h.Mesai;
                ws.Cell(satir, 10).Value = h.ToplamKesintiler;
                ws.Cell(satir, 11).Value = h.OdenecekTutar;
                ws.Cell(satir, 12).Value = h.OdemeDurum.ToString();
                ws.Cell(satir, 13).Value = h.OdemeTarihi.HasValue ? h.OdemeTarihi.Value.ToString("dd.MM.yyyy") : "-";

                // Para formatı
                for (int col = 3; col <= 11; col++)
                    ws.Cell(satir, col).Style.NumberFormat.Format = "#,##0.00";

                satir++;
            }

            // Toplam satırı
            ws.Cell(satir, 1).Value = "TOPLAM";
            ws.Cell(satir, 1).Style.Font.Bold = true;
            ws.Cell(satir, 3).Value = filtrelenmisHareketler.Sum(h => h.BrutMaas);
            ws.Cell(satir, 4).Value = filtrelenmisHareketler.Sum(h => h.NetMaas);
            ws.Cell(satir, 11).Value = filtrelenmisHareketler.Sum(h => h.OdenecekTutar);
            for (int col = 3; col <= 11; col++)
            {
                ws.Cell(satir, col).Style.NumberFormat.Format = "#,##0.00";
                ws.Cell(satir, col).Style.Font.Bold = true;
            }

            ws.Columns().AdjustToContents();

            var dosyaAdi = $"Maas_Hareketleri_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";
            var klasor = Path.Combine("wwwroot", "exports");
            Directory.CreateDirectory(klasor);
            var dosyaYolu = Path.Combine(klasor, dosyaAdi);
            workbook.SaveAs(dosyaYolu);

            BildirimGoster($"Excel dosyası oluşturuldu: {dosyaAdi}", true);
        }
        catch (Exception ex)
        {
            BildirimGoster($"Excel export hatası: {ex.Message}", false);
        }
    }

    private void BildirimGoster(string mesaj, bool basarili)
    {
        bildirimMesaj = mesaj;
        bildirimBasarili = basarili;
        bildirimTimer?.Dispose();
        bildirimTimer = new System.Threading.Timer(_ =>
        {
            bildirimMesaj = null;
            InvokeAsync(StateHasChanged);
        }, null, 3000, System.Threading.Timeout.Infinite);
    }

    public void Dispose()
    {
        bildirimTimer?.Dispose();
    }

    private class PersonelBazliOzet
    {
        public int SoforId { get; set; }
        public string AdSoyad { get; set; } = string.Empty;
        public int KayitSayisi { get; set; }
        public decimal ToplamBrut { get; set; }
        public decimal ToplamNet { get; set; }
        public decimal ToplamOdenecek { get; set; }
        public int OdenenSayisi { get; set; }
        public int BekleyenSayisi { get; set; }
    }
}
