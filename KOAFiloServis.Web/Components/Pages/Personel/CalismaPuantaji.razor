        PersonelPuantajOnayDurumu.Onaylandi => "Onaylandı",
        PersonelPuantajOnayDurumu.Reddedildi => "Reddedildi",
        _ => "Taslak"
    };

    private static string GetOnayBadgeClass(PersonelPuantajOnayDurumu durum) => durum switch
    {
