    private void BankayaYatanDegisti(PersonelOdemeKalemi item, ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var val))
        {
            item.BankayaYatan = val;
            item.EldenOdenecek = item.GercekMaas - item.BankayaYatan - item.Kesinti + item.PersonelHarcamasi - item.Avans;
        }
    }

    private async Task BankayaYatanKaydet()
    {
        if (personelListesi == null || !personelListesi.Any()) return;
        isKaydediliyor = true;
        try
        {
            int guncellenen = 0;
            foreach (var item in personelListesi)
            {
                var personelId = item.Personel.Id;
                var sofor = await DbContext.Soforler.FindAsync(personelId);
                if (sofor != null && sofor.ResmiNetMaas != item.BankayaYatan)
                {
                    sofor.ResmiNetMaas = item.BankayaYatan;
                    sofor.UpdatedAt = DateTime.UtcNow;
                    guncellenen++;
                }
            }
            await DbContext.SaveChangesAsync();
            ToastService.ShowSuccess($"{guncellenen} personelin bankaya yatan tutarı güncellendi.");
            await YenileData();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Kaydetme sırasında hata: {ex.Message}");
        }
        finally
        {
            isKaydediliyor = false;
        }
    }

