@page "/personel/banka-odeme-listesi"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using KOAFiloServis.Web.Services.Interfaces
@using KOAFiloServis.Web.Data
@using Microsoft.EntityFrameworkCore
@inject ISoforService SoforService
@inject IPersonelFinansService FinansService
@inject IPersonelMaasIzinService PersonelMaasService
@inject IBankaHesapService BankaHesapService
@inject ApplicationDbContext DbContext
@inject IToastService ToastService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Personel Banka Ödeme Listesi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3><i class="bi bi-bank me-2"></i>Personel Banka Ödeme Listesi</h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/personel">Personel</a></li>
                    <li class="breadcrumb-item active">Banka Ödeme Listesi</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex gap-2">
            <select class="form-select form-select-sm" style="width: 120px;" @bind="secilenYil" @bind:after="YenileData">
                @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <select class="form-select form-select-sm" style="width: 150px;" @bind="secilenAy" @bind:after="YenileData">
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m">@(new DateTime(2024, m, 1).ToString("MMMM"))</option>
                }
            </select>
            <select class="form-select form-select-sm" style="width: 180px;" @bind="secilenGorev" @bind:after="YenileData">
                <option value="">Tüm Görevler</option>
                @foreach (PersonelGorev gorev in Enum.GetValues(typeof(PersonelGorev)))
                {
                    <option value="@gorev">@GetGorevAdi(gorev)</option>
                }
            </select>
            <div class="btn-group" role="group">
                <button class="btn btn-outline-success btn-sm" @onclick="ExcelAktar" disabled="@(personelListesi == null || !personelListesi.Any())">
                    <i class="bi bi-file-earmark-excel me-1"></i>Excel
                </button>
                <button class="btn btn-success btn-sm" @onclick="VakifbankModalAc" disabled="@(personelListesi == null || !personelListesi.Any(p => p.BankayaYatan > 0))" title="Vakıfbank toplu maaş ödeme formatı">
                    <i class="bi bi-bank me-1"></i>Vakıfbank Toplu Maaş
                </button>
                <button class="btn btn-outline-primary btn-sm" @onclick="BankaEftExport" disabled="@(personelListesi == null || !personelListesi.Any())" title="Banka EFT/Havale toplu ödeme dosyası">
                    <i class="bi bi-file-earmark-text me-1"></i>EFT CSV
                </button>
                <button class="btn btn-outline-danger btn-sm" @onclick="PdfAktar" disabled="@(personelListesi == null || !personelListesi.Any())" title="PDF olarak aktar">
                    <i class="bi bi-file-earmark-pdf me-1"></i>PDF
                </button>
            </div>
            <div class="btn-group" role="group">
                <button class="btn btn-warning btn-sm" @onclick="TopluTahakkukModalAc" disabled="@(personelListesi == null || !personelListesi.Any())" title="Seçili dönem için toplu maaş tahakkuku oluştur">
                    <i class="bi bi-receipt me-1"></i>Toplu Tahakkuk
                </button>
                <button class="btn btn-primary btn-sm" @onclick="TopluOdemeModalAc" disabled="@(personelListesi == null || !personelListesi.Any())" title="Banka hesabından toplu maaş ödemesi yap">
                    <i class="bi bi-cash-stack me-1"></i>Bankadan Öde
                </button>
                <button class="btn btn-success btn-sm" @onclick="BankayaYatanKaydet" disabled="@(personelListesi == null || !personelListesi.Any() || isKaydediliyor)" title="Bankaya Yatan tutarlarını personel kartlarına kaydet">
                    @if (isKaydediliyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    <i class="bi bi-floppy me-1"></i>Kaydet
                </button>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (personelListesi != null && personelListesi.Any())
    {
        <!-- Ana Tablo -->
        <div class="card mb-3">
            <div class="card-header bg-primary text-white py-2">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-list-ul me-2"></i>
                        @(new DateTime(secilenYil, secilenAy, 1).ToString("MMMM yyyy")) Banka Ödeme Listesi
                    </h5>
                    <span class="badge bg-light text-primary">@personelListesi.Count personel</span>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover mb-0" id="bankaOdemeTablosu">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th style="width: 40px;" class="text-center">Sıra</th>
                                <th>Ad Soyad</th>
                                <th>Görev</th>
                                <th>Banka / IBAN</th>
                                <th class="text-end bg-info bg-opacity-10" style="width: 150px;" title="Banka hesabına yatırılacak resmi net maaş">Bankaya Yatan</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int siraNo = 0; }
                            @foreach (var item in personelListesi)
                            {
                                siraNo++;
                                <tr>
                                    <td class="text-center">@(item.SiralamaNo > 0 ? item.SiralamaNo : siraNo)</td>
                                    <td>
                                        <strong>@item.Personel.TamAd</strong>
                                        <br />
                                        <small class="text-muted">@item.Personel.SoforKodu</small>
                                    </td>
                                    <td>
                                        <span class="badge @GetGorevBadgeClass(item.Personel.Gorev)">
                                            @GetGorevAdi(item.Personel.Gorev)
                                        </span>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(item.Personel.BankaAdi) || !string.IsNullOrWhiteSpace(item.Personel.IBAN))
                                        {
                                            <small>@(item.Personel.BankaAdi ?? "")</small>
                                            <br />
                                            <small class="text-muted font-monospace">@FormatIBAN(item.Personel.IBAN)</small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-end bg-info bg-opacity-10" style="width:150px;">
                                        <div class="input-group input-group-sm">
                                            <input type="number" class="form-control form-control-sm text-end"
                                                   step="0.01" min="0"
                                                   value="@item.BankayaYatan"
                                                   @onchange="(e) => BankayaYatanDegisti(item, e)" />
                                            <span class="input-group-text">₺</span>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                            <tfoot class="table-dark">
                            <tr>
                                <td colspan="4" class="text-end"><strong>GENEL TOPLAM</strong></td>
                                <td class="text-end bg-info"><strong>@FormatPara(personelListesi.Sum(p => p.BankayaYatan))</strong></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <!-- Görev Dağılımı Özet Tablosu -->
        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-info text-white py-2">
                        <h6 class="mb-0"><i class="bi bi-pie-chart me-2"></i>Görev Dağılımına Göre Ödemeler</h6>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm table-bordered mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Görev</th>
                                    <th class="text-center">Kişi</th>
                                    <th class="text-end">Bankaya Yatan</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ozet in gorevOzetleri)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge @ozet.BadgeClass">@ozet.GorevAdi</span>
                                        </td>
                                        <td class="text-center">@ozet.KisiSayisi</td>
                                        <td class="text-end">@FormatPara(ozet.ToplamBankayaYatan)</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-dark">
                                <tr>
                                    <td><strong>TOPLAM</strong></td>
                                    <td class="text-center"><strong>@gorevOzetleri.Sum(g => g.KisiSayisi)</strong></td>
                                    <td class="text-end"><strong>@FormatPara(gorevOzetleri.Sum(g => g.ToplamBankayaYatan))</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-secondary text-white py-2">
                        <h6 class="mb-0"><i class="bi bi-calculator me-2"></i>Ödeme Özeti</h6>
                    </div>
                    <div class="card-body">
                        <table class="table table-sm mb-0">
                            <tr class="table-info">
                                <td><i class="bi bi-bank text-info me-2"></i>Toplam Bankaya Yatan</td>
                                <td class="text-end"><strong class="fs-5">@FormatPara(personelListesi.Sum(p => p.BankayaYatan))</strong></td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            Seçilen dönem için aktif personel bulunamadı.
        </div>
    }
</div>

@* Vakıfbank Format Modal *@
@if (showVakifbankModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-bank me-2"></i>Vakıfbank Toplu Maaş Ödeme Dosyası</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showVakifbankModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        Lütfen Vakıfbank tarafından verilen bilgileri girin. Bu bilgiler dosyanın başlık bölümüne eklenecektir.
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">VB Müşteri Numarası <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="vbMusteriNo" placeholder="Vakıfbank müşteri no" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Ödeme Tarihi <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" @bind="vbOdemeTarihi" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Şube Kodu</label>
                            <input type="text" class="form-control" @bind="vbSubeKodu" placeholder="Şube kodu" maxlength="10" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Kurum Kodu</label>
                            <input type="text" class="form-control" @bind="vbKurumKodu" placeholder="Kurum kodu" maxlength="20" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Ay</label>
                            <select class="form-select" @bind="vbAy">
                                @for (int m = 1; m <= 12; m++)
                                {
                                    <option value="@m">@(new DateTime(2024, m, 1).ToString("MMMM")) (@m)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Ödeme Türü</label>
                            <select class="form-select" @bind="vbOdemeTuru">
                                <option value="MAAS">MAAS - Maaş Ödemesi</option>
                                <option value="ÜCRET">ÜCRET - Ücret Ödemesi</option>
                                <option value="AVANS">AVANS - Avans Ödemesi</option>
                                <option value="PRIM">PRIM - Prim Ödemesi</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Para Birimi</label>
                            <select class="form-select" @bind="vbParaBirimi">
                                <option value="TRY">TRY - Türk Lirası</option>
                                <option value="USD">USD - Amerikan Doları</option>
                                <option value="EUR">EUR - Euro</option>
                            </select>
                        </div>
                    </div>

                    @if (personelListesi != null)
                    {
                        var liste = personelListesi.Where(p => p.BankayaYatan > 0).ToList();
                        <div class="alert alert-secondary mt-3">
                            <div class="d-flex justify-content-between">
                                <span><i class="bi bi-people me-2"></i>Personel sayısı: <strong>@liste.Count</strong></span>
                                <span>Toplam tutar: <strong>@FormatPara(liste.Sum(p => p.BankayaYatan))</strong></span>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showVakifbankModal = false">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="VakifbankExcelAktar">
                        <i class="bi bi-download me-1"></i>Dosyayı İndir
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Toplu Tahakkuk Modal *@
@if (showTahakkukModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title"><i class="bi bi-receipt me-2"></i>Toplu Maaş Tahakkuku</h5>
                    <button type="button" class="btn-close" @onclick="() => showTahakkukModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info mb-3">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>@(new DateTime(secilenYil, secilenAy, 1).ToString("MMMM yyyy"))</strong> dönemi için <strong>@personelListesi!.Count</strong> personele toplam <strong>@FormatPara(personelListesi.Sum(p => p.EldenOdenecek))</strong> elden ödeme tahakkuku oluşturulacaktır.
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Tahakkuk Tarihi</label>
                            <input type="date" class="form-control" @bind="tahakkukTarihi" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Tahakkuk Açıklaması</label>
                            <input type="text" class="form-control" @bind="tahakkukAciklama" placeholder="Opsiyonel açıklama" />
                        </div>
                    </div>

                    <div class="table-responsive" style="max-height: 300px;">
                        <table class="table table-sm table-bordered">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>
                                        <input type="checkbox" class="form-check-input" checked="@TumunuSecildiMi()" @onchange="TumunuSecToggle" />
                                    </th>
                                    <th>Personel</th>
                                    <th class="text-end">Gerçek Maaş</th>
                                    <th class="text-end">Bankaya Yatan</th>
                                    <th class="text-end">Elden Ödenecek</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in personelListesi!)
                                {
                                    <tr>
                                        <td>
                                            <input type="checkbox" class="form-check-input" @bind="item.Secili" />
                                        </td>
                                        <td>@item.Personel.TamAd</td>
                                        <td class="text-end">@FormatPara(item.GercekMaas)</td>
                                        <td class="text-end">@FormatPara(item.BankayaYatan)</td>
                                        <td class="text-end"><strong>@FormatPara(item.EldenOdenecek)</strong></td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-warning">
                                <tr>
                                    <td colspan="2"><strong>Seçili Toplam (@personelListesi.Count(p => p.Secili) kişi)</strong></td>
                                    <td class="text-end"><strong>@FormatPara(personelListesi.Where(p => p.Secili).Sum(p => p.GercekMaas))</strong></td>
                                    <td class="text-end"><strong>@FormatPara(personelListesi.Where(p => p.Secili).Sum(p => p.BankayaYatan))</strong></td>
                                    <td class="text-end"><strong>@FormatPara(personelListesi.Where(p => p.Secili).Sum(p => p.EldenOdenecek))</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showTahakkukModal = false">İptal</button>
                    <button type="button" class="btn btn-warning" @onclick="TopluTahakkukKaydet" disabled="@(!personelListesi.Any(p => p.Secili) || isProcessing)">
                        @if (isProcessing)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Tahakkuk Oluştur
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Toplu Ödeme Modal *@
@if (showOdemeModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-cash-stack me-2"></i>Toplu Banka Ödemesi</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showOdemeModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-primary mb-3">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>@(new DateTime(secilenYil, secilenAy, 1).ToString("MMMM yyyy"))</strong> dönemi için <strong>@personelListesi!.Count</strong> personele toplam <strong>@FormatPara(personelListesi.Sum(p => p.BankayaYatan))</strong> banka ödemesi yapılacaktır.
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Ödeme Yapılacak Hesap <span class="text-danger">*</span></label>
                            <select class="form-select" @bind="secilenBankaHesapId">
                                <option value="0">-- Hesap Seçin --</option>
                                @foreach (var hesap in bankaHesaplari)
                                {
                                    <option value="@hesap.Id">@hesap.HesapAdi (@hesap.BankaAdi)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Ödeme Tarihi</label>
                            <input type="date" class="form-control" @bind="odemeTarihi" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Belge No</label>
                            <input type="text" class="form-control" @bind="odemeBelgeNo" placeholder="Dekont no vb." />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-12">
                            <label class="form-label">Açıklama</label>
                            <input type="text" class="form-control" @bind="odemeAciklama" placeholder="Ödeme açıklaması" />
                        </div>
                    </div>

                    @if (secilenBankaHesapId > 0)
                    {
                        var secilenHesap = bankaHesaplari.FirstOrDefault(h => h.Id == secilenBankaHesapId);
                        if (secilenHesap != null)
                        {
                            <div class="alert alert-secondary mb-3">
                                <div class="d-flex justify-content-between">
                                    <span><i class="bi bi-bank me-2"></i><strong>@secilenHesap.HesapAdi</strong></span>
                                    <span>IBAN: <code>@secilenHesap.Iban</code></span>
                                </div>
                            </div>
                        }
                    }

                    <div class="table-responsive" style="max-height: 300px;">
                        <table class="table table-sm table-bordered">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>
                                        <input type="checkbox" class="form-check-input" checked="@TumunuSecildiMi()" @onchange="TumunuSecToggle" />
                                    </th>
                                    <th>Personel</th>
                                    <th>IBAN</th>
                                    <th class="text-end">Ödenecek</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in personelListesi!.Where(p => p.BankayaYatan > 0))
                                {
                                    <tr class="@(string.IsNullOrWhiteSpace(item.Personel.IBAN) ? "table-danger" : "")">
                                        <td>
                                            <input type="checkbox" class="form-check-input" @bind="item.Secili" disabled="@(string.IsNullOrWhiteSpace(item.Personel.IBAN))" />
                                        </td>
                                        <td>@item.Personel.TamAd</td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(item.Personel.IBAN))
                                            {
                                                <small class="font-monospace">@FormatIBAN(item.Personel.IBAN)</small>
                                            }
                                            else
                                            {
                                                <span class="text-danger"><i class="bi bi-exclamation-triangle me-1"></i>IBAN Eksik</span>
                                            }
                                        </td>
                                        <td class="text-end"><strong>@FormatPara(item.BankayaYatan)</strong></td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-primary">
                                <tr>
                                    <td colspan="3"><strong>Seçili Toplam (@personelListesi.Count(p => p.Secili && p.BankayaYatan > 0) kişi)</strong></td>
                                    <td class="text-end"><strong>@FormatPara(personelListesi.Where(p => p.Secili && p.BankayaYatan > 0).Sum(p => p.BankayaYatan))</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    @if (personelListesi.Any(p => string.IsNullOrWhiteSpace(p.Personel.IBAN) && p.BankayaYatan > 0))
                    {
                        <div class="alert alert-warning mt-3">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            <strong>@personelListesi.Count(p => string.IsNullOrWhiteSpace(p.Personel.IBAN) && p.BankayaYatan > 0)</strong> personelin IBAN bilgisi eksik olduğu için ödeme listesine dahil edilemedi.
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showOdemeModal = false">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="TopluOdemeKaydet" disabled="@(secilenBankaHesapId == 0 || !personelListesi.Any(p => p.Secili && p.BankayaYatan > 0) || isProcessing)">
                        @if (isProcessing)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Ödeme Yap
                    </button>
                </div>
            </div>
        </div>
    </div>
}

