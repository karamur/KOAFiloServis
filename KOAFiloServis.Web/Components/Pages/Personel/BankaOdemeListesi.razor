            worksheet.Cell(row, 12).Value = personelListesi.Sum(p => p.Odenecek);
            worksheet.Range(row, 5, row, 12).Style.Font.Bold = true;
            worksheet.Range(row, 5, row, 12).Style.Fill.BackgroundColor = ClosedXML.Excel.XLColor.LightYellow;

            // Para formatı
            worksheet.Range(4, 6, row, 12).Style.NumberFormat.Format = "#,##0.00 ₺";

            // Görev Özeti Tablosu
            row += 3;
            worksheet.Cell(row, 1).Value = "Görev Dağılımı Özeti";
            worksheet.Range(row, 1, row, 7).Merge().Style.Font.Bold = true;
            row++;

            worksheet.Cell(row, 1).Value = "Görev";
            worksheet.Cell(row, 2).Value = "Kişi Sayısı";
            worksheet.Cell(row, 3).Value = "SGK Maaş";
            worksheet.Cell(row, 4).Value = "Kalan Maaş";
            worksheet.Cell(row, 5).Value = "Ara Toplam";
            worksheet.Cell(row, 6).Value = "Kesinti";
            worksheet.Cell(row, 7).Value = "Ödenecek";
            worksheet.Row(row).Style.Font.Bold = true;
            row++;

            foreach (var ozet in gorevOzetleri)
            {
                worksheet.Cell(row, 1).Value = ozet.GorevAdi;
                worksheet.Cell(row, 2).Value = ozet.KisiSayisi;
                worksheet.Cell(row, 3).Value = ozet.ToplamSgkMaas;
