    private static string FormatPara(decimal tutar)
        => tutar.ToString("N2") + " ₺";

    private static string FormatIBAN(string? iban)
    {
        if (string.IsNullOrWhiteSpace(iban)) return "";
        // TR00 0000 0000 0000 0000 0000 00 formatı
        var clean = iban.Replace(" ", "");
        if (clean.Length >= 26)
        {
            return $"{clean[..4]} {clean[4..8]} {clean[8..12]} {clean[12..16]} {clean[16..20]} {clean[20..24]} {clean[24..]}";
        }
        return iban;
    }

    private static string GetGorevAdi(PersonelGorev gorev)
    {
        return gorev switch
        {
            PersonelGorev.Sofor => "Şoför",
            PersonelGorev.OfisCalisani => "Ofis Çalışanı",
            PersonelGorev.Muhasebe => "Muhasebe",
            PersonelGorev.Yonetici => "Yönetici",
            PersonelGorev.Teknik => "Teknik",
            PersonelGorev.Diger => "Diğer",
            _ => gorev.ToString()
        };
    }

    private static string GetGorevBadgeClass(PersonelGorev gorev)
    {
        return gorev switch
        {
            PersonelGorev.Sofor => "bg-primary",
            PersonelGorev.OfisCalisani => "bg-info",
            PersonelGorev.Muhasebe => "bg-success",
            PersonelGorev.Yonetici => "bg-warning text-dark",
            PersonelGorev.Teknik => "bg-secondary",
            _ => "bg-dark"
        };
    }

