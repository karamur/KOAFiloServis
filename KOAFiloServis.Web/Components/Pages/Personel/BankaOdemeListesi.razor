    private async Task YenileData()
    {
        isLoading = true;
        try
        {
            // Aktif personelleri al
            var tumPersoneller = await SoforService.GetAllAsync();
            var aktifPersoneller = tumPersoneller
                .Where(p => p.Aktif)
                .OrderBy(p => p.SiralamaNo == 0 ? int.MaxValue : p.SiralamaNo)
                .ThenBy(p => p.Ad)
                .ToList();

            // Görev filtresi
            if (!string.IsNullOrEmpty(secilenGorev) && Enum.TryParse<PersonelGorev>(secilenGorev, out var gorev))
            {
                aktifPersoneller = aktifPersoneller.Where(p => p.Gorev == gorev).ToList();
            }

            // Her personel için avans ve borç bilgilerini al
            personelListesi = new List<PersonelOdemeKalemi>();
            var donemMaasKayitlari = await PersonelMaasService.GetMaaslarAsync(secilenYil, secilenAy);
            var donemMaasMap = donemMaasKayitlari
                .GroupBy(m => m.SoforId)
                .ToDictionary(g => g.Key, g => g.First());

            foreach (var personel in aktifPersoneller)
            {
                var finansOzet = await FinansService.GetPersonelFinansOzetAsync(personel.Id);
                donemMaasMap.TryGetValue(personel.Id, out var donemMaas);

                var bankayaYatan = donemMaas?.NetMaas ?? personel.ResmiNetMaas;
                var gercekMaas = donemMaas != null
                    ? donemMaas.NetMaas + donemMaas.ToplamEklemeler
                    : personel.ResmiNetMaas + personel.DigerMaas;

                var item = new PersonelOdemeKalemi
                {
                    Personel = personel,
                    SiralamaNo = personel.SiralamaNo,
                    GercekMaas = gercekMaas,
                    BankayaYatan = bankayaYatan,
                    Avans = finansOzet?.KalanAvans ?? 0,
                    Kesinti = 0,
                    PersonelHarcamasi = (finansOzet?.ToplamHarcama ?? 0) + (finansOzet?.KalanBorc > 0 ? finansOzet!.KalanBorc : 0)
                };

                item.EldenOdenecek = item.GercekMaas - item.BankayaYatan - item.Kesinti + item.PersonelHarcamasi - item.Avans;

                personelListesi.Add(item);
            }

            // Görev özetlerini hesapla
            gorevOzetleri = personelListesi
                .GroupBy(p => p.Personel.Gorev)
                .Select(g => new GorevOzet
                {
                    Gorev = g.Key,
                    GorevAdi = GetGorevAdi(g.Key),
                    BadgeClass = GetGorevBadgeClass(g.Key),
                    KisiSayisi = g.Count(),
                    ToplamGercekMaas = g.Sum(x => x.GercekMaas),
                    ToplamBankayaYatan = g.Sum(x => x.BankayaYatan),
                    ToplamAvans = g.Sum(x => x.Avans),
                    ToplamKesinti = g.Sum(x => x.Kesinti),
                    ToplamPersonelHarcamasi = g.Sum(x => x.PersonelHarcamasi),
                    ToplamEldenOdenecek = g.Sum(x => x.EldenOdenecek)
                })
                .OrderBy(g => g.Gorev)
                .ToList();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Veri yüklenirken hata: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

