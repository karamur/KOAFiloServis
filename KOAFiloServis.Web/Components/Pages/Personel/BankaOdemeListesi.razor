    private async Task BankaEftExport()
    {
        try
        {
            if (personelListesi == null || !personelListesi.Any()) return;

            var ibanliPersoneller = personelListesi.Where(p => !string.IsNullOrWhiteSpace(p.Personel.IBAN) && p.Odenecek > 0).ToList();
            var ibansizPersoneller = personelListesi.Where(p => string.IsNullOrWhiteSpace(p.Personel.IBAN) && p.Odenecek > 0).ToList();

            // Banka EFT dosyası oluştur (Türk bankaları genel format - semicolon delimited)
            var sb = new System.Text.StringBuilder();
            // Header: Tarih, Toplam Tutar, Toplam Adet
            sb.AppendLine($"BASLIK;{DateTime.Now:dd.MM.yyyy};{ibanliPersoneller.Count};{ibanliPersoneller.Sum(p => p.Odenecek):F2};TRY;MAAS {new DateTime(secilenYil, secilenAy, 1):MMMM yyyy}");
            sb.AppendLine("IBAN;AD_SOYAD;TUTAR;ACIKLAMA;PERSONEL_KODU");

            foreach (var item in ibanliPersoneller)
            {
                var iban = item.Personel.IBAN!.Replace(" ", "").Trim();
                var adSoyad = item.Personel.TamAd.Replace(";", " ");
                var aciklama = $"{new DateTime(secilenYil, secilenAy, 1):yyyy-MM} Maas Odemesi";
                sb.AppendLine($"{iban};{adSoyad};{item.Odenecek:F2};{aciklama};{item.Personel.SoforKodu}");
            }

            // Toplam satırı
            sb.AppendLine($"TOPLAM;;;{ibanliPersoneller.Sum(p => p.Odenecek):F2};;");

            var bytes = System.Text.Encoding.UTF8.GetPreamble().Concat(System.Text.Encoding.UTF8.GetBytes(sb.ToString())).ToArray();
            var dosyaAdi = $"eft_maas_odeme_{secilenYil}_{secilenAy:00}.csv";
            await JS.InvokeVoidAsync("downloadFileFromBase64", dosyaAdi, Convert.ToBase64String(bytes));

            var mesaj = $"EFT dosyası oluşturuldu: {ibanliPersoneller.Count} personel.";
            if (ibansizPersoneller.Any())
            {
                mesaj += $" ⚠ {ibansizPersoneller.Count} personelin IBAN bilgisi eksik: {string.Join(", ", ibansizPersoneller.Select(p => p.Personel.TamAd))}";
                ToastService.ShowWarning(mesaj);
            }
            else
            {
                ToastService.ShowSuccess(mesaj);
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"EFT dosyası oluşturulurken hata: {ex.Message}");
        }
    }

