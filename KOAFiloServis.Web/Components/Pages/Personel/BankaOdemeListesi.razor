@page "/personel/banka-odeme-listesi"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using KOAFiloServis.Web.Services.Interfaces
@using KOAFiloServis.Web.Data
@using Microsoft.EntityFrameworkCore
@inject ISoforService SoforService
@inject IPersonelFinansService FinansService
@inject IBankaHesapService BankaHesapService
@inject ApplicationDbContext DbContext
@inject IToastService ToastService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Personel Banka Ödeme Listesi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3><i class="bi bi-bank me-2"></i>Personel Banka Ödeme Listesi</h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/personel">Personel</a></li>
                    <li class="breadcrumb-item active">Banka Ödeme Listesi</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex gap-2">
            <select class="form-select form-select-sm" style="width: 120px;" @bind="secilenYil" @bind:after="YenileData">
                @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <select class="form-select form-select-sm" style="width: 150px;" @bind="secilenAy" @bind:after="YenileData">
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m">@(new DateTime(2024, m, 1).ToString("MMMM"))</option>
                }
            </select>
            <select class="form-select form-select-sm" style="width: 180px;" @bind="secilenGorev" @bind:after="YenileData">
                <option value="">Tüm Görevler</option>
                @foreach (PersonelGorev gorev in Enum.GetValues(typeof(PersonelGorev)))
                {
                    <option value="@gorev">@GetGorevAdi(gorev)</option>
                }
            </select>
            <div class="btn-group" role="group">
                <button class="btn btn-outline-success btn-sm" @onclick="ExcelAktar" disabled="@(personelListesi == null || !personelListesi.Any())">
                    <i class="bi bi-file-earmark-excel me-1"></i>Excel
                </button>
                <button class="btn btn-success btn-sm" @onclick="BankaEftExport" disabled="@(personelListesi == null || !personelListesi.Any())" title="Banka EFT/Havale toplu ödeme dosyası">
                    <i class="bi bi-bank me-1"></i>EFT Dosyası
                </button>
            </div>
            <div class="btn-group" role="group">
                <button class="btn btn-warning btn-sm" @onclick="TopluTahakkukModalAc" disabled="@(personelListesi == null || !personelListesi.Any())" title="Seçili dönem için toplu maaş tahakkuku oluştur">
                    <i class="bi bi-receipt me-1"></i>Toplu Tahakkuk
                </button>
                <button class="btn btn-primary btn-sm" @onclick="TopluOdemeModalAc" disabled="@(personelListesi == null || !personelListesi.Any())" title="Banka hesabından toplu maaş ödemesi yap">
                    <i class="bi bi-cash-stack me-1"></i>Bankadan Öde
                </button>
            </div>
            <button class="btn btn-outline-primary btn-sm" @onclick="Yazdir" disabled="@(personelListesi == null || !personelListesi.Any())">
                <i class="bi bi-printer me-1"></i>Yazdır
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (personelListesi != null && personelListesi.Any())
    {
        <!-- Ana Tablo -->
        <div class="card mb-3">
            <div class="card-header bg-primary text-white py-2">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-list-ul me-2"></i>
                        @(new DateTime(secilenYil, secilenAy, 1).ToString("MMMM yyyy")) Banka Ödeme Listesi
                    </h5>
                    <span class="badge bg-light text-primary">@personelListesi.Count personel</span>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover mb-0" id="bankaOdemeTablosu">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th style="width: 40px;" class="text-center">Sıra</th>
                                <th>Ad Soyad</th>
                                <th>Görev</th>
                                <th>Banka / IBAN</th>
                                <th class="text-end bg-info bg-opacity-10" style="width: 110px;" title="SGK'ya bildirilen maaş">SGK Maaş</th>
                                <th class="text-end bg-warning bg-opacity-10" style="width: 110px;" title="SGK dışı ödeme (TopluMaaş - SGK Maaş)">Kalan Maaş</th>
                                <th class="text-end bg-secondary bg-opacity-10" style="width: 110px;" title="SGK + Kalan toplam">Ara Toplam</th>
                                <th class="text-end text-warning" style="width: 90px;">Avans</th>
                                <th class="text-end text-danger" style="width: 90px;">Kesinti</th>
                                <th class="text-end text-success" style="width: 90px;">Alacak</th>
                                <th class="text-end bg-success bg-opacity-25" style="width: 130px;"><strong>Ödenecek</strong></th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int siraNo = 0; }
                            @foreach (var item in personelListesi)
                            {
                                siraNo++;
                                <tr>
                                    <td class="text-center">@(item.SiralamaNo > 0 ? item.SiralamaNo : siraNo)</td>
                                    <td>
                                        <strong>@item.Personel.TamAd</strong>
                                        <br />
                                        <small class="text-muted">@item.Personel.SoforKodu</small>
                                    </td>
                                    <td>
                                        <span class="badge @GetGorevBadgeClass(item.Personel.Gorev)">
                                            @GetGorevAdi(item.Personel.Gorev)
                                        </span>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(item.Personel.BankaAdi) || !string.IsNullOrWhiteSpace(item.Personel.IBAN))
                                        {
                                            <small>@(item.Personel.BankaAdi ?? "")</small>
                                            <br />
                                            <small class="text-muted font-monospace">@FormatIBAN(item.Personel.IBAN)</small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-end bg-info bg-opacity-10">
                                        <span title="SGK'ya bildirilen maaş">@FormatPara(item.SgkMaas)</span>
                                    </td>
                                    <td class="text-end bg-warning bg-opacity-10">
                                        @if (item.KalanMaas > 0)
                                        {
                                            <span title="SGK dışı ödeme">@FormatPara(item.KalanMaas)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-end bg-secondary bg-opacity-10">
                                        <strong title="SGK + Kalan">@FormatPara(item.AraToplam)</strong>
                                    </td>
                                    <td class="text-end text-warning">
                                        @if (item.Avans > 0)
                                        {
                                            <span>-@FormatPara(item.Avans)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-end text-danger">
                                        @if (item.Kesinti > 0)
                                        {
                                            <span>-@FormatPara(item.Kesinti)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-end text-success">
                                        @if (item.Alacak > 0)
                                        {
                                            <span>+@FormatPara(item.Alacak)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-end bg-success bg-opacity-25">
                                        <strong>@FormatPara(item.Odenecek)</strong>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-dark">
                            <tr>
                                <td colspan="4" class="text-end"><strong>GENEL TOPLAM</strong></td>
                                <td class="text-end bg-info"><strong>@FormatPara(personelListesi.Sum(p => p.SgkMaas))</strong></td>
                                <td class="text-end bg-warning text-dark"><strong>@FormatPara(personelListesi.Sum(p => p.KalanMaas))</strong></td>
                                <td class="text-end"><strong>@FormatPara(personelListesi.Sum(p => p.AraToplam))</strong></td>
                                <td class="text-end text-warning"><strong>-@FormatPara(personelListesi.Sum(p => p.Avans))</strong></td>
                                <td class="text-end text-danger"><strong>-@FormatPara(personelListesi.Sum(p => p.Kesinti))</strong></td>
                                <td class="text-end text-success"><strong>+@FormatPara(personelListesi.Sum(p => p.Alacak))</strong></td>
                                <td class="text-end bg-success"><strong>@FormatPara(personelListesi.Sum(p => p.Odenecek))</strong></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <!-- Görev Dağılımı Özet Tablosu -->
        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-info text-white py-2">
                        <h6 class="mb-0"><i class="bi bi-pie-chart me-2"></i>Görev Dağılımına Göre Ödemeler</h6>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm table-bordered mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Görev</th>
                                    <th class="text-center">Kişi</th>
                                    <th class="text-end">SGK Maaş</th>
                                    <th class="text-end">Kalan Maaş</th>
                                    <th class="text-end">Ara Toplam</th>
                                    <th class="text-end">Kesintiler</th>
                                    <th class="text-end">Ödenecek</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ozet in gorevOzetleri)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge @ozet.BadgeClass">@ozet.GorevAdi</span>
                                        </td>
                                        <td class="text-center">@ozet.KisiSayisi</td>
                                        <td class="text-end">@FormatPara(ozet.ToplamSgkMaas)</td>
                                        <td class="text-end">@FormatPara(ozet.ToplamKalanMaas)</td>
                                        <td class="text-end">@FormatPara(ozet.ToplamAraToplam)</td>
                                        <td class="text-end text-danger">@FormatPara(ozet.ToplamKesinti)</td>
                                        <td class="text-end"><strong>@FormatPara(ozet.ToplamOdenecek)</strong></td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-dark">
                                <tr>
                                    <td><strong>TOPLAM</strong></td>
                                    <td class="text-center"><strong>@gorevOzetleri.Sum(g => g.KisiSayisi)</strong></td>
                                    <td class="text-end"><strong>@FormatPara(gorevOzetleri.Sum(g => g.ToplamSgkMaas))</strong></td>
                                    <td class="text-end"><strong>@FormatPara(gorevOzetleri.Sum(g => g.ToplamKalanMaas))</strong></td>
                                    <td class="text-end"><strong>@FormatPara(gorevOzetleri.Sum(g => g.ToplamAraToplam))</strong></td>
                                    <td class="text-end"><strong>@FormatPara(gorevOzetleri.Sum(g => g.ToplamKesinti))</strong></td>
                                    <td class="text-end"><strong>@FormatPara(gorevOzetleri.Sum(g => g.ToplamOdenecek))</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-secondary text-white py-2">
                        <h6 class="mb-0"><i class="bi bi-calculator me-2"></i>Ödeme Özeti</h6>
                    </div>
                    <div class="card-body">
                        <table class="table table-sm mb-0">
                            <tr class="table-info">
                                <td><i class="bi bi-shield-check text-info me-2"></i>Toplam SGK Maaş</td>
                                <td class="text-end"><strong>@FormatPara(personelListesi.Sum(p => p.SgkMaas))</strong></td>
                            </tr>
                            <tr class="table-warning">
                                <td><i class="bi bi-plus-lg text-warning me-2"></i>Toplam Kalan Maaş (Ek Ödeme)</td>
                                <td class="text-end"><strong>+ @FormatPara(personelListesi.Sum(p => p.KalanMaas))</strong></td>
                            </tr>
                            <tr class="table-secondary">
                                <td><i class="bi bi-calculator text-secondary me-2"></i><strong>Ara Toplam (SGK + Kalan)</strong></td>
                                <td class="text-end"><strong>= @FormatPara(personelListesi.Sum(p => p.AraToplam))</strong></td>
                            </tr>
                            <tr>
                                <td colspan="2"><hr class="my-1" /></td>
                            </tr>
                            <tr>
                                <td><i class="bi bi-dash-circle text-warning me-2"></i>Toplam Avans Kesintisi</td>
                                <td class="text-end text-warning">- @FormatPara(personelListesi.Sum(p => p.Avans))</td>
                            </tr>
                            <tr>
                                <td><i class="bi bi-dash-circle text-danger me-2"></i>Toplam Kesinti</td>
                                <td class="text-end text-danger">- @FormatPara(personelListesi.Sum(p => p.Kesinti))</td>
                            </tr>
                            <tr>
                                <td><i class="bi bi-plus-circle text-success me-2"></i>Toplam Alacak</td>
                                <td class="text-end text-success">+ @FormatPara(personelListesi.Sum(p => p.Alacak))</td>
                            </tr>
                            <tr class="table-success">
                                <td><strong><i class="bi bi-bank me-2"></i>Net Ödenecek Tutar</strong></td>
                                <td class="text-end"><strong class="fs-5">@FormatPara(personelListesi.Sum(p => p.Odenecek))</strong></td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            Seçilen dönem için aktif personel bulunamadı.
        </div>
    }
</div>

@* Toplu Tahakkuk Modal *@
@if (showTahakkukModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title"><i class="bi bi-receipt me-2"></i>Toplu Maaş Tahakkuku</h5>
                    <button type="button" class="btn-close" @onclick="() => showTahakkukModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info mb-3">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>@(new DateTime(secilenYil, secilenAy, 1).ToString("MMMM yyyy"))</strong> dönemi için <strong>@personelListesi!.Count</strong> personele toplam <strong>@FormatPara(personelListesi.Sum(p => p.Odenecek))</strong> maaş tahakkuku oluşturulacaktır.
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Tahakkuk Tarihi</label>
                            <input type="date" class="form-control" @bind="tahakkukTarihi" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Tahakkuk Açıklaması</label>
                            <input type="text" class="form-control" @bind="tahakkukAciklama" placeholder="Opsiyonel açıklama" />
                        </div>
                    </div>

                    <div class="table-responsive" style="max-height: 300px;">
                        <table class="table table-sm table-bordered">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>
                                        <input type="checkbox" class="form-check-input" checked="@TumunuSecildiMi()" @onchange="TumunuSecToggle" />
                                    </th>
                                    <th>Personel</th>
                                    <th class="text-end">SGK Maaş</th>
                                    <th class="text-end">Kalan</th>
                                    <th class="text-end">Ödenecek</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in personelListesi!)
                                {
                                    <tr>
                                        <td>
                                            <input type="checkbox" class="form-check-input" @bind="item.Secili" />
                                        </td>
                                        <td>@item.Personel.TamAd</td>
                                        <td class="text-end">@FormatPara(item.SgkMaas)</td>
                                        <td class="text-end">@FormatPara(item.KalanMaas)</td>
                                        <td class="text-end"><strong>@FormatPara(item.Odenecek)</strong></td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-warning">
                                <tr>
                                    <td colspan="2"><strong>Seçili Toplam (@personelListesi.Count(p => p.Secili) kişi)</strong></td>
                                    <td class="text-end"><strong>@FormatPara(personelListesi.Where(p => p.Secili).Sum(p => p.SgkMaas))</strong></td>
                                    <td class="text-end"><strong>@FormatPara(personelListesi.Where(p => p.Secili).Sum(p => p.KalanMaas))</strong></td>
                                    <td class="text-end"><strong>@FormatPara(personelListesi.Where(p => p.Secili).Sum(p => p.Odenecek))</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showTahakkukModal = false">İptal</button>
                    <button type="button" class="btn btn-warning" @onclick="TopluTahakkukKaydet" disabled="@(!personelListesi.Any(p => p.Secili) || isProcessing)">
                        @if (isProcessing)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Tahakkuk Oluştur
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Toplu Ödeme Modal *@
@if (showOdemeModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-cash-stack me-2"></i>Toplu Banka Ödemesi</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showOdemeModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-primary mb-3">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>@(new DateTime(secilenYil, secilenAy, 1).ToString("MMMM yyyy"))</strong> dönemi için <strong>@personelListesi!.Count</strong> personele toplam <strong>@FormatPara(personelListesi.Sum(p => p.Odenecek))</strong> ödeme yapılacaktır.
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Ödeme Yapılacak Hesap <span class="text-danger">*</span></label>
                            <select class="form-select" @bind="secilenBankaHesapId">
                                <option value="0">-- Hesap Seçin --</option>
                                @foreach (var hesap in bankaHesaplari)
                                {
                                    <option value="@hesap.Id">@hesap.HesapAdi (@hesap.BankaAdi)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Ödeme Tarihi</label>
                            <input type="date" class="form-control" @bind="odemeTarihi" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Belge No</label>
                            <input type="text" class="form-control" @bind="odemeBelgeNo" placeholder="Dekont no vb." />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-12">
                            <label class="form-label">Açıklama</label>
                            <input type="text" class="form-control" @bind="odemeAciklama" placeholder="Ödeme açıklaması" />
                        </div>
                    </div>

                    @if (secilenBankaHesapId > 0)
                    {
                        var secilenHesap = bankaHesaplari.FirstOrDefault(h => h.Id == secilenBankaHesapId);
                        if (secilenHesap != null)
                        {
                            <div class="alert alert-secondary mb-3">
                                <div class="d-flex justify-content-between">
                                    <span><i class="bi bi-bank me-2"></i><strong>@secilenHesap.HesapAdi</strong></span>
                                    <span>IBAN: <code>@secilenHesap.Iban</code></span>
                                </div>
                            </div>
                        }
                    }

                    <div class="table-responsive" style="max-height: 300px;">
                        <table class="table table-sm table-bordered">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>
                                        <input type="checkbox" class="form-check-input" checked="@TumunuSecildiMi()" @onchange="TumunuSecToggle" />
                                    </th>
                                    <th>Personel</th>
                                    <th>IBAN</th>
                                    <th class="text-end">Ödenecek</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in personelListesi!.Where(p => p.Odenecek > 0))
                                {
                                    <tr class="@(string.IsNullOrWhiteSpace(item.Personel.IBAN) ? "table-danger" : "")">
                                        <td>
                                            <input type="checkbox" class="form-check-input" @bind="item.Secili" disabled="@(string.IsNullOrWhiteSpace(item.Personel.IBAN))" />
                                        </td>
                                        <td>@item.Personel.TamAd</td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(item.Personel.IBAN))
                                            {
                                                <small class="font-monospace">@FormatIBAN(item.Personel.IBAN)</small>
                                            }
                                            else
                                            {
                                                <span class="text-danger"><i class="bi bi-exclamation-triangle me-1"></i>IBAN Eksik</span>
                                            }
                                        </td>
                                        <td class="text-end"><strong>@FormatPara(item.Odenecek)</strong></td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-primary">
                                <tr>
                                    <td colspan="3"><strong>Seçili Toplam (@personelListesi.Count(p => p.Secili && p.Odenecek > 0) kişi)</strong></td>
                                    <td class="text-end"><strong>@FormatPara(personelListesi.Where(p => p.Secili && p.Odenecek > 0).Sum(p => p.Odenecek))</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    @if (personelListesi.Any(p => string.IsNullOrWhiteSpace(p.Personel.IBAN) && p.Odenecek > 0))
                    {
                        <div class="alert alert-warning mt-3">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            <strong>@personelListesi.Count(p => string.IsNullOrWhiteSpace(p.Personel.IBAN) && p.Odenecek > 0)</strong> personelin IBAN bilgisi eksik olduğu için ödeme listesine dahil edilemedi.
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showOdemeModal = false">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="TopluOdemeKaydet" disabled="@(secilenBankaHesapId == 0 || !personelListesi.Any(p => p.Secili && p.Odenecek > 0) || isProcessing)">
                        @if (isProcessing)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Ödeme Yap
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int secilenYil = DateTime.Now.Year;
    private int secilenAy = DateTime.Now.Month;
    private string secilenGorev = "";
    private bool isLoading = false;
    private bool isProcessing = false;

    private List<PersonelOdemeKalemi>? personelListesi;
    private List<GorevOzet> gorevOzetleri = new();

    // Toplu Tahakkuk Modal
    private bool showTahakkukModal = false;
    private DateTime tahakkukTarihi = DateTime.Today;
    private string tahakkukAciklama = "";

    // Toplu Ödeme Modal
    private bool showOdemeModal = false;
    private List<BankaHesap> bankaHesaplari = new();
    private int secilenBankaHesapId = 0;
    private DateTime odemeTarihi = DateTime.Today;
    private string odemeBelgeNo = "";
    private string odemeAciklama = "";

    protected override async Task OnInitializedAsync()
    {
        await YenileData();
        bankaHesaplari = await BankaHesapService.GetActiveAsync();
    }

    private async Task YenileData()
    {
        isLoading = true;
        try
        {
            // Aktif personelleri al
            var tumPersoneller = await SoforService.GetAllAsync();
            var aktifPersoneller = tumPersoneller
                .Where(p => p.Aktif && p.SGKBordroDahilMi)
                .OrderBy(p => p.SiralamaNo == 0 ? int.MaxValue : p.SiralamaNo)
                .ThenBy(p => p.Ad)
                .ToList();

            // Görev filtresi
            if (!string.IsNullOrEmpty(secilenGorev) && Enum.TryParse<PersonelGorev>(secilenGorev, out var gorev))
            {
                aktifPersoneller = aktifPersoneller.Where(p => p.Gorev == gorev).ToList();
            }

            // Her personel için avans ve borç bilgilerini al
            personelListesi = new List<PersonelOdemeKalemi>();

            foreach (var personel in aktifPersoneller)
            {
                var finansOzet = await FinansService.GetPersonelFinansOzetAsync(personel.Id);

                var item = new PersonelOdemeKalemi
                {
                    Personel = personel,
                    SiralamaNo = personel.SiralamaNo,
                    // SGK Maaş ve Kalan Maaş ayrımı
                    SgkMaas = personel.SgkMaasi,
                    KalanMaas = personel.EkOdeme, // TopluMaas - SgkMaasi
                    ResmiMaas = personel.ResmiNetMaas, // Geriye uyumluluk için
                    Avans = finansOzet?.KalanAvans ?? 0, // Açık avanslar
                    Kesinti = finansOzet?.KalanBorc > 0 ? finansOzet.KalanBorc : 0, // Personelden alınacak borçlar
                    Alacak = finansOzet?.KalanBorc < 0 ? Math.Abs(finansOzet.KalanBorc) : 0 // Personele ödenecek (negatif borç = alacak)
                };

                // Ara Toplam = SGK Maaş + Kalan Maaş
                item.AraToplam = item.SgkMaas + item.KalanMaas;

                // Ödenecek = Ara Toplam - Avans - Kesinti + Alacak
                item.Odenecek = item.AraToplam - item.Avans - item.Kesinti + item.Alacak;

                personelListesi.Add(item);
            }

            // Görev özetlerini hesapla
            gorevOzetleri = personelListesi
                .GroupBy(p => p.Personel.Gorev)
                .Select(g => new GorevOzet
                {
                    Gorev = g.Key,
                    GorevAdi = GetGorevAdi(g.Key),
                    BadgeClass = GetGorevBadgeClass(g.Key),
                    KisiSayisi = g.Count(),
                    ToplamSgkMaas = g.Sum(x => x.SgkMaas),
                    ToplamKalanMaas = g.Sum(x => x.KalanMaas),
                    ToplamAraToplam = g.Sum(x => x.AraToplam),
                    ToplamResmiMaas = g.Sum(x => x.ResmiMaas),
                    ToplamAvans = g.Sum(x => x.Avans),
                    ToplamKesinti = g.Sum(x => x.Avans + x.Kesinti),
                    ToplamAlacak = g.Sum(x => x.Alacak),
                    ToplamOdenecek = g.Sum(x => x.Odenecek)
                })
                .OrderBy(g => g.Gorev)
                .ToList();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Veri yüklenirken hata: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

