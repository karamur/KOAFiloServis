<!-- Hareket Detay Modal -->
@if (detayMaas != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-receipt me-2"></i>Maaş Detayı - @(detayMaas.Sofor != null ? detayMaas.Sofor.TamAd : "-")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="DetayKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body py-2">
                                    <h6 class="text-primary mb-2">Dönem Bilgisi</h6>
                                    <table class="table table-sm table-borderless mb-0">
                                        <tr><td class="text-muted">Dönem:</td><td class="text-end fw-bold">@(new DateTime(detayMaas.Yil, detayMaas.Ay, 1).ToString("MMMM yyyy"))</td></tr>
                                        <tr><td class="text-muted">Çalışma Günü:</td><td class="text-end">@detayMaas.CalismaGunu gün</td></tr>
                                        <tr><td class="text-muted">İzinli Gün:</td><td class="text-end">@detayMaas.IzinliGun gün</td></tr>
                                        <tr><td class="text-muted">Raporlu Gün:</td><td class="text-end">@detayMaas.RaporluGun gün</td></tr>
                                        <tr><td class="text-muted">Devamsızlık:</td><td class="text-end">@detayMaas.DevamsizlikGun gün</td></tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body py-2">
                                    <h6 class="text-primary mb-2">Ödeme Bilgisi</h6>
                                    <table class="table table-sm table-borderless mb-0">
                                        <tr>
                                            <td class="text-muted">Durum:</td>
                                            <td class="text-end">
                                                @switch (detayMaas.OdemeDurum)
                                                {
                                                    case MaasOdemeDurum.Odendi:
                                                        <span class="badge bg-success">Ödendi</span>
                                                        break;
                                                    case MaasOdemeDurum.Bekliyor:
                                                        <span class="badge bg-warning text-dark">Bekliyor</span>
                                                        break;
                                                    case MaasOdemeDurum.KismiOdendi:
                                                        <span class="badge bg-info">Kısmi</span>
                                                        break;
                                                    case MaasOdemeDurum.IptalEdildi:
                                                        <span class="badge bg-secondary">İptal</span>
                                                        break;
                                                }
                                            </td>
                                        </tr>
                                        <tr><td class="text-muted">Ödeme Tarihi:</td><td class="text-end">@(detayMaas.OdemeTarihi.HasValue ? detayMaas.OdemeTarihi.Value.ToString("dd.MM.yyyy") : "-")</td></tr>
                                        @if (!string.IsNullOrEmpty(detayMaas.OdemeAciklama))
                                        {
                                            <tr><td class="text-muted">Açıklama:</td><td class="text-end">@detayMaas.OdemeAciklama</td></tr>
                                        }
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="card border-primary">
                                <div class="card-header bg-primary text-white py-1"><small class="fw-bold">Maaş Bilgileri</small></div>
                                <div class="card-body py-2">
                                    <table class="table table-sm table-borderless mb-0">
                                        <tr><td>Brüt Maaş:</td><td class="text-end fw-bold">@detayMaas.BrutMaas.ToString("N2") ₺</td></tr>
                                        <tr><td>Net Maaş:</td><td class="text-end fw-bold">@detayMaas.NetMaas.ToString("N2") ₺</td></tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-success">
                                <div class="card-header bg-success text-white py-1"><small class="fw-bold">Ek Ödemeler (@detayMaas.ToplamEklemeler.ToString("N2") ₺)</small></div>
                                <div class="card-body py-2">
                                    <table class="table table-sm table-borderless mb-0">
                                        @if (detayMaas.Prim > 0) { <tr><td>Prim:</td><td class="text-end">@detayMaas.Prim.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.Ikramiye > 0) { <tr><td>İkramiye:</td><td class="text-end">@detayMaas.Ikramiye.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.Yemek > 0) { <tr><td>Yemek:</td><td class="text-end">@detayMaas.Yemek.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.Yol > 0) { <tr><td>Yol:</td><td class="text-end">@detayMaas.Yol.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.Mesai > 0) { <tr><td>Mesai:</td><td class="text-end">@detayMaas.Mesai.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.DigerEklemeler > 0) { <tr><td>Personel Harcaması:</td><td class="text-end text-success">+@detayMaas.DigerEklemeler.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.ToplamEklemeler == 0) { <tr><td colspan="2" class="text-center text-muted">-</td></tr> }
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-danger">
                                <div class="card-header bg-danger text-white py-1"><small class="fw-bold">Kesintiler (@detayMaas.ToplamKesintiler.ToString("N2") ₺)</small></div>
                                <div class="card-body py-2">
                                    <table class="table table-sm table-borderless mb-0">
                                        @if (detayMaas.SGKIsciPayi > 0) { <tr><td>SGK İşçi:</td><td class="text-end">@detayMaas.SGKIsciPayi.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.GelirVergisi > 0) { <tr><td>Gelir V.:</td><td class="text-end">@detayMaas.GelirVergisi.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.DamgaVergisi > 0) { <tr><td>Damga V.:</td><td class="text-end">@detayMaas.DamgaVergisi.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.IssizlikPrimi > 0) { <tr><td>İşsizlik:</td><td class="text-end">@detayMaas.IssizlikPrimi.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.Avans > 0) { <tr><td>Avans:</td><td class="text-end">@detayMaas.Avans.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.IcraTakibi > 0) { <tr><td>İcra:</td><td class="text-end">@detayMaas.IcraTakibi.ToString("N2") ₺</td></tr> }
                                        @if (detayMaas.DigerKesintiler > 0) { <tr><td>Diğer:</td><td class="text-end">@detayMaas.DigerKesintiler.ToString("N2") ₺</td></tr> }
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="alert alert-primary mt-3 mb-0 text-center">
                        <h5 class="mb-0">Ödenecek Tutar: <strong>@detayMaas.OdenecekTutar.ToString("N2") ₺</strong></h5>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="DetayKapat">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Bildirim Toast -->
@if (!string.IsNullOrEmpty(bildirimMesaj))
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999;">
        <div class="toast show" role="alert">
            <div class="toast-header @(bildirimBasarili ? "bg-success" : "bg-danger") text-white">
                <i class="bi @(bildirimBasarili ? "bi-check-circle" : "bi-exclamation-circle") me-2"></i>
