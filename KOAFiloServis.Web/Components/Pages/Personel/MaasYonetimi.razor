            </div>
            <div class="toast-body">@bildirimMesaj</div>
        </div>
    </div>
}

@code {
    // ===== SEKME =====
    private string aktifTab = "yonetim";

    // ===== MAAŞ YÖNETİMİ STATE =====
    private int maasYil = DateTime.Today.Year;
    private int maasAy = DateTime.Today.Month;
    private MaasRaporOzet? maasRapor;
    private PersonelMaas? duzenlenenMaas;
    private bool isLoading = false;
    private List<PersonelAvans> acikAvanslar = new();
    private bool isMahsupUygulaniyor = false;
    private bool odemeOnayModal = false;
    private MaasDetay? secilenOdemeMaas;
    private DateTime odemeTarihi = DateTime.Today;
    private string? odemeAciklama;
    private bool isOdemeYapiliyor = false;
    private string? bildirimMesaj;
    private bool bildirimBasarili;
    private System.Threading.Timer? bildirimTimer;

    // ===== MAAŞ HAREKETLERİ STATE =====
    private List<Sofor> soforler = new();
    private List<PersonelMaas> hareketler = new();
    private List<PersonelMaas> filtrelenmisHareketler = new();
    private List<PersonelBazliOzet> personelOzetleri = new();
    private PersonelMaas? detayMaas;
    private int hSecilenSoforId = 0;
    private int hareketYil = 0;
    private int hareketAy = 0;
    private int hSecilenDurum = -1;

    // ===== DURUM TABLOSU STATE =====
    private string durAramaMetni = string.Empty;
    private string durSecilenGorev = string.Empty;
    private int durYil = DateTime.Today.Year;
    private int durAy = DateTime.Today.Month;
    private bool durDetayYukleniyor = false;
    private List<PersonelDurumSatir> durSatirlar = new();
    private List<Sofor> durTumPersoneller = new();
    private int durSecilenPersonelId;
    private Sofor? durSecilenPersonel;
    private string durAktifSekme = "ekstra";
    private PersonelFinansOzet? durFinansOzet;
    private List<PersonelAvans> durAvanslar = new();
    private List<PersonelBorc> durBorclar = new();
    private List<PersonelMaas> durMaasGecmisi = new();
    private List<EkstreHareket> durEkstreHareketler = new();
    private BordroDetay? durBordroDetay;
    private List<PersonelCebindenHarcamaItem> durCebHarcamalar = new();
    private IEnumerable<PersonelDurumSatir> DurFiltreliSatirlar => durSatirlar
        .Where(s => (string.IsNullOrWhiteSpace(durAramaMetni)
                || s.AdSoyad.Contains(durAramaMetni, StringComparison.OrdinalIgnoreCase)
                || s.SoforKodu.Contains(durAramaMetni, StringComparison.OrdinalIgnoreCase))
            && (string.IsNullOrWhiteSpace(durSecilenGorev)
                || s.GorevEnum.ToString() == durSecilenGorev));

