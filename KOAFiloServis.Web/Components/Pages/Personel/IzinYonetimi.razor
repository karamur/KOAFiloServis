                        <label class="form-label">Personel</label>
                        <select class="form-select" @bind="yeniIzin.SoforId">
                            <option value="0">-- Se�iniz --</option>
                            @foreach (var sofor in soforler)
                            {
                                <option value="@sofor.Id">@sofor.TamAd</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">�zin T�r�</label>
                        <select class="form-select" @bind="yeniIzin.IzinTipi">
                            @foreach (IzinTipi tip in Enum.GetValues(typeof(IzinTipi)))
                            {
                                <option value="@tip">@GetIzinTipiAdi(tip)</option>
                            }
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label">Ba�lang��</label>
