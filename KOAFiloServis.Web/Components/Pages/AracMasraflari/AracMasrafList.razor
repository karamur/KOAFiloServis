@page "/arac-masraflari"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@inject IAracMasrafService AracMasrafService
@inject IAracService AracService
@inject IMasrafKalemiService MasrafKalemiService
@inject NavigationManager Navigation
@inject IToastService ToastService
@inject IExcelService ExcelService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Araç Masrafları</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-cash-stack me-2"></i>Araç Masraf Hareketleri</h3>
        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="YeniMasraf">
                <i class="bi bi-plus-lg me-1"></i>Yeni Masraf
            </button>
            <button class="btn btn-outline-success" @onclick="ExcelIndir" disabled="@(!FiltrelenmisMasraflar.Any())">
                <i class="bi bi-file-earmark-excel me-1"></i>Excel
            </button>
        </div>
    </div>

    <!-- Filtreleme Alanı -->
    <div class="card shadow-sm mb-3">
        <div class="card-body bg-light">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small">Plaka</label>
                    <input type="text" class="form-control form-control-sm" @bind="filtrePlaka" @bind:event="oninput" placeholder="Plaka ara..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Şase No</label>
                    <input type="text" class="form-control form-control-sm" @bind="filtreSase" @bind:event="oninput" placeholder="Şase ara..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Araç</label>
                    <select class="form-select form-select-sm" @bind="filtreAracId">
                        <option value="0">Tümü</option>
                        @foreach (var a in araclar.OrderBy(x => x.AktifPlaka))
                        {
                            <option value="@a.Id">@a.AktifPlaka - @a.Marka @a.Model</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Masraf Kalemi</label>
                    <select class="form-select form-select-sm" @bind="filtreMasrafKalemiId">
                        <option value="0">Tümü</option>
                        @foreach (var k in masrafKalemleri.OrderBy(x => x.MasrafAdi))
                        {
                            <option value="@k.Id">@k.MasrafAdi</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Kategori</label>
                    <select class="form-select form-select-sm" @bind="filtreKategori">
                        <option value="">Tümü</option>
                        @foreach (MasrafKategori k in Enum.GetValues<MasrafKategori>())
                        {
                            <option value="@k.ToString()">@k.ToString()</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Ödeme Kaynağı</label>
                    <select class="form-select form-select-sm" @bind="filtreOdemeKaynak">
                        <option value="">Tümü</option>
                        @foreach (MasrafOdemeKaynak k in Enum.GetValues<MasrafOdemeKaynak>())
                        {
                            <option value="@k.ToString()">@GetOdemeKaynakAdi(k)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Başlangıç</label>
                    <input type="date" class="form-control form-control-sm"
                           value="@filtreBaslangic?.ToString("yyyy-MM-dd")"
                           @onchange="(e) => filtreBaslangic = ParseDate(e.Value)" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Bitiş</label>
                    <input type="date" class="form-control form-control-sm"
                           value="@filtreBitis?.ToString("yyyy-MM-dd")"
                           @onchange="(e) => filtreBitis = ParseDate(e.Value)" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Min Tutar</label>
                    <input type="number" step="0.01" class="form-control form-control-sm" @bind="filtreMinTutar" placeholder="0,00" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Max Tutar</label>
                    <input type="number" step="0.01" class="form-control form-control-sm" @bind="filtreMaxTutar" placeholder="0,00" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Belge No / Açıklama</label>
                    <input type="text" class="form-control form-control-sm" @bind="filtreArama" @bind:event="oninput" placeholder="Belge no, açıklama..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Arıza Kaynaklı</label>
                    <select class="form-select form-select-sm" @bind="filtreAriza">
                        <option value="">Tümü</option>
                        <option value="evet">Evet</option>
                        <option value="hayir">Hayır</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Muhasebe Fişi</label>
                    <select class="form-select form-select-sm" @bind="filtreFisDurumu">
                        <option value="">Tümü</option>
                        <option value="var">Oluşturuldu</option>
                        <option value="yok">Yok</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Personel Geri Ödeme</label>
                    <select class="form-select form-select-sm" @bind="filtrePersonelOdendi">
                        <option value="">Tümü</option>
                        <option value="evet">Ödendi</option>
                        <option value="hayir">Ödenmedi</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-1">
                    <button class="btn btn-secondary btn-sm w-100" @onclick="FiltreyiTemizle">
                        <i class="bi bi-x-circle"></i> Temizle
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Özet Kartları -->
    <div class="row g-2 mb-3">
        <div class="col-md-3">
            <div class="card border-primary">
                <div class="card-body py-2">
                    <small class="text-muted">Filtre Sonucu Hareket</small>
                    <div class="fs-4 fw-bold text-primary">@FiltrelenmisMasraflar.Count</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-success">
                <div class="card-body py-2">
                    <small class="text-muted">Toplam Tutar</small>
                    <div class="fs-4 fw-bold text-success">@FiltrelenmisMasraflar.Sum(m => m.Tutar).ToString("N2") ₺</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-warning">
                <div class="card-body py-2">
                    <small class="text-muted">Arıza Kaynaklı</small>
                    <div class="fs-4 fw-bold text-warning">@FiltrelenmisMasraflar.Count(m => m.ArizaKaynaklimi)</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-info">
                <div class="card-body py-2">
                    <small class="text-muted">Personel Cebinden (Bekleyen)</small>
                    <div class="fs-4 fw-bold text-info">
                        @FiltrelenmisMasraflar.Where(m => m.IsPersonelCebinden && !m.PersoneleOdendi).Sum(m => m.Tutar).ToString("N2") ₺
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else if (!FiltrelenmisMasraflar.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Kriterlere uygun masraf hareketi bulunamadı.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0 align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th @onclick="() => Sirala(nameof(AracMasraf.MasrafTarihi))" style="cursor:pointer;">
                                    Tarih @SiralamaIkonu(nameof(AracMasraf.MasrafTarihi))
                                </th>
                                <th>Plaka</th>
                                <th>Marka / Model</th>
                                <th>Masraf Kalemi</th>
                                <th>Kategori</th>
                                <th @onclick="() => Sirala(nameof(AracMasraf.Tutar))" style="cursor:pointer;" class="text-end">
                                    Tutar @SiralamaIkonu(nameof(AracMasraf.Tutar))
                                </th>
                                <th>Belge No</th>
                                <th>Ödeme Kaynağı</th>
                                <th>Ödemeyi Yapan</th>
                                <th>Muh. Fişi</th>
                                <th>Güzergah</th>
                                <th class="text-center">Arıza</th>
                                <th class="text-center" style="width:160px;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var masraf in SiraliMasraflar)
                            {
                                <tr class="@(masraf.ArizaKaynaklimi ? "table-warning" : "")">
                                    <td><strong>@masraf.MasrafTarihi.ToString("dd.MM.yyyy")</strong></td>
                                    <td>@masraf.Arac?.AktifPlaka</td>
                                    <td><small>@masraf.Arac?.Marka @masraf.Arac?.Model</small></td>
                                    <td>@masraf.MasrafKalemi?.MasrafAdi</td>
                                    <td><span class="badge bg-secondary">@masraf.MasrafKalemi?.Kategori</span></td>
                                    <td class="text-end"><strong>@masraf.Tutar.ToString("N2") ₺</strong></td>
                                    <td>@masraf.BelgeNo</td>
                                    <td>
                                        <span class="badge @GetOdemeKaynakBadge(masraf.OdemeKaynak)">@GetOdemeKaynakAdi(masraf.OdemeKaynak)</span>
                                    </td>
                                    <td><small>@GetMuhatapText(masraf)</small></td>
                                    <td>
                                        @if (masraf.MuhasebeFisId.HasValue)
                                        {
                                            <span class="badge bg-success" title="Fiş No: @masraf.MuhasebeFisId">Var</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Yok</span>
                                        }
                                    </td>
                                    <td><small>@masraf.Guzergah?.GuzergahAdi</small></td>
                                    <td class="text-center">
                                        @if (masraf.ArizaKaynaklimi)
                                        {
                                            <span class="badge bg-warning text-dark">Evet</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-info" @onclick="() => DetayAc(masraf)" title="Detay">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button class="btn btn-outline-primary" @onclick="() => Duzenle(masraf.Id)" title="Düzenle">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            @if (masraf.IsPersonelCebinden && !masraf.PersoneleOdendi)
                                            {
                                                <button class="btn btn-outline-success" @onclick="() => PersoneleOdemeYap(masraf)" title="Personele Ödendi İşaretle">
                                                    <i class="bi bi-cash-coin"></i>
                                                </button>
                                            }
                                            <button class="btn btn-outline-danger" @onclick="() => SilOnay(masraf)" title="Sil">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <th colspan="5" class="text-end">Toplam:</th>
                                <th class="text-end">@FiltrelenmisMasraflar.Sum(m => m.Tutar).ToString("N2") ₺</th>
                                <th colspan="7"></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<!-- Silme Onay Modal -->
@if (showDeleteModal && silinecekMasraf != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle text-danger me-2"></i>Silme Onayı</h5>
                    <button type="button" class="btn-close" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <p>Bu masraf kaydını silmek istediğinize emin misiniz?</p>
                    <ul class="mb-0 small text-muted">
                        <li><strong>Tarih:</strong> @silinecekMasraf.MasrafTarihi.ToString("dd.MM.yyyy")</li>
                        <li><strong>Plaka:</strong> @silinecekMasraf.Arac?.AktifPlaka</li>
                        <li><strong>Tutar:</strong> @silinecekMasraf.Tutar.ToString("N2") ₺</li>
                        <li><strong>Masraf Kalemi:</strong> @silinecekMasraf.MasrafKalemi?.MasrafAdi</li>
                    </ul>
                    @if (silinecekMasraf.MuhasebeFisId.HasValue)
                    {
                        <div class="alert alert-warning mt-2 mb-0 small">
                            <i class="bi bi-info-circle me-1"></i>Bağlı muhasebe fişi de silinecek.
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showDeleteModal = false">İptal</button>
                    <button type="button" class="btn btn-danger" @onclick="Sil">
                        <i class="bi bi-trash me-1"></i>Sil
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Detay Modal -->
@if (showDetayModal && detayMasraf != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);" @onclick="() => showDetayModal = false">
        <div class="modal-dialog modal-lg" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-receipt me-2 text-info"></i>Masraf Detayı</h5>
                    <button type="button" class="btn-close" @onclick="() => showDetayModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6"><strong>Tarih:</strong> @detayMasraf.MasrafTarihi.ToString("dd.MM.yyyy")</div>
                        <div class="col-md-6"><strong>Plaka:</strong> @detayMasraf.Arac?.AktifPlaka</div>
                        <div class="col-md-6"><strong>Marka/Model:</strong> @detayMasraf.Arac?.Marka @detayMasraf.Arac?.Model</div>
                        <div class="col-md-6"><strong>Şase:</strong> <small>@detayMasraf.Arac?.SaseNo</small></div>
                        <div class="col-md-6"><strong>Masraf Kalemi:</strong> @detayMasraf.MasrafKalemi?.MasrafAdi</div>
                        <div class="col-md-6"><strong>Kategori:</strong> @detayMasraf.MasrafKalemi?.Kategori</div>
                        <div class="col-md-6"><strong>Tutar:</strong> <span class="fs-5 fw-bold text-success">@detayMasraf.Tutar.ToString("N2") ₺</span></div>
                        <div class="col-md-6"><strong>Belge No:</strong> @detayMasraf.BelgeNo</div>
                        <div class="col-md-6"><strong>Ödeme Kaynağı:</strong> <span class="badge @GetOdemeKaynakBadge(detayMasraf.OdemeKaynak)">@GetOdemeKaynakAdi(detayMasraf.OdemeKaynak)</span></div>
                        <div class="col-md-6"><strong>Ödemeyi Yapan:</strong> @GetMuhatapText(detayMasraf)</div>
                        <div class="col-md-6"><strong>Güzergah:</strong> @detayMasraf.Guzergah?.GuzergahAdi</div>
                        <div class="col-md-6">
                            <strong>Arıza Kaynaklı:</strong>
                            @if (detayMasraf.ArizaKaynaklimi)
                            {
                                <span class="badge bg-warning text-dark">Evet</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Hayır</span>
                            }
                        </div>
                        <div class="col-md-6">
                            <strong>Muhasebe Fişi:</strong>
                            @if (detayMasraf.MuhasebeFisId.HasValue)
                            {
                                <span class="badge bg-success">#@detayMasraf.MuhasebeFisId</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Yok</span>
                            }
                        </div>
                        @if (detayMasraf.IsPersonelCebinden)
                        {
                            <div class="col-md-6">
                                <strong>Personel Geri Ödeme:</strong>
                                @if (detayMasraf.PersoneleOdendi)
                                {
                                    <span class="badge bg-success">Ödendi (@detayMasraf.PersonelOdemeTarihi?.ToString("dd.MM.yyyy"))</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Bekliyor</span>
                                }
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(detayMasraf.Aciklama))
                        {
                            <div class="col-12">
                                <strong>Açıklama:</strong>
                                <div class="alert alert-light mb-0">@detayMasraf.Aciklama</div>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" @onclick="() => { var id = detayMasraf!.Id; showDetayModal = false; Duzenle(id); }">
                        <i class="bi bi-pencil me-1"></i>Düzenle
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="() => showDetayModal = false">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<AracMasraf> masraflar = new();
    private List<Arac> araclar = new();
    private List<MasrafKalemi> masrafKalemleri = new();
    private bool isLoading = true;

    // Filtreler
    private string filtrePlaka = string.Empty;
    private string filtreSase = string.Empty;
    private int filtreAracId = 0;
    private int filtreMasrafKalemiId = 0;
    private string filtreKategori = string.Empty;
    private string filtreOdemeKaynak = string.Empty;
    private DateTime? filtreBaslangic;
    private DateTime? filtreBitis;
    private decimal? filtreMinTutar;
    private decimal? filtreMaxTutar;
    private string filtreArama = string.Empty;
    private string filtreAriza = string.Empty;
    private string filtreFisDurumu = string.Empty;
    private string filtrePersonelOdendi = string.Empty;

    // Sıralama
    private string siralamaAlani = nameof(AracMasraf.MasrafTarihi);
    private bool siralamaAzalan = true;

    // Modaller
    private bool showDeleteModal = false;
    private AracMasraf? silinecekMasraf;
    private bool showDetayModal = false;
    private AracMasraf? detayMasraf;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            masraflar = await AracMasrafService.GetAllAsync();
            araclar = await AracService.GetAllAsync();
            masrafKalemleri = await MasrafKalemiService.GetAllAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Veriler yüklenemedi: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private List<AracMasraf> FiltrelenmisMasraflar => masraflar.Where(m =>
        (string.IsNullOrWhiteSpace(filtrePlaka) || (m.Arac?.AktifPlaka ?? string.Empty).Contains(filtrePlaka, StringComparison.OrdinalIgnoreCase))
        && (string.IsNullOrWhiteSpace(filtreSase) || (m.Arac?.SaseNo ?? string.Empty).Contains(filtreSase, StringComparison.OrdinalIgnoreCase))
        && (filtreAracId == 0 || m.AracId == filtreAracId)
        && (filtreMasrafKalemiId == 0 || m.MasrafKalemiId == filtreMasrafKalemiId)
        && (string.IsNullOrEmpty(filtreKategori) || (m.MasrafKalemi != null && m.MasrafKalemi.Kategori.ToString() == filtreKategori))
        && (string.IsNullOrEmpty(filtreOdemeKaynak) || m.OdemeKaynak.ToString() == filtreOdemeKaynak)
        && (!filtreBaslangic.HasValue || m.MasrafTarihi.Date >= filtreBaslangic.Value.Date)
        && (!filtreBitis.HasValue || m.MasrafTarihi.Date <= filtreBitis.Value.Date)
        && (!filtreMinTutar.HasValue || m.Tutar >= filtreMinTutar.Value)
        && (!filtreMaxTutar.HasValue || m.Tutar <= filtreMaxTutar.Value)
        && (string.IsNullOrWhiteSpace(filtreArama)
            || (m.BelgeNo ?? string.Empty).Contains(filtreArama, StringComparison.OrdinalIgnoreCase)
            || (m.Aciklama ?? string.Empty).Contains(filtreArama, StringComparison.OrdinalIgnoreCase))
        && (string.IsNullOrEmpty(filtreAriza)
            || (filtreAriza == "evet" && m.ArizaKaynaklimi)
            || (filtreAriza == "hayir" && !m.ArizaKaynaklimi))
        && (string.IsNullOrEmpty(filtreFisDurumu)
            || (filtreFisDurumu == "var" && m.MuhasebeFisId.HasValue)
            || (filtreFisDurumu == "yok" && !m.MuhasebeFisId.HasValue))
        && (string.IsNullOrEmpty(filtrePersonelOdendi)
            || (filtrePersonelOdendi == "evet" && m.IsPersonelCebinden && m.PersoneleOdendi)
            || (filtrePersonelOdendi == "hayir" && m.IsPersonelCebinden && !m.PersoneleOdendi))
    ).ToList();

    private List<AracMasraf> SiraliMasraflar => siralamaAlani switch
    {
        nameof(AracMasraf.Tutar) => siralamaAzalan
            ? FiltrelenmisMasraflar.OrderByDescending(m => m.Tutar).ToList()
            : FiltrelenmisMasraflar.OrderBy(m => m.Tutar).ToList(),
        _ => siralamaAzalan
            ? FiltrelenmisMasraflar.OrderByDescending(m => m.MasrafTarihi).ToList()
            : FiltrelenmisMasraflar.OrderBy(m => m.MasrafTarihi).ToList(),
    };

    private void Sirala(string alan)
    {
        if (siralamaAlani == alan) siralamaAzalan = !siralamaAzalan;
        else { siralamaAlani = alan; siralamaAzalan = true; }
    }

    private MarkupString SiralamaIkonu(string alan)
    {
        if (siralamaAlani != alan) return new MarkupString("<i class=\"bi bi-arrow-down-up text-muted\"></i>");
        return new MarkupString(siralamaAzalan
            ? "<i class=\"bi bi-arrow-down\"></i>"
            : "<i class=\"bi bi-arrow-up\"></i>");
    }

    private void FiltreyiTemizle()
    {
        filtrePlaka = filtreSase = filtreKategori = filtreOdemeKaynak = filtreArama = filtreAriza = filtreFisDurumu = filtrePersonelOdendi = string.Empty;
        filtreAracId = 0;
        filtreMasrafKalemiId = 0;
        filtreBaslangic = filtreBitis = null;
        filtreMinTutar = filtreMaxTutar = null;
    }

    private static DateTime? ParseDate(object? raw)
    {
        if (raw == null) return null;
        return DateTime.TryParse(raw.ToString(), out var d) ? d : null;
    }

    private void YeniMasraf() => Navigation.NavigateTo("/arac-masraflari/yeni");
    private void Duzenle(int id) => Navigation.NavigateTo($"/arac-masraflari/{id}");

    private void DetayAc(AracMasraf masraf)
    {
        detayMasraf = masraf;
        showDetayModal = true;
    }

    private async Task PersoneleOdemeYap(AracMasraf masraf)
    {
        try
        {
            var guncel = await AracMasrafService.GetByIdAsync(masraf.Id);
            if (guncel == null) return;
            guncel.PersoneleOdendi = true;
            guncel.PersonelOdemeTarihi = DateTime.Now;
            await AracMasrafService.UpdateAsync(guncel, false);
            masraf.PersoneleOdendi = true;
            masraf.PersonelOdemeTarihi = guncel.PersonelOdemeTarihi;
            ToastService.ShowSuccess("Personele ödeme yapıldı olarak işaretlendi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private void SilOnay(AracMasraf masraf)
    {
        silinecekMasraf = masraf;
        showDeleteModal = true;
    }

    private async Task Sil()
    {
        if (silinecekMasraf == null) return;
        try
        {
            await AracMasrafService.DeleteAsync(silinecekMasraf.Id);
            ToastService.ShowSuccess("Masraf kaydı silindi.");
            await LoadData();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            showDeleteModal = false;
            silinecekMasraf = null;
        }
    }

    private async Task ExcelIndir()
    {
        try
        {
            var rows = SiraliMasraflar.Select(m => new
            {
                Tarih = m.MasrafTarihi.ToString("dd.MM.yyyy"),
                Plaka = m.Arac?.AktifPlaka ?? string.Empty,
                Marka = m.Arac?.Marka ?? string.Empty,
                Model = m.Arac?.Model ?? string.Empty,
                MasrafKalemi = m.MasrafKalemi?.MasrafAdi ?? string.Empty,
                Kategori = m.MasrafKalemi?.Kategori.ToString() ?? string.Empty,
                Tutar = m.Tutar,
                BelgeNo = m.BelgeNo ?? string.Empty,
                OdemeKaynak = GetOdemeKaynakAdi(m.OdemeKaynak),
                Odeyen = GetMuhatapText(m),
                Guzergah = m.Guzergah?.GuzergahAdi ?? string.Empty,
                ArizaKaynakli = m.ArizaKaynaklimi ? "Evet" : "Hayır",
                MuhasebeFisi = m.MuhasebeFisId.HasValue ? "Var" : "Yok",
                Aciklama = m.Aciklama ?? string.Empty
            }).ToList();

            var bytes = ExcelService.ExportToExcel(rows, "AracMasraflari");
            var ad = $"AracMasraflari_{DateTime.Now:yyyyMMdd_HHmm}.xlsx";
            await JS.InvokeVoidAsync("downloadFile", ad, Convert.ToBase64String(bytes), "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Excel hatası: {ex.Message}");
        }
    }

    private static string GetMuhatapText(AracMasraf masraf)
    {
        if (masraf.Sofor != null) return $"Personel: {masraf.Sofor.TamAd}";
        if (masraf.Cari?.CariTipi == CariTipi.Personel) return $"Personel: {masraf.Cari.Unvan}";
        if (masraf.Cari != null) return $"Cari: {masraf.Cari.Unvan}";
        return "Kasa";
    }

    private static string GetOdemeKaynakAdi(MasrafOdemeKaynak k) => k switch
    {
        MasrafOdemeKaynak.Kasa => "Kasa",
        MasrafOdemeKaynak.Banka => "Banka",
        MasrafOdemeKaynak.PersonelCebinden => "Personel Cebinden",
        _ => k.ToString()
    };

    private static string GetOdemeKaynakBadge(MasrafOdemeKaynak k) => k switch
    {
        MasrafOdemeKaynak.Kasa => "bg-success",
        MasrafOdemeKaynak.Banka => "bg-primary",
        MasrafOdemeKaynak.PersonelCebinden => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}
