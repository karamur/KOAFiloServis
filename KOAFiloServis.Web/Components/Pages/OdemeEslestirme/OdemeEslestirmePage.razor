@page "/odeme-eslestirme"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@inject IOdemeEslestirmeService EslestirmeService
@inject IFaturaService FaturaService
@inject IBankaKasaHareketService HareketService
@inject ICariService CariService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>�deme E�le�tirme</PageTitle>

<div class="container-fluid">
    <h3 class="mb-3"><i class="bi bi-link-45deg me-2"></i>Fatura / �deme E�le�tirme</h3>

    <div class="row mb-3">
        <div class="col-md-4">
            <div class="mb-3">
                <label class="form-label">Cari Se�iniz</label>
                <select class="form-select" @onchange="CariSecildi">
                    <option value="">-- Cari Se�iniz --</option>
                    @foreach (var cari in cariler)
                    {
                        <option value="@cari.Id">@cari.Unvan</option>
                    }
                </select>
            </div>
        </div>
    </div>

    @if (secilenCariId > 0)
    {
        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-danger text-white">
                        <h6 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i>�denmemi� Faturalar</h6>
                    </div>
                    <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                        @if (odenmemisFaturalar == null || !odenmemisFaturalar.Any())
                        {
                            <p class="text-muted">�denmemi� fatura bulunmuyor.</p>
                        }
                        else
                        {
                            @foreach (var fatura in odenmemisFaturalar)
                            {
                                <div class="card mb-2 @(secilenFaturaId == fatura.Id ? "border-primary" : "")" 
                                     style="cursor: pointer;" @onclick="() => FaturaSec(fatura)">
                                    <div class="card-body py-2">
                                        <div class="d-flex justify-content-between">
                                            <strong>@fatura.FaturaNo</strong>
                                            <span class="badge bg-warning text-dark">@fatura.KalanTutar.ToString("N2") ?</span>
                                        </div>
                                        <small class="text-muted">@fatura.FaturaTarihi.ToString("dd.MM.yyyy") | Toplam: @fatura.GenelToplam.ToString("N2") ?</small>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h6 class="mb-0"><i class="bi bi-cash-stack me-2"></i>E�le�tirilmemi� Hareketler</h6>
                    </div>
                    <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                        @if (eslestirmeyeUygunHareketler == null || !eslestirmeyeUygunHareketler.Any())
                        {
                            <p class="text-muted">E�le�tirilmemi� hareket bulunmuyor.</p>
                        }
                        else
                        {
                            @foreach (var hareket in eslestirmeyeUygunHareketler)
                            {
                                <div class="card mb-2 @(secilenHareketId == hareket.Id ? "border-primary" : "")" 
                                     style="cursor: pointer;" @onclick="() => HareketSec(hareket)">
                                    <div class="card-body py-2">
                                        <div class="d-flex justify-content-between">
                                            <strong>@hareket.IslemNo</strong>
                                            <span class="badge bg-success">@hareket.Tutar.ToString("N2") ?</span>
                                        </div>
                                        <small class="text-muted">@hareket.IslemTarihi.ToString("dd.MM.yyyy") | @hareket.BankaHesap?.HesapAdi</small>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (secilenFaturaId > 0 && secilenHareketId > 0)
        {
            <div class="card mt-3">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0">E�le�tirme Yap</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <label class="form-label">Fatura Kalan Tutar</label>
                            <input type="text" class="form-control" readonly value="@secilenFatura?.KalanTutar.ToString("N2") ?" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">E�le�tirilecek Tutar (?)</label>
                            <input type="number" class="form-control" @bind="eslestirmeTutar" step="0.01" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">&nbsp;</label>
                            <button class="btn btn-primary d-block w-100" @onclick="Eslestir">
                                <i class="bi bi-link-45deg me-1"></i>E�le�tir
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="card mt-3">
            <div class="card-header">
                <h6 class="mb-0">Son E�le�tirmeler</h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Tarih</th>
                                <th>Fatura</th>
                                <th>Hareket</th>
                                <th>Tutar</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (eslestirmeler != null)
                            {
                                @foreach (var esl in eslestirmeler)
                                {
                                    <tr>
                                        <td>@esl.EslestirmeTarihi.ToString("dd.MM.yyyy")</td>
                                        <td>@esl.Fatura?.FaturaNo</td>
                                        <td>@esl.BankaKasaHareket?.IslemNo</td>
                                        <td><strong>@esl.EslestirilenTutar.ToString("N2") ?</strong></td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => EslestirmeIptal(esl.Id)">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Cari> cariler = new();
    private List<Fatura>? odenmemisFaturalar;
    private List<BankaKasaHareket>? eslestirmeyeUygunHareketler;
    private List<OdemeEslestirme>? eslestirmeler;

    private int secilenCariId = 0;
    private int secilenFaturaId = 0;
    private int secilenHareketId = 0;
    private Fatura? secilenFatura;
    private BankaKasaHareket? secilenHareket;
    private decimal eslestirmeTutar = 0;

    protected override async Task OnInitializedAsync()
    {
        cariler = await CariService.GetAllAsync();
    }

    private async Task CariSecildi(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int cariId) && cariId > 0)
        {
            secilenCariId = cariId;
            await LoadCariData();
        }
        else
        {
            secilenCariId = 0;
            odenmemisFaturalar = null;
            eslestirmeyeUygunHareketler = null;
        }

        secilenFaturaId = 0;
        secilenHareketId = 0;
        secilenFatura = null;
        secilenHareket = null;
    }

    private async Task LoadCariData()
    {
        var faturalar = await FaturaService.GetByCariIdAsync(secilenCariId);
        odenmemisFaturalar = faturalar.Where(f => f.Durum == FaturaDurum.Beklemede || f.Durum == FaturaDurum.KismiOdendi).ToList();

        eslestirmeyeUygunHareketler = await HareketService.GetEslestirmeyeUygunHareketlerAsync(secilenCariId, HareketTipi.Giris);
        eslestirmeler = await EslestirmeService.GetAllAsync();
        eslestirmeler = eslestirmeler.Where(e => e.Fatura?.CariId == secilenCariId).Take(10).ToList();
    }

    private void FaturaSec(Fatura fatura)
    {
        secilenFaturaId = fatura.Id;
        secilenFatura = fatura;
        eslestirmeTutar = Math.Min(fatura.KalanTutar, secilenHareket?.Tutar ?? fatura.KalanTutar);
    }

    private void HareketSec(BankaKasaHareket hareket)
    {
        secilenHareketId = hareket.Id;
        secilenHareket = hareket;
        eslestirmeTutar = Math.Min(secilenFatura?.KalanTutar ?? hareket.Tutar, hareket.Tutar);
    }

    private async Task Eslestir()
    {
        if (secilenFaturaId == 0 || secilenHareketId == 0 || eslestirmeTutar <= 0)
            return;

        var eslestirme = new OdemeEslestirme
        {
            FaturaId = secilenFaturaId,
            BankaKasaHareketId = secilenHareketId,
            EslestirmeTarihi = DateTime.Today,
            EslestirilenTutar = eslestirmeTutar
        };

        await EslestirmeService.CreateAsync(eslestirme);

        // Refresh data
        await LoadCariData();
        secilenFaturaId = 0;
        secilenHareketId = 0;
        secilenFatura = null;
        secilenHareket = null;
        eslestirmeTutar = 0;
    }

    private async Task EslestirmeIptal(int id)
    {
        await EslestirmeService.DeleteAsync(id);
        await LoadCariData();
    }
}
