@page "/belge-uyarilari"
@using KOAFiloServis.Web.Services
@using KOAFiloServis.Shared.Entities
@using System.IO
@inject IBelgeUyariService BelgeUyariService
@inject ISecureFileService SecureFileService
@inject IExcelService ExcelService
@inject IPdfService PdfService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IToastService ToastService
@rendermode InteractiveServer

<PageTitle>Belge Sure Uyarilari</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-file-earmark-medical me-2"></i>Belge Süre Uyarıları</h3>
        <div class="d-flex gap-2">
            <select class="form-select" style="width: 180px;" @bind="gunFiltre" @bind:after="YenileAsync">
                <option value="7">7 Gün İçinde</option>
                <option value="15">15 Gün İçinde</option>
                <option value="30">30 Gün İçinde</option>
                <option value="60">60 Gün İçinde</option>
                <option value="90">90 Gün İçinde</option>
            </select>
            <button class="btn btn-danger" @onclick="PdfExport" disabled="@(uyarilar == null || !FiltrelenmisTumUyarilar.Any())">
                <i class="bi bi-file-earmark-pdf me-1"></i>PDF
            </button>
            <button class="btn btn-success" @onclick="ExcelExport" disabled="@(uyarilar == null || !FiltrelenmisTumUyarilar.Any())">
                <i class="bi bi-file-earmark-excel me-1"></i>Excel
            </button>
        </div>
    </div>

    <!-- Sekme Navigasyonu -->
    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <button class="nav-link @(aktifSekme == "uyarilar" ? "active" : "")" @onclick='() => aktifSekme = "uyarilar"'>
                <i class="bi bi-exclamation-triangle me-1"></i>Süre Uyarıları
                @if (uyarilar != null && uyarilar.TumUyarilar.Any())
                {
                    <span class="badge bg-danger ms-1">@uyarilar.TumUyarilar.Count(u => u.Seviye == BelgeUyariSeviye.Kritik)</span>
                }
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(aktifSekme == "tablo" ? "active" : "")" @onclick="SekmeTabloAc">
                <i class="bi bi-table me-1"></i>Personel Belge Tablosu
                @if (belgeTablosu != null)
                {
                    <span class="badge bg-secondary ms-1">@belgeTablosu.Count</span>
                }
            </button>
        </li>
    </ul>

    <!-- Süre Uyarıları Sekmesi -->
    @if (aktifSekme == "uyarilar")
    {
    <div class="card mb-4">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small mb-1">Kaynak</label>
                    <select class="form-select form-select-sm" @bind="kaynakFiltre">
                        <option value="Tumu">Tümü</option>
                        <option value="Personel">Personel</option>
                        <option value="Araç">Araç</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-1">Seviye</label>
                    <select class="form-select form-select-sm" @bind="seviyeFiltre">
                        <option value="Tumu">Tümü</option>
                        <option value="Kritik">Süresi Geçmiş</option>
                        <option value="Acil">7 Gün İçinde</option>
                        <option value="Uyari">Yaklaşan</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small mb-1">Arama</label>
                    <input type="text" class="form-control form-control-sm" @bind="aramaMetni" @bind:event="oninput" placeholder="Belge türü, personel veya plaka ara..." />
                </div>
                <div class="col-md-12 text-end">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="FiltreleriTemizle" disabled="@(!FiltreVarMi)">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Filtreleri Temizle
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (uyarilar != null)
    {
        <!-- Ozet Kartlari -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-danger text-white h-100">
                    <div class="card-body text-center">
                        <h1 class="mb-0">@FiltrelenmisTumUyarilar.Count(u => u.Seviye == BelgeUyariSeviye.Kritik)</h1>
                        <small>Suresi Gecmis</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-dark h-100">
                    <div class="card-body text-center">
                        <h1 class="mb-0">@FiltrelenmisTumUyarilar.Count(u => u.Seviye == BelgeUyariSeviye.Acil)</h1>
                        <small>7 Gun Icinde</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white h-100">
                    <div class="card-body text-center">
                        <h1 class="mb-0">@FiltrelenmisTumUyarilar.Count(u => u.Seviye == BelgeUyariSeviye.Uyari)</h1>
                        <small>30 Gun Icinde</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white h-100">
                    <div class="card-body text-center">
                        <h1 class="mb-0">@FiltrelenmisTumUyarilar.Count</h1>
                        <small>Toplam Uyari</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Personel Belgeleri -->
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-header bg-primary text-white">
                        <h6 class="mb-0"><i class="bi bi-person-badge me-2"></i>Personel Belgeleri</h6>
                    </div>
                    <div class="card-body p-0">
                        @if (FiltrelenmisPersonelUyarilari.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Personel</th>
                                            <th>Belge</th>
                                            <th>Bitis</th>
                                            <th class="text-center">Durum</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var u in FiltrelenmisPersonelUyarilari)
                                        {
                                            <tr>
                                                <td>
                                                    <a href="@u.DetayUrl" class="text-decoration-none">
                                                        <strong>@u.Baslik</strong>
                                                    </a>
                                                </td>
                                                <td>@u.BelgeTuru</td>
                                                <td>@u.BitisTarihi.ToString("dd.MM.yyyy")</td>
                                                <td class="text-center">
                                                    <span class="badge @u.SeviyeClass">
                                                        @if (u.KalanGun < 0)
                                                        {
                                                            @(Math.Abs(u.KalanGun) + " gun gecti")
                                                        }
                                                        else
                                                        {
                                                            @(u.KalanGun + " gun")
                                                        }
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center text-success py-4">
                                <i class="bi bi-check-circle" style="font-size: 2rem;"></i>
                                <p class="mb-0 mt-2">Personel belgeleri guncel!</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Arac Belgeleri -->
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-header bg-success text-white">
                        <h6 class="mb-0"><i class="bi bi-truck me-2"></i>Arac Belgeleri</h6>
                    </div>
                    <div class="card-body p-0">
                        @if (FiltrelenmisAracUyarilari.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Plaka</th>
                                            <th>Belge</th>
                                            <th>Bitis</th>
                                            <th class="text-center">Durum</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var u in FiltrelenmisAracUyarilari)
                                        {
                                            <tr>
                                                <td>
                                                    <a href="@u.DetayUrl" class="text-decoration-none">
                                                        <strong>@u.Baslik</strong>
                                                    </a>
                                                </td>
                                                <td>@u.BelgeTuru</td>
                                                <td>@u.BitisTarihi.ToString("dd.MM.yyyy")</td>
                                                <td class="text-center">
                                                    <span class="badge @u.SeviyeClass">
                                                        @if (u.KalanGun < 0)
                                                        {
                                                            @(Math.Abs(u.KalanGun) + " gun gecti")
                                                        }
                                                        else
                                                        {
                                                            @(u.KalanGun + " gun")
                                                        }
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center text-success py-4">
                                <i class="bi bi-check-circle" style="font-size: 2rem;"></i>
                                <p class="mb-0 mt-2">Arac belgeleri guncel!</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-list-ul me-2"></i>Tum Uyarilar</h6>
                <span class="badge bg-dark">@FiltrelenmisTumUyarilar.Count kayıt</span>
            </div>
            <div class="card-body p-0">
                @if (FiltrelenmisTumUyarilar.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Kaynak</th>
                                    <th>Belge Türü</th>
                                    <th>Ad / Plaka</th>
                                    <th>Bitiş</th>
                                    <th class="text-center">Durum</th>
                                    <th class="text-center">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var uyari in FiltrelenmisTumUyarilar)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge @(uyari.Kaynak == "Personel" ? "bg-primary" : "bg-success")">@uyari.Kaynak</span>
                                        </td>
                                        <td>@uyari.BelgeTuru</td>
                                        <td><strong>@uyari.Baslik</strong></td>
                                        <td>@uyari.BitisTarihi.ToString("dd.MM.yyyy")</td>
                                        <td class="text-center">
                                            <span class="badge @uyari.SeviyeClass">
                                                @(uyari.KalanGun < 0 ? $"{Math.Abs(uyari.KalanGun)} gün geçti" : $"{uyari.KalanGun} gün")
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <a class="btn btn-sm btn-outline-primary" href="@uyari.DetayUrl">
                                                <i class="bi bi-box-arrow-up-right"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-4">Filtreye uygun uyarı bulunamadı.</div>
                }
            </div>
        </div>

        <!-- Diger Onemli Belgeler -->
        @if (uyarilar.DigerTumPersonelBelgeler.Any())
        {
            <div class="card mb-4">
                <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="bi bi-folder2-open me-2"></i>Diger Onemli Belgeler</h6>
                    <div class="d-flex gap-2 align-items-center">
                        <span class="badge bg-light text-dark">@FiltrelenmisDigerBelgeler.Count kayit</span>
                        <input type="text" class="form-control form-control-sm" style="width:200px;"
                               placeholder="Personel veya belge ara..."
                               @bind="digerBelgeArama" @bind:event="oninput" />
                        <select class="form-select form-select-sm" style="width:160px;" @bind="digerBelgeDurum">
                            <option value="">Tum Durumlar</option>
                            <option value="eksik">Eksik</option>
                            <option value="gecmis">Suresi Gecmis</option>
                            <option value="yaklasan">Yaklasan (30 gun)</option>
                            <option value="gecerli">Gecerli</option>
                        </select>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Personel</th>
                                    <th>Belge</th>
                                    <th class="text-center">Zorunlu</th>
                                    <th class="text-center">Durum</th>
                                    <th>Gecerlilik Tarihi</th>
                                    <th class="text-center">Dosya</th>
                                    <th class="text-center">Islem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var b in FiltrelenmisDigerBelgeler)
                                {
                                    <tr class="@(!b.Tamamlandi ? "table-warning" : b.KalanGun < 0 ? "table-danger" : "")">
                                        <td>
                                            <strong>@b.PersonelAdi</strong>
                                            <br /><small class="text-muted">@b.PersonelKodu</small>
                                        </td>
                                        <td>@b.EvrakAdi</td>
                                        <td class="text-center">
                                            @if (b.Zorunlu)
                                            {
                                                <span class="badge bg-danger">Zorunlu</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-light text-muted border">Istege Bagli</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <span class="badge @b.DurumClass">@b.DurumMetin</span>
                                        </td>
                                        <td>
                                            @if (b.GecerlilikBitisTarihi.HasValue)
                                            {
                                                <span class="@(b.KalanGun < 0 ? "text-danger fw-bold" : b.KalanGun <= 30 ? "text-warning fw-semibold" : "")">
                                                    @b.GecerlilikBitisTarihi.Value.ToString("dd.MM.yyyy")
                                                </span>
                                            }
                                            else if (b.TamamlanmaTarihi.HasValue)
                                            {
                                                <small class="text-muted">@b.TamamlanmaTarihi.Value.ToString("dd.MM.yyyy")</small>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (!string.IsNullOrWhiteSpace(b.DosyaYolu))
                                            {
                                                <i class="bi bi-paperclip text-success" title="Dosya mevcut"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-dash text-muted"></i>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <a class="btn btn-sm btn-outline-primary" href="@b.DetayUrl" title="Ozluk Evrak Sayfasina Git">
                                                <i class="bi bi-box-arrow-up-right"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- Belge Turu Bazinda Ozet -->
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-bar-chart me-2"></i>Belge Turu Ozeti</h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-2 text-center mb-3">
                        <div class="p-3 border rounded @(uyarilar.EhliyetUyarilari.Any(u => u.KalanGun < 0) ? "border-danger" : "")">
                            <i class="bi bi-card-text" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">@uyarilar.EhliyetUyarilari.Count</h4>
                            <small class="text-muted">Ehliyet</small>
                        </div>
                    </div>
                    <div class="col-md-2 text-center mb-3">
                        <div class="p-3 border rounded @(uyarilar.SrcUyarilari.Any(u => u.KalanGun < 0) ? "border-danger" : "")">
                            <i class="bi bi-file-earmark-check" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">@uyarilar.SrcUyarilari.Count</h4>
                            <small class="text-muted">SRC Belgesi</small>
                        </div>
                    </div>
                    <div class="col-md-2 text-center mb-3">
                        <div class="p-3 border rounded @(uyarilar.PsikoteknikUyarilari.Any(u => u.KalanGun < 0) ? "border-danger" : "")">
                            <i class="bi bi-clipboard2-pulse" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">@uyarilar.PsikoteknikUyarilari.Count</h4>
                            <small class="text-muted">Psikoteknik</small>
                        </div>
                    </div>
                    <div class="col-md-2 text-center mb-3">
                        <div class="p-3 border rounded @(uyarilar.MuayeneUyarilari.Any(u => u.KalanGun < 0) ? "border-danger" : "")">
                            <i class="bi bi-wrench-adjustable" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">@uyarilar.MuayeneUyarilari.Count</h4>
                            <small class="text-muted">Muayene</small>
                        </div>
                    </div>
                    <div class="col-md-2 text-center mb-3">
                        <div class="p-3 border rounded @(uyarilar.KaskoUyarilari.Any(u => u.KalanGun < 0) ? "border-danger" : "")">
                            <i class="bi bi-shield-check" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">@uyarilar.KaskoUyarilari.Count</h4>
                            <small class="text-muted">Kasko</small>
                        </div>
                    </div>
                    <div class="col-md-2 text-center mb-3">
                        <div class="p-3 border rounded @(uyarilar.TrafikSigortasiUyarilari.Any(u => u.KalanGun < 0) ? "border-danger" : "")">
                            <i class="bi bi-shield-exclamation" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">@uyarilar.TrafikSigortasiUyarilari.Count</h4>
                            <small class="text-muted">Trafik Sigortasi</small>
                        </div>
                    </div>
                    <div class="col-md-2 text-center mb-3">
                        <div class="p-3 border rounded @(uyarilar.DigerAracEvrakUyarilari.Any(u => u.KalanGun < 0) ? "border-danger" : "")">
                            <i class="bi bi-folder2-open" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">@uyarilar.DigerAracEvrakUyarilari.Count</h4>
                            <small class="text-muted">Diger Evraklar</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    } @* /uyarilar sekmesi *@

    <!-- Personel Belge Tablosu Sekmesi -->
    @if (aktifSekme == "tablo")
    {
        <!-- Filtreler -->
        <div class="card mb-3">
            <div class="card-body py-2">
                <div class="row g-2 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label small mb-1">Personel Ara</label>
                        <input type="text" class="form-control form-control-sm" placeholder="Ad, soyad veya kod..."
                               @bind="tabloArama" @bind:event="oninput" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small mb-1">Görev</label>
                        <select class="form-select form-select-sm" @bind="tabloGorevFiltre">
                            <option value="">Tümü</option>
                            @foreach (PersonelGorev g in Enum.GetValues(typeof(PersonelGorev)))
                            {
                                <option value="@g">@GetGorevAdi(g)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small mb-1">Durum</label>
                        <select class="form-select form-select-sm" @bind="tabloAktifFiltre">
                            <option value="">Tümü</option>
                            <option value="aktif">Aktif</option>
                            <option value="pasif">Pasif</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small mb-1">Belge Filtresi</label>
                        <select class="form-select form-select-sm" @bind="tabloBelgeFiltre">
                            <option value="">Tümü</option>
                            <option value="eksik">Tarihi Girilmemiş</option>
                            <option value="gecmis">Süresi Geçmiş</option>
                            <option value="yaklasan">30 Gün İçinde</option>
                        </select>
                    </div>
                    <div class="col-md-3 d-flex gap-1 align-items-end">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="TabloFiltreleriniTemizle">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-success" @onclick="TabloExcelAktar" disabled="@(FiltrelenmisBelgeTablosu.Count == 0)">
                            <i class="bi bi-file-earmark-excel me-1"></i>Excel
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="TabloYazdir" disabled="@(FiltrelenmisBelgeTablosu.Count == 0)">
                            <i class="bi bi-printer me-1"></i>Yazdır
                        </button>
                        <button class="btn btn-sm btn-success" @onclick="SeciliPersonellerinBelgeleriniIndir"
                                disabled="@(belgeTablosu == null || !belgeTablosu.Any(x => x.Secili))">
                            <i class="bi bi-download me-1"></i>Seçilenleri İndir
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Özet Kartlar -->
        @if (belgeTablosu != null)
        {
            <div class="row mb-3 g-2">
                <div class="col">
                    <div class="card border-danger text-center py-2">
                        <div class="fw-bold text-danger fs-4">@belgeTablosu.SelectMany(GetTumBelgeTarihleri).Count(t => t < DateTime.Today)</div>
                        <small class="text-muted">Süresi Geçmiş</small>
                    </div>
                </div>
                <div class="col">
                    <div class="card border-warning text-center py-2">
                        <div class="fw-bold text-warning fs-4">@belgeTablosu.SelectMany(GetTumBelgeTarihleri).Count(t => t >= DateTime.Today && (t - DateTime.Today).Days <= 30)</div>
                        <small class="text-muted">30 Gün İçinde</small>
                    </div>
                </div>
                <div class="col">
                    <div class="card border-secondary text-center py-2">
                        <div class="fw-bold text-secondary fs-4">@belgeTablosu.Sum(p => GetEksikBelgeSayisi(p))</div>
                        <small class="text-muted">Tarihi Girilmemiş</small>
                    </div>
                </div>
                <div class="col">
                    <div class="card border-primary text-center py-2">
                        <div class="fw-bold text-primary fs-4">@belgeTablosu.Count</div>
                        <small class="text-muted">Toplam Personel</small>
                    </div>
                </div>
            </div>
        }

        @if (isTabloyukleniyor)
        {
            <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
        }
        else if (belgeTablosu != null)
        {
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center py-2">
                    <span>
                        <i class="bi bi-table me-1"></i>
                        Personel Belge Takip Tablosu
                        <span class="badge bg-secondary ms-1">@FiltrelenmisBelgeTablosu.Count kayıt</span>
                    </span>
                    <div class="d-flex gap-2 align-items-center">
                        <span class="small text-muted">
                            @belgeTablosu.Count(x => x.Secili) personel seçildi
                        </span>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="TumunuSecToggle">
                            <i class="bi bi-check-all me-1"></i>@(belgeTablosu.All(x => x.Secili) ? "Seçimi Kaldır" : "Tümünü Seç")
                        </button>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered table-hover mb-0 align-middle" id="belgeTablosu" style="font-size:0.82rem;">
                            <thead class="table-dark sticky-top">
                                <tr>
                                    <th style="width:36px;" class="text-center">
                                        <input type="checkbox" class="form-check-input"
                                               checked="@(FiltrelenmisBelgeTablosu.Any() && FiltrelenmisBelgeTablosu.All(x => x.Secili))"
                                               @onchange="TumunuSecToggle" />
                                    </th>
                                    <th>Personel</th>
                                    <th class="text-center" style="width:40px;">Görev</th>
                                    <th class="text-center bg-primary bg-opacity-25" style="width:90px;" title="Ehliyet Geçerlilik">Ehliyet</th>
                                    <th class="text-center bg-info bg-opacity-25" style="width:90px;" title="Kimlik Geçerlilik">Kimlik</th>
                                    <th class="text-center bg-success bg-opacity-25" style="width:90px;" title="SRC Belgesi">SRC</th>
                                    <th class="text-center bg-warning bg-opacity-25" style="width:90px;" title="Psikoteknik">Psikoteknik</th>
                                    <th class="text-center bg-danger bg-opacity-25" style="width:90px;" title="Adli Sicil">Adli Sicil</th>
                                    <th class="text-center bg-secondary bg-opacity-25" style="width:90px;" title="Sağlık Raporu">Sağlık</th>
                                    <th class="text-center" style="width:90px;" title="Sürücü Ceza Barkodlu Belge">Ceza Barkod</th>
                                    <th class="text-center" style="width:60px;">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in FiltrelenmisBelgeTablosu)
                                {
                                    <tr class="@(!item.Aktif ? "table-secondary opacity-75" : "")">
                                        <td class="text-center">
                                            <input type="checkbox" class="form-check-input"
                                                   checked="@item.Secili"
                                                   @onchange="(e) => item.Secili = (bool)(e.Value ?? false)" />
                                        </td>
                                        <td>
                                            <strong>@item.PersonelAdi</strong>
                                            <br /><small class="text-muted">@item.PersonelKodu</small>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge @GetGorevBadgeClass(item.Gorev)" style="font-size:0.7rem;">@GetGorevAdi(item.Gorev)</span>
                                        </td>
                                        <!-- Ehliyet -->
                                        <td class="text-center p-1">
                                            @BelgeCelHtml(item, "Ehliyet", item.EhliyetGecerlilik)
                                        </td>
                                        <!-- Kimlik -->
                                        <td class="text-center p-1">
                                            @BelgeCelHtml(item, "Kimlik", item.KimlikGecerlilik)
                                        </td>
                                        <!-- SRC -->
                                        <td class="text-center p-1">
                                            @BelgeCelHtml(item, "Src", item.SrcGecerlilik)
                                        </td>
                                        <!-- Psikoteknik -->
                                        <td class="text-center p-1">
                                            @BelgeCelHtml(item, "Psikoteknik", item.PsikoteknikGecerlilik)
                                        </td>
                                        <!-- Adli Sicil -->
                                        <td class="text-center p-1">
                                            @BelgeCelHtml(item, "AdliSicil", item.AdliSicilGecerlilik)
                                        </td>
                                        <!-- Sağlık Raporu -->
                                        <td class="text-center p-1">
                                            @BelgeCelHtml(item, "SaglikRaporu", item.SaglikRaporuGecerlilik)
                                        </td>
                                        <!-- Sürücü Ceza Barkod -->
                                        <td class="text-center p-1">
                                            @BelgeCelHtml(item, "SuruculCezaBarkod", item.SuruculCezaBarkodGecerlilik)
                                        </td>
                                        <td class="text-center p-1" style="min-width:110px;">
                                            <div class="d-flex flex-column align-items-center gap-1">
                                                <div class="d-flex gap-1">
                                                    <button class="btn btn-xs btn-outline-info" title="Özlük İşlem — Belgeleri Görüntüle / İndir"
                                                            @onclick="() => OzlukIslemAc(item)">
                                                        <i class="bi bi-file-earmark-person"></i>
                                                    </button>
                                                    <a class="btn btn-xs btn-outline-secondary" href="/personel/@item.SoforId/ozluk-evrak" title="Özlük Evrak Sayfası">
                                                        <i class="bi bi-folder2-open"></i>
                                                    </a>
                                                </div>
                                                @if (item.ToplamEvrakSayisi > 0)
                                                {
                                                    <span class="badge @(item.YuklenmisEvrakSayisi == item.ToplamEvrakSayisi ? "bg-success" : item.YuklenmisEvrakSayisi == 0 ? "bg-secondary" : "bg-warning text-dark")" style="font-size:0.65rem;">
                                                        @item.YuklenmisEvrakSayisi/@item.ToplamEvrakSayisi
                                                    </span>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    } @* /tablo sekmesi *@

    <!-- Tarih Düzenleme Modal -->
    @if (showTarihModal && editItem != null)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color:rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-sm">
                <div class="modal-content">
                    <div class="modal-header py-2">
                        <h6 class="modal-title"><i class="bi bi-pencil me-2"></i>@editBelgeAdi Tarihi</h6>
                        <button type="button" class="btn-close btn-sm" @onclick="ModalKapat"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-2 small text-muted">@editItem.PersonelAdi</p>
                        <label class="form-label small">Geçerlilik Bitiş Tarihi</label>
                        <input type="date" class="form-control form-control-sm"
                               value="@editTarih?.ToString("yyyy-MM-dd")"
                               @onchange="(e) => editTarih = e.Value != null && DateTime.TryParse(e.Value.ToString(), out var d) ? d : (DateTime?)null" />
                        <div class="mt-2">
                            <button class="btn btn-sm btn-link text-danger p-0" @onclick="() => editTarih = null">
                                <i class="bi bi-x-circle me-1"></i>Tarihi Kaldır
                            </button>
                        </div>
                    </div>
                    <div class="modal-footer py-2">
                        <button class="btn btn-sm btn-secondary" @onclick="ModalKapat">İptal</button>
                        <button class="btn btn-sm btn-primary" @onclick="TarihKaydet" disabled="@isTarihKaydediliyor">
                            @if (isTarihKaydediliyor) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Kaydet
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Özlük İşlem Modal -->
    @if (showOzlukModal && ozlukModalItem != null)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color:rgba(0,0,0,0.5);" @onclick="OzlukModalKapat">
            <div class="modal-dialog modal-lg" @onclick:stopPropagation="true">
                <div class="modal-content">
                    <div class="modal-header py-2">
                        <h6 class="modal-title">
                            <i class="bi bi-file-earmark-person me-2 text-info"></i>
                            <strong>@ozlukModalItem.PersonelAdi</strong>
                            <small class="text-muted ms-2">(@ozlukModalItem.PersonelKodu)</small>
                        </h6>
                        <button class="btn-close btn-sm" @onclick="OzlukModalKapat"></button>
                    </div>
                    <div class="modal-body">
                        @if (isOzlukYukleniyor)
                        {
                            <div class="text-center py-3"><div class="spinner-border spinner-border-sm text-info"></div></div>
                        }
                        else
                        {
                            <div class="mb-3 d-flex align-items-center gap-2">
                                <span class="badge bg-primary">@ozlukModalItem.YuklenmisEvrakSayisi / @ozlukModalItem.ToplamEvrakSayisi belge yüklü</span>
                                @if (ozlukModalItem.EvrakDosyalari.Any(e => e.DosyaVar))
                                {
                                    <span class="text-muted small">İndirmek istediğiniz belgeleri seçin</span>
                                }
                            </div>
                            @if (!ozlukModalItem.EvrakDosyalari.Any(e => e.DosyaVar))
                            {
                                <div class="alert alert-warning py-2">
                                    <i class="bi bi-exclamation-triangle me-1"></i>Bu personele ait yüklenmiş belge bulunmamaktadır.
                                    <a href="/personel/@ozlukModalItem.SoforId/ozluk-evrak" class="alert-link ms-1">Belge yüklemek için tıklayın.</a>
                                </div>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th style="width:36px;">
                                                    <input type="checkbox" class="form-check-input"
                                                           checked="@ozlukModalItem.EvrakDosyalari.Where(e => e.DosyaVar).All(e => e.Secili)"
                                                           @onchange="OzlukModalTumunuSec" />
                                                </th>
                                                <th>Belge Adı</th>
                                                <th style="width:120px;">Dosya</th>
                                                <th style="width:80px;" class="text-center">İşlem</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var dosya in ozlukModalItem.EvrakDosyalari)
                                            {
                                                <tr class="@(!dosya.DosyaVar ? "text-muted" : "")">
                                                    <td>
                                                        @if (dosya.DosyaVar)
                                                        {
                                                            <input type="checkbox" class="form-check-input"
                                                                   checked="@dosya.Secili"
                                                                   @onchange="(e) => dosya.Secili = (bool)(e.Value ?? false)" />
                                                        }
                                                    </td>
                                                    <td>@dosya.EvrakAdi</td>
                                                    <td>
                                                        @if (dosya.DosyaVar)
                                                        {
                                                            <span class="badge bg-success"><i class="bi bi-paperclip me-1"></i>Var</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-secondary">Yok</span>
                                                        }
                                                    </td>
                                                    <td class="text-center">
                                                        @if (dosya.DosyaVar)
                                                        {
                                                            <button class="btn btn-xs btn-outline-primary" title="Bu belgeyi indir"
                                                                    @onclick="() => TekDosyaIndir(dosya)">
                                                                <i class="bi bi-download"></i>
                                                            </button>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        }
                    </div>
                    <div class="modal-footer py-2 gap-2">
                        @if (!isOzlukYukleniyor && ozlukModalItem.EvrakDosyalari.Any(e => e.DosyaVar))
                        {
                            <button class="btn btn-sm btn-success" @onclick="OzlukSecilenleriIndir"
                                    disabled="@(!ozlukModalItem.EvrakDosyalari.Any(e => e.Secili))">
                                <i class="bi bi-download me-1"></i>Seçilenleri İndir
                            </button>
                            <button class="btn btn-sm btn-primary" @onclick="OzlukTumunuPdfIndir">
                                <i class="bi bi-file-earmark-pdf me-1"></i>Tümünü PDF İndir
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="OzlukTumunuPdfYazdir">
                                <i class="bi bi-printer me-1"></i>Yazdır
                            </button>
                        }
                        <a class="btn btn-sm btn-outline-info" href="/personel/@ozlukModalItem.SoforId/ozluk-evrak">
                            <i class="bi bi-folder2-open me-1"></i>Özlük Sayfası
                        </a>
                        <button class="btn btn-sm btn-secondary" @onclick="OzlukModalKapat">Kapat</button>
                    </div>
                </div>
            </div>
        </div>
    }

</div>

@code {
    private BelgeUyariOzet? uyarilar;
    private bool isLoading = true;
    private int gunFiltre = 30;
    private string kaynakFiltre = "Tumu";
    private string seviyeFiltre = "Tumu";
    private string aramaMetni = string.Empty;
    private string aktifSekme = "uyarilar";

    private string digerBelgeArama = string.Empty;
    private string digerBelgeDurum = string.Empty;

    // Belge Tablosu
    private List<PersonelBelgeTabloKalemi>? belgeTablosu;
    private bool isTabloyukleniyor = false;
    private string tabloArama = string.Empty;
    private string tabloGorevFiltre = string.Empty;
    private string tabloAktifFiltre = string.Empty;
    private string tabloBelgeFiltre = string.Empty;

    // Tarih düzenleme modal
    private bool showTarihModal = false;
    private PersonelBelgeTabloKalemi? editItem;
    private string editBelgeAlani = string.Empty;
    private string editBelgeAdi = string.Empty;
    private DateTime? editTarih;
    private bool isTarihKaydediliyor = false;

    // Özlük İşlem modal
    private bool showOzlukModal = false;
    private PersonelBelgeTabloKalemi? ozlukModalItem;
    private bool isOzlukYukleniyor = false;

    private bool FiltreVarMi => kaynakFiltre != "Tumu"
        || seviyeFiltre != "Tumu"
        || !string.IsNullOrWhiteSpace(aramaMetni);
    private List<PersonelBelgeDetay> FiltrelenmisDigerBelgeler => (uyarilar?.DigerTumPersonelBelgeler ?? new List<PersonelBelgeDetay>())
        .Where(b => string.IsNullOrWhiteSpace(digerBelgeArama)
            || b.PersonelAdi.Contains(digerBelgeArama, StringComparison.OrdinalIgnoreCase)
            || b.PersonelKodu.Contains(digerBelgeArama, StringComparison.OrdinalIgnoreCase)
            || b.EvrakAdi.Contains(digerBelgeArama, StringComparison.OrdinalIgnoreCase))
        .Where(b => digerBelgeDurum switch
        {
            "eksik" => !b.Tamamlandi,
            "gecmis" => b.Tamamlandi && b.KalanGun.HasValue && b.KalanGun < 0,
            "yaklasan" => b.Tamamlandi && b.KalanGun.HasValue && b.KalanGun >= 0 && b.KalanGun <= 30,
            "gecerli" => b.Tamamlandi && (!b.KalanGun.HasValue || b.KalanGun > 30),
            _ => true
        })
        .OrderBy(b => b.PersonelAdi)
        .ThenBy(b => b.EvrakAdi)
        .ToList();


    private List<BelgeUyari> FiltrelenmisPersonelUyarilari => FiltreUygula(
        (uyarilar?.EhliyetUyarilari ?? new List<BelgeUyari>())
        .Concat(uyarilar?.SrcUyarilari ?? new List<BelgeUyari>())
        .Concat(uyarilar?.PsikoteknikUyarilari ?? new List<BelgeUyari>())
        .Concat(uyarilar?.SaglikRaporuUyarilari ?? new List<BelgeUyari>())
        .Concat(uyarilar?.DigerPersonelEvrakUyarilari ?? new List<BelgeUyari>()));

    private List<BelgeUyari> FiltrelenmisAracUyarilari => FiltreUygula(
        (uyarilar?.MuayeneUyarilari ?? new List<BelgeUyari>())
        .Concat(uyarilar?.KaskoUyarilari ?? new List<BelgeUyari>())
        .Concat(uyarilar?.TrafikSigortasiUyarilari ?? new List<BelgeUyari>())
        .Concat(uyarilar?.DigerAracEvrakUyarilari ?? new List<BelgeUyari>()));

    private List<BelgeUyari> FiltrelenmisTumUyarilar => FiltreUygula(uyarilar?.TumUyarilar ?? new List<BelgeUyari>());

    protected override async Task OnInitializedAsync()
    {
        await YenileAsync();
    }

    private async Task YenileAsync()
    {
        isLoading = true;
        try
        {
            uyarilar = await BelgeUyariService.GetBelgeUyarilarAsync(gunFiltre);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ExcelExport()
    {
        if (FiltrelenmisTumUyarilar.Any())
        {
            var excelBytes = ExcelService.ExportBelgeUyarilari(FiltrelenmisTumUyarilar);
            var fileName = "BelgeUyarilari_" + DateTime.Now.ToString("yyyyMMdd_HHmmss") + ".xlsx";
            var base64 = Convert.ToBase64String(excelBytes);
            await JS.InvokeVoidAsync("downloadFile", fileName, base64, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
        }
    }

    private async Task PdfExport()
    {
        if (FiltrelenmisTumUyarilar.Any())
        {
            var pdfBytes = PdfService.GenerateBelgeUyariRaporuPdf(FiltrelenmisTumUyarilar);
            var fileName = "BelgeUyarilari_" + DateTime.Now.ToString("yyyyMMdd_HHmmss") + ".pdf";
            var base64 = Convert.ToBase64String(pdfBytes);
            await JS.InvokeVoidAsync("downloadFile", fileName, base64, "application/pdf");
        }
    }

    private void FiltreleriTemizle()
    {
        kaynakFiltre = "Tumu";
        seviyeFiltre = "Tumu";
        aramaMetni = string.Empty;
    }

    private List<BelgeUyari> FiltreUygula(IEnumerable<BelgeUyari> kaynak)
    {
        return kaynak
            .Where(u => kaynakFiltre == "Tumu" || u.Kaynak == kaynakFiltre)
            .Where(u => seviyeFiltre switch
            {
                "Kritik" => u.Seviye == BelgeUyariSeviye.Kritik,
                "Acil" => u.Seviye == BelgeUyariSeviye.Acil,
                "Uyari" => u.Seviye == BelgeUyariSeviye.Uyari,
                _ => true
            })
            .Where(u => string.IsNullOrWhiteSpace(aramaMetni)
                || u.Baslik.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase)
                || u.BelgeTuru.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase)
                || u.Kaynak.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase))
            .OrderBy(u => u.KalanGun)
            .ThenBy(u => u.Baslik)
            .ToList();
    }

    // ─── Belge Tablosu Metodları ────────────────────────────────────────

    private List<PersonelBelgeTabloKalemi> FiltrelenmisBelgeTablosu => (belgeTablosu ?? new())
        .Where(p => string.IsNullOrWhiteSpace(tabloArama)
            || p.PersonelAdi.Contains(tabloArama, StringComparison.OrdinalIgnoreCase)
            || p.PersonelKodu.Contains(tabloArama, StringComparison.OrdinalIgnoreCase))
        .Where(p => string.IsNullOrWhiteSpace(tabloGorevFiltre) || p.Gorev == tabloGorevFiltre)
        .Where(p => tabloAktifFiltre switch
        {
            "aktif" => p.Aktif,
            "pasif" => !p.Aktif,
            _ => true
        })
        .Where(p => tabloBelgeFiltre switch
        {
            "eksik" => GetEksikBelgeSayisi(p) > 0,
            "gecmis" => GetTumBelgeTarihleri(p).Any(t => t < DateTime.Today),
            "yaklasan" => GetTumBelgeTarihleri(p).Any(t => t >= DateTime.Today && (t - DateTime.Today).Days <= 30),
            _ => true
        })
        .ToList();

    private async Task SekmeTabloAc()
    {
        aktifSekme = "tablo";
        await BelgeTabloyuYukle();
    }

    private async Task BelgeTabloyuYukle()
    {
        if (belgeTablosu != null) return;
        isTabloyukleniyor = true;
        StateHasChanged();
        try
        {
            belgeTablosu = await BelgeUyariService.GetPersonelBelgeTablosuAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Belge tablosu yüklenirken hata: {ex.Message}");
        }
        finally
        {
            isTabloyukleniyor = false;
            StateHasChanged();
        }
    }

    private void TabloFiltreleriniTemizle()
    {
        tabloArama = string.Empty;
        tabloGorevFiltre = string.Empty;
        tabloAktifFiltre = string.Empty;
        tabloBelgeFiltre = string.Empty;
    }

    private void TumunuSecToggle()
    {
        if (belgeTablosu == null) return;
        var tumSecili = FiltrelenmisBelgeTablosu.All(x => x.Secili);
        foreach (var item in FiltrelenmisBelgeTablosu)
            item.Secili = !tumSecili;
    }

    private void TarihDuzenle(PersonelBelgeTabloKalemi item, string alan, string adiGoster, DateTime? mevcutTarih)
    {
        editItem = item;
        editBelgeAlani = alan;
        editBelgeAdi = adiGoster;
        editTarih = mevcutTarih;
        showTarihModal = true;
    }

    private void ModalKapat()
    {
        showTarihModal = false;
        editItem = null;
    }

    private async Task TarihKaydet()
    {
        if (editItem == null) return;
        isTarihKaydediliyor = true;
        try
        {
            var ok = await BelgeUyariService.PersonelBelgeTarihGuncelleAsync(editItem.SoforId, editBelgeAlani, editTarih);
            if (ok)
            {
                // Yerel modeli güncelle
                switch (editBelgeAlani)
                {
                    case "Ehliyet": editItem.EhliyetGecerlilik = editTarih; break;
                    case "Kimlik": editItem.KimlikGecerlilik = editTarih; break;
                    case "Src": editItem.SrcGecerlilik = editTarih; break;
                    case "Psikoteknik": editItem.PsikoteknikGecerlilik = editTarih; break;
                    case "AdliSicil": editItem.AdliSicilGecerlilik = editTarih; break;
                    case "SaglikRaporu": editItem.SaglikRaporuGecerlilik = editTarih; break;
                    case "SuruculCezaBarkod": editItem.SuruculCezaBarkodGecerlilik = editTarih; break;
                }
                ToastService.ShowSuccess($"{editItem.PersonelAdi} – {editBelgeAdi} tarihi güncellendi.");
                ModalKapat();
            }
            else
            {
                ToastService.ShowError("Güncelleme başarısız.");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isTarihKaydediliyor = false;
        }
    }

    // ── Özlük İşlem Modal metodları ──────────────────────────────────────────
    private async Task OzlukIslemAc(PersonelBelgeTabloKalemi item)
    {
        ozlukModalItem = item;
        showOzlukModal = true;
        isOzlukYukleniyor = true;
        StateHasChanged();
        try
        {
            var guncel = await BelgeUyariService.GetTekPersonelBelgeAsync(item.SoforId);
            if (guncel != null)
            {
                item.EvrakDosyalari = guncel.EvrakDosyalari;
                item.ToplamEvrakSayisi = guncel.ToplamEvrakSayisi;
                item.YuklenmisEvrakSayisi = guncel.YuklenmisEvrakSayisi;
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Evrak bilgileri alınamadı: {ex.Message}");
        }
        finally
        {
            isOzlukYukleniyor = false;
            StateHasChanged();
        }
    }

    private void OzlukModalKapat()
    {
        showOzlukModal = false;
        ozlukModalItem = null;
    }

    private void OzlukModalTumunuSec(ChangeEventArgs e)
    {
        if (ozlukModalItem == null) return;
        var secili = (bool)(e.Value ?? false);
        foreach (var d in ozlukModalItem.EvrakDosyalari.Where(x => x.DosyaVar))
            d.Secili = secili;
    }

    private async Task TekDosyaIndir(OzlukEvrakDosyaBilgisi dosya)
    {
        if (string.IsNullOrEmpty(dosya.DosyaYolu)) return;
        try
        {
            var bytes = await SecureFileService.ReadDecryptedAsync(dosya.DosyaYolu);
            if (bytes == null || bytes.Length == 0)
            {
                ToastService.ShowWarning("Dosya okunamadı veya boş.");
                return;
            }
            var uzanti = Path.GetExtension(dosya.DosyaYolu).ToLowerInvariant();
            var contentType = uzanti switch
            {
                ".pdf" => "application/pdf",
                ".jpg" or ".jpeg" => "image/jpeg",
                ".png" => "image/png",
                _ => "application/octet-stream"
            };
            var ad = dosya.DosyaAdi ?? $"{dosya.EvrakAdi}{uzanti}";
            await JS.InvokeVoidAsync("downloadFile", ad, Convert.ToBase64String(bytes), contentType);
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"İndirme hatası: {ex.Message}");
        }
    }

    private async Task OzlukSecilenleriIndir()
    {
        if (ozlukModalItem == null) return;
        var seciliDosyalar = ozlukModalItem.EvrakDosyalari.Where(d => d.Secili && d.DosyaVar).ToList();
        if (!seciliDosyalar.Any()) { ToastService.ShowWarning("Lütfen belge seçin."); return; }
        try
        {
            var seciliYollar = seciliDosyalar.Select(d => d.DosyaYolu!).ToList();
            var zipBytes = await BelgeUyariService.SeciliPersonelBelgelerZipAsync(
                new List<int> { ozlukModalItem.SoforId }, seciliYollar);
            if (zipBytes.Length == 0) { ToastService.ShowWarning("İndirilebilecek belge bulunamadı."); return; }
            var dosyaAdi = seciliDosyalar.Count == 1
                ? (seciliDosyalar[0].DosyaAdi ?? $"{seciliDosyalar[0].EvrakAdi}{Path.GetExtension(seciliDosyalar[0].DosyaYolu ?? "")}") 
                : $"{ozlukModalItem.PersonelKodu}_Belgeler_{DateTime.Now:yyyyMMdd_HHmm}.zip";
            var contentType = seciliDosyalar.Count == 1
                ? Path.GetExtension(seciliDosyalar[0].DosyaYolu ?? "").ToLower() switch
                  { ".pdf" => "application/pdf", ".jpg" or ".jpeg" => "image/jpeg", ".png" => "image/png", _ => "application/octet-stream" }
                : "application/zip";
            await JS.InvokeVoidAsync("downloadFile", dosyaAdi, Convert.ToBase64String(zipBytes), contentType);
            ToastService.ShowSuccess($"{seciliDosyalar.Count} belge indirildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"İndirme hatası: {ex.Message}");
        }
    }

