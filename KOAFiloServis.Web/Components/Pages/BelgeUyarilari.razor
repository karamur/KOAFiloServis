    private static IEnumerable<DateTime> GetTumBelgeTarihleri(PersonelBelgeTabloKalemi p)
    {
        DateTime?[] list = [p.EhliyetGecerlilik, p.KimlikGecerlilik, p.SrcGecerlilik,
            p.PsikoteknikGecerlilik, p.AdliSicilGecerlilik, p.SaglikRaporuGecerlilik, p.SuruculCezaBarkodGecerlilik];
        return list.Where(d => d.HasValue).Select(d => d!.Value);
    }

    private static int GetEksikBelgeSayisi(PersonelBelgeTabloKalemi p)
    {
        DateTime?[] list = [p.EhliyetGecerlilik, p.KimlikGecerlilik, p.SrcGecerlilik,
            p.PsikoteknikGecerlilik, p.AdliSicilGecerlilik, p.SaglikRaporuGecerlilik, p.SuruculCezaBarkodGecerlilik];
        return list.Count(d => !d.HasValue);
    }

