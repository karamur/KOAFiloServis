    private RenderFragment BelgeCelHtml(PersonelBelgeTabloKalemi item, string alan, DateTime? tarih) => builder =>
    {
        var cls = PersonelBelgeTabloKalemi.BelgeDurumClass(tarih);
        var txt = PersonelBelgeTabloKalemi.BelgeDurumMetin(tarih);
        builder.OpenElement(0, "button");
        builder.AddAttribute(1, "class", $"badge {cls} border-0 w-100");
        builder.AddAttribute(2, "style", "cursor:pointer;font-size:0.75rem;");
        builder.AddAttribute(3, "title", $"Düzenle: {alan}");
        builder.AddAttribute(4, "onclick", EventCallback.Factory.Create(this, () =>
            TarihDuzenle(item, alan, GetBelgeAdi(alan), tarih)));
        builder.AddContent(5, txt);
        builder.CloseElement();
    };

