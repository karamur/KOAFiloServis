    private async Task SeciliPersonellerinBelgeleriniIndir()
    {
        if (belgeTablosu == null) return;
        var secili = belgeTablosu.Where(x => x.Secili).ToList();
        if (!secili.Any()) { ToastService.ShowWarning("Lütfen en az bir personel seçin."); return; }

        var dosyasiOlanlar = secili.Where(p => p.YuklenmisEvrakSayisi > 0).ToList();
        if (!dosyasiOlanlar.Any())
        {
            ToastService.ShowWarning("Seçili personellerin yüklenmiş belgesi bulunmamaktadır.");
            return;
        }

        try
        {
            var idler = dosyasiOlanlar.Select(p => p.SoforId).ToList();
            var zipBytes = await BelgeUyariService.SeciliPersonelBelgelerZipAsync(idler);
            if (zipBytes.Length == 0)
            {
                ToastService.ShowWarning("İndirilebilecek belge bulunamadı.");
                return;
            }
            var dosyaAdi = $"PersonelBelgeler_{DateTime.Now:yyyyMMdd_HHmm}.zip";
            await JS.InvokeVoidAsync("downloadFile", dosyaAdi, Convert.ToBase64String(zipBytes), "application/zip");
            ToastService.ShowSuccess($"{dosyasiOlanlar.Count} personelin belgeleri ZIP olarak indirildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"İndirme hatası: {ex.Message}");
        }
    }

    private async Task TabloExcelAktar()
    {
        var liste = FiltrelenmisBelgeTablosu;
        if (!liste.Any()) return;
        // Tüm filtrelenmiş listeyi indirme için seç ve indir
        foreach (var x in liste) x.Secili = true;
        await SeciliPersonellerinBelgeleriniIndir();
        foreach (var x in liste) x.Secili = false;
    }

