@page "/raporlar/yakit-verimlilik"
@attribute [Authorize]
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using Microsoft.AspNetCore.Authorization
@inject IAracService AracService
@inject IAracMasrafService MasrafService
@inject IServisCalismaService ServisService
@inject IJSRuntime JSRuntime
@inject ILogger<YakitVerimlilikRaporu> Logger
@rendermode InteractiveServer

<PageTitle>Yakıt Tüketimi ve Verimlilik Raporu</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">
            <i class="bi bi-fuel-pump me-2 text-warning"></i>Yakıt Tüketimi ve Verimlilik Raporu
        </h3>
        <div class="d-flex gap-2">
            <button class="btn btn-success" @onclick="ExcelExport">
                <i class="bi bi-file-earmark-excel me-1"></i>Excel
            </button>
            <button class="btn btn-outline-secondary" @onclick="LoadDataAsync">
                <i class="bi bi-arrow-clockwise me-1"></i>Yenile
            </button>
        </div>
    </div>

    <!-- Filtreler -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Başlangıç Tarihi</label>
                    <input type="date" class="form-control" @bind="baslangicTarihi" @bind:event="onchange" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Bitiş Tarihi</label>
                    <input type="date" class="form-control" @bind="bitisTarihi" @bind:event="onchange" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Araç</label>
                    <select class="form-select" @bind="seciliAracId">
                        <option value="0">Tüm Araçlar</option>
                        @foreach (var arac in araclar)
                        {
                            <option value="@arac.Id">@arac.AktifPlaka - @arac.Marka @arac.Model</option>
                        }
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-primary w-100" @onclick="LoadDataAsync">
                        <i class="bi bi-search me-1"></i>Filtrele
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else
    {
        <!-- Özet Kartlar -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-warning text-dark h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title mb-1">Toplam Yakıt Gideri</h6>
                                <h3 class="mb-0">@toplamYakitGideri.ToString("N2") ₺</h3>
                            </div>
                            <i class="bi bi-fuel-pump" style="font-size: 2.5rem; opacity: 0.5;"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title mb-1">Toplam KM</h6>
                                <h3 class="mb-0">@toplamKm.ToString("N0") km</h3>
                            </div>
                            <i class="bi bi-speedometer" style="font-size: 2.5rem; opacity: 0.5;"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title mb-1">Ortalama ₺/KM</h6>
                                <h3 class="mb-0">@ortalamaKmMaliyet.ToString("N3") ₺</h3>
                            </div>
                            <i class="bi bi-calculator" style="font-size: 2.5rem; opacity: 0.5;"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-primary text-white h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title mb-1">Analiz Edilen Araç</h6>
                                <h3 class="mb-0">@analizEdilenAracSayisi</h3>
                            </div>
                            <i class="bi bi-truck" style="font-size: 2.5rem; opacity: 0.5;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Grafik Alanı -->
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="bi bi-bar-chart-fill me-2 text-primary"></i>Araç Bazında Yakıt Gideri
                    </div>
                    <div class="card-body">
                        <canvas id="yakitGideriChart" style="max-height: 300px;"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="bi bi-graph-up me-2 text-success"></i>KM Başına Maliyet Karşılaştırması
                    </div>
                    <div class="card-body">
                        <canvas id="kmMaliyetChart" style="max-height: 300px;"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Aylık Trend -->
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-graph-up-arrow me-2 text-info"></i>Aylık Yakıt Gideri Trendi
            </div>
            <div class="card-body">
                <canvas id="aylikTrendChart" style="max-height: 250px;"></canvas>
            </div>
        </div>

        <!-- Detaylı Tablo -->
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-table me-2"></i>Araç Bazında Verimlilik Detayları</span>
                <span class="badge bg-secondary">@verimlilikVerileri.Count araç</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th style="cursor: pointer" @onclick="() => SortBy(nameof(AracVerimlilik.Plaka))">
                                    Plaka
                                    @if (sortColumn == nameof(AracVerimlilik.Plaka))
                                    {
                                        <i class="bi @(sortAscending ? "bi-sort-up" : "bi-sort-down") ms-1"></i>
                                    }
                                </th>
                                <th>Araç</th>
                                <th class="text-end" style="cursor: pointer" @onclick="() => SortBy(nameof(AracVerimlilik.ToplamYakit))">
                                    Yakıt Gideri
                                    @if (sortColumn == nameof(AracVerimlilik.ToplamYakit))
                                    {
                                        <i class="bi @(sortAscending ? "bi-sort-up" : "bi-sort-down") ms-1"></i>
                                    }
                                </th>
                                <th class="text-end" style="cursor: pointer" @onclick="() => SortBy(nameof(AracVerimlilik.ToplamKm))">
                                    Toplam KM
                                    @if (sortColumn == nameof(AracVerimlilik.ToplamKm))
                                    {
                                        <i class="bi @(sortAscending ? "bi-sort-up" : "bi-sort-down") ms-1"></i>
                                    }
                                </th>
                                <th class="text-end" style="cursor: pointer" @onclick="() => SortBy(nameof(AracVerimlilik.KmBasinaMaliyet))">
                                    ₺/KM
                                    @if (sortColumn == nameof(AracVerimlilik.KmBasinaMaliyet))
                                    {
                                        <i class="bi @(sortAscending ? "bi-sort-up" : "bi-sort-down") ms-1"></i>
                                    }
                                </th>
                                <th class="text-end">Sefer Sayısı</th>
                                <th class="text-center">Verimlilik</th>
                                <th>Detay</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in GetSortedData())
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-dark">@item.Plaka</span>
                                    </td>
                                    <td>@item.MarkaModel</td>
                                    <td class="text-end fw-bold text-warning">@item.ToplamYakit.ToString("N2") ₺</td>
                                    <td class="text-end">@item.ToplamKm.ToString("N0") km</td>
                                    <td class="text-end">
                                        <span class="badge @GetMaliyetBadgeClass(item.KmBasinaMaliyet)">
                                            @item.KmBasinaMaliyet.ToString("N3") ₺
                                        </span>
                                    </td>
                                    <td class="text-end">@item.SeferSayisi</td>
                                    <td class="text-center">
                                        @{
                                            var verimlilik = GetVerimlilikDurumu(item.KmBasinaMaliyet);
                                        }
                                        <span class="badge @verimlilik.BadgeClass">
                                            <i class="bi @verimlilik.Icon me-1"></i>@verimlilik.Text
                                        </span>
                                    </td>
                                    <td>
                                        <a href="/araclar/@item.AracId" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        @if (verimlilikVerileri.Any())
                        {
                            <tfoot class="table-light">
                                <tr class="fw-bold">
                                    <td colspan="2">TOPLAM / ORTALAMA</td>
                                    <td class="text-end text-warning">@toplamYakitGideri.ToString("N2") ₺</td>
                                    <td class="text-end">@toplamKm.ToString("N0") km</td>
                                    <td class="text-end">
                                        <span class="badge bg-dark">@ortalamaKmMaliyet.ToString("N3") ₺</span>
                                    </td>
                                    <td class="text-end">@verimlilikVerileri.Sum(v => v.SeferSayisi)</td>
                                    <td colspan="2"></td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>
            </div>
        </div>

        @if (!verimlilikVerileri.Any())
        {
            <div class="alert alert-info mt-4">
                <i class="bi bi-info-circle me-2"></i>
                Seçilen tarih aralığında yakıt masrafı kaydı bulunamadı.
            </div>
        }
    }
</div>

@code {
    private bool isLoading = true;
    private DateTime baslangicTarihi = DateTime.Today.AddMonths(-3);
    private DateTime bitisTarihi = DateTime.Today;
    private int seciliAracId = 0;

    private List<Arac> araclar = new();
    private List<AracVerimlilik> verimlilikVerileri = new();
    private List<AylikYakitTrend> aylikTrendler = new();

    private decimal toplamYakitGideri = 0;
    private decimal toplamKm = 0;
    private decimal ortalamaKmMaliyet = 0;
    private int analizEdilenAracSayisi = 0;

    private string sortColumn = nameof(AracVerimlilik.ToplamYakit);
    private bool sortAscending = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadAraclarAsync();
        await LoadDataAsync();
    }

    private async Task LoadAraclarAsync()
    {
        try
        {
            var result = await AracService.GetAllAsync();
            araclar = result.Where(a => a.Aktif).OrderBy(a => a.AktifPlaka).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Araçlar yüklenirken hata");
        }
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        try
        {
            verimlilikVerileri.Clear();
            aylikTrendler.Clear();

            // Yakıt masraflarını getir
            var yakitMasraflar = await MasrafService.GetByKategoriAsync(
                MasrafKategori.Yakit, 
                baslangicTarihi, 
                bitisTarihi);

            if (seciliAracId > 0)
            {
                yakitMasraflar = yakitMasraflar.Where(m => m.AracId == seciliAracId).ToList();
            }

            // Servis çalışmalarından KM bilgisini al
            var servisler = await ServisService.GetByDateRangeAsync(baslangicTarihi, bitisTarihi);

            if (seciliAracId > 0)
            {
                servisler = servisler.Where(s => s.AracId == seciliAracId).ToList();
            }

            // Araç bazında gruplama
            var aracGruplar = yakitMasraflar
                .GroupBy(m => m.AracId)
                .ToList();

            foreach (var grup in aracGruplar)
            {
                var arac = araclar.FirstOrDefault(a => a.Id == grup.Key);
                if (arac == null) continue;

                var aracServisler = servisler.Where(s => s.AracId == grup.Key).ToList();
                var toplamAracKm = aracServisler
                    .Where(s => s.KmBitis.HasValue && s.KmBaslangic.HasValue)
                    .Sum(s => (s.KmBitis ?? 0) - (s.KmBaslangic ?? 0));

                verimlilikVerileri.Add(new AracVerimlilik
                {
                    AracId = grup.Key,
                    Plaka = arac.AktifPlaka ?? "Plaka Yok",
                    MarkaModel = $"{arac.Marka} {arac.Model}",
                    ToplamYakit = grup.Sum(m => m.Tutar),
                    ToplamKm = toplamAracKm,
                    SeferSayisi = aracServisler.Count,
                    KmBasinaMaliyet = toplamAracKm > 0 
                        ? grup.Sum(m => m.Tutar) / toplamAracKm 
                        : 0
                });
            }

            // Aylık trend hesapla
            aylikTrendler = yakitMasraflar
                .GroupBy(m => new { m.MasrafTarihi.Year, m.MasrafTarihi.Month })
                .OrderBy(g => g.Key.Year).ThenBy(g => g.Key.Month)
                .Select(g => new AylikYakitTrend
                {
                    Ay = new DateTime(g.Key.Year, g.Key.Month, 1).ToString("MMM yyyy"),
                    Tutar = g.Sum(m => m.Tutar)
                })
                .ToList();

            // Özet değerler
            toplamYakitGideri = verimlilikVerileri.Sum(v => v.ToplamYakit);
            toplamKm = verimlilikVerileri.Sum(v => v.ToplamKm);
            ortalamaKmMaliyet = toplamKm > 0 ? toplamYakitGideri / toplamKm : 0;
            analizEdilenAracSayisi = verimlilikVerileri.Count;

            isLoading = false;
            StateHasChanged();

            // Grafikleri render et
            await Task.Delay(100);
            await RenderChartsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Yakıt verimlilik verileri yüklenirken hata");
            isLoading = false;
        }
    }

    private async Task RenderChartsAsync()
    {
        try
        {
            // Yakıt gideri bar chart
            var yakitLabels = verimlilikVerileri.OrderByDescending(v => v.ToplamYakit).Take(10).Select(v => v.Plaka).ToArray();
            var yakitData = verimlilikVerileri.OrderByDescending(v => v.ToplamYakit).Take(10).Select(v => v.ToplamYakit).ToArray();

            await JSRuntime.InvokeVoidAsync("renderBarChart", "yakitGideriChart", yakitLabels, yakitData, "Yakıt Gideri (₺)", "#ffc107");

            // KM başına maliyet chart
            var kmLabels = verimlilikVerileri.Where(v => v.KmBasinaMaliyet > 0).OrderByDescending(v => v.KmBasinaMaliyet).Take(10).Select(v => v.Plaka).ToArray();
            var kmData = verimlilikVerileri.Where(v => v.KmBasinaMaliyet > 0).OrderByDescending(v => v.KmBasinaMaliyet).Take(10).Select(v => v.KmBasinaMaliyet).ToArray();

            await JSRuntime.InvokeVoidAsync("renderBarChart", "kmMaliyetChart", kmLabels, kmData, "₺/KM Maliyet", "#28a745");

            // Aylık trend line chart
            var trendLabels = aylikTrendler.Select(t => t.Ay).ToArray();
            var trendData = aylikTrendler.Select(t => t.Tutar).ToArray();

            await JSRuntime.InvokeVoidAsync("renderLineChart", "aylikTrendChart", trendLabels, trendData, "Aylık Yakıt Gideri", "#17a2b8");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Grafik render hatası");
        }
    }

    private void SortBy(string column)
    {
        if (sortColumn == column)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
    }

    private IEnumerable<AracVerimlilik> GetSortedData()
    {
        return sortColumn switch
        {
            nameof(AracVerimlilik.Plaka) => sortAscending 
                ? verimlilikVerileri.OrderBy(v => v.Plaka) 
                : verimlilikVerileri.OrderByDescending(v => v.Plaka),
            nameof(AracVerimlilik.ToplamYakit) => sortAscending 
                ? verimlilikVerileri.OrderBy(v => v.ToplamYakit) 
                : verimlilikVerileri.OrderByDescending(v => v.ToplamYakit),
            nameof(AracVerimlilik.ToplamKm) => sortAscending 
                ? verimlilikVerileri.OrderBy(v => v.ToplamKm) 
                : verimlilikVerileri.OrderByDescending(v => v.ToplamKm),
            nameof(AracVerimlilik.KmBasinaMaliyet) => sortAscending 
                ? verimlilikVerileri.OrderBy(v => v.KmBasinaMaliyet) 
                : verimlilikVerileri.OrderByDescending(v => v.KmBasinaMaliyet),
            _ => verimlilikVerileri.OrderByDescending(v => v.ToplamYakit)
        };
    }

    private string GetMaliyetBadgeClass(decimal maliyet)
    {
        if (maliyet == 0) return "bg-secondary";
        if (maliyet < 1.5m) return "bg-success";
        if (maliyet < 2.5m) return "bg-warning text-dark";
        return "bg-danger";
    }

    private (string BadgeClass, string Icon, string Text) GetVerimlilikDurumu(decimal kmMaliyet)
    {
        if (kmMaliyet == 0) return ("bg-secondary", "bi-dash", "Veri Yok");
        if (kmMaliyet < 1.5m) return ("bg-success", "bi-check-circle-fill", "Verimli");
        if (kmMaliyet < 2.0m) return ("bg-info", "bi-info-circle-fill", "Normal");
        if (kmMaliyet < 2.5m) return ("bg-warning text-dark", "bi-exclamation-circle-fill", "Dikkat");
        return ("bg-danger", "bi-x-circle-fill", "Verimsiz");
    }

    private async Task ExcelExport()
    {
        try
        {
            var csvContent = "Plaka;Marka/Model;Yakıt Gideri;Toplam KM;TL/KM;Sefer Sayısı;Verimlilik\n";

            foreach (var item in GetSortedData())
            {
                var verimlilik = GetVerimlilikDurumu(item.KmBasinaMaliyet);
                csvContent += $"{item.Plaka};{item.MarkaModel};{item.ToplamYakit:N2};{item.ToplamKm:N0};{item.KmBasinaMaliyet:N3};{item.SeferSayisi};{verimlilik.Text}\n";
            }

            var fileName = $"YakitVerimlilik_{baslangicTarihi:yyyyMMdd}_{bitisTarihi:yyyyMMdd}.csv";
            var bytes = System.Text.Encoding.UTF8.GetBytes(csvContent);
            var base64 = Convert.ToBase64String(bytes);

            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, "text/csv", base64);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Excel export hatası");
        }
    }

    private class AracVerimlilik
    {
        public int AracId { get; set; }
        public string Plaka { get; set; } = "";
        public string MarkaModel { get; set; } = "";
        public decimal ToplamYakit { get; set; }
        public decimal ToplamKm { get; set; }
        public int SeferSayisi { get; set; }
        public decimal KmBasinaMaliyet { get; set; }
    }

    private class AylikYakitTrend
    {
        public string Ay { get; set; } = "";
        public decimal Tutar { get; set; }
    }
}
