@page "/fatura-hazirlik"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Models
@using KOAFiloServis.Web.Services
@inject IFaturaHazirlikService FaturaHazirlikService
@inject ICariService CariService
@inject IFaturaService FaturaService
@inject IToastService ToastService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Fatura Hazirlik Listesi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-file-earmark-text me-2"></i>Fatura Hazirlik Listesi</h3>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary" @onclick="TaslakListeAc">
                <i class="bi bi-file-earmark-plus me-1"></i>Taslaklar (@taslakFaturalar.Count)
            </button>
        </div>
    </div>

    <!-- Gelismis Filtreler -->
    <div class="card mb-4">
        <div class="card-header bg-primary text-white py-2">
            <i class="bi bi-funnel me-2"></i>Filtreler
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-2">
                    <label class="form-label">Fatura Tipi</label>
                    <select class="form-select" @bind="filtreFaturaYonu">
                        <option value="">Tumu</option>
                        <option value="1">Gelir (Giden Fatura)</option>
                        <option value="2">Gider (Gelen Fatura)</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Yil</label>
                    <select class="form-select" @bind="filtreYil" @bind:after="YilAyDegisti">
                        @for (int y = DateTime.Today.Year; y >= DateTime.Today.Year - 5; y--)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Ay</label>
                    <select class="form-select" @bind="filtreAy" @bind:after="YilAyDegisti">
                        <option value="0">Tum Yil</option>
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m">@GetAyAdi(m)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Baslangic</label>
                    <input type="date" class="form-control" @bind="baslangicTarihi" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Bitis</label>
                    <input type="date" class="form-control" @bind="bitisTarihi" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Arama</label>
                    <input type="text" class="form-control" placeholder="Fatura No / Cari" @bind="aramaMetni" />
                </div>
            </div>
            <div class="row g-3 mt-1">
                <div class="col-md-3">
                    <label class="form-label">Cari / Musteri</label>
                    <select class="form-select" @bind="secilenCariId">
                        <option value="">-- Tum Cariler --</option>
                        @foreach (var cari in cariler)
                        {
                            <option value="@cari.Id">@cari.Unvan</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Vergi No / TC</label>
                    <input type="text" class="form-control" placeholder="Vergi/TC No" @bind="filtreVergiNo" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Vergi Dairesi</label>
                    <input type="text" class="form-control" placeholder="Vergi Dairesi" @bind="filtreVergiDairesi" />
                </div>
                <div class="col-md-3 d-flex align-items-end gap-2">
                    <button class="btn btn-primary" @onclick="Listele">
                        <i class="bi bi-search me-1"></i>Ara
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="FiltreTemizle">
                        <i class="bi bi-x-lg me-1"></i>Temizle
                    </button>
                    <button class="btn btn-outline-success" @onclick="HazirlikListele">
                        <i class="bi bi-calculator me-1"></i>Hazirlik
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (showFaturaList && filtreliFaturalar != null)
    {
        <!-- Fatura Listesi -->
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="bi bi-list-ul me-2"></i>Faturalar (@filtreliFaturalar.Count adet)
                </h5>
                <div>
                    <span class="badge bg-success fs-6 me-2">Gelir: @FormatPara(filtreliFaturalar.Where(f => f.FaturaYonu == FaturaYonu.Giden).Sum(f => f.GenelToplam))</span>
                    <span class="badge bg-danger fs-6">Gider: @FormatPara(filtreliFaturalar.Where(f => f.FaturaYonu == FaturaYonu.Gelen).Sum(f => f.GenelToplam))</span>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>Fatura No</th>
                                <th>Tarih</th>
                                <th>Cari / Unvan</th>
                                <th>Vergi No</th>
                                <th>Vergi Dairesi</th>
                                <th class="text-center">Tip</th>
                                <th class="text-end">Tutar</th>
                                <th class="text-center">Durum</th>
                                <th class="text-center">Islem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var fatura in filtreliFaturalar)
                            {
                                <tr @ondblclick="() => HizliDetayAc(fatura)" style="cursor: pointer;" title="Detay icin cift tikla">
                                    <td><strong>@fatura.FaturaNo</strong></td>
                                    <td>@fatura.FaturaTarihi.ToString("dd.MM.yyyy")</td>
                                    <td>@fatura.Cari?.Unvan</td>
                                    <td>@fatura.Cari?.VergiNo</td>
                                    <td>@fatura.Cari?.VergiDairesi</td>
                                    <td class="text-center">
                                        @if (fatura.FaturaYonu == FaturaYonu.Giden)
                                        {
                                            <span class="badge bg-success">Gelir</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Gider</span>
                                        }
                                    </td>
                                    <td class="text-end @(fatura.FaturaYonu == FaturaYonu.Giden ? "text-success" : "text-danger")">
                                        <strong>@FormatPara(fatura.GenelToplam)</strong>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @GetDurumClass(fatura.Durum)">@GetDurumAdi(fatura.Durum)</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary" @onclick="() => HizliDetayAc(fatura)" title="Duzenle">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            <button class="btn btn-outline-danger" @onclick="() => FaturaSilOnay(fatura)" title="Sil">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else if (liste != null)
    {
        <!-- Ozet Kartlari -->
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <h6 class="card-title">Kesilecek Faturalar (Gelir)</h6>
                        <h3>@FormatPara(liste.ToplamKesilecekTutar)</h3>
                        <small>@liste.KesilecekFaturalar.Count musteri, @liste.KesilecekFaturalar.Sum(x => x.ToplamSeferSayisi) sefer</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-danger text-white">
                    <div class="card-body">
                        <h6 class="card-title">Gelecek Faturalar (Gider)</h6>
                        <h3>@FormatPara(liste.ToplamGelecekTutar)</h3>
                        <small>@liste.GelecekFaturalar.Count tedarikci</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card @(liste.NetKar >= 0 ? "bg-primary" : "bg-warning") text-white">
                    <div class="card-body">
                        <h6 class="card-title">Net Kar/Zarar</h6>
                        <h3>@FormatPara(liste.NetKar)</h3>
                        <small>@liste.BaslangicTarihi.ToString("dd.MM.yyyy") - @liste.BitisTarihi.ToString("dd.MM.yyyy")</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Kesilecek Faturalar -->
        <div class="card mb-4">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">
                    <i class="bi bi-arrow-up-circle me-2"></i>
                    Kesilecek Faturalar (Satis - Musterilerden Alinacak)
                </h5>
            </div>
            <div class="card-body">
                @if (!liste.KesilecekFaturalar.Any())
                {
                    <div class="alert alert-info">Bu donemde kesilecek fatura bulunmamaktadir.</div>
                }
                else
                {
                    <div class="accordion" id="kesilecekFaturalar">
                        @foreach (var fatura in liste.KesilecekFaturalar)
                        {
                            var accordionId = $"kesil_{fatura.CariId}";
                            <div class="accordion-item">
                                <h2 class="accordion-header">
                                    <button class="accordion-button collapsed" type="button" 
                                            data-bs-toggle="collapse" data-bs-target="#@accordionId">
                                        <div class="d-flex justify-content-between w-100 me-3">
                                            <span>
                                                <strong>@fatura.CariUnvan</strong>
                                                <span class="badge bg-secondary ms-2">@fatura.CariKodu</span>
                                            </span>
                                            <span>
                                                <span class="badge bg-info">@fatura.ToplamSeferSayisi sefer</span>
                                                <strong class="text-success ms-2">@FormatPara(fatura.ToplamTutar)</strong>
                                            </span>
                                        </div>
                                    </button>
                                </h2>
                                <div id="@accordionId" class="accordion-collapse collapse" data-bs-parent="#kesilecekFaturalar">
                                    <div class="accordion-body">
                                        <table class="table table-sm table-striped">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Guzergah</th>
                                                    <th>Baslangic - Bitis</th>
                                                    <th class="text-center">Sefer</th>
                                                    <th class="text-end">Birim Fiyat</th>
                                                    <th class="text-end">Toplam</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var detay in fatura.Detaylar)
                                                {
                                                    <tr>
                                                        <td>
                                                            <strong>@detay.GuzergahAdi</strong>
                                                            <br /><small class="text-muted">@detay.GuzergahKodu</small>
                                                        </td>
                                                        <td>@detay.BaslangicNoktasi - @detay.BitisNoktasi</td>
                                                        <td class="text-center">@detay.SeferSayisi</td>
                                                        <td class="text-end">@FormatPara(detay.BirimFiyat)</td>
                                                        <td class="text-end"><strong>@FormatPara(detay.ToplamTutar)</strong></td>
                                                    </tr>
                                                }
                                            </tbody>
                                            <tfoot class="table-success">
                                                <tr>
                                                    <th colspan="4">TOPLAM</th>
                                                    <th class="text-end">@FormatPara(fatura.ToplamTutar)</th>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Gelecek Faturalar -->
        <div class="card mb-4">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">
                    <i class="bi bi-arrow-down-circle me-2"></i>
                    Gelecek Faturalar (Alis - Tedarikcilere Odenecek)
                </h5>
            </div>
            <div class="card-body">
                @if (!liste.GelecekFaturalar.Any())
                {
                    <div class="alert alert-info">Bu donemde gelecek fatura bulunmamaktadir.</div>
                }
                else
                {
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Tedarikci</th>
                                <th>Tip</th>
                                <th class="text-center">Sefer</th>
                                <th class="text-end">Tutar</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var fatura in liste.GelecekFaturalar)
                            {
                                <tr>
                                    <td><strong>@fatura.CariUnvan</strong></td>
                                    <td>
                                        @if (fatura.FaturaTipi == GelecekFaturaTipi.AracKirasi)
                                        {
                                            <span class="badge bg-warning text-dark">Arac Kirasi</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info">Komisyon</span>
                                        }
                                    </td>
                                    <td class="text-center">@fatura.ToplamSeferSayisi</td>
                                    <td class="text-end text-danger"><strong>@FormatPara(fatura.ToplamTutar)</strong></td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-danger">
                            <tr>
                                <th colspan="3">TOPLAM GIDER</th>
                                <th class="text-end">@FormatPara(liste.ToplamGelecekTutar)</th>
                            </tr>
                        </tfoot>
                    </table>
                }
            </div>
        </div>
    }
</div>

<!-- Hizli Detay / Duzenleme Modal -->
@if (showDetayModal && editFatura != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-pencil-square me-2"></i>Fatura Detay / Duzenleme</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Fatura No *</label>
                            <input type="text" class="form-control" @bind="editFatura.FaturaNo" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Fatura Tarihi *</label>
                            <input type="date" class="form-control" @bind="editFatura.FaturaTarihi" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Vade Tarihi</label>
                            <input type="date" class="form-control" @bind="editFatura.VadeTarihi" />
                        </div>
                    </div>
                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label class="form-label">Cari *</label>
                            <select class="form-select" @bind="editFatura.CariId">
                                <option value="0">Secin...</option>
                                @foreach (var cari in cariler)
                                {
                                    <option value="@cari.Id">@cari.Unvan</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">E-Fatura Tipi</label>
                            <select class="form-select" @bind="editFatura.EFaturaTipi">
                                <option value="@EFaturaTipi.EFatura">E-Fatura</option>
                                <option value="@EFaturaTipi.EArsiv">E-Arsiv</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Durum</label>
                            <select class="form-select" @bind="editFatura.Durum">
                                <option value="@FaturaDurum.Beklemede">Beklemede</option>
                                <option value="@FaturaDurum.KismiOdendi">Kismi Odendi</option>
                                <option value="@FaturaDurum.Odendi">Odendi</option>
                            </select>
                        </div>
                    </div>
                    <div class="row g-3 mt-1">
                        <div class="col-md-4">
                            <label class="form-label">Ara Toplam</label>
                            <div class="input-group">
                                <input type="number" class="form-control" @bind="editFatura.AraToplam" step="0.01" />
                                <span class="input-group-text">TL</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">KDV Tutar</label>
                            <div class="input-group">
                                <input type="number" class="form-control" @bind="editFatura.KdvTutar" step="0.01" />
                                <span class="input-group-text">TL</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Genel Toplam *</label>
                            <div class="input-group">
                                <input type="number" class="form-control" @bind="editFatura.GenelToplam" step="0.01" />
                                <span class="input-group-text">TL</span>
                            </div>
                        </div>
                    </div>
                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label class="form-label">ETTN No</label>
                            <input type="text" class="form-control" @bind="editFatura.EttnNo" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Aciklama</label>
                            <input type="text" class="form-control" @bind="editFatura.Aciklama" />
                        </div>
                    </div>

                    <!-- Cari Bilgileri (Salt Okunur) -->
                    @if (editFatura.Cari != null)
                    {
                        <div class="card mt-3 bg-light">
                            <div class="card-body py-2">
                                <h6 class="card-title mb-2"><i class="bi bi-building me-1"></i>Cari Bilgileri</h6>
                                <div class="row">
                                    <div class="col-md-4"><small class="text-muted">Unvan:</small><br /><strong>@editFatura.Cari.Unvan</strong></div>
                                    <div class="col-md-4"><small class="text-muted">Vergi No:</small><br /><strong>@editFatura.Cari.VergiNo</strong></div>
                                    <div class="col-md-4"><small class="text-muted">Vergi Dairesi:</small><br /><strong>@editFatura.Cari.VergiDairesi</strong></div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button type="button" class="btn btn-primary" @onclick="FaturaKaydet" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Silme Onay Modal -->
@if (showSilModal && silinecekFatura != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-trash me-2"></i>Fatura Silme Onayi</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body text-center">
                    <h5>Fatura silinecek!</h5>
                    <p class="text-muted">Bu islemi geri alamazsiniz.</p>
                    <div class="d-flex justify-content-center gap-2">
                        <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                        <button type="button" class="btn btn-danger" @onclick="FaturaSil">
                            <i class="bi bi-trash"></i> Sil
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // Filtreler
    private DateTime baslangicTarihi = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime bitisTarihi = DateTime.Today;
    private int? secilenCariId;
    private string filtreFaturaYonu = "";
    private int filtreYil = DateTime.Today.Year;
    private int filtreAy = DateTime.Today.Month;
    private string aramaMetni = "";
    private string filtreVergiNo = "";
    private string filtreVergiDairesi = "";

    // Data
    private List<Cari> cariler = new();
    private List<Fatura> tumFaturalar = new();
    private List<Fatura> filtreliFaturalar = new();
    private FaturaHazirlikListesi? liste;
    private List<Fatura> taslakFaturalar = new();
    
    // Duzenleme
    private Fatura? editFatura;
    private bool showDetayModal = false;
    private bool isSaving = false;
    
    // Silme
    private bool showSilModal = false;
    private Fatura? silinecekFatura;

    // State
    private bool isLoading = false;
    private bool showFaturaList = false;

    protected override async Task OnInitializedAsync()
    {
        cariler = await CariService.GetAllAsync();
        await YenileAsync();
    }

    private async Task YenileAsync()
    {
        tumFaturalar = await FaturaService.GetAllAsync();
    }

    private void YilAyDegisti()
    {
        if (filtreAy > 0)
        {
            baslangicTarihi = new DateTime(filtreYil, filtreAy, 1);
            bitisTarihi = baslangicTarihi.AddMonths(1).AddDays(-1);
        }
        else
        {
            baslangicTarihi = new DateTime(filtreYil, 1, 1);
            bitisTarihi = new DateTime(filtreYil, 12, 31);
        }
    }

    private void Listele()
    {
        isLoading = true;
        showFaturaList = true;
        liste = null;

        try
        {
            var filtered = tumFaturalar.AsEnumerable();

            filtered = filtered.Where(f => f.FaturaTarihi >= baslangicTarihi && f.FaturaTarihi <= bitisTarihi);

            if (!string.IsNullOrEmpty(filtreFaturaYonu) && int.TryParse(filtreFaturaYonu, out var yonu))
                filtered = filtered.Where(f => (int)f.FaturaYonu == yonu);

            if (secilenCariId.HasValue && secilenCariId > 0)
                filtered = filtered.Where(f => f.CariId == secilenCariId.Value);

            if (!string.IsNullOrEmpty(aramaMetni))
                filtered = filtered.Where(f =>
                    f.FaturaNo.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ||
                    (f.Cari?.Unvan?.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ?? false));

            if (!string.IsNullOrEmpty(filtreVergiNo))
                filtered = filtered.Where(f =>
                    (f.Cari?.VergiNo?.Contains(filtreVergiNo, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (f.Cari?.TcKimlikNo?.Contains(filtreVergiNo, StringComparison.OrdinalIgnoreCase) ?? false));

            if (!string.IsNullOrEmpty(filtreVergiDairesi))
                filtered = filtered.Where(f =>
                    f.Cari?.VergiDairesi?.Contains(filtreVergiDairesi, StringComparison.OrdinalIgnoreCase) ?? false);

            filtreliFaturalar = filtered.OrderByDescending(f => f.FaturaTarihi).ToList();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HazirlikListele()
    {
        isLoading = true;
        showFaturaList = false;
        filtreliFaturalar = new();

        try
        {
            liste = await FaturaHazirlikService.GetFaturaHazirlikListesiAsync(
                baslangicTarihi, bitisTarihi, secilenCariId);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void FiltreTemizle()
    {
        filtreYil = DateTime.Today.Year;
        filtreAy = DateTime.Today.Month;
        baslangicTarihi = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        bitisTarihi = DateTime.Today;
        secilenCariId = null;
        filtreFaturaYonu = "";
        aramaMetni = "";
        filtreVergiNo = "";
        filtreVergiDairesi = "";
        showFaturaList = false;
        liste = null;
        filtreliFaturalar = new();
    }

    private void HizliDetayAc(Fatura fatura)
    {
        editFatura = new Fatura
        {
            Id = fatura.Id,
            FaturaNo = fatura.FaturaNo,
            FaturaTarihi = fatura.FaturaTarihi,
            VadeTarihi = fatura.VadeTarihi,
            CariId = fatura.CariId,
            Cari = fatura.Cari,
            EFaturaTipi = fatura.EFaturaTipi,
            FaturaYonu = fatura.FaturaYonu,
            FaturaTipi = fatura.FaturaTipi,
            AraToplam = fatura.AraToplam,
            KdvTutar = fatura.KdvTutar,
            GenelToplam = fatura.GenelToplam,
            OdenenTutar = fatura.OdenenTutar,
            EttnNo = fatura.EttnNo,
            Aciklama = fatura.Aciklama,
            Durum = fatura.Durum
        };
        showDetayModal = true;
    }

    private async Task FaturaKaydet()
    {
        if (editFatura == null || string.IsNullOrWhiteSpace(editFatura.FaturaNo) || editFatura.CariId <= 0)
        {
            ToastService.ShowWarning("Fatura No ve Cari zorunludur!");
            return;
        }

        isSaving = true;
        StateHasChanged();

        try
        {
            editFatura.FaturaTarihi = DateTime.SpecifyKind(editFatura.FaturaTarihi, DateTimeKind.Utc);
            if (editFatura.VadeTarihi.HasValue)
                editFatura.VadeTarihi = DateTime.SpecifyKind(editFatura.VadeTarihi.Value, DateTimeKind.Utc);

            await FaturaService.UpdateAsync(editFatura);
            ToastService.ShowSuccess("Fatura guncellendi.");
            
            ModalKapat();
            await YenileAsync();
            Listele(); // Listeyi yenile
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private void ModalKapat()
    {
        showDetayModal = false;
        showSilModal = false;
        editFatura = null;
        silinecekFatura = null;
    }

    private void FaturaSilOnay(Fatura fatura)
    {
        silinecekFatura = fatura;
        showSilModal = true;
    }

    private async Task FaturaSil()
    {
        if (silinecekFatura == null) return;

        try
        {
            await FaturaService.DeleteAsync(silinecekFatura.Id);
            ToastService.ShowSuccess("Fatura silindi.");
            showSilModal = false;
            silinecekFatura = null;
            await YenileAsync();
            Listele();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private void TaslakListeAc()
    {
        // Taslaklar sayfasina yonlendirme
        Navigation.NavigateTo("/fatura-taslaklari");
    }

    private string FormatPara(decimal tutar) => tutar.ToString("N2", new System.Globalization.CultureInfo("tr-TR")) + " TL";

    private string GetAyAdi(int ay) => ay switch
    {
        1 => "Ocak", 2 => "Subat", 3 => "Mart", 4 => "Nisan",
        5 => "Mayis", 6 => "Haziran", 7 => "Temmuz", 8 => "Agustos",
        9 => "Eylul", 10 => "Ekim", 11 => "Kasim", 12 => "Aralik",
        _ => ""
    };

    private string GetDurumClass(FaturaDurum durum) => durum switch
    {
        FaturaDurum.Beklemede => "bg-warning text-dark",
        FaturaDurum.KismiOdendi => "bg-info",
        FaturaDurum.Odendi => "bg-success",
        FaturaDurum.IptalEdildi => "bg-secondary",
        _ => "bg-secondary"
    };

    private string GetDurumAdi(FaturaDurum durum) => durum switch
    {
        FaturaDurum.Beklemede => "Beklemede",
        FaturaDurum.KismiOdendi => "Kismi Odendi",
        FaturaDurum.Odendi => "Odendi",
        FaturaDurum.IptalEdildi => "Iptal",
        _ => durum.ToString()
    };
