@page "/hakedis-tablosu"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using Microsoft.AspNetCore.Authorization
@inject IHakedisService HakedisService
@inject ICariService CariService
@inject IGuzergahService GuzergahService
@inject IToastService ToastService
@inject NavigationManager NavigationManager
@attribute [Authorize]

<PageTitle>Hakedis Tablosu</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="bi bi-table me-2"></i>Hakedis/Puantaj Tablosu</h2>
            <p class="text-muted mb-0">Aylık hakedis kayıtlarını görüntüle ve düzenle</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/hakedis-excel-import" class="btn btn-success">
                <i class="bi bi-file-earmark-excel me-1"></i> Excel Import
            </a>
            <button class="btn btn-primary" @onclick="YeniKayit">
                <i class="bi bi-plus-lg me-1"></i> Yeni Kayıt
            </button>
        </div>
    </div>

    <!-- Dönem ve Filtreler -->
    <div class="card mb-4">
        <div class="card-body py-3">
            <div class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small">Yıl</label>
                    <select class="form-select form-select-sm" @bind="filterYil" @bind:after="LoadData">
                        @for (int y = DateTime.Now.Year + 1; y >= 2020; y--)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Ay</label>
                    <select class="form-select form-select-sm" @bind="filterAy" @bind:after="LoadData">
                        <option value="1">Ocak</option>
                        <option value="2">Şubat</option>
                        <option value="3">Mart</option>
                        <option value="4">Nisan</option>
                        <option value="5">Mayıs</option>
                        <option value="6">Haziran</option>
                        <option value="7">Temmuz</option>
                        <option value="8">Ağustos</option>
                        <option value="9">Eylül</option>
                        <option value="10">Ekim</option>
                        <option value="11">Kasım</option>
                        <option value="12">Aralık</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Kurum</label>
                    <select class="form-select form-select-sm" @bind="filterKurumId" @bind:after="ApplyFilter">
                        <option value="">Tümü</option>
                        @foreach (var kurum in kurumlar)
                        {
                            <option value="@kurum.Id">@kurum.Unvan</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Fatura Durumu</label>
                    <select class="form-select form-select-sm" @bind="filterFaturaDurum" @bind:after="ApplyFilter">
                        <option value="">Tümü</option>
                        <option value="faturasiz_gelir">Faturasız Gelir</option>
                        <option value="faturasiz_gider">Faturasız Gider</option>
                        <option value="odenmemis_gelir">Ödenmemiş Gelir</option>
                        <option value="odenmemis_gider">Ödenmemiş Gider</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <button class="btn btn-outline-secondary btn-sm w-100" @onclick="ClearFilter">
                        <i class="bi bi-x-lg"></i> Temizle
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- İstatistikler -->
    @if (istatistikler != null)
    {
        <div class="row mb-4">
            <div class="col-lg-2 col-md-4 col-6 mb-2">
                <div class="card bg-primary text-white">
                    <div class="card-body py-2 text-center">
                        <h4 class="mb-0">@istatistikler.ToplamKayit</h4>
                        <small>Toplam Kayıt</small>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6 mb-2">
                <div class="card bg-success text-white">
                    <div class="card-body py-2 text-center">
                        <h4 class="mb-0">@istatistikler.ToplamAlinacak.ToString("N0") ₺</h4>
                        <small>Alınacak</small>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6 mb-2">
                <div class="card bg-danger text-white">
                    <div class="card-body py-2 text-center">
                        <h4 class="mb-0">@istatistikler.ToplamOdenecek.ToString("N0") ₺</h4>
                        <small>Ödenecek</small>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6 mb-2">
                <div class="card @(istatistikler.ToplamFark >= 0 ? "bg-success" : "bg-danger") text-white">
                    <div class="card-body py-2 text-center">
                        <h4 class="mb-0">@istatistikler.ToplamFark.ToString("N0") ₺</h4>
                        <small>Fark (Kar/Zarar)</small>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6 mb-2">
                <div class="card bg-warning text-dark">
                    <div class="card-body py-2 text-center">
                        <h4 class="mb-0">@istatistikler.FaturasizGelir / @istatistikler.FaturasizGider</h4>
                        <small>Faturasız G/Ç</small>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6 mb-2">
                <div class="card bg-secondary text-white">
                    <div class="card-body py-2 text-center">
                        <h4 class="mb-0">@istatistikler.OdenmemisGelir / @istatistikler.OdenmemisGider</h4>
                        <small>Ödenmemiş G/Ç</small>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Toplu İşlemler -->
    @if (seciliIdler.Any())
    {
        <div class="alert alert-info d-flex justify-content-between align-items-center mb-4">
            <span><strong>@seciliIdler.Count</strong> kayıt seçildi</span>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-success" @onclick="TopluOnayla">
                    <i class="bi bi-check-all me-1"></i> Toplu Onayla
                </button>
                <button class="btn btn-sm btn-primary" @onclick="() => showTopluFaturaModal = true">
                    <i class="bi bi-receipt me-1"></i> Fatura İşaretle
                </button>
                <button class="btn btn-sm btn-warning" @onclick="() => showTopluOdemeModal = true">
                    <i class="bi bi-cash me-1"></i> Ödeme İşaretle
                </button>
                <button class="btn btn-sm btn-outline-secondary" @onclick="() => seciliIdler.Clear()">
                    <i class="bi bi-x-lg"></i> Seçimi Kaldır
                </button>
            </div>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else
    {
        <!-- Hakedis Tablosu -->
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover table-striped mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th width="40">
                                    <input type="checkbox" class="form-check-input" 
                                           @onchange="ToggleTumunuSec" 
                                           checked="@(filteredKayitlar.Any() && filteredKayitlar.All(k => seciliIdler.Contains(k.Id)))" />
                                </th>
                                <th>Kurum</th>
                                <th>Güzergah</th>
                                <th>Yön</th>
                                <th>Plaka</th>
                                <th>Şoför</th>
                                <th>Fatura Kesici</th>
                                <th class="text-end">Gün</th>
                                <th class="text-end">Gelir</th>
                                <th class="text-end">Alınacak</th>
                                <th class="text-end">Gider</th>
                                <th class="text-end">Ödenecek</th>
                                <th class="text-end">Fark</th>
                                <th class="text-center">Gelir Fat.</th>
                                <th class="text-center">Gider Fat.</th>
                                <th class="text-center">Gelir Öd.</th>
                                <th class="text-center">Gider Öd.</th>
                                <th width="100">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var kayit in filteredKayitlar)
                            {
                                <tr @onclick="() => ToggleSecim(kayit.Id)" style="cursor: pointer;">
                                    <td @onclick:stopPropagation="true">
                                        <input type="checkbox" class="form-check-input" 
                                               checked="@seciliIdler.Contains(kayit.Id)" 
                                               @onchange="() => ToggleSecim(kayit.Id)" />
                                    </td>
                                    <td>@(kayit.KurumCari?.Unvan ?? kayit.KurumAdi)</td>
                                    <td>@(kayit.Guzergah?.GuzergahAdi ?? kayit.GuzergahAdi)</td>
                                    <td>
                                        <span class="badge @GetYonBadge(kayit.Yon)">@GetYonText(kayit.Yon)</span>
                                    </td>
                                    <td>@kayit.Plaka</td>
                                    <td>
                                        @(kayit.Sofor?.TamAd ?? kayit.SoforAdi)
                                        @if (kayit.SoforOdemeTipi != SoforOdemeTipi.Ozmal)
                                        {
                                            <span class="badge bg-info ms-1" title="@kayit.SoforOdemeTipi">
                                                <i class="bi bi-building"></i>
                                            </span>
                                        }
                                    </td>
                                    <td>@(kayit.FaturaKesiciCari?.Unvan ?? kayit.FaturaKesiciAdi)</td>
                                    <td class="text-end">@kayit.Gun.ToString("N1")</td>
                                    <td class="text-end text-success">@kayit.GelirToplam.ToString("N2")</td>
                                    <td class="text-end text-success fw-bold">@kayit.Alinacak.ToString("N2")</td>
                                    <td class="text-end">@kayit.ToplamGider.ToString("N2")</td>
                                    <td class="text-end fw-bold text-danger">@kayit.Odenecek.ToString("N2")</td>
                                    <td class="text-end @(kayit.FarkTutari >= 0 ? "text-success" : "text-danger") fw-bold">@kayit.FarkTutari.ToString("N2")</td>
                                    <td class="text-center">
                                        @if (kayit.GelirFaturaKesildi)
                                        {
                                            <span class="badge bg-success" title="@kayit.GelirFaturaNo">
                                                <i class="bi bi-check"></i>
                                            </span>
                                        }
                                        else if (kayit.GelirToplam > 0)
                                        {
                                            <span class="badge bg-danger"><i class="bi bi-x"></i></span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (kayit.GiderFaturaAlindi)
                                        {
                                            <span class="badge bg-success" title="@kayit.GiderFaturaNo">
                                                <i class="bi bi-check"></i>
                                            </span>
                                        }
                                        else if (kayit.ToplamGider > 0)
                                        {
                                            <span class="badge bg-danger"><i class="bi bi-x"></i></span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @GetOdemeBadge(kayit.GelirOdemeDurumu)">
                                            @GetOdemeKisaText(kayit.GelirOdemeDurumu)
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @GetOdemeBadge(kayit.GiderOdemeDurumu)">
                                            @GetOdemeKisaText(kayit.GiderOdemeDurumu)
                                        </span>
                                    </td>
                                    <td @onclick:stopPropagation="true">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary" @onclick="() => Duzenle(kayit)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-outline-danger" @onclick="() => SilOnay(kayit)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr class="fw-bold">
                                <td colspan="8" class="text-end">TOPLAM:</td>
                                <td class="text-end text-success">@filteredKayitlar.Sum(k => k.GelirToplam).ToString("N2")</td>
                                <td class="text-end text-success">@filteredKayitlar.Sum(k => k.Alinacak).ToString("N2")</td>
                                <td class="text-end">@filteredKayitlar.Sum(k => k.ToplamGider).ToString("N2")</td>
                                <td class="text-end text-danger">@filteredKayitlar.Sum(k => k.Odenecek).ToString("N2")</td>
                                <td class="text-end @(filteredKayitlar.Sum(k => k.FarkTutari) >= 0 ? "text-success" : "text-danger")">@filteredKayitlar.Sum(k => k.FarkTutari).ToString("N2")</td>
                                <td colspan="5"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        @if (!filteredKayitlar.Any())
        {
            <div class="alert alert-info mt-4">
                <i class="bi bi-info-circle me-2"></i>
                Kayıt bulunamadı. "Excel Import" ile veri aktarabilir veya "Yeni Kayıt" ile manuel ekleyebilirsiniz.
            </div>
        }
    }
</div>

<!-- Düzenleme Modal -->
@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi @(editKayit.Id == 0 ? "bi-plus-circle" : "bi-pencil") me-2"></i>
                        @(editKayit.Id == 0 ? "Yeni Hakedis Kaydı" : "Hakedis Düzenle")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <!-- Sol Taraf - Temel Bilgiler -->
                        <div class="col-md-6">
                            <h6 class="mb-3"><i class="bi bi-info-circle me-1"></i> Temel Bilgiler</h6>
                            
                            <div class="row mb-3">
                                <div class="col-6">
                                    <label class="form-label small">Kurum *</label>
                                    <input type="text" class="form-control form-control-sm" @bind="editKayit.KurumAdi" placeholder="Kurum adı" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label small">Güzergah *</label>
                                    <input type="text" class="form-control form-control-sm" @bind="editKayit.GuzergahAdi" placeholder="Güzergah adı" />
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-4">
                                    <label class="form-label small">Yön</label>
                                    <select class="form-select form-select-sm" @bind="editKayit.Yon">
                                        @foreach (var yon in Enum.GetValues<PuantajYon>())
                                        {
                                            <option value="@yon">@GetYonText(yon)</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-4">
                                    <label class="form-label small">Plaka</label>
                                    <input type="text" class="form-control form-control-sm" @bind="editKayit.Plaka" />
                                </div>
                                <div class="col-4">
                                    <label class="form-label small">Gün</label>
                                    <input type="number" step="0.5" class="form-control form-control-sm" @bind="editKayit.Gun" />
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-6">
                                    <label class="form-label small">Şoför</label>
                                    <input type="text" class="form-control form-control-sm" @bind="editKayit.SoforAdi" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label small">Şoför Telefon</label>
                                    <input type="text" class="form-control form-control-sm" @bind="editKayit.SoforTelefon" />
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-6">
                                    <label class="form-label small">Şoför Ödeme Tipi</label>
                                    <select class="form-select form-select-sm" @bind="editKayit.SoforOdemeTipi">
                                        <option value="@SoforOdemeTipi.Ozmal">Öz Mal</option>
                                        <option value="@SoforOdemeTipi.Kiralik">Kiralık</option>
                                        <option value="@SoforOdemeTipi.Komisyoncu">Komisyoncu</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-6">
                                    <label class="form-label small">Fatura Kesici</label>
                                    <input type="text" class="form-control form-control-sm" @bind="editKayit.FaturaKesiciAdi" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label small">Fatura Kesici Telefon</label>
                                    <input type="text" class="form-control form-control-sm" @bind="editKayit.FaturaKesiciTelefon" />
                                </div>
                            </div>
                        </div>

                        <!-- Sağ Taraf - Mali Bilgiler -->
                        <div class="col-md-6">
                            <h6 class="mb-3"><i class="bi bi-currency-lira me-1"></i> Mali Bilgiler</h6>
                            
                            <!-- GELİR -->
                            <div class="card mb-3 border-success">
                                <div class="card-header bg-success text-white py-2">
                                    <small class="fw-bold">GELİR (Müşteriden Alınacak)</small>
                                </div>
                                <div class="card-body py-2">
                                    <div class="row g-2">
                                        <div class="col-3">
                                            <label class="form-label small">Birim Gelir</label>
                                            <input type="number" step="0.01" class="form-control form-control-sm" @bind="editKayit.BirimGelir" />
                                        </div>
                                        <div class="col-3">
                                            <label class="form-label small">Toplam Gelir</label>
                                            <input type="number" step="0.01" class="form-control form-control-sm" @bind="editKayit.ToplamGelir" />
                                        </div>
                                        <div class="col-3">
                                            <label class="form-label small">KDV %20</label>
                                            <input type="number" step="0.01" class="form-control form-control-sm" @bind="editKayit.GelirKdv20Tutari" />
                                        </div>
                                        <div class="col-3">
                                            <label class="form-label small">KDV %10</label>
                                            <input type="number" step="0.01" class="form-control form-control-sm" @bind="editKayit.GelirKdv10Tutari" />
                                        </div>
                                    </div>
                                    <div class="row g-2 mt-1">
                                        <div class="col-4">
                                            <label class="form-label small">Kesinti</label>
                                            <input type="number" step="0.01" class="form-control form-control-sm" @bind="editKayit.GelirKesinti" />
                                        </div>
                                        <div class="col-4">
                                            <label class="form-label small">Alınacak</label>
                                            <input type="number" step="0.01" class="form-control form-control-sm fw-bold" @bind="editKayit.Alinacak" />
                                        </div>
                                        <div class="col-4">
                                            <label class="form-label small">Fark (Kar/Zarar)</label>
                                            <input type="number" class="form-control form-control-sm fw-bold @(editKayit.FarkTutari >= 0 ? "text-success" : "text-danger")" readonly 
                                                   value="@editKayit.FarkTutari.ToString("N2")" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- GİDER -->
                            <div class="card mb-3 border-danger">
                                <div class="card-header bg-danger text-white py-2">
                                    <small class="fw-bold">GİDER (Tedarikçiye Ödenecek)</small>
                                </div>
                                <div class="card-body py-2">
                                    <div class="row g-2">
                                        <div class="col-3">
                                            <label class="form-label small">Birim Gider</label>
                                            <input type="number" step="0.01" class="form-control form-control-sm" @bind="editKayit.BirimGider" />
                                        </div>
                                        <div class="col-3">
                                            <label class="form-label small">Toplam Gider</label>
                                            <input type="number" step="0.01" class="form-control form-control-sm" @bind="editKayit.ToplamGider" />
                                        </div>
                                        <div class="col-3">
                                            <label class="form-label small">KDV %20</label>
                                            <input type="number" step="0.01" class="form-control form-control-sm" @bind="editKayit.GiderKdv20Tutari" />
                                        </div>
                                        <div class="col-3">
                                            <label class="form-label small">KDV %10</label>
                                            <input type="number" step="0.01" class="form-control form-control-sm" @bind="editKayit.GiderKdv10Tutari" />
                                        </div>
                                    </div>
                                    <div class="row g-2 mt-1">
                                        <div class="col-4">
                                            <label class="form-label small">Kesinti</label>
                                            <input type="number" step="0.01" class="form-control form-control-sm" @bind="editKayit.GiderKesinti" />
                                        </div>
                                        <div class="col-4">
                                            <label class="form-label small">Ödenecek</label>
                                            <input type="number" step="0.01" class="form-control form-control-sm fw-bold" @bind="editKayit.Odenecek" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Fatura ve Ödeme Durumları -->
                            <div class="row">
                                <div class="col-6">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" @bind="editKayit.GelirFaturaKesildi" id="chkGelirFatura" />
                                        <label class="form-check-label small" for="chkGelirFatura">Gelir Faturası Kesildi</label>
                                    </div>
                                    @if (editKayit.GelirFaturaKesildi)
                                    {
                                        <input type="text" class="form-control form-control-sm mt-1" @bind="editKayit.GelirFaturaNo" placeholder="Fatura No" />
                                    }
                                </div>
                                <div class="col-6">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" @bind="editKayit.GiderFaturaAlindi" id="chkGiderFatura" />
                                        <label class="form-check-label small" for="chkGiderFatura">Gider Faturası Alındı</label>
                                    </div>
                                    @if (editKayit.GiderFaturaAlindi)
                                    {
                                        <input type="text" class="form-control form-control-sm mt-1" @bind="editKayit.GiderFaturaNo" placeholder="Fatura No" />
                                    }
                                </div>
                            </div>

                            <div class="row mt-2">
                                <div class="col-6">
                                                    <label class="form-label small">Gelir Ödeme Durumu</label>
                                                    <select class="form-select form-select-sm" @bind="editKayit.GelirOdemeDurumu">
                                                        @foreach (var durum in Enum.GetValues<PuantajOdemeDurum>())
                                                        {
                                                            <option value="@durum">@GetOdemeText(durum)</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="col-6">
                                                    <label class="form-label small">Gider Ödeme Durumu</label>
                                                    <select class="form-select form-select-sm" @bind="editKayit.GiderOdemeDurumu">
                                                        @foreach (var durum in Enum.GetValues<PuantajOdemeDurum>())
                                                        {
                                                            <option value="@durum">@GetOdemeText(durum)</option>
                                                        }
                                                    </select>
                                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3 mt-3">
                        <label class="form-label small">Notlar</label>
                        <textarea class="form-control form-control-sm" @bind="editKayit.Notlar" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="Kaydet" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i> Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Silme Onay Modal -->
@if (showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Kayıt Silme</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <p>Bu hakedis kaydını silmek istediğinize emin misiniz?</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showDeleteModal = false">İptal</button>
                    <button class="btn btn-danger" @onclick="SilKayit" disabled="@isSaving">Sil</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Toplu Fatura Modal -->
@if (showTopluFaturaModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-receipt me-2"></i>Toplu Fatura İşaretle</h5>
                    <button type="button" class="btn-close" @onclick="() => showTopluFaturaModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Fatura Tipi</label>
                        <select class="form-select" @bind="topluFaturaGelir">
                            <option value="true">Gelir Faturası</option>
                            <option value="false">Gider Faturası</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Fatura No</label>
                        <input type="text" class="form-control" @bind="topluFaturaNo" placeholder="Fatura numarası" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showTopluFaturaModal = false">İptal</button>
                    <button class="btn btn-primary" @onclick="TopluFaturaIsaretle">İşaretle</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Toplu Ödeme Modal -->
@if (showTopluOdemeModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-cash me-2"></i>Toplu Ödeme İşaretle</h5>
                    <button type="button" class="btn-close" @onclick="() => showTopluOdemeModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Ödeme Tipi</label>
                        <select class="form-select" @bind="topluOdemeGelir">
                            <option value="true">Gelir (Tahsilat)</option>
                            <option value="false">Gider (Ödeme)</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showTopluOdemeModal = false">İptal</button>
                    <button class="btn btn-success" @onclick="TopluOdemeIsaretle">Ödendi İşaretle</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int filterYil = DateTime.Now.Year;
    private int filterAy = DateTime.Now.Month;
    private string filterKurumId = "";
    private string filterFaturaDurum = "";

    private List<PuantajKayit> kayitlar = new();
    private List<PuantajKayit> filteredKayitlar = new();
    private List<Cari> kurumlar = new();
    private HakedisIstatistikleri? istatistikler;
    private PuantajKayit editKayit = new();
    private PuantajKayit? deleteKayit;

    private HashSet<int> seciliIdler = new();

    private bool isLoading = true;
    private bool isSaving = false;
    private bool showModal = false;
    private bool showDeleteModal = false;
    private bool showTopluFaturaModal = false;
    private bool showTopluOdemeModal = false;

    private bool topluFaturaGelir = true;
    private string topluFaturaNo = "";
    private bool topluOdemeGelir = false;

    protected override async Task OnInitializedAsync()
    {
        // URL parametrelerini kontrol et
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("yil", out var yilStr) && int.TryParse(yilStr, out var yil))
            filterYil = yil;
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("ay", out var ayStr) && int.TryParse(ayStr, out var ay))
            filterAy = ay;

        kurumlar = await CariService.GetByTipAsync(CariTipi.Musteri);
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            int? kurumId = !string.IsNullOrEmpty(filterKurumId) && int.TryParse(filterKurumId, out var k) ? k : null;
            kayitlar = await HakedisService.GetHakedislerAsync(filterYil, filterAy, kurumId);
            istatistikler = await HakedisService.GetIstatistiklerAsync(filterYil, filterAy);
            ApplyFilter();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplyFilter()
    {
        var query = kayitlar.AsEnumerable();

        if (!string.IsNullOrEmpty(filterFaturaDurum))
        {
            query = filterFaturaDurum switch
            {
                "faturasiz_gelir" => query.Where(k => !k.GelirFaturaKesildi && k.GelirToplam > 0),
                "faturasiz_gider" => query.Where(k => !k.GiderFaturaAlindi && k.ToplamGider > 0),
                "odenmemis_gelir" => query.Where(k => k.GelirOdemeDurumu != PuantajOdemeDurum.Odendi && k.GelirToplam > 0),
                "odenmemis_gider" => query.Where(k => k.GiderOdemeDurumu != PuantajOdemeDurum.Odendi && k.Odenecek > 0),
                _ => query
            };
        }

        filteredKayitlar = query.ToList();
    }

    private void ClearFilter()
    {
        filterKurumId = "";
        filterFaturaDurum = "";
        ApplyFilter();
    }

    private void YeniKayit()
    {
        editKayit = new PuantajKayit
        {
            Yil = filterYil,
            Ay = filterAy,
            Gun = 1,
            GelirKdvOrani = 20
        };
        showModal = true;
    }

    private void Duzenle(PuantajKayit kayit)
    {
        editKayit = new PuantajKayit
        {
            Id = kayit.Id,
            Yil = kayit.Yil,
            Ay = kayit.Ay,
            KurumCariId = kayit.KurumCariId,
            KurumAdi = kayit.KurumAdi,
            GuzergahId = kayit.GuzergahId,
            GuzergahAdi = kayit.GuzergahAdi,
            Yon = kayit.Yon,
            AracId = kayit.AracId,
            Plaka = kayit.Plaka,
            SoforId = kayit.SoforId,
            SoforAdi = kayit.SoforAdi,
            SoforTelefon = kayit.SoforTelefon,
            SoforOdemeTipi = kayit.SoforOdemeTipi,
            OdemeYapilacakCariId = kayit.OdemeYapilacakCariId,
            FaturaKesiciCariId = kayit.FaturaKesiciCariId,
            FaturaKesiciAdi = kayit.FaturaKesiciAdi,
            FaturaKesiciTelefon = kayit.FaturaKesiciTelefon,
            Gun = kayit.Gun,
            BirimGelir = kayit.BirimGelir,
            ToplamGelir = kayit.ToplamGelir,
            GelirKdvOrani = kayit.GelirKdvOrani,
            GelirKdv20Tutari = kayit.GelirKdv20Tutari,
            GelirKdv10Tutari = kayit.GelirKdv10Tutari,
            GelirKesinti = kayit.GelirKesinti,
            Alinacak = kayit.Alinacak,
            BirimGider = kayit.BirimGider,
            ToplamGider = kayit.ToplamGider,
            GiderKdv20Tutari = kayit.GiderKdv20Tutari,
            GiderKdv10Tutari = kayit.GiderKdv10Tutari,
            GiderKesinti = kayit.GiderKesinti,
            Odenecek = kayit.Odenecek,
            GelirFaturaKesildi = kayit.GelirFaturaKesildi,
            GelirFaturaNo = kayit.GelirFaturaNo,
            GiderFaturaAlindi = kayit.GiderFaturaAlindi,
            GiderFaturaNo = kayit.GiderFaturaNo,
            GelirOdemeDurumu = kayit.GelirOdemeDurumu,
            GiderOdemeDurumu = kayit.GiderOdemeDurumu,
            Notlar = kayit.Notlar
        };
        showModal = true;
    }

    private async Task Kaydet()
    {
        isSaving = true;
        try
        {
            if (editKayit.Id == 0)
            {
                await HakedisService.CreateHakedisAsync(editKayit);
                ToastService.ShowSuccess("Kayıt eklendi.");
            }
            else
            {
                await HakedisService.UpdateHakedisAsync(editKayit);
                ToastService.ShowSuccess("Kayıt güncellendi.");
            }
            await LoadData();
            showModal = false;
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void SilOnay(PuantajKayit kayit)
    {
        deleteKayit = kayit;
        showDeleteModal = true;
    }

    private async Task SilKayit()
    {
        if (deleteKayit == null) return;
        isSaving = true;
        try
        {
            await HakedisService.DeleteHakedisAsync(deleteKayit.Id);
            ToastService.ShowSuccess("Kayıt silindi.");
            await LoadData();
            showDeleteModal = false;
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void CloseModal() => showModal = false;

    private void ToggleSecim(int id)
    {
        if (seciliIdler.Contains(id))
            seciliIdler.Remove(id);
        else
            seciliIdler.Add(id);
    }

    private void ToggleTumunuSec(ChangeEventArgs e)
    {
        if ((bool)(e.Value ?? false))
            seciliIdler = filteredKayitlar.Select(k => k.Id).ToHashSet();
        else
            seciliIdler.Clear();
    }

    private async Task TopluOnayla()
    {
        await HakedisService.TopluOnaylaAsync(seciliIdler.ToList(), "system");
        ToastService.ShowSuccess($"{seciliIdler.Count} kayıt onaylandı.");
        seciliIdler.Clear();
        await LoadData();
    }

    private async Task TopluFaturaIsaretle()
    {
        await HakedisService.TopluFaturaIsaretle(seciliIdler.ToList(), topluFaturaGelir, topluFaturaNo);
        ToastService.ShowSuccess($"{seciliIdler.Count} kayıt fatura işaretlendi.");
        seciliIdler.Clear();
        showTopluFaturaModal = false;
        await LoadData();
    }

    private async Task TopluOdemeIsaretle()
    {
        await HakedisService.TopluOdemeIsaretle(seciliIdler.ToList(), topluOdemeGelir, 0);
        ToastService.ShowSuccess($"{seciliIdler.Count} kayıt ödendi işaretlendi.");
        seciliIdler.Clear();
        showTopluOdemeModal = false;
        await LoadData();
    }

    private string GetYonBadge(PuantajYon yon) => yon switch
    {
        PuantajYon.Sabah => "bg-warning text-dark",
        PuantajYon.Aksam => "bg-info",
        PuantajYon.SabahAksam => "bg-primary",
        _ => "bg-secondary"
    };

    private string GetYonText(PuantajYon yon) => yon switch
    {
        PuantajYon.Sabah => "Sabah",
        PuantajYon.Aksam => "Akşam",
        PuantajYon.SabahAksam => "S+A",
        PuantajYon.Diger => "Diğer",
        _ => "?"
    };

    private string GetOdemeBadge(PuantajOdemeDurum durum) => durum switch
    {
        PuantajOdemeDurum.Odendi => "bg-success",
        PuantajOdemeDurum.KismiOdendi => "bg-warning text-dark",
        PuantajOdemeDurum.Odenmedi => "bg-danger",
        PuantajOdemeDurum.Iptal => "bg-dark",
        _ => "bg-secondary"
    };

    private string GetOdemeKisaText(PuantajOdemeDurum durum) => durum switch
    {
        PuantajOdemeDurum.Odendi => "✓",
        PuantajOdemeDurum.KismiOdendi => "½",
        PuantajOdemeDurum.Odenmedi => "✗",
        PuantajOdemeDurum.Iptal => "İ",
        _ => "?"
    };

    private string GetOdemeText(PuantajOdemeDurum durum) => durum switch
    {
        PuantajOdemeDurum.Odendi => "Ödendi",
        PuantajOdemeDurum.KismiOdendi => "Kısmi Ödendi",
        PuantajOdemeDurum.Odenmedi => "Ödenmedi",
        PuantajOdemeDurum.Iptal => "İptal",
        _ => "?"
    };
}
