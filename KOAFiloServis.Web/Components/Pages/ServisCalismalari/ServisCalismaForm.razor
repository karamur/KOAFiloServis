@page "/servis-calismalari/yeni"
@page "/servis-calismalari/{Id:int}"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@inject IServisCalismaService ServisCalismaService
@inject IAracService AracService
@inject ISoforService SoforService
@inject IGuzergahService GuzergahService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>@(IsEdit ? "Servis Çalışması Düzenle" : "Yeni Servis Çalışması")</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-calendar-check me-2"></i>@(IsEdit ? "Servis Çalışması Düzenle" : "Yeni Servis Çalışması")</h3>
        <button class="btn btn-secondary" @onclick="Geri">
            <i class="bi bi-arrow-left me-1"></i>Geri
        </button>
    </div>

    <div class="card">
        <div class="card-body">
            <EditForm Model="calisma" OnValidSubmit="Kaydet">
                <DataAnnotationsValidator />

                <div class="row">
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Çalışma Tarihi *</label>
                            <InputDate @bind-Value="calisma.CalismaTarihi" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Servis Türü *</label>
                            <InputSelect @bind-Value="calisma.ServisTuru" class="form-select">
                                @foreach (ServisTuru tur in Enum.GetValues(typeof(ServisTuru)))
                                {
                                    <option value="@tur">@GetServisTuruText(tur)</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Durum</label>
                            <InputSelect @bind-Value="calisma.Durum" class="form-select">
                                @foreach (CalismaDurum durum in Enum.GetValues(typeof(CalismaDurum)))
                                {
                                    <option value="@durum">@GetDurumText(durum)</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Araç (Plaka) *</label>
                            <div class="position-relative">
                                <input type="text" class="form-control" placeholder="Plaka veya marka ara..."
                                       value="@scPlakaArama"
                                       @oninput="ScPlakaFiltrele"
                                       @onfocus="() => scPlakaDropAcik = true"
                                       @onblur="ScPlakaDropKapat" />
                                @if (scPlakaDropAcik && scFiltreliAraclar.Any())
                                {
                                    <div class="dropdown-menu show w-100" style="max-height:220px;overflow-y:auto;z-index:1050;">
                                        @foreach (var a in scFiltreliAraclar)
                                        {
                                            <button type="button" class="dropdown-item" @onmousedown="() => ScAracSec(a)">
                                                <strong>@a.AktifPlaka</strong> — @a.Marka @a.Model
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                            @if (calisma.AracId > 0)
                            {
                                <small class="text-success"><i class="bi bi-check-circle me-1"></i>Seçili: @scPlakaArama</small>
                            }
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Şoför *</label>
                            <InputSelect @bind-Value="calisma.SoforId" class="form-select">
                                <option value="0">-- Şoför Seçiniz --</option>
                                @foreach (var sofor in soforler)
                                {
                                    <option value="@sofor.Id">@sofor.TamAd</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Güzergah *</label>
                            <InputSelect @bind-Value="calisma.GuzergahId" class="form-select" @onchange="GuzergahDegisti">
                                <option value="0">-- Güzergah Seçiniz --</option>
                                @foreach (var guzergah in guzergahlar)
                                {
                                    <option value="@guzergah.Id">@guzergah.GuzergahAdi (@guzergah.Cari?.Unvan) - @guzergah.BirimFiyat.ToString("N2")₺</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Fiyat (₺)</label>
                            <InputNumber @bind-Value="calisma.Fiyat" class="form-control" />
                            <small class="text-muted">Boş bırakılırsa güzergah fiyatı kullanılır</small>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Km Başlangıç</label>
                            <InputNumber @bind-Value="calisma.KmBaslangic" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Km Bitiş</label>
                            <InputNumber @bind-Value="calisma.KmBitis" class="form-control" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Başlangıç Saati</label>
                            <InputText @bind-Value="baslangicSaati" class="form-control" type="time" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Bitiş Saati</label>
                            <InputText @bind-Value="bitisSaati" class="form-control" type="time" />
                        </div>
                    </div>
                </div>

                <div class="card bg-light mb-3">
                    <div class="card-body">
                        <h6 class="card-title text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Arıza Bilgileri</h6>
                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-check">
                                    <InputCheckbox @bind-Value="calisma.ArizaOlduMu" class="form-check-input" id="arizaOldu" />
                                    <label class="form-check-label" for="arizaOldu">Arıza Oldu</label>
                                </div>
                            </div>
                            <div class="col-md-9">
                                @if (calisma.ArizaOlduMu)
                                {
                                    <div class="mb-3">
                                        <label class="form-label">Arıza Açıklaması</label>
                                        <InputTextArea @bind-Value="calisma.ArizaAciklamasi" class="form-control" rows="2" />
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Notlar</label>
                    <InputTextArea @bind-Value="calisma.Notlar" class="form-control" rows="2" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="Geri">
                        <i class="bi bi-x-lg me-1"></i>İptal
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int? Id { get; set; }

    private ServisCalisma calisma = new();
    private List<Arac> araclar = new();
    private List<Arac> scFiltreliAraclar = new();
    private List<Sofor> soforler = new();
    private List<Guzergah> guzergahlar = new();
    private string? baslangicSaati;
    private string? bitisSaati;
    private bool IsEdit => Id.HasValue;
    private string scPlakaArama = string.Empty;
    private bool scPlakaDropAcik = false;

    protected override async Task OnInitializedAsync()
    {
        araclar = await AracService.GetActiveAsync();
        scFiltreliAraclar = araclar;
        soforler = await SoforService.GetActiveSoforlerAsync(); // Sadece şoför görevli personeller
        guzergahlar = await GuzergahService.GetActiveAsync();

        if (IsEdit)
        {
            var existing = await ServisCalismaService.GetByIdAsync(Id!.Value);
            if (existing != null)
            {
                calisma = existing;
                baslangicSaati = calisma.BaslangicSaati?.ToString(@"hh\:mm");
                bitisSaati = calisma.BitisSaati?.ToString(@"hh\:mm");
                var seciliArac = araclar.FirstOrDefault(a => a.Id == calisma.AracId);
                if (seciliArac != null) scPlakaArama = $"{seciliArac.AktifPlaka} - {seciliArac.Marka} {seciliArac.Model}";
            }
            else
            {
                Navigation.NavigateTo("/servis-calismalari");
            }
        }
        else
        {
            calisma.CalismaTarihi = DateTime.Today;
            calisma.ServisTuru = ServisTuru.Sabah;
            calisma.Durum = CalismaDurum.Tamamlandi;
        }
    }

    private void ScPlakaFiltrele(ChangeEventArgs e)
    {
        scPlakaArama = e.Value?.ToString() ?? string.Empty;
        calisma.AracId = 0;
        scPlakaDropAcik = true;
        var ara = scPlakaArama.Trim().ToLowerInvariant();
        scFiltreliAraclar = string.IsNullOrEmpty(ara)
            ? araclar
            : araclar.Where(a =>
                (a.AktifPlaka ?? string.Empty).ToLowerInvariant().Contains(ara) ||
                (a.Marka ?? string.Empty).ToLowerInvariant().Contains(ara) ||
                (a.Model ?? string.Empty).ToLowerInvariant().Contains(ara)).ToList();
    }

    private void ScAracSec(Arac arac)
    {
        calisma.AracId = arac.Id;
        scPlakaArama = $"{arac.AktifPlaka} - {arac.Marka} {arac.Model}";
        scPlakaDropAcik = false;
        scFiltreliAraclar = araclar;
    }

    private async Task ScPlakaDropKapat()
    {
        await Task.Delay(150);
        scPlakaDropAcik = false;
    }

    private void GuzergahDegisti(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int guzergahId))
        {
            calisma.GuzergahId = guzergahId;
            var guzergah = guzergahlar.FirstOrDefault(g => g.Id == guzergahId);
            if (guzergah != null && !calisma.Fiyat.HasValue)
            {
                calisma.Fiyat = guzergah.BirimFiyat;
            }
        }
    }

    private async Task Kaydet()
    {
        if (calisma.AracId == 0 || calisma.SoforId == 0 || calisma.GuzergahId == 0)
            return;

        if (TimeSpan.TryParse(baslangicSaati, out var bs))
            calisma.BaslangicSaati = bs;

        if (TimeSpan.TryParse(bitisSaati, out var bts))
            calisma.BitisSaati = bts;

        if (calisma.ArizaOlduMu)
        {
            calisma.Durum = CalismaDurum.ArizaNedeniyleYapilamadi;
        }

        if (IsEdit)
        {
            await ServisCalismaService.UpdateAsync(calisma);
        }
        else
        {
            await ServisCalismaService.CreateAsync(calisma);
        }
        Navigation.NavigateTo("/servis-calismalari");
    }

    private void Geri()
    {
        Navigation.NavigateTo("/servis-calismalari");
    }

    private string GetServisTuruText(ServisTuru tur) => tur switch
    {
        ServisTuru.Sabah => "Sabah",
        ServisTuru.Aksam => "Akşam",
        ServisTuru.SabahAksam => "Sabah+Akşam",
        ServisTuru.Ozel => "Özel",
        _ => tur.ToString()
    };

    private string GetDurumText(CalismaDurum durum) => durum switch
    {
        CalismaDurum.Planli => "Planlı",
        CalismaDurum.Tamamlandi => "Tamamlandı",
        CalismaDurum.IptalEdildi => "İptal Edildi",
        CalismaDurum.ArizaNedeniyleYapilamadi => "Arıza Nedeniyle Yapılamadı",
        _ => durum.ToString()
    };
}
