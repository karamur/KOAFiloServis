@page "/filo-operasyon/komisyonculuk/yeni"
@page "/filo-operasyon/komisyonculuk/{Id:int}"
@page "/filo-operasyon/komisyonculuk/{Id:int}/duzenle"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@inject IFiloOperasyonService FiloOperasyonService
@inject ICariService CariService
@inject IAracService AracService
@inject ISoforService SoforService
@inject NavigationManager NavigationManager
@inject IToastService ToastService

<PageTitle>@(_isEdit ? "İş Düzenle" : "Yeni Komisyonculuk İşi") | KOA Filo Servis</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="/filo-operasyon">Filo Operasyon</a></li>
                    <li class="breadcrumb-item"><a href="/filo-operasyon/komisyonculuk">Komisyonculuk</a></li>
                    <li class="breadcrumb-item active">@(_isEdit ? "Düzenle" : "Yeni İş")</li>
                </ol>
            </nav>
            <h3 class="mb-0">
                <i class="bi bi-briefcase me-2"></i>@(_isEdit ? $"İş Düzenle: {_model.IsKodu}" : "Yeni Komisyonculuk İşi")
            </h3>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else
    {
        <EditForm Model="_model" OnValidSubmit="Kaydet">
            <DataAnnotationsValidator />

            <div class="row">
                <!-- Sol Kolon - İş Bilgileri -->
                <div class="col-md-8">
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>İş Bilgileri</h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label">İş Kodu</label>
                                    <input type="text" class="form-control" @bind="_model.IsKodu" readonly />
                                    <small class="text-muted">Otomatik oluşturulur</small>
                                </div>
                                <div class="col-md-8">
                                    <label class="form-label">Müşteri <span class="text-danger">*</span></label>
                                    <select class="form-select" @bind="_model.MusteriCariId">
                                        <option value="0">-- Müşteri Seçin --</option>
                                        @foreach (var cari in _cariler.Where(c => c.CariTipi == CariTipi.Musteri || c.CariTipi == CariTipi.MusteriTedarikci))
                                        {
                                            <option value="@cari.Id">@cari.Unvan</option>
                                        }
                                    </select>
                                    <ValidationMessage For="() => _model.MusteriCariId" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label">İş Açıklaması <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" @bind="_model.IsAciklamasi" 
                                           placeholder="Ör: XYZ Firması personel servisi" />
                                    <ValidationMessage For="() => _model.IsAciklamasi" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">İş Tipi</label>
                                    <select class="form-select" @bind="_model.IsTipi">
                                        <option value="@KomisyonculukIsTipi.SoforluArac">Şoförlü Araç</option>
                                        <option value="@KomisyonculukIsTipi.SoforsuzArac">Şoförsüz Araç</option>
                                        <option value="@KomisyonculukIsTipi.SadeceArac">Sadece Araç</option>
                                        <option value="@KomisyonculukIsTipi.PersonelServisi">Personel Servisi</option>
                                        <option value="@KomisyonculukIsTipi.Transfer">Transfer</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Başlangıç Tarihi</label>
                                    <input type="date" class="form-control" @bind="_model.BaslangicTarihi" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Bitiş Tarihi</label>
                                    <input type="date" class="form-control" @bind="_model.BitisTarihi" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Fiyatlandırma -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="bi bi-currency-exchange me-2"></i>Fiyatlandırma (Alınan İş Bedeli)</h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <label class="form-label">Fiyatlama Tipi</label>
                                    <select class="form-select" @bind="_model.FiyatlamaTipi" @bind:after="HesaplaToplam">
                                        <option value="@KomisyonculukFiyatlamaTipi.Gunluk">Günlük</option>
                                        <option value="@KomisyonculukFiyatlamaTipi.Aylik">Aylık</option>
                                        <option value="@KomisyonculukFiyatlamaTipi.SeferBasina">Sefer Başına</option>
                                        <option value="@KomisyonculukFiyatlamaTipi.SaatBasina">Saat Başına</option>
                                        <option value="@KomisyonculukFiyatlamaTipi.TopluPaket">Toplu Paket</option>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Birim Fiyat (₺)</label>
                                    <input type="number" step="0.01" class="form-control" @bind="_model.BirimFiyat" 
                                           @bind:after="HesaplaToplam" />
                                </div>
                                @if (_model.FiyatlamaTipi == KomisyonculukFiyatlamaTipi.Gunluk || 
                                     _model.FiyatlamaTipi == KomisyonculukFiyatlamaTipi.SaatBasina)
                                {
                                    <div class="col-md-3">
                                        <label class="form-label">Toplam @(_model.FiyatlamaTipi == KomisyonculukFiyatlamaTipi.Gunluk ? "Gün" : "Saat")</label>
                                        <input type="number" class="form-control" @bind="_model.ToplamGun" 
                                               @bind:after="HesaplaToplam" />
                                    </div>
                                }
                                @if (_model.FiyatlamaTipi == KomisyonculukFiyatlamaTipi.SeferBasina)
                                {
                                    <div class="col-md-3">
                                        <label class="form-label">Toplam Sefer</label>
                                        <input type="number" class="form-control" @bind="_model.ToplamSefer" 
                                               @bind:after="HesaplaToplam" />
                                    </div>
                                }
                                <div class="col-md-3">
                                    <label class="form-label">Toplam Tutar (₺)</label>
                                    <input type="number" step="0.01" class="form-control fw-bold" @bind="_model.ToplamTutar" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Notlar -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="bi bi-journal-text me-2"></i>Notlar</h5>
                        </div>
                        <div class="card-body">
                            <textarea class="form-control" rows="3" @bind="_model.Notlar" 
                                      placeholder="İş ile ilgili ek notlar..."></textarea>
                        </div>
                    </div>
                </div>

                <!-- Sağ Kolon - Durum ve Fatura -->
                <div class="col-md-4">
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="bi bi-gear me-2"></i>Durum</h5>
                        </div>
                        <div class="card-body">
                            <label class="form-label">İş Durumu</label>
                            <select class="form-select" @bind="_model.Durum">
                                <option value="@KomisyonculukIsDurum.Aktif">Aktif</option>
                                <option value="@KomisyonculukIsDurum.Beklemede">Beklemede</option>
                                <option value="@KomisyonculukIsDurum.Tamamlandi">Tamamlandı</option>
                                <option value="@KomisyonculukIsDurum.IptalEdildi">İptal Edildi</option>
                            </select>
                        </div>
                    </div>

                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="bi bi-receipt me-2"></i>Fatura Bilgileri</h5>
                        </div>
                        <div class="card-body">
                            <div class="form-check mb-3">
                                <input type="checkbox" class="form-check-input" id="faturaKesildi" 
                                       @bind="_model.FaturaKesildi" />
                                <label class="form-check-label" for="faturaKesildi">
                                    Müşteriye fatura kesildi
                                </label>
                            </div>
                            @if (_model.FaturaKesildi)
                            {
                                <div class="mb-3">
                                    <label class="form-label">Fatura Kesim Tarihi</label>
                                    <input type="date" class="form-control" @bind="_model.FaturaKesimTarihi" />
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Özet Kart -->
                    @if (_isEdit)
                    {
                        <div class="card border-primary">
                            <div class="card-header bg-primary text-white">
                                <h5 class="mb-0"><i class="bi bi-calculator me-2"></i>Kar/Zarar Özeti</h5>
                            </div>
                            <div class="card-body">
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Alınan İş Bedeli:</span>
                                    <span class="text-success fw-bold">@_model.ToplamTutar.ToString("N2") ₺</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Toplam Maliyet:</span>
                                    <span class="text-danger fw-bold">@_toplamMaliyet.ToString("N2") ₺</span>
                                </div>
                                <hr />
                                <div class="d-flex justify-content-between">
                                    <span class="fw-bold">Net Kar:</span>
                                    @{
                                        var netKar = _model.ToplamTutar - _toplamMaliyet;
                                    }
                                    <span class="fw-bold @(netKar >= 0 ? "text-success" : "text-danger")">
                                        @netKar.ToString("N2") ₺
                                    </span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            @if (_isEdit)
            {
                <div class="card mb-4 border-info">
                    <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-diagram-3 me-2"></i>İş Atamaları</h5>
                        <button type="button" class="btn btn-light btn-sm" @onclick="YeniAtamaAc">
                            <i class="bi bi-plus-lg me-1"></i>Atama Ekle
                        </button>
                    </div>
                    <div class="card-body p-0">
                        @if (!_model.Atamalar.Any())
                        {
                            <div class="p-4 text-center text-muted">Henüz atama yapılmadı.</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm mb-0 align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Araç</th>
                                            <th>Sahiplik</th>
                                            <th>Atama Tipi</th>
                                            <th>Atama</th>
                                            <th class="text-end">Toplam Maliyet</th>
                                            <th>Tarih</th>
                                            <th class="text-end">İşlem</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var atama in _model.Atamalar.Where(a => !a.IsDeleted))
                                        {
                                            <tr>
                                                <td>@(atama.Arac?.AktifPlaka ?? atama.DisAracPlaka ?? "-" )</td>
                                                <td>
                                                    @if (atama.Arac != null)
                                                    {
                                                        <span class="badge @GetSahiplikBadge(atama.Arac.SahiplikTipi)">@GetSahiplikText(atama.Arac.SahiplikTipi)</span>
                                                    }
                                                </td>
                                                <td>
                                                    <span class="badge bg-secondary">@GetAtamaTipiText(atama.AtamaTipi)</span>
                                                    @if (atama.TedarikciOdendi)
                                                    {
                                                        <div><small class="text-success">Ödendi</small></div>
                                                    }
                                                </td>
                                                <td>@GetAtamaTarafBilgisi(atama)</td>
                                                <td class="text-end fw-bold text-danger">@atama.ToplamMaliyet.ToString("N2") ₺</td>
                                                <td>
                                                    @atama.BaslangicTarihi.ToString("dd.MM.yyyy")
                                                    @if (atama.BitisTarihi.HasValue)
                                                    {
                                                        <div><small class="text-muted">@atama.BitisTarihi.Value.ToString("dd.MM.yyyy")</small></div>
                                                    }
                                                </td>
                                                <td class="text-end">
                                                    <div class="btn-group btn-group-sm">
                                                        <button type="button" class="btn btn-outline-primary" @onclick="() => AtamaDuzenleAc(atama)">
                                                            <i class="bi bi-pencil"></i>
                                                        </button>
                                                        <button type="button" class="btn btn-outline-danger" @onclick="() => AtamaSil(atama)">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Kaydet Butonları -->
            <div class="card">
                <div class="card-body d-flex justify-content-between">
                    <a href="/filo-operasyon/komisyonculuk" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Geri
                    </a>
                    <div>
                        <button type="submit" class="btn btn-primary" disabled="@_saving">
                            @if (_saving)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            <i class="bi bi-check-lg me-1"></i> 
                            @(_isEdit ? "Güncelle" : "Kaydet")
                        </button>
                        @if (!_isEdit)
                        {
                            <button type="button" class="btn btn-success ms-2" @onclick="KaydetVeAtama" disabled="@_saving">
                                <i class="bi bi-plus-lg me-1"></i> Kaydet ve Atama Yap
                            </button>
                        }
                    </div>
                </div>
            </div>
        </EditForm>
    }
</div>

@if (_atamaModalOpen)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-light">
                    <h5 class="modal-title">@(_atamaModel.Id == 0 ? "Yeni İş Ataması" : "İş Ataması Düzenle")</h5>
                    <button type="button" class="btn-close" @onclick="AtamaModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Araç <span class="text-danger">*</span></label>
                            <select class="form-select" @bind="_atamaModel.AracId" @bind:after="AtamaAracDegistiAsync">
                                <option value="">-- Araç Seçin --</option>
                                @foreach (var arac in _araclar)
                                {
                                    <option value="@arac.Id">@(arac.AktifPlaka ?? arac.SaseNo)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Başlangıç Tarihi</label>
                            <input type="date" class="form-control" @bind="_atamaModel.BaslangicTarihi" />
                        </div>

                        @if (GetSeciliAtamaAraci() is Arac seciliArac)
                        {
                            <div class="col-12">
                                <div class="alert @GetSahiplikAlertClass(seciliArac.SahiplikTipi) py-2 mb-0">
                                    <strong>@GetSahiplikText(seciliArac.SahiplikTipi)</strong> kuralı: @GetSahiplikAciklama(seciliArac.SahiplikTipi)
                                </div>
                            </div>
                        }

                        <div class="col-md-6">
                            <label class="form-label">Atama Tipi</label>
                            <input type="text" class="form-control" value="@GetSeciliAtamaTipiText()" readonly />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Bitiş Tarihi</label>
                            <input type="date" class="form-control" @bind="_atamaModel.BitisTarihi" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Firma Şoförü</label>
                            <select class="form-select" @bind="_atamaModel.SoforId" disabled="@AtamaDisKaynakliMi()">
                                <option value="">-- Şoför Seçin --</option>
                                @foreach (var sofor in _soforler)
                                {
                                    <option value="@sofor.Id">@sofor.TamAd</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Tedarikçi / Komisyoncu</label>
                            <select class="form-select" @bind="_atamaModel.TedarikciCariId" disabled="@AtamaOzmalMi()">
                                <option value="">-- Cari Seçin --</option>
                                @foreach (var cari in _tedarikciCariler)
                                {
                                    <option value="@cari.Id">@cari.Unvan</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Dış Şoför</label>
                            <input type="text" class="form-control" @bind="_atamaModel.DisSoforAdSoyad" disabled="@(!AtamaDisKaynakliMi())" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Dış Şoför Telefon</label>
                            <input type="text" class="form-control" @bind="_atamaModel.DisSoforTelefon" disabled="@(!AtamaDisKaynakliMi())" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Dış Araç Plaka</label>
                            <input type="text" class="form-control" @bind="_atamaModel.DisAracPlaka" disabled="@(!AtamaDisKaynakliMi())" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Araç Kira Bedeli</label>
                            <input type="number" step="0.01" class="form-control" @bind="_atamaModel.AracKiraBedeli" disabled="@AtamaOzmalMi()" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Şoför Maliyeti</label>
                            <input type="number" step="0.01" class="form-control" @bind="_atamaModel.SoforMaliyeti" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Yakıt Maliyeti</label>
                            <input type="number" step="0.01" class="form-control" @bind="_atamaModel.YakitMaliyeti" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Otoyol Maliyeti</label>
                            <input type="number" step="0.01" class="form-control" @bind="_atamaModel.OtoyolMaliyeti" />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Diğer Masraflar</label>
                            <input type="number" step="0.01" class="form-control" @bind="_atamaModel.DigerMasraflar" />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Notlar</label>
                            <textarea class="form-control" rows="2" @bind="_atamaModel.Notlar"></textarea>
                        </div>
                        <div class="col-md-12">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="tedarikciOdendiSwitch" @bind="_atamaModel.TedarikciOdendi">
                                <label class="form-check-label" for="tedarikciOdendiSwitch">Tedarikçi / Komisyoncu ödemesi yapıldı</label>
                            </div>
                        </div>
                        @if (_atamaModel.TedarikciOdendi)
                        {
                            <div class="col-md-6">
                                <label class="form-label">Ödeme Tarihi</label>
                                <input type="date" class="form-control" @bind="_atamaModel.TedarikciOdemeTarihi" />
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="AtamaModalKapat">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="AtamaKaydet" disabled="@_atamaKaydediliyor">
                        @if (_atamaKaydediliyor)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int? Id { get; set; }

    private bool _isEdit => Id.HasValue;
    private bool _loading = true;
    private bool _saving = false;
    private bool _atamaModalOpen = false;
    private bool _atamaKaydediliyor = false;
    private KomisyonculukIs _model = new();
    private List<Cari> _cariler = new();
    private List<Cari> _tedarikciCariler = new();
    private List<Arac> _araclar = new();
    private List<Sofor> _soforler = new();
    private KomisyonculukIsAtama _atamaModel = new();
    private decimal _toplamMaliyet = 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LookupYukleAsync();

            if (_isEdit)
            {
                await IsYukleAsync();
            }
            else
            {
                _model.IsKodu = await FiloOperasyonService.GenerateIsKoduAsync();
                _model.BaslangicTarihi = DateTime.Today;
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Veri yüklenirken hata: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LookupYukleAsync()
    {
        _cariler = await CariService.GetAllAsync();
        _tedarikciCariler = _cariler
            .Where(c => c.CariTipi == CariTipi.Tedarikci || c.CariTipi == CariTipi.MusteriTedarikci)
            .OrderBy(c => c.Unvan)
            .ToList();
        _araclar = (await AracService.GetActiveAsync()).OrderBy(a => a.AktifPlaka ?? a.SaseNo).ToList();
        _soforler = (await SoforService.GetActiveSoforlerAsync()).OrderBy(s => s.TamAd).ToList();
    }

    private async Task IsYukleAsync()
    {
        var existing = await FiloOperasyonService.GetKomisyonculukIsAsync(Id!.Value);
        if (existing == null)
        {
            ToastService.ShowError("İş bulunamadı.");
            NavigationManager.NavigateTo("/filo-operasyon/komisyonculuk");
            return;
        }

        _model = existing;
        _toplamMaliyet = existing.Atamalar.Where(a => !a.IsDeleted).Sum(a => a.ToplamMaliyet);
    }

    private void HesaplaToplam()
    {
        _model.ToplamTutar = _model.FiyatlamaTipi switch
        {
            KomisyonculukFiyatlamaTipi.Gunluk => _model.BirimFiyat * _model.ToplamGun,
            KomisyonculukFiyatlamaTipi.SaatBasina => _model.BirimFiyat * _model.ToplamGun,
            KomisyonculukFiyatlamaTipi.SeferBasina => _model.BirimFiyat * _model.ToplamSefer,
            KomisyonculukFiyatlamaTipi.Aylik => _model.BirimFiyat,
            KomisyonculukFiyatlamaTipi.TopluPaket => _model.BirimFiyat,
            _ => _model.BirimFiyat
        };
    }

    private async Task Kaydet()
    {
        if (_model.MusteriCariId == 0)
        {
            ToastService.ShowError("Lütfen müşteri seçin.");
            return;
        }

        if (string.IsNullOrWhiteSpace(_model.IsAciklamasi))
        {
            ToastService.ShowError("Lütfen iş açıklaması girin.");
            return;
        }

        _saving = true;
        try
        {
            if (_isEdit)
            {
                await FiloOperasyonService.UpdateKomisyonculukIsAsync(_model);
                ToastService.ShowSuccess("İş başarıyla güncellendi.");
            }
            else
            {
                var created = await FiloOperasyonService.CreateKomisyonculukIsAsync(_model);
                ToastService.ShowSuccess("İş başarıyla oluşturuldu.");
            }
            NavigationManager.NavigateTo("/filo-operasyon/komisyonculuk");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Kayıt hatası: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task KaydetVeAtama()
    {
        if (_model.MusteriCariId == 0)
        {
            ToastService.ShowError("Lütfen müşteri seçin.");
            return;
        }

        _saving = true;
        try
        {
            var created = await FiloOperasyonService.CreateKomisyonculukIsAsync(_model);
            ToastService.ShowSuccess("İş oluşturuldu, şimdi atama yapabilirsiniz.");
            NavigationManager.NavigateTo($"/filo-operasyon/komisyonculuk/{created.Id}");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Kayıt hatası: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    private void YeniAtamaAc()
    {
        _atamaModel = new KomisyonculukIsAtama
        {
            KomisyonculukIsId = _model.Id,
            BaslangicTarihi = _model.BaslangicTarihi == default ? DateTime.Today : _model.BaslangicTarihi
        };
        _atamaModalOpen = true;
    }

    private void AtamaDuzenleAc(KomisyonculukIsAtama atama)
    {
        _atamaModel = new KomisyonculukIsAtama
        {
            Id = atama.Id,
            KomisyonculukIsId = atama.KomisyonculukIsId,
            AracId = atama.AracId,
            TedarikciCariId = atama.TedarikciCariId,
            DisAracPlaka = atama.DisAracPlaka,
            AtamaTipi = atama.AtamaTipi,
            SoforId = atama.SoforId,
            DisSoforAdSoyad = atama.DisSoforAdSoyad,
            DisSoforTelefon = atama.DisSoforTelefon,
            AracKiraBedeli = atama.AracKiraBedeli,
            SoforMaliyeti = atama.SoforMaliyeti,
            YakitMaliyeti = atama.YakitMaliyeti,
            OtoyolMaliyeti = atama.OtoyolMaliyeti,
            DigerMasraflar = atama.DigerMasraflar,
            VerilenIsFaturaId = atama.VerilenIsFaturaId,
            TedarikciOdendi = atama.TedarikciOdendi,
            TedarikciOdemeTarihi = atama.TedarikciOdemeTarihi,
            BaslangicTarihi = atama.BaslangicTarihi,
            BitisTarihi = atama.BitisTarihi,
            Notlar = atama.Notlar
        };
        _atamaModalOpen = true;
    }

    private void AtamaModalKapat()
    {
        _atamaModalOpen = false;
    }

    private async Task AtamaAracDegistiAsync()
    {
        var arac = GetSeciliAtamaAraci();
        if (arac == null)
            return;

        switch (arac.SahiplikTipi)
        {
            case AracSahiplikTipi.Ozmal:
                _atamaModel.TedarikciCariId = null;
                _atamaModel.DisAracPlaka = null;
                _atamaModel.DisSoforAdSoyad = null;
                _atamaModel.DisSoforTelefon = null;
                _atamaModel.AracKiraBedeli = 0;
                break;
            case AracSahiplikTipi.Kiralik:
                _atamaModel.TedarikciCariId ??= arac.KiralikCariId;
                _atamaModel.DisAracPlaka = null;
                _atamaModel.DisSoforAdSoyad = null;
                _atamaModel.DisSoforTelefon = null;
                _atamaModel.AracKiraBedeli = _atamaModel.AracKiraBedeli > 0 ? _atamaModel.AracKiraBedeli : (arac.SeferBasinaKiraBedeli ?? arac.GunlukKiraBedeli ?? 0);
                break;
            case AracSahiplikTipi.Komisyon:
                _atamaModel.SoforId = null;
                _atamaModel.TedarikciCariId ??= arac.KomisyoncuCariId;
                _atamaModel.DisAracPlaka ??= arac.AktifPlaka ?? arac.SaseNo;
                break;
        }

        await Task.CompletedTask;
    }

    private async Task AtamaKaydet()
    {
        if (!_isEdit || _model.Id == 0)
            return;

        if (!_atamaModel.AracId.HasValue)
        {
            ToastService.ShowError("Lütfen araç seçin.");
            return;
        }

        if ((AtamaOzmalMi() || AtamaKiralikMi()) && !_atamaModel.SoforId.HasValue)
        {
            ToastService.ShowError("Bu atama tipinde firma şoförü seçilmelidir.");
            return;
        }

        if (AtamaKomisyonMu() && !_atamaModel.TedarikciCariId.HasValue)
        {
            ToastService.ShowError("Komisyon araçta komisyoncu cari seçilmelidir.");
            return;
        }

        _atamaKaydediliyor = true;
        try
        {
            if (_atamaModel.Id == 0)
                await FiloOperasyonService.CreateIsAtamaAsync(_atamaModel);
            else
                await FiloOperasyonService.UpdateIsAtamaAsync(_atamaModel);

            await IsYukleAsync();
            _atamaModalOpen = false;
            ToastService.ShowSuccess("Atama kaydedildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Atama kaydı sırasında hata: {ex.Message}");
        }
        finally
        {
            _atamaKaydediliyor = false;
        }
    }

    private async Task AtamaSil(KomisyonculukIsAtama atama)
    {
        try
        {
            await FiloOperasyonService.DeleteIsAtamaAsync(atama.Id);
            await IsYukleAsync();
            ToastService.ShowSuccess("Atama silindi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Atama silinirken hata: {ex.Message}");
        }
    }

    private Arac? GetSeciliAtamaAraci() => _araclar.FirstOrDefault(a => a.Id == _atamaModel.AracId);
    private bool AtamaOzmalMi() => GetSeciliAtamaAraci()?.SahiplikTipi == AracSahiplikTipi.Ozmal;
    private bool AtamaKiralikMi() => GetSeciliAtamaAraci()?.SahiplikTipi == AracSahiplikTipi.Kiralik;
    private bool AtamaKomisyonMu() => GetSeciliAtamaAraci()?.SahiplikTipi == AracSahiplikTipi.Komisyon;
    private bool AtamaDisKaynakliMi() => AtamaKomisyonMu();

    private string GetSeciliAtamaTipiText()
    {
        var arac = GetSeciliAtamaAraci();
        if (arac == null)
            return "Araç seçilmedi";

        var atamaTipi = arac.SahiplikTipi switch
        {
            AracSahiplikTipi.Ozmal => AracAtamaTipi.OzmalSoforlu,
            AracSahiplikTipi.Kiralik => AracAtamaTipi.KiralikKendiSofor,
            AracSahiplikTipi.Komisyon => AracAtamaTipi.KiralikDisSofor,
            _ => _atamaModel.AtamaTipi
        };

        return GetAtamaTipiText(atamaTipi);
    }

    private static string GetSahiplikText(AracSahiplikTipi sahiplikTipi) => sahiplikTipi switch
    {
        AracSahiplikTipi.Ozmal => "Özmal",
        AracSahiplikTipi.Kiralik => "Kiralık",
        AracSahiplikTipi.Komisyon => "Komisyon",
        _ => "Diğer"
    };

    private static string GetSahiplikBadge(AracSahiplikTipi sahiplikTipi) => sahiplikTipi switch
    {
        AracSahiplikTipi.Ozmal => "bg-success",
        AracSahiplikTipi.Kiralik => "bg-warning text-dark",
        AracSahiplikTipi.Komisyon => "bg-info text-dark",
        _ => "bg-secondary"
    };

    private static string GetSahiplikAlertClass(AracSahiplikTipi sahiplikTipi) => sahiplikTipi switch
    {
        AracSahiplikTipi.Ozmal => "alert-success",
        AracSahiplikTipi.Kiralik => "alert-warning",
        AracSahiplikTipi.Komisyon => "alert-info",
        _ => "alert-secondary"
    };

    private static string GetSahiplikAciklama(AracSahiplikTipi sahiplikTipi) => sahiplikTipi switch
    {
        AracSahiplikTipi.Ozmal => "Araç ve şoför firmaya aittir. Dış kaynak alanları kullanılmaz.",
        AracSahiplikTipi.Kiralik => "Araç kiralık yapıdadır, şoför firma üzerinden seçilir ve kiralık cari otomatik bağlanır.",
        AracSahiplikTipi.Komisyon => "Araç, şoför ve operasyon masrafları komisyoncuya aittir. İç şoför yerine dış kaynak bilgileri kullanılır.",
        _ => "Ek kural tanımlanmamış."
    };

    private static string GetAtamaTarafBilgisi(KomisyonculukIsAtama atama)
    {
        if (atama.Arac?.SahiplikTipi == AracSahiplikTipi.Komisyon)
            return $"{atama.TedarikciCari?.Unvan ?? "-"} / {atama.DisSoforAdSoyad ?? atama.DisAracPlaka ?? "Dış kaynak"}";

        if (atama.Arac?.SahiplikTipi == AracSahiplikTipi.Kiralik)
            return $"{atama.TedarikciCari?.Unvan ?? "-"} / {atama.Sofor?.TamAd ?? "Firma şoförü yok"}";

        return atama.Sofor?.TamAd ?? "Firma şoförü yok";
    }

    private static string GetAtamaTipiText(AracAtamaTipi atamaTipi) => atamaTipi switch
    {
        AracAtamaTipi.OzmalSoforlu => "Özmal + Firma Şoförü",
        AracAtamaTipi.OzmalDisSofor => "Özmal + Dış Şoför",
        AracAtamaTipi.KiralikKendiSofor => "Kiralık + Firma Şoförü",
        AracAtamaTipi.KiralikDisSofor => "Dış Kaynak Tam Paket",
        AracAtamaTipi.SadeceArac => "Sadece Araç",
        _ => atamaTipi.ToString()
    };
