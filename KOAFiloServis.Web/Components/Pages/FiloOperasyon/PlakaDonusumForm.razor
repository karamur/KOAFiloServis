@page "/filo-operasyon/plaka-donusum/yeni"
@page "/filo-operasyon/plaka-donusum/{Id:int}/duzenle"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@inject IFiloOperasyonService FiloOperasyonService
@inject IAracService AracService
@inject ICariService CariService
@inject NavigationManager NavigationManager
@inject IToastService ToastService

<PageTitle>@(_isEdit ? "Plaka Dönüşüm Düzenle" : "Yeni Plaka Dönüşümü") | KOA Filo Servis</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="/filo-operasyon">Filo Operasyon</a></li>
                    <li class="breadcrumb-item"><a href="/filo-operasyon/plaka-donusum">Plaka Dönüşüm</a></li>
                    <li class="breadcrumb-item active">@(_isEdit ? "Düzenle" : "Yeni")</li>
                </ol>
            </nav>
            <h3 class="mb-0">
                <i class="bi bi-card-text me-2"></i>@(_isEdit ? "Plaka Dönüşüm Düzenle" : "Yeni Plaka Dönüşümü")
            </h3>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else
    {
        <EditForm Model="_model" OnValidSubmit="Kaydet">
            <DataAnnotationsValidator />

            <div class="row">
                <!-- Sol Kolon -->
                <div class="col-md-8">
                    <!-- Araç ve Plaka Bilgileri -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="bi bi-car-front me-2"></i>Araç ve Plaka Bilgileri</h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Araç <span class="text-danger">*</span></label>
                                    <select class="form-select" @bind="_model.AracId" @bind:after="AracSecildi" disabled="@_isEdit">
                                        <option value="0">-- Araç Seçin --</option>
                                        @foreach (var arac in _araclar)
                                        {
                                            <option value="@arac.Id">@arac.AktifPlaka - @arac.Marka @arac.Model</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Başvuru Tarihi</label>
                                    <input type="date" class="form-control" @bind="_model.BasvuruTarihi" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Eski Plaka -->
                    <div class="card mb-4">
                        <div class="card-header bg-warning">
                            <h5 class="mb-0"><i class="bi bi-arrow-left-circle me-2"></i>Eski Plaka (Dönüştürülecek)</h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Eski Plaka</label>
                                    <input type="text" class="form-control" @bind="_model.EskiPlaka" 
                                           placeholder="Ör: 34 C 1234" disabled="@_isEdit" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Eski Plaka Tipi</label>
                                    <select class="form-select" @bind="_model.EskiPlakaTipi" disabled="@_isEdit">
                                        <option value="@PlakaTipi.CPlakaLimonSari">C Plaka - Limon Sarısı (Ticari)</option>
                                        <option value="@PlakaTipi.CPlakaTurkuaz">C Plaka - Turkuaz (Servis)</option>
                                        <option value="@PlakaTipi.MPlaka">M Plaka (Minibüs)</option>
                                        <option value="@PlakaTipi.SPlaka">S Plaka (Servis)</option>
                                        <option value="@PlakaTipi.OzelPlaka">Özel Plaka (Beyaz)</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Yeni Plaka -->
                    <div class="card mb-4">
                        <div class="card-header bg-success text-white">
                            <h5 class="mb-0"><i class="bi bi-arrow-right-circle me-2"></i>Yeni Plaka</h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Yeni Plaka</label>
                                    <input type="text" class="form-control" @bind="_model.YeniPlaka" 
                                           placeholder="Dönüşüm tamamlandığında girilecek" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Yeni Plaka Tipi</label>
                                    <select class="form-select" @bind="_model.YeniPlakaTipi">
                                        <option value="@PlakaTipi.OzelPlaka">Özel Plaka (Beyaz)</option>
                                        <option value="@PlakaTipi.CPlakaLimonSari">C Plaka - Limon Sarısı</option>
                                        <option value="@PlakaTipi.CPlakaTurkuaz">C Plaka - Turkuaz</option>
                                        <option value="@PlakaTipi.MPlaka">M Plaka</option>
                                        <option value="@PlakaTipi.SPlaka">S Plaka</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Masraflar -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="bi bi-cash-stack me-2"></i>Masraflar</h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <label class="form-label">Plaka Bedeli</label>
                                    <div class="input-group">
                                        <input type="number" step="0.01" class="form-control" @bind="_model.PlakaBedeliMasrafi" />
                                        <span class="input-group-text">₺</span>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Emniyet Harcı</label>
                                    <div class="input-group">
                                        <input type="number" step="0.01" class="form-control" @bind="_model.EmnivetHarci" />
                                        <span class="input-group-text">₺</span>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Noter Masrafı</label>
                                    <div class="input-group">
                                        <input type="number" step="0.01" class="form-control" @bind="_model.NoterMasrafi" />
                                        <span class="input-group-text">₺</span>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Diğer Masraflar</label>
                                    <div class="input-group">
                                        <input type="number" step="0.01" class="form-control" @bind="_model.DigerMasraflar" />
                                        <span class="input-group-text">₺</span>
                                    </div>
                                </div>
                            </div>
                            <div class="row mt-3">
                                <div class="col-12">
                                    <div class="alert alert-info mb-0">
                                        <div class="d-flex justify-content-between">
                                            <span><i class="bi bi-calculator me-2"></i>Toplam Masraf:</span>
                                            <strong>@_model.ToplamMasraf.ToString("N2") ₺</strong>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Notlar -->
                    <div class="card mb-4">
                        <div class="card-body">
                            <label class="form-label">Notlar</label>
                            <textarea class="form-control" rows="3" @bind="_model.Notlar"></textarea>
                        </div>
                    </div>
                </div>

                <!-- Sağ Kolon -->
                <div class="col-md-4">
                    <!-- Durum -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="bi bi-flag me-2"></i>İşlem Durumu</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">Durum</label>
                                <select class="form-select" @bind="_model.Durum">
                                    <option value="@PlakaDonusumDurum.BasvuruYapildi">Başvuru Yapıldı</option>
                                    <option value="@PlakaDonusumDurum.EvrakIncelemede">Evrak İncelemede</option>
                                    <option value="@PlakaDonusumDurum.Onaylandi">Onaylandı</option>
                                    <option value="@PlakaDonusumDurum.YeniPlakaAlindi">Yeni Plaka Alındı</option>
                                    <option value="@PlakaDonusumDurum.Tamamlandi">Tamamlandı</option>
                                    <option value="@PlakaDonusumDurum.Reddedildi">Reddedildi</option>
                                    <option value="@PlakaDonusumDurum.IptalEdildi">İptal Edildi</option>
                                </select>
                            </div>
                            @if (_model.Durum == PlakaDonusumDurum.Onaylandi || 
                                 _model.Durum == PlakaDonusumDurum.YeniPlakaAlindi || 
                                 _model.Durum == PlakaDonusumDurum.Tamamlandi)
                            {
                                <div class="mb-3">
                                    <label class="form-label">Onay Tarihi</label>
                                    <input type="date" class="form-control" @bind="_model.OnayTarihi" />
                                </div>
                            }
                            @if (_model.Durum == PlakaDonusumDurum.Tamamlandi)
                            {
                                <div class="mb-3">
                                    <label class="form-label">Tamamlanma Tarihi</label>
                                    <input type="date" class="form-control" @bind="_model.TamamlanmaTarihi" />
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Eski Plaka Satışı -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="bi bi-tag me-2"></i>Eski Plaka Satışı</h5>
                        </div>
                        <div class="card-body">
                            <div class="form-check mb-3">
                                <input type="checkbox" class="form-check-input" id="plakaSatilacak" 
                                       @bind="_model.PlakaSatilacakMi" />
                                <label class="form-check-label" for="plakaSatilacak">
                                    Eski plaka satılacak
                                </label>
                            </div>
                            @if (_model.PlakaSatilacakMi)
                            {
                                <div class="mb-3">
                                    <label class="form-label">Plaka Satış Bedeli</label>
                                    <div class="input-group">
                                        <input type="number" step="0.01" class="form-control" @bind="_model.PlakaSatisBedeli" />
                                        <span class="input-group-text">₺</span>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Alıcı</label>
                                    <select class="form-select" @bind="_model.PlakaSatisCarisiId">
                                        <option value="">-- Alıcı Seçin --</option>
                                        @foreach (var cari in _cariler)
                                        {
                                            <option value="@cari.Id">@cari.Unvan</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-check mb-3">
                                    <input type="checkbox" class="form-check-input" id="plakaSatildi" 
                                           @bind="_model.PlakaSatildi" />
                                    <label class="form-check-label" for="plakaSatildi">
                                        Plaka satıldı
                                    </label>
                                </div>
                                @if (_model.PlakaSatildi)
                                {
                                    <div class="mb-3">
                                        <label class="form-label">Satış Tarihi</label>
                                        <input type="date" class="form-control" @bind="_model.PlakaSatisTarihi" />
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <!-- Kar/Zarar Özeti -->
                    @if (_model.PlakaSatilacakMi && _model.PlakaSatisBedeli.HasValue)
                    {
                        <div class="card border-primary">
                            <div class="card-header bg-primary text-white">
                                <h5 class="mb-0"><i class="bi bi-calculator me-2"></i>Kar/Zarar</h5>
                            </div>
                            <div class="card-body">
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Toplam Masraf:</span>
                                    <span class="text-danger">@_model.ToplamMasraf.ToString("N2") ₺</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Plaka Satış Geliri:</span>
                                    <span class="text-success">@_model.PlakaSatisBedeli?.ToString("N2") ₺</span>
                                </div>
                                <hr />
                                @{
                                    var netSonuc = (_model.PlakaSatisBedeli ?? 0) - _model.ToplamMasraf;
                                }
                                <div class="d-flex justify-content-between">
                                    <span class="fw-bold">Net Sonuç:</span>
                                    <span class="fw-bold @(netSonuc >= 0 ? "text-success" : "text-danger")">
                                        @netSonuc.ToString("N2") ₺
                                    </span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Kaydet Butonları -->
            <div class="card">
                <div class="card-body d-flex justify-content-between">
                    <a href="/filo-operasyon/plaka-donusum" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Geri
                    </a>
                    <button type="submit" class="btn btn-primary" disabled="@_saving">
                        @if (_saving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i> 
                        @(_isEdit ? "Güncelle" : "Kaydet")
                    </button>
                </div>
            </div>
        </EditForm>
    }
</div>

@code {
    [Parameter]
    public int? Id { get; set; }

    private bool _isEdit => Id.HasValue;
    private bool _loading = true;
    private bool _saving = false;
    private PlakaDonusum _model = new();
    private List<Arac> _araclar = new();
    private List<Cari> _cariler = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _araclar = await AracService.GetAllAsync();
            _cariler = await CariService.GetAllAsync();

            if (_isEdit)
            {
                var existing = await FiloOperasyonService.GetPlakaDonusumAsync(Id!.Value);
                if (existing == null)
                {
                    ToastService.ShowError("Kayıt bulunamadı.");
                    NavigationManager.NavigateTo("/filo-operasyon/plaka-donusum");
                    return;
                }
                _model = existing;
            }
            else
            {
                _model.BasvuruTarihi = DateTime.Today;
                _model.EskiPlakaTipi = PlakaTipi.CPlakaLimonSari;
                _model.YeniPlakaTipi = PlakaTipi.OzelPlaka;
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Veri yüklenirken hata: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private void AracSecildi()
    {
        if (_model.AracId > 0)
        {
            var arac = _araclar.FirstOrDefault(a => a.Id == _model.AracId);
            if (arac != null && !string.IsNullOrEmpty(arac.AktifPlaka))
            {
                _model.EskiPlaka = arac.AktifPlaka;
            }
        }
    }

    private async Task Kaydet()
    {
        if (_model.AracId == 0)
        {
            ToastService.ShowError("Lütfen araç seçin.");
            return;
        }

        if (string.IsNullOrWhiteSpace(_model.EskiPlaka))
        {
            ToastService.ShowError("Eski plaka bilgisi gerekli.");
            return;
        }

        _saving = true;
        try
        {
            if (_isEdit)
            {
                await FiloOperasyonService.UpdatePlakaDonusumAsync(_model);
                ToastService.ShowSuccess("Kayıt başarıyla güncellendi.");
            }
            else
            {
                await FiloOperasyonService.CreatePlakaDonusumAsync(_model);
                ToastService.ShowSuccess("Kayıt başarıyla oluşturuldu.");
            }
            NavigationManager.NavigateTo("/filo-operasyon/plaka-donusum");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Kayıt hatası: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }
}
