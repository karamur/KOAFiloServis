@inherits LayoutComponentBase
@inject CRMFiloServis.Web.Services.IKullaniciService KullaniciService
@inject NavigationManager Navigation

@if (!isInitialized)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Yukleniyor...</span>
        </div>
    </div>
}
else if (aktifKullanici == null)
{
    <!-- Kullanici giris yapmamis - Login sayfasina yonlendir -->
}
else
{
    <div class="page">
        <div class="sidebar">
            <NavMenu />
        </div>

        <main>
            <div class="top-row px-4 d-flex justify-content-between align-items-center">
                <span class="text-muted">@DateTime.Now.ToString("dd MMMM yyyy, dddd")</span>
                <div class="d-flex align-items-center gap-3">
                    <CRMFiloServis.Web.Components.Shared.FirmaSelector />
                    <div class="dropdown">
                        <button class="btn btn-light btn-sm dropdown-toggle border" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle me-1"></i>@aktifKullanici.AdSoyad
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><span class="dropdown-item-text text-muted small">@aktifKullanici.Rol?.RolAdi</span></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/ayarlar/profil"><i class="bi bi-gear me-2"></i>Ayarlar</a></li>
                            <li><a class="dropdown-item text-danger" @onclick="CikisYap" style="cursor:pointer;"><i class="bi bi-box-arrow-right me-2"></i>Cikis Yap</a></li>
                        </ul>
                    </div>
                </div>
            </div>

            <article class="content px-4">
                @Body
            </article>
        </main>
    </div>

    <!-- Toast Bildirimleri -->
    <CRMFiloServis.Web.Components.Shared.ToastContainer />
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private CRMFiloServis.Shared.Entities.Kullanici? aktifKullanici;
    private bool isInitialized = false;

    protected override async Task OnInitializedAsync()
    {
        aktifKullanici = await KullaniciService.GetAktifKullaniciAsync();
        isInitialized = true;

        if (aktifKullanici == null)
        {
            Navigation.NavigateTo("/login", true);
        }
    }

    private async Task CikisYap()
    {
        await KullaniciService.CikisYapAsync();
        Navigation.NavigateTo("/login", true);
    }
}
