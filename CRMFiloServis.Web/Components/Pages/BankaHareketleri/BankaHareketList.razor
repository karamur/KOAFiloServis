@page "/banka-hareketleri"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@inject IBankaKasaHareketService HareketService
@inject IBankaHesapService BankaHesapService
@inject ICariService CariService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Banka/Kasa Hareketleri</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-arrow-left-right me-2"></i>Banka/Kasa Hareketleri</h3>
        <button class="btn btn-primary" @onclick="YeniHareket">
            <i class="bi bi-plus-lg me-1"></i>Yeni Hareket
        </button>
    </div>

    @if (hareketler == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else if (!hareketler.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Henüz hareket kaydı bulunmamaktadır.
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>İşlem No</th>
                                <th>Tarih</th>
                                <th>Hesap</th>
                                <th>Cari</th>
                                <th>Tip</th>
                                <th>Tutar</th>
                                <th>Açıklama</th>
                                <th style="width: 120px;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var hareket in hareketler)
                            {
                                <tr>
                                    <td><strong>@hareket.IslemNo</strong></td>
                                    <td>@hareket.IslemTarihi.ToString("dd.MM.yyyy")</td>
                                    <td>@hareket.BankaHesap?.HesapAdi</td>
                                    <td>@hareket.Cari?.Unvan</td>
                                    <td>
                                        @if (hareket.HareketTipi == HareketTipi.Giris)
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-arrow-down me-1"></i>Giriş
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">
                                                <i class="bi bi-arrow-up me-1"></i>Çıkış
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <strong class="@(hareket.HareketTipi == HareketTipi.Giris ? "text-success" : "text-danger")">
                                            @(hareket.HareketTipi == HareketTipi.Giris ? "+" : "-")@hareket.Tutar.ToString("N2") ?
                                        </strong>
                                    </td>
                                    <td>@hareket.Aciklama</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Duzenle(hareket.Id)" title="Düzenle">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => SilOnay(hareket)" title="Sil">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@if (showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Silme Onayı</h5>
                    <button type="button" class="btn-close" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <p><strong>@silinecekHareket?.IslemNo</strong> numaralı hareketi silmek istediğinize emin misiniz?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showDeleteModal = false">İptal</button>
                    <button type="button" class="btn btn-danger" @onclick="Sil">Sil</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<BankaKasaHareket>? hareketler;
    private bool showDeleteModal = false;
    private BankaKasaHareket? silinecekHareket;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        hareketler = await HareketService.GetAllAsync();
    }

    private void YeniHareket()
    {
        Navigation.NavigateTo("/banka-hareketleri/yeni");
    }

    private void Duzenle(int id)
    {
        Navigation.NavigateTo($"/banka-hareketleri/{id}");
    }

    private void SilOnay(BankaKasaHareket hareket)
    {
        silinecekHareket = hareket;
        showDeleteModal = true;
    }

    private async Task Sil()
    {
        if (silinecekHareket != null)
        {
            await HareketService.DeleteAsync(silinecekHareket.Id);
            await LoadData();
        }
        showDeleteModal = false;
        silinecekHareket = null;
    }
}
