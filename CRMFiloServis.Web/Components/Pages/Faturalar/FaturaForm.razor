@page "/faturalar/yeni"
@page "/faturalar/{Id:int}"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@inject IFaturaService FaturaService
@inject ICariService CariService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>@(IsEdit ? "Fatura D³zenle" : "Yeni Fatura")</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-receipt me-2"></i>@(IsEdit ? "Fatura D³zenle" : "Yeni Fatura")</h3>
        <button class="btn btn-secondary" @onclick="Geri">
            <i class="bi bi-arrow-left me-1"></i>Geri
        </button>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-3">
                <div class="card-header">
                    <h6 class="mb-0">Fatura Bilgileri</h6>
                </div>
                <div class="card-body">
                    <EditForm Model="fatura" OnValidSubmit="Kaydet">
                        <DataAnnotationsValidator />

                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Fatura No *</label>
                                    <InputText @bind-Value="fatura.FaturaNo" class="form-control" readonly="@IsEdit" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Fatura Tarihi *</label>
                                    <InputDate @bind-Value="fatura.FaturaTarihi" class="form-control" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Vade Tarihi</label>
                                    <InputDate @bind-Value="fatura.VadeTarihi" class="form-control" />
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Fatura Tipi *</label>
                                    <InputSelect @bind-Value="fatura.FaturaTipi" class="form-select" @onchange="TipDegisti">
                                        @foreach (FaturaTipi tip in Enum.GetValues(typeof(FaturaTipi)))
                                        {
                                            <option value="@tip">@GetTipText(tip)</option>
                                        }
                                    </InputSelect>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Cari *</label>
                                    <InputSelect @bind-Value="fatura.CariId" class="form-select">
                                        <option value="0">-- Cari Seńiniz --</option>
                                        @foreach (var cari in cariler)
                                        {
                                            <option value="@cari.Id">@cari.Unvan</option>
                                        }
                                    </InputSelect>
                                </div>
                            </div>
                        </div>

                        <hr />
                        <h6>Fatura Kalemleri</h6>

                        <div class="table-responsive mb-3">
                            <table class="table table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 40%;">Ań²klama</th>
                                        <th style="width: 10%;">Miktar</th>
                                        <th style="width: 10%;">Birim</th>
                                        <th style="width: 15%;">Birim Fiyat</th>
                                        <th style="width: 10%;">KDV %</th>
                                        <th style="width: 15%;">Toplam</th>
                                        <th style="width: 50px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < fatura.FaturaKalemleri.Count; i++)
                                    {
                                        var index = i;
                                        var kalem = fatura.FaturaKalemleri.ElementAt(index);
                                        <tr>
                                            <td>
                                                <input type="text" class="form-control form-control-sm" @bind="kalem.Aciklama" />
                                            </td>
                                            <td>
                                                <input type="number" class="form-control form-control-sm" @bind="kalem.Miktar" @bind:after="HesaplaToplam" step="0.01" />
                                            </td>
                                            <td>
                                                <input type="text" class="form-control form-control-sm" @bind="kalem.Birim" />
                                            </td>
                                            <td>
                                                <input type="number" class="form-control form-control-sm" @bind="kalem.BirimFiyat" @bind:after="HesaplaToplam" step="0.01" />
                                            </td>
                                            <td>
                                                <input type="number" class="form-control form-control-sm" @bind="kalem.KdvOrani" @bind:after="HesaplaToplam" />
                                            </td>
                                            <td class="text-end">
                                                <strong>@((kalem.Miktar * kalem.BirimFiyat * (1 + kalem.KdvOrani / 100)).ToString("N2")) ?</strong>
                                            </td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => KalemSil(index)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <button type="button" class="btn btn-outline-primary btn-sm mb-3" @onclick="KalemEkle">
                            <i class="bi bi-plus me-1"></i>Kalem Ekle
                        </button>

                        <div class="mb-3">
                            <label class="form-label">Ań²klama</label>
                            <InputTextArea @bind-Value="fatura.Aciklama" class="form-control" rows="2" />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg me-1"></i>Kaydet
                            </button>
                            <button type="button" class="btn btn-secondary" @onclick="Geri">
                                <i class="bi bi-x-lg me-1"></i>▌ptal
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0">Toplam</h6>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Ara Toplam:</span>
                        <strong>@araToplam.ToString("N2") ?</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>KDV Toplam:</span>
                        <strong>@kdvToplam.ToString("N2") ?</strong>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between">
                        <span class="h5">Genel Toplam:</span>
                        <strong class="h5 text-primary">@genelToplam.ToString("N2") ?</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int? Id { get; set; }

    private Fatura fatura = new();
    private List<Cari> cariler = new();
    private bool IsEdit => Id.HasValue;

    private decimal araToplam => fatura.FaturaKalemleri.Sum(k => k.Miktar * k.BirimFiyat);
    private decimal kdvToplam => fatura.FaturaKalemleri.Sum(k => k.Miktar * k.BirimFiyat * k.KdvOrani / 100);
    private decimal genelToplam => araToplam + kdvToplam;

    protected override async Task OnInitializedAsync()
    {
        cariler = await CariService.GetAllAsync();

        if (IsEdit)
        {
            var existing = await FaturaService.GetByIdWithKalemlerAsync(Id!.Value);
            if (existing != null)
            {
                fatura = existing;
            }
            else
            {
                Navigation.NavigateTo("/faturalar");
            }
        }
        else
        {
            fatura.FaturaTipi = FaturaTipi.SatisFaturasi;
            fatura.FaturaNo = await FaturaService.GenerateNextFaturaNoAsync(FaturaTipi.SatisFaturasi);
            fatura.FaturaTarihi = DateTime.Today;
            fatura.VadeTarihi = DateTime.Today.AddDays(30);
            fatura.Durum = FaturaDurum.Beklemede;
            KalemEkle();
        }
    }

    private async Task TipDegisti(ChangeEventArgs e)
    {
        if (!IsEdit && Enum.TryParse<FaturaTipi>(e.Value?.ToString(), out var tip))
        {
            fatura.FaturaTipi = tip;
            fatura.FaturaNo = await FaturaService.GenerateNextFaturaNoAsync(tip);
        }
    }

    private void KalemEkle()
    {
        fatura.FaturaKalemleri.Add(new FaturaKalem
        {
            SiraNo = fatura.FaturaKalemleri.Count + 1,
            Miktar = 1,
            Birim = "Adet",
            KdvOrani = 20
        });
    }

    private void KalemSil(int index)
    {
        var kalem = fatura.FaturaKalemleri.ElementAt(index);
        fatura.FaturaKalemleri.Remove(kalem);
    }

    private void HesaplaToplam()
    {
        StateHasChanged();
    }

    private async Task Kaydet()
    {
        if (fatura.CariId == 0 || !fatura.FaturaKalemleri.Any())
            return;

        fatura.AraToplam = araToplam;
        fatura.KdvTutar = kdvToplam;
        fatura.GenelToplam = genelToplam;

        if (IsEdit)
        {
            await FaturaService.UpdateAsync(fatura);
        }
        else
        {
            await FaturaService.CreateAsync(fatura);
        }
        Navigation.NavigateTo("/faturalar");
    }

    private void Geri()
    {
        Navigation.NavigateTo("/faturalar");
    }

    private string GetTipText(FaturaTipi tip) => tip switch
    {
        FaturaTipi.SatisFaturasi => "Sat²■ Faturas²",
        FaturaTipi.AlisFaturasi => "Al²■ Faturas²",
        FaturaTipi.SatisIadeFaturasi => "Sat²■ ▌ade Faturas²",
        FaturaTipi.AlisIadeFaturasi => "Al²■ ▌ade Faturas²",
        _ => tip.ToString()
    };
}
