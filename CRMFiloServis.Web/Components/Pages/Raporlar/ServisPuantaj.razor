@page "/rapor/servis-puantaj"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@inject IToastService ToastService
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Servis Araç Puantaj Listesi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0"><i class="bi bi-calendar-grid-3x3 me-2 text-primary"></i>Aylık Servis Puantaj Listesi</h3>
            <small class="text-muted">Servis araçlarının ay içerisindeki çalışma günleri (Excel Aktarım / Toplu İşlem Modülü)</small>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-success btn-sm">
                <i class="bi bi-file-excel me-1"></i>Excel'e Aktar
            </button>
            <button class="btn btn-primary btn-sm">
                <i class="bi bi-save me-1"></i>Kaydet
            </button>
        </div>
    </div>

    <!-- FİLTRE KART -->
    <div class="card shadow-sm mb-3">
        <div class="card-body py-2 bg-light">
            <div class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small mb-1 fw-bold">Yıl</label>
                    <select class="form-select form-select-sm" @bind="secilenYil">
                        @for(int i = DateTime.Today.Year - 1; i <= DateTime.Today.Year; i++)
                        {
                            <option value="@i">@i</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1 fw-bold">Ay</label>
                    <select class="form-select form-select-sm" @bind="secilenAy">
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m">@m.ToString("D2")</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1 fw-bold">Vardiya Türü</label>
                    <select class="form-select form-select-sm">
                        <option value="">Tümü</option>
                        <option value="sabah">Sabah Servisi</option>
                        <option value="aksam">Akşam Servisi</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1 fw-bold">Araç Arama</label>
                    <input type="text" class="form-control form-control-sm" placeholder="Plaka..." />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-secondary btn-sm w-100" @onclick="Yenile"><i class="bi bi-arrow-clockwise me-1"></i>Yenile</button>
                </div>
            </div>
        </div>
    </div>

    <!-- PUANTAJ TABLOSU -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive" style="max-height: 60vh;">
                <table class="table table-bordered table-hover table-sm text-center mb-0 align-middle">
                    <thead class="table-dark sticky-top">
                        <tr>
                            <th class="align-middle text-start" style="min-width: 150px; position: sticky; left: 0; z-index: 2; background-color: #212529;">Araç Plakası</th>
                            <th class="align-middle text-start" style="min-width: 150px; position: sticky; left: 150px; z-index: 2; background-color: #212529;">Şoför / Sahibi</th>

                            @for(int gun = 1; gun <= DateTime.DaysInMonth(secilenYil, secilenAy); gun++)
                            {
                                var date = new DateTime(secilenYil, secilenAy, gun);
                                var isWeekend = date.DayOfWeek == DayOfWeek.Sunday || date.DayOfWeek == DayOfWeek.Saturday;
                                <th style="width: 35px; @(isWeekend ? "background-color: #c79595; color: white;" : "")" title="@date.ToString("dd MMMM dddd")">
                                    @gun<br/><small style="font-size:10px;">@date.ToString("ddd").Substring(0,2)</small>
                                </th>
                            }
                            <th class="align-middle bg-primary text-white" style="min-width: 60px;">Toplam Gün</th>
                            <th class="align-middle bg-success text-white" style="min-width: 90px;">Hakediş</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var arac in mockPuantajList)
                        {
                            <tr>
                                <td class="text-start fw-bold" style="position: sticky; left: 0; background-color: white; z-index: 1;">@arac.Plaka</td>
                                <td class="text-start text-muted" style="position: sticky; left: 150px; background-color: white; z-index: 1;"><small>@arac.CariAd</small></td>

                                @for(int gun = 1; gun <= DateTime.DaysInMonth(secilenYil, secilenAy); gun++)
                                {
                                    var isWk = new DateTime(secilenYil, secilenAy, gun).DayOfWeek == DayOfWeek.Sunday;
                                    var cellColor = isWk ? "#fdf2f2" : "transparent";

                                    <td class="p-0 align-middle" style="background-color: @cellColor;">
                                        <!-- Editable Input for exact attendance: 1=worked, 0=absent, 0.5=half day, etc -->
                                        <input type="text" class="form-control form-control-sm text-center border-0 shadow-none p-0 h-100" 
                                               style="font-size: 13px; font-weight: bold; background: transparent; cursor: pointer;"
                                               value="@(isWk ? "" : "X")"
                                               maxlength="2" />
                                    </td>
                                }
                                <td class="fw-bold fs-6 text-primary">@arac.CalisanGun</td>
                                <td class="text-success fw-bold text-end pe-2" style="font-size: 13px;">@((arac.CalisanGun * 850).ToString("C0"))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="card-footer bg-light p-2 d-flex justify-content-between align-items-center">
                <small class="text-muted"><i class="bi bi-info-circle me-1"></i>Kısaltmalar: <strong>X</strong>=Tam Gün, <strong>D</strong>=Devamsız, <strong>R</strong>=Raporlu, <strong>Y</strong>=Yarım Gün</small>
            </div>
        </div>
    </div>
</div>

@code {
    private int secilenYil = DateTime.Today.Year;
    private int secilenAy = DateTime.Today.Month;

    private List<MockPuantaj> mockPuantajList = new();

    protected override void OnInitialized()
    {
        Yenile();
    }

    private void Yenile()
    {
        mockPuantajList.Clear();
        var plakaList = new[] { "34 ABC 123", "34 DEF 456", "34 GHI 789", "34 JKL 012", "34 MNO 345" };
        var cariList = new[] { "Ahmet Yılmaz", "Mehmet Kaya", "Ayşe Demir", "Koç Taşımacılık", "Yıldız Seyahat" };

        for(int i = 0; i < 5; i++)
        {
            var workingDays = Enumerable.Range(1, DateTime.DaysInMonth(secilenYil, secilenAy))
                               .Count(d => new DateTime(secilenYil, secilenAy, d).DayOfWeek != DayOfWeek.Sunday);

            mockPuantajList.Add(new MockPuantaj
            {
                Plaka = plakaList[i],
                CariAd = cariList[i],
                CalisanGun = workingDays - (i % 2 == 0 ? 1 : 0) // Rastgele gun cikart
            });
        }
    }

    public class MockPuantaj
    {
        public string Plaka { get; set; } = "";
        public string CariAd { get; set; } = "";
        public int CalisanGun { get; set; }
    }
}
