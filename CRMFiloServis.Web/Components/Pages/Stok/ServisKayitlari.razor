@page "/stok/servis"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@inject IStokService StokService
@inject IAracService AracService
@inject ICariService CariService
@inject NavigationManager Navigation
@inject IToastService ToastService
@rendermode InteractiveServer

<PageTitle>Servis Kayıtları</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">
            <i class="bi bi-tools me-2"></i>Servis Kayıtları
        </h3>
        <div>
            <button class="btn btn-outline-secondary me-2" @onclick='() => Navigation.NavigateTo("/stok")'>
                <i class="bi bi-arrow-left me-1"></i>Geri
            </button>
            <button class="btn btn-success" @onclick="YeniServis">
                <i class="bi bi-plus-lg me-1"></i>Yeni Servis Kaydı
            </button>
        </div>
    </div>

    <!-- Filtreler -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Araç</label>
                    <select class="form-select" @bind="filtreAracId" @bind:after="LoadDataAsync">
                        <option value="">Tümü</option>
                        @foreach (var arac in araclar)
                        {
                            <option value="@arac.Id">@arac.AktifPlaka - @arac.Marka @arac.Model</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Servis Tipi</label>
                    <select class="form-select" @bind="filtreServisTipi" @bind:after="LoadDataAsync">
                        <option value="">Tümü</option>
                        @foreach (var tip in Enum.GetValues<ServisTipi>())
                        {
                            <option value="@tip">@GetServisTipiAdi(tip)</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Başlangıç Tarihi</label>
                    <input type="date" class="form-control" @bind="filtreBaslangic" @bind:after="LoadDataAsync" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Bitiş Tarihi</label>
                    <input type="date" class="form-control" @bind="filtreBitis" @bind:after="LoadDataAsync" />
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Tarih</th>
                                <th>Araç</th>
                                <th>Servis Tipi</th>
                                <th>Servis Adı</th>
                                <th>Servisci</th>
                                <th class="text-end">İşçilik</th>
                                <th class="text-end">Parça</th>
                                <th class="text-end">Toplam</th>
                                <th>Km</th>
                                <th>Durum</th>
                                <th class="text-center">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (servisler.Any())
                            {
                                @foreach (var servis in servisler)
                                {
                                    <tr>
                                        <td>@servis.ServisTarihi.ToString("dd.MM.yyyy")</td>
                                        <td>
                                            <strong>@servis.Arac?.AktifPlaka</strong><br/>
                                            <small class="text-muted">@servis.Arac?.Marka @servis.Arac?.Model</small>
                                        </td>
                                        <td><span class="badge bg-info">@GetServisTipiAdi(servis.ServisTipi)</span></td>
                                        <td>@servis.ServisAdi</td>
                                        <td>@(servis.ServisciCari?.Unvan ?? "-")</td>
                                        <td class="text-end">@servis.IscilikTutari.ToString("N2") ₺</td>
                                        <td class="text-end">@servis.ParcaTutari.ToString("N2") ₺</td>
                                        <td class="text-end fw-bold">@servis.ToplamTutar.ToString("N2") ₺</td>
                                        <td>@(servis.Kilometre?.ToString("N0") ?? "-")</td>
                                        <td>
                                            <span class="badge @GetDurumBadge(servis.Durum)">
                                                @GetDurumAdi(servis.Durum)
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => DuzenleServis(servis)" title="Düzenle">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-info me-1" @onclick="() => DetayGoster(servis)" title="Detay">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => SilServis(servis)" title="Sil">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="11" class="text-center text-muted py-4">
                                        <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                                        <p class="mb-0 mt-2">Kayıt bulunamadı</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            @if (servisler.Any())
            {
                <div class="card-footer">
                    <div class="row">
                        <div class="col-md-4">
                            <strong>Toplam Kayıt:</strong> @servisler.Count
                        </div>
                        <div class="col-md-4 text-center">
                            <strong>Toplam İşçilik:</strong> @servisler.Sum(s => s.IscilikTutari).ToString("N2") ₺
                        </div>
                        <div class="col-md-4 text-end">
                            <strong>Genel Toplam:</strong> @servisler.Sum(s => s.ToplamTutar).ToString("N2") ₺
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Servis Modal -->
@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-tools me-2"></i>
                        @(editingServis?.Id > 0 ? "Servis Kaydı Düzenle" : "Yeni Servis Kaydı")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="editingServis" OnValidSubmit="SaveServis">
                        <DataAnnotationsValidator />
                        
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Araç *</label>
                                <InputSelect class="form-select" @bind-Value="editingServis!.AracId">
                                    <option value="0">Seçiniz</option>
                                    @foreach (var arac in araclar)
                                    {
                                        <option value="@arac.Id">@arac.AktifPlaka - @arac.Marka @arac.Model</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Servis Tarihi *</label>
                                <InputDate class="form-control" @bind-Value="editingServis.ServisTarihi" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Kilometre</label>
                                <InputNumber class="form-control" @bind-Value="editingServis.Kilometre" />
                            </div>
                            
                            <div class="col-md-4">
                                <label class="form-label">Servis Tipi</label>
                                <InputSelect class="form-select" @bind-Value="editingServis.ServisTipi">
                                    @foreach (var tip in Enum.GetValues<ServisTipi>())
                                    {
                                        <option value="@tip">@GetServisTipiAdi(tip)</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Servisci Firma</label>
                                <InputSelect class="form-select" @bind-Value="editingServis.ServisciCariId">
                                    <option value="">Seçiniz</option>
                                    @foreach (var cari in cariler)
                                    {
                                        <option value="@cari.Id">@cari.Unvan</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Durum</label>
                                <InputSelect class="form-select" @bind-Value="editingServis.Durum">
                                    @foreach (var durum in Enum.GetValues<ServisDurum>())
                                    {
                                        <option value="@durum">@GetDurumAdi(durum)</option>
                                    }
                                </InputSelect>
                            </div>
                            
                            <div class="col-12">
                                <label class="form-label">Servis Adı *</label>
                                <InputText class="form-control" @bind-Value="editingServis.ServisAdi" />
                            </div>
                            
                            <div class="col-md-4">
                                <label class="form-label">İşçilik Tutarı</label>
                                <InputNumber class="form-control" @bind-Value="editingServis.IscilikTutari" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">KDV Oranı (%)</label>
                                <InputNumber class="form-control" @bind-Value="editingServis.KdvOrani" />
                            </div>
                            <div class="col-md-4">
                                <div class="form-check mt-4">
                                    <InputCheckbox class="form-check-input" @bind-Value="editingServis.GarantiKapsaminda" id="garanti" />
                                    <label class="form-check-label" for="garanti">Garanti Kapsamında</label>
                                </div>
                            </div>
                            
                            <div class="col-12">
                                <label class="form-label">Açıklama</label>
                                <InputTextArea class="form-control" @bind-Value="editingServis.Aciklama" rows="2" />
                            </div>
                            
                            <div class="col-12">
                                <label class="form-label">Notlar</label>
                                <InputTextArea class="form-control" @bind-Value="editingServis.Notlar" rows="2" />
                            </div>
                        </div>
                        
                        <div class="mt-4 d-flex justify-content-end">
                            <button type="button" class="btn btn-secondary me-2" @onclick="CloseModal">İptal</button>
                            <button type="submit" class="btn btn-primary" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                Kaydet
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<!-- Detay Modal -->
@if (showDetayModal && selectedServis != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-tools me-2"></i>Servis Detayı
                    </h5>
                    <button type="button" class="btn-close" @onclick="() => showDetayModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <strong>Araç:</strong> @selectedServis.Arac?.AktifPlaka - @selectedServis.Arac?.Marka @selectedServis.Arac?.Model
                        </div>
                        <div class="col-md-6">
                            <strong>Tarih:</strong> @selectedServis.ServisTarihi.ToString("dd.MM.yyyy")
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <strong>Servis Tipi:</strong> @GetServisTipiAdi(selectedServis.ServisTipi)
                        </div>
                        <div class="col-md-6">
                            <strong>Servisci:</strong> @(selectedServis.ServisciCari?.Unvan ?? "-")
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-12">
                            <strong>Servis Adı:</strong> @selectedServis.ServisAdi
                        </div>
                    </div>
                    
                    @if (selectedServis.Parcalar?.Any() == true)
                    {
                        <h6 class="mt-4">Kullanılan Parçalar</h6>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Parça Adı</th>
                                    <th class="text-end">Miktar</th>
                                    <th class="text-end">Birim Fiyat</th>
                                    <th class="text-end">Toplam</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var parca in selectedServis.Parcalar)
                                {
                                    <tr>
                                        <td>@parca.ParcaAdi</td>
                                        <td class="text-end">@parca.Miktar @parca.Birim</td>
                                        <td class="text-end">@parca.BirimFiyat.ToString("N2") ₺</td>
                                        <td class="text-end">@parca.ToplamTutar.ToString("N2") ₺</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    
                    <hr />
                    <div class="row">
                        <div class="col-md-4"><strong>İşçilik:</strong> @selectedServis.IscilikTutari.ToString("N2") ₺</div>
                        <div class="col-md-4"><strong>Parça:</strong> @selectedServis.ParcaTutari.ToString("N2") ₺</div>
                        <div class="col-md-4"><strong>KDV:</strong> @selectedServis.KdvTutar.ToString("N2") ₺</div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-12 text-end">
                            <h4><strong>Toplam:</strong> @selectedServis.ToplamTutar.ToString("N2") ₺</h4>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showDetayModal = false">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool showModal = false;
    private bool showDetayModal = false;
    private bool isSaving = false;
    
    private List<ServisKaydi> servisler = new();
    private List<Arac> araclar = new();
    private List<Cari> cariler = new();
    private ServisKaydi? editingServis;
    private ServisKaydi? selectedServis;
    
    // Filtreler
    private int? filtreAracId;
    private ServisTipi? filtreServisTipi;
    private DateTime? filtreBaslangic;
    private DateTime? filtreBitis;

    protected override async Task OnInitializedAsync()
    {
        araclar = await AracService.GetAllAsync();
        cariler = await CariService.GetAllAsync();
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            servisler = await StokService.GetServisKayitlariAsync(filtreAracId, filtreServisTipi, filtreBaslangic, filtreBitis);
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Veri yüklenirken hata: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void YeniServis()
    {
        editingServis = new ServisKaydi
        {
            ServisTarihi = DateTime.Today,
            ServisTipi = ServisTipi.PeriyodikBakim,
            KdvOrani = 20,
            Durum = ServisDurum.Tamamlandi
        };
        showModal = true;
    }

    private void DuzenleServis(ServisKaydi servis)
    {
        editingServis = new ServisKaydi
        {
            Id = servis.Id,
            AracId = servis.AracId,
            ServisTarihi = servis.ServisTarihi,
            ServisciCariId = servis.ServisciCariId,
            ServisTipi = servis.ServisTipi,
            ServisAdi = servis.ServisAdi,
            Aciklama = servis.Aciklama,
            IscilikTutari = servis.IscilikTutari,
            KdvOrani = servis.KdvOrani,
            Kilometre = servis.Kilometre,
            Durum = servis.Durum,
            GarantiKapsaminda = servis.GarantiKapsaminda,
            Notlar = servis.Notlar
        };
        showModal = true;
    }

    private async Task DetayGoster(ServisKaydi servis)
    {
        selectedServis = await StokService.GetServisKaydiByIdAsync(servis.Id);
        showDetayModal = true;
    }

    private async Task SaveServis()
    {
        if (editingServis == null || editingServis.AracId == 0) return;
        
        try
        {
            isSaving = true;
            
            if (editingServis.Id > 0)
            {
                await StokService.UpdateServisKaydiAsync(editingServis);
                ToastService.ShowSuccess("Servis kaydı güncellendi");
            }
            else
            {
                await StokService.CreateServisKaydiAsync(editingServis);
                ToastService.ShowSuccess("Servis kaydı oluşturuldu");
            }
            
            showModal = false;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Kayıt hatası: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task SilServis(ServisKaydi servis)
    {
        try
        {
            await StokService.DeleteServisKaydiAsync(servis.Id);
            ToastService.ShowSuccess("Servis kaydı silindi");
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Silme hatası: {ex.Message}");
        }
    }

    private void CloseModal()
    {
        showModal = false;
        editingServis = null;
    }

    private string GetServisTipiAdi(ServisTipi tip) => tip switch
    {
        ServisTipi.PeriyodikBakim => "Periyodik Bakım",
        ServisTipi.Onarim => "Onarım",
        ServisTipi.Kasko => "Kasko",
        ServisTipi.TrafikSigortasi => "Trafik Sigortası",
        ServisTipi.Muayene => "Muayene",
        ServisTipi.LastikDegisimi => "Lastik Değişimi",
        ServisTipi.YagDegisimi => "Yağ Değişimi",
        ServisTipi.FrenBakimi => "Fren Bakımı",
        ServisTipi.KlimaBakimi => "Klima Bakımı",
        ServisTipi.MotorBakimi => "Motor Bakımı",
        ServisTipi.KaportaBoya => "Kaporta/Boya",
        ServisTipi.CamDegisimi => "Cam Değişimi",
        ServisTipi.AkuDegisimi => "Akü Değişimi",
        ServisTipi.Cekici => "Çekici",
        _ => "Diğer"
    };

    private string GetDurumAdi(ServisDurum durum) => durum switch
    {
        ServisDurum.Beklemede => "Beklemede",
        ServisDurum.Devam => "Devam Ediyor",
        ServisDurum.Tamamlandi => "Tamamlandı",
        ServisDurum.IptalEdildi => "İptal Edildi",
        _ => durum.ToString()
    };

    private string GetDurumBadge(ServisDurum durum) => durum switch
    {
        ServisDurum.Beklemede => "bg-warning",
        ServisDurum.Devam => "bg-info",
        ServisDurum.Tamamlandi => "bg-success",
        ServisDurum.IptalEdildi => "bg-secondary",
        _ => "bg-secondary"
    };
}
