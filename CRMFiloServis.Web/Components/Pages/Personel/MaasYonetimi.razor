@page "/personel/maas"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@using CRMFiloServis.Web.Services.Interfaces
@inject IPersonelMaasIzinService PersonelService
@inject IPersonelFinansService PersonelFinansService
@inject ISoforService SoforService
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Personel Maaş Yönetimi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-cash-stack me-2"></i>Personel Maaş Yönetimi</h3>
        <div class="d-flex gap-2">
            <select class="form-select" style="width: 120px;" @bind="secilenYil" @bind:after="YenileData">
                @for (int y = DateTime.Today.Year; y >= DateTime.Today.Year - 3; y--)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <select class="form-select" style="width: 150px;" @bind="secilenAy" @bind:after="YenileData">
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m">@(new DateTime(2024, m, 1).ToString("MMMM"))</option>
                }
            </select>
            <button class="btn btn-success" @onclick="TopluMaasOlustur">
                <i class="bi bi-plus-circle me-1"></i>Toplu Maaş Oluştur
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (maasRapor != null)
    {
        <!-- Özet Kartları -->
        <div class="row mb-4">
            <div class="col-md-2">
                <div class="card bg-primary text-white">
                    <div class="card-body text-center py-2">
                        <h6 class="mb-0">Personel</h6>
                        <h4 class="mb-0">@maasRapor.PersonelSayisi</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-info text-white">
                    <div class="card-body text-center py-2">
                        <h6 class="mb-0">Brüt Maaş</h6>
                        <h5 class="mb-0">@maasRapor.ToplamBrutMaas.ToString("N0") ?</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-success text-white">
                    <div class="card-body text-center py-2">
                        <h6 class="mb-0">Net Maaş</h6>
                        <h5 class="mb-0">@maasRapor.ToplamNetMaas.ToString("N0") ?</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-warning text-dark">
                    <div class="card-body text-center py-2">
                        <h6 class="mb-0">SGK (İşçi)</h6>
                        <h5 class="mb-0">@maasRapor.ToplamSGKIsci.ToString("N0") ?</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-danger text-white">
                    <div class="card-body text-center py-2">
                        <h6 class="mb-0">SGK (İşveren)</h6>
                        <h5 class="mb-0">@maasRapor.ToplamSGKIsveren.ToString("N0") ?</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-secondary text-white">
                    <div class="card-body text-center py-2">
                        <h6 class="mb-0">Toplam Ödeme</h6>
                        <h5 class="mb-0">@maasRapor.ToplamOdeme.ToString("N0") ?</h5>
                    </div>
                </div>
            </div>
        </div>

        <!-- Maaş Listesi -->
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Personel</th>
                                <th class="text-end">Brüt Maaş</th>
                                <th class="text-end">Net Maaş</th>
                                <th class="text-end">Eklemeler</th>
                                <th class="text-end">Kesintiler</th>
                                <th class="text-end">Ödenecek</th>
                                <th class="text-center">Durum</th>
                                <th class="text-center">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var maas in maasRapor.Detaylar)
                            {
                                <tr>
                                    <td><strong>@maas.SoforAdSoyad</strong></td>
                                    <td class="text-end">@maas.BrutMaas.ToString("N0") ?</td>
                                    <td class="text-end">@maas.NetMaas.ToString("N0") ?</td>
                                    <td class="text-end text-success">+@maas.ToplamEklemeler.ToString("N0") ?</td>
                                    <td class="text-end text-danger">-@maas.ToplamKesintiler.ToString("N0") ?</td>
                                    <td class="text-end"><strong>@maas.OdenecekTutar.ToString("N0") ?</strong></td>
                                    <td class="text-center">
                                        @if (maas.OdemeDurum == "Odendi")
                                        {
                                            <span class="badge bg-success" title="@(maas.OdemeTarihi?.ToString("dd.MM.yyyy"))">
                                                <i class="bi bi-check-circle me-1"></i>Ödendi
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="bi bi-clock me-1"></i>Bekliyor
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary" @onclick="() => DuzenleAc(maas.MaasId)" title="Düzenle">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            @if (maas.OdemeDurum != "Odendi")
                                            {
                                                <button class="btn btn-outline-success" @onclick="() => OdemeModalAc(maas)" title="Ödeme Yap" disabled="@isOdemeYapiliyor">
                                                    <i class="bi bi-cash-coin"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-outline-warning btn-sm" @onclick="() => OdemeIptalEt(maas.MaasId)" title="Ödemeyi İptal Et">
                                                    <i class="bi bi-arrow-counterclockwise"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<!-- Maaş Düzenleme Modal -->
@if (duzenlenenMaas != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Maaş Düzenle - @duzenlenenMaas.Sofor?.TamAd</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="text-primary">Maaş Bilgileri</h6>
                            <div class="mb-2">
                                <label class="form-label small">Brüt Maaş</label>
                                <input type="number" class="form-control form-control-sm" @bind="duzenlenenMaas.BrutMaas" />
                            </div>
                            <div class="mb-2">
                                <label class="form-label small">Net Maaş</label>
                                <input type="number" class="form-control form-control-sm" @bind="duzenlenenMaas.NetMaas" />
                            </div>
                            <div class="mb-2">
                                <label class="form-label small">Çalışma Günü</label>
                                <input type="number" class="form-control form-control-sm" @bind="duzenlenenMaas.CalismaGunu" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-success">Ek Ödemeler</h6>
                            <div class="row">
                                <div class="col-6 mb-2">
                                    <label class="form-label small">Prim</label>
                                    <input type="number" class="form-control form-control-sm" @bind="duzenlenenMaas.Prim" />
                                </div>
                                <div class="col-6 mb-2">
                                    <label class="form-label small">İkramiye</label>
                                    <input type="number" class="form-control form-control-sm" @bind="duzenlenenMaas.Ikramiye" />
                                </div>
                                <div class="col-6 mb-2">
                                    <label class="form-label small">Mesai</label>
                                    <input type="number" class="form-control form-control-sm" @bind="duzenlenenMaas.Mesai" />
                                </div>
                                <div class="col-6 mb-2">
                                    <label class="form-label small">Yemek</label>
                                    <input type="number" class="form-control form-control-sm" @bind="duzenlenenMaas.Yemek" />
                                </div>
                                <div class="col-6 mb-2">
                                    <label class="form-label small">Yol Parası</label>
                                    <input type="number" class="form-control form-control-sm" @bind="duzenlenenMaas.Yol" />
                                </div>
                                <div class="col-6 mb-2">
                                    <label class="form-label small">Diğer Eklemeler</label>
                                    <input type="number" class="form-control form-control-sm" @bind="duzenlenenMaas.DigerEklemeler" />
                                </div>
                            </div>
                        </div>
                    </div>
                    <hr />
                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="text-danger">Kesintiler</h6>
                            <div class="row">
                                <div class="col-6 mb-2">
                                    <label class="form-label small">Avans</label>
                                    <input type="number" class="form-control form-control-sm" @bind="duzenlenenMaas.Avans" />
                                </div>
                                <div class="col-6 mb-2">
                                    <label class="form-label small">İcra Takibi</label>
                                    <input type="number" class="form-control form-control-sm" @bind="duzenlenenMaas.IcraTakibi" />
                                </div>
                            </div>

                            <div class="mt-3 border rounded p-3 bg-light-subtle">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="mb-0 text-dark"><i class="bi bi-wallet2 me-2"></i>Açık Avans Mahsubu</h6>
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="AcikAvanslariMaasaMahsupEt"
                                            disabled="@(isMahsupUygulaniyor || !acikAvanslar.Any() || MahsupEdilebilirTutar <= 0 || duzenlenenMaas.OdemeDurum == MaasOdemeDurum.Odendi)">
                                        @if (isMahsupUygulaniyor)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        <i class="bi bi-arrow-down-circle me-1"></i>Maaşa Mahsup Et
                                    </button>
                                </div>

                                <div class="small text-muted mb-2">
                                    Açık Avans: <strong>@ToplamAcikAvans.ToString("N2") ₺</strong> |
                                    Mahsup Edilebilir: <strong>@MahsupEdilebilirTutar.ToString("N2") ₺</strong>
                                </div>

                                @if (acikAvanslar.Any())
                                {
                                    <div class="table-responsive">
                                        <table class="table table-sm table-bordered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>Tarih</th>
                                                    <th class="text-end">Tutar</th>
                                                    <th class="text-end">Mahsup</th>
                                                    <th class="text-end">Kalan</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var avans in acikAvanslar)
                                                {
                                                    <tr>
                                                        <td>@avans.AvansTarihi.ToString("dd.MM.yyyy")</td>
                                                        <td class="text-end">@avans.Tutar.ToString("N2") ₺</td>
                                                        <td class="text-end">@avans.MahsupEdilen.ToString("N2") ₺</td>
                                                        <td class="text-end text-danger"><strong>@avans.Kalan.ToString("N2") ₺</strong></td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <div class="small text-muted">Bu personel için açık avans bulunmuyor.</div>
                                }
                            </div>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-info">Hesaplanan</h6>
                            <table class="table table-sm">
                                <tr>
                                    <td>Ödenecek Tutar:</td>
                                    <td class="text-end"><strong>@duzenlenenMaas.OdenecekTutar.ToString("N0") ?</strong></td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="ModalKapat">İptal</button>
                    <button class="btn btn-primary" @onclick="MaasKaydet">Kaydet</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Ödeme Onay Modalı -->
@if (odemeOnayModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-cash-coin me-2"></i>Ödeme Yap</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="OdemeModalKapat"></button>
                </div>
                <div class="modal-body">
                    @if (secilenOdemeMaas != null)
                    {
                        <div class="alert alert-info">
                            <strong>@secilenOdemeMaas.SoforAdSoyad</strong> - Ödenecek Tutar: <strong>@secilenOdemeMaas.OdenecekTutar.ToString("N2") ₺</strong>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Ödeme Tarihi</label>
                            <input type="date" class="form-control" @bind="odemeTarihi" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Açıklama (Opsiyonel)</label>
                            <textarea class="form-control" rows="2" @bind="odemeAciklama" placeholder="Ödeme ile ilgili not..."></textarea>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="OdemeModalKapat" disabled="@isOdemeYapiliyor">İptal</button>
                    <button class="btn btn-success" @onclick="OdemeOnayla" disabled="@isOdemeYapiliyor">
                        @if (isOdemeYapiliyor)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                            <span>İşleniyor...</span>
                        }
                        else
                        {
                            <i class="bi bi-check-circle me-1"></i>
                            <span>Ödemeyi Onayla</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Bildirim Toast -->
@if (!string.IsNullOrEmpty(bildirimMesaj))
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999;">
        <div class="toast show" role="alert">
            <div class="toast-header @(bildirimBasarili ? "bg-success" : "bg-danger") text-white">
                <i class="bi @(bildirimBasarili ? "bi-check-circle" : "bi-exclamation-circle") me-2"></i>
                <strong class="me-auto">@(bildirimBasarili ? "Başarılı" : "Hata")</strong>
                <button type="button" class="btn-close btn-close-white" @onclick="() => bildirimMesaj = null"></button>
            </div>
            <div class="toast-body">
                @bildirimMesaj
            </div>
        </div>
    </div>
}

@code {
    private int secilenYil = DateTime.Today.Year;
    private int secilenAy = DateTime.Today.Month;
    private MaasRaporOzet? maasRapor;
    private PersonelMaas? duzenlenenMaas;
    private bool isLoading = false;
    private List<PersonelAvans> acikAvanslar = new();
    private bool isMahsupUygulaniyor = false;

    // Ödeme modal state
    private bool odemeOnayModal = false;
    private MaasDetay? secilenOdemeMaas;
    private DateTime odemeTarihi = DateTime.Today;
    private string? odemeAciklama;
    private bool isOdemeYapiliyor = false;

    // Bildirim state
    private string? bildirimMesaj;
    private bool bildirimBasarili;
    private System.Threading.Timer? bildirimTimer;

    protected override async Task OnInitializedAsync()
    {
        await YenileData();
    }

    private async Task YenileData()
    {
        isLoading = true;
        try
        {
            maasRapor = await PersonelService.GetMaasRaporuAsync(secilenYil, secilenAy);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task TopluMaasOlustur()
    {
        await PersonelService.TopluMaasOlusturAsync(secilenYil, secilenAy);
        await YenileData();
        BildirimGoster("Toplu maaş kayıtları oluşturuldu.", true);
    }

    private async Task DuzenleAc(int maasId)
    {
        duzenlenenMaas = await PersonelService.GetMaasByIdAsync(maasId);
        await AcikAvanslariYukleAsync();
    }

    private void ModalKapat()
    {
        duzenlenenMaas = null;
        acikAvanslar.Clear();
    }

    private async Task MaasKaydet()
    {
        if (duzenlenenMaas != null)
        {
            await PersonelService.UpdateMaasAsync(duzenlenenMaas);
            await AcikAvanslariYukleAsync();
            ModalKapat();
            await YenileData();
            BildirimGoster("Maaş bilgileri güncellendi.", true);
        }
    }

    private decimal ToplamAcikAvans => acikAvanslar.Sum(a => a.Kalan);

    private decimal MahsupEdilebilirTutar => duzenlenenMaas == null
        ? 0
        : Math.Max(0, duzenlenenMaas.OdenecekTutar);

    private async Task AcikAvanslariYukleAsync()
    {
        if (duzenlenenMaas == null)
        {
            acikAvanslar.Clear();
            return;
        }

        var avanslar = await PersonelFinansService.GetAvanslarAsync(personelId: duzenlenenMaas.SoforId);
        acikAvanslar = avanslar
            .Where(a => a.Durum != AvansDurum.IptalEdildi && a.Kalan > 0)
            .OrderBy(a => a.AvansTarihi)
            .ToList();
    }

    private async Task AcikAvanslariMaasaMahsupEt()
    {
        if (duzenlenenMaas == null || isMahsupUygulaniyor)
            return;

        isMahsupUygulaniyor = true;
        try
        {
            var mahsupTutar = await PersonelFinansService.MaasaAcikAvansMahsupEtAsync(
                duzenlenenMaas.Id,
                DateTime.Today,
                $"{secilenAy:D2}/{secilenYil} dönemi maaş mahsubu");

            duzenlenenMaas = await PersonelService.GetMaasByIdAsync(duzenlenenMaas.Id);
            await AcikAvanslariYukleAsync();
            await YenileData();

            BildirimGoster($"Açık avanslardan {mahsupTutar:N2} ₺ maaşa mahsup edildi.", true);
        }
        catch (Exception ex)
        {
            BildirimGoster($"Mahsup sırasında hata: {ex.Message}", false);
        }
        finally
        {
            isMahsupUygulaniyor = false;
        }
    }

    private void OdemeModalAc(MaasDetay maas)
    {
        secilenOdemeMaas = maas;
        odemeTarihi = DateTime.Today;
        odemeAciklama = null;
        odemeOnayModal = true;
    }

    private void OdemeModalKapat()
    {
        odemeOnayModal = false;
        secilenOdemeMaas = null;
        odemeAciklama = null;
    }

    private async Task OdemeOnayla()
    {
        if (secilenOdemeMaas == null) return;

        isOdemeYapiliyor = true;
        try
        {
            await PersonelService.MaasOdemeYapAsync(secilenOdemeMaas.MaasId, odemeTarihi);

            // Açıklama varsa güncelle
            if (!string.IsNullOrWhiteSpace(odemeAciklama))
            {
                var maas = await PersonelService.GetMaasByIdAsync(secilenOdemeMaas.MaasId);
                if (maas != null)
                {
                    maas.OdemeAciklama = odemeAciklama;
                    await PersonelService.UpdateMaasAsync(maas);
                }
            }

            OdemeModalKapat();
            await YenileData();
            BildirimGoster($"Ödeme başarıyla kaydedildi.", true);
        }
        catch (Exception ex)
        {
            BildirimGoster($"Ödeme sırasında hata: {ex.Message}", false);
        }
        finally
        {
            isOdemeYapiliyor = false;
        }
    }

    private async Task OdemeIptalEt(int maasId)
    {
        try
        {
            var maas = await PersonelService.GetMaasByIdAsync(maasId);
            if (maas != null)
            {
                maas.OdemeTarihi = null;
                maas.OdemeDurum = MaasOdemeDurum.Bekliyor;
                maas.OdemeAciklama = null;
                await PersonelService.UpdateMaasAsync(maas);
                await YenileData();
                BildirimGoster("Ödeme iptal edildi.", true);
            }
        }
        catch (Exception ex)
        {
            BildirimGoster($"İptal sırasında hata: {ex.Message}", false);
        }
    }

    private void BildirimGoster(string mesaj, bool basarili)
    {
        bildirimMesaj = mesaj;
        bildirimBasarili = basarili;

        // 3 saniye sonra otomatik kapat
        bildirimTimer?.Dispose();
        bildirimTimer = new System.Threading.Timer(_ =>
        {
            bildirimMesaj = null;
            InvokeAsync(StateHasChanged);
        }, null, 3000, System.Threading.Timeout.Infinite);
    }

    public void Dispose()
    {
        bildirimTimer?.Dispose();
    }
}
