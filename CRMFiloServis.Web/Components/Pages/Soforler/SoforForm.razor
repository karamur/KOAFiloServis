@page "/soforler/yeni"
@page "/soforler/{Id:int}"
@page "/personel/yeni"
@page "/personel/{Id:int}"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@inject ISoforService SoforService
@inject IToastService ToastService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>@(IsEdit ? "Personel Düzenle" : "Yeni Personel")</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-person-badge me-2"></i>@(IsEdit ? "Personel Düzenle" : "Yeni Personel")</h3>
        <button class="btn btn-secondary" @onclick="Geri">
            <i class="bi bi-arrow-left me-1"></i>Geri
        </button>
    </div>

    <div class="card">
        <div class="card-body">
            <EditForm Model="sofor" OnValidSubmit="Kaydet">
                <DataAnnotationsValidator />

                <!-- Temel Bilgiler -->
                <h5 class="text-primary mb-3"><i class="bi bi-person me-2"></i>Temel Bilgiler</h5>
                <div class="row">
                    <div class="col-md-2">
                        <div class="mb-3">
                            <label class="form-label">Sıralama No</label>
                            <InputNumber @bind-Value="sofor.SiralamaNo" class="form-control" />
                            <small class="text-muted">Bordro sıralama için</small>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="mb-3">
                            <label class="form-label">Personel Kodu *</label>
                            <InputText @bind-Value="sofor.SoforKodu" class="form-control" readonly="@IsEdit" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Ad *</label>
                            <InputText @bind-Value="sofor.Ad" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Soyad *</label>
                            <InputText @bind-Value="sofor.Soyad" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="mb-3">
                            <label class="form-label">TC Kimlik No</label>
                            <InputText @bind-Value="sofor.TcKimlikNo" class="form-control" maxlength="11" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Görev *</label>
                            <InputSelect @bind-Value="sofor.Gorev" class="form-select" @bind-Value:after="GorevDegisti">
                                @foreach (PersonelGorev gorev in Enum.GetValues(typeof(PersonelGorev)))
                                {
                                    <option value="@gorev">@GetGorevAdi(gorev)</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Departman</label>
                            <InputText @bind-Value="sofor.Departman" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Pozisyon</label>
                            <InputText @bind-Value="sofor.Pozisyon" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">İşe Başlama Tarihi</label>
                            <InputDate @bind-Value="sofor.IseBaslamaTarihi" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">İşten Çıkış Tarihi</label>
                            <InputDate @bind-Value="sofor.IstenAyrilmaTarihi" class="form-control" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">SGK Çıkış Tarihi</label>
                            <InputDate @bind-Value="sofor.SgkCikisTarihi" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Telefon</label>
                            <InputText @bind-Value="sofor.Telefon" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <InputText @bind-Value="sofor.Email" class="form-control" type="email" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Adres</label>
                            <InputText @bind-Value="sofor.Adres" class="form-control" />
                        </div>
                    </div>
                </div>

                <!-- Şoför Belgeleri (Sadece Şoför seçiliyse göster) -->
                @if (sofor.Gorev == PersonelGorev.Sofor)
                {
                    <hr />
                    <h5 class="text-primary mb-3"><i class="bi bi-file-earmark-text me-2"></i>Şoför Belgeleri</h5>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Ehliyet No</label>
                                <InputText @bind-Value="sofor.EhliyetNo" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Ehliyet Geçerlilik</label>
                                <InputDate @bind-Value="sofor.EhliyetGecerlilikTarihi" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">SRC Belgesi Geçerlilik</label>
                                <InputDate @bind-Value="sofor.SrcBelgesiGecerlilikTarihi" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Psikoteknik Geçerlilik</label>
                                <InputDate @bind-Value="sofor.PsikoteknikGecerlilikTarihi" class="form-control" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Sağlık Raporu Geçerlilik</label>
                                <InputDate @bind-Value="sofor.SaglikRaporuGecerlilikTarihi" class="form-control" />
                            </div>
                        </div>
                    </div>
                }

                <!-- Maaş ve Banka Bilgileri -->
                <hr />
                <h5 class="text-primary mb-3"><i class="bi bi-cash-stack me-2"></i>Maaş ve Banka Bilgileri</h5>
                <div class="row">
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Brüt Maaş Hesaplama Tipi</label>
                            <InputSelect @bind-Value="sofor.BrutMaasHesaplamaTipi" class="form-select" @bind-Value:after="BrutMaasHesaplaAsync">
                                <option value="@BrutMaasHesaplamaTipi.Manuel">Manuel Giriş</option>
                                <option value="@BrutMaasHesaplamaTipi.Saatlik">Saatlik Ücret</option>
                                <option value="@BrutMaasHesaplamaTipi.Gunluk">Günlük Ücret</option>
                                <option value="@BrutMaasHesaplamaTipi.Aylik">Aylık Ücret</option>
                            </InputSelect>
                        </div>
                    </div>
                    @if (sofor.BrutMaasHesaplamaTipi != BrutMaasHesaplamaTipi.Manuel)
                    {
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">@GetCalismaMiktariLabel()</label>
                                <InputNumber @bind-Value="sofor.CalismaMiktari" class="form-control" @bind-Value:after="BrutMaasHesaplaAsync" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">@GetBirimUcretLabel()</label>
                                <InputNumber @bind-Value="sofor.BirimUcret" class="form-control" @bind-Value:after="BrutMaasHesaplaAsync" />
                            </div>
                        </div>
                    }
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Brüt Maaş (₺)</label>
                            <InputNumber @bind-Value="sofor.BrutMaas" class="form-control" readonly="@(sofor.BrutMaasHesaplamaTipi != BrutMaasHesaplamaTipi.Manuel)" @bind-Value:after="BrutMaasHesaplaAsync" />
                            @if (sofor.BrutMaasHesaplamaTipi != BrutMaasHesaplamaTipi.Manuel)
                            {
                                <small class="text-muted">Hesaplanan: @sofor.CalismaMiktari x @sofor.BirimUcret = @sofor.BrutMaas.ToString("N2")</small>
                            }
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Resmi Net Maaş (₺) *</label>
                            <InputNumber @bind-Value="sofor.ResmiNetMaas" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Diğer Maaş (₺)</label>
                            <InputNumber @bind-Value="sofor.DigerMaas" class="form-control" />
                            <small class="text-muted">Kuruş farkı veya ekleme için negatif değer kullanılabilir.</small>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Net Maaş (₺)</label>
                            <input type="text" class="form-control bg-light" readonly value="@((sofor.ResmiNetMaas + sofor.DigerMaas).ToString("N2"))" />
                            <small class="text-muted">Resmi Net + Diğer = Net Maaş</small>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Banka Adı</label>
                            <InputText @bind-Value="sofor.BankaAdi" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">IBAN</label>
                            <InputText @bind-Value="sofor.IBAN" class="form-control" placeholder="TR00 0000 0000 0000 0000 0000 00" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <div class="form-check form-switch mt-4">
                                <InputCheckbox @bind-Value="sofor.SGKBordroDahilMi" class="form-check-input" id="sgkBordro" />
                                <label class="form-check-label" for="sgkBordro">
                                    <strong>SGK Bordro Düzenlensin</strong>
                                </label>
                            </div>
                        </div>
                    </div>
                    @if (sofor.SGKBordroDahilMi)
                    {
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Bordro Tipi *</label>
                                <InputSelect @bind-Value="sofor.BordroTipiPersonel" class="form-select" @bind-Value:after="BordroTipiDegisti">
                                    <option value="@PersonelBordroTipi.Normal">Normal</option>
                                    <option value="@PersonelBordroTipi.Arge">ARGE</option>
                                </InputSelect>
                            </div>
                        </div>
                    }
                </div>

                @* ARGE Personeli Uyarıları *@
                @if (sofor.SGKBordroDahilMi && sofor.BordroTipiPersonel == PersonelBordroTipi.Arge)
                {
                    <div class="alert alert-warning">
                        <h6><i class="bi bi-lightbulb me-2"></i>ARGE Personeli - Yasal Mevzuat Uyarıları</h6>
                        <ul class="mb-0 small">
                            <li>ARGE personeli 5746 sayılı Ar-Ge Faaliyetlerinin Desteklenmesi Hakkında Kanun kapsamında değerlendirilmektedir.</li>
                            <li>ARGE personeli için SGK işveren payı desteği (%100'e kadar) uygulanabilir.</li>
                            <li>Gelir vergisi stopaj teşviki uygulanabilir (Ar-Ge merkezleri için %100, diğerleri için %80).</li>
                            <li>Personelin ARGE faaliyetlerinde çalıştığını belgeleyen kayıtlar düzenli tutulmalıdır.</li>
                            <li>ARGE projelerinde çalışma süreleri ve saatleri ayrı takip edilmelidir.</li>
                        </ul>
                        @if (string.IsNullOrWhiteSpace(sofor.TcKimlikNo))
                        {
                            <div class="mt-2 text-danger">
                                <i class="bi bi-exclamation-triangle me-1"></i>
                                <strong>Uyarı:</strong> ARGE personeli için TC Kimlik No zorunludur!
                            </div>
                        }
                    </div>
                }

                <!-- Durum ve Notlar -->
                <hr />
                <div class="row">
                    <div class="col-md-2">
                        <div class="mb-3">
                            <div class="form-check form-switch mt-4">
                                <InputCheckbox @bind-Value="sofor.Aktif" class="form-check-input" id="aktif" />
                                <label class="form-check-label" for="aktif">
                                    <strong>@(sofor.Aktif ? "Aktif" : "Pasif")</strong>
                                </label>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-10">
                        <div class="mb-3">
                            <label class="form-label">Notlar</label>
                            <InputTextArea @bind-Value="sofor.Notlar" class="form-control" rows="2" />
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="Geri">
                        <i class="bi bi-x-lg me-1"></i>İptal
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int? Id { get; set; }

    private Sofor sofor = new();
    private bool IsEdit => Id.HasValue;
    private decimal ToplamNetMaas => sofor.ResmiNetMaas + sofor.DigerMaas;

    protected override async Task OnInitializedAsync()
    {
        if (IsEdit)
        {
            var existing = await SoforService.GetByIdAsync(Id!.Value);
            if (existing != null)
            {
                sofor = existing;
            }
            else
            {
                Navigation.NavigateTo("/personel");
            }
        }
        else
        {
            sofor.SoforKodu = await SoforService.GenerateNextKodAsync(sofor.Gorev);
            sofor.Aktif = true;
            sofor.Gorev = PersonelGorev.Sofor;
        }
    }

    private async Task Kaydet()
    {
        if (string.IsNullOrWhiteSpace(sofor.Ad) || string.IsNullOrWhiteSpace(sofor.Soyad))
        {
            ToastService.ShowWarning("Ad ve Soyad alanları zorunludur!");
            return;
        }

        // ARGE personeli için TC Kimlik No zorunlu
        if (sofor.SGKBordroDahilMi && sofor.BordroTipiPersonel == PersonelBordroTipi.Arge)
        {
            if (string.IsNullOrWhiteSpace(sofor.TcKimlikNo))
            {
                ToastService.ShowError("ARGE personeli için TC Kimlik No zorunludur! Yasal mevzuat gereği ARGE çalışanlarının kimlik bilgileri eksiksiz olmalıdır.");
                return;
            }

            if (sofor.TcKimlikNo.Length != 11 || !sofor.TcKimlikNo.All(char.IsDigit))
            {
                ToastService.ShowError("TC Kimlik No 11 haneli olmalıdır!");
                return;
            }
        }

        // SGK bordro dahilse ama tipi Yok seçiliyse uyar
        if (sofor.SGKBordroDahilMi && sofor.BordroTipiPersonel == PersonelBordroTipi.Yok)
        {
            sofor.BordroTipiPersonel = PersonelBordroTipi.Normal;
        }

        // SGK bordro dahil değilse tipi Yok yap
        if (!sofor.SGKBordroDahilMi)
        {
            sofor.BordroTipiPersonel = PersonelBordroTipi.Yok;
        }

        await BrutMaasHesaplaAsync();
        sofor.NetMaas = YuvarlaPara(sofor.ResmiNetMaas + sofor.DigerMaas);

        try
        {
            if (IsEdit)
            {
                await SoforService.UpdateAsync(sofor);
                ToastService.ShowSuccess($"{sofor.TamAd} başarıyla güncellendi.");
            }
            else
            {
                await SoforService.CreateAsync(sofor);
                ToastService.ShowSuccess($"{sofor.TamAd} başarıyla eklendi.");
            }
            Navigation.NavigateTo("/personel");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Kayıt sırasında hata oluştu: {ex.Message}");
        }
    }

    private void Geri()
    {
        Navigation.NavigateTo("/personel");
    }

    private async Task GorevDegisti()
    {
        if (!IsEdit)
        {
            sofor.SoforKodu = await SoforService.GenerateNextKodAsync(sofor.Gorev);
        }
    }

    private void BordroTipiDegisti()
    {
        // ARGE seçildiğinde uyarı göster
        if (sofor.BordroTipiPersonel == PersonelBordroTipi.Arge)
        {
            if (string.IsNullOrWhiteSpace(sofor.TcKimlikNo))
            {
                ToastService.ShowWarning("ARGE personeli için TC Kimlik No zorunludur! Lütfen doldurun.");
            }
            // Eski ArgePersoneli alanını da güncelle (geriye dönük uyumluluk)
            sofor.ArgePersoneli = true;
        }
        else
        {
            sofor.ArgePersoneli = false;
        }
    }

    private Task BrutMaasHesaplaAsync()
    {
        sofor.CalismaMiktari = YuvarlaPara(sofor.CalismaMiktari);
        sofor.BirimUcret = YuvarlaPara(sofor.BirimUcret);

        if (sofor.BrutMaasHesaplamaTipi != BrutMaasHesaplamaTipi.Manuel)
        {
            sofor.BrutMaas = YuvarlaPara(sofor.CalismaMiktari * sofor.BirimUcret);
        }
        else
        {
            sofor.BrutMaas = YuvarlaPara(sofor.BrutMaas);
        }

        sofor.ResmiNetMaas = YuvarlaPara(sofor.ResmiNetMaas);
        sofor.DigerMaas = YuvarlaPara(sofor.DigerMaas);
        sofor.NetMaas = YuvarlaPara(sofor.ResmiNetMaas + sofor.DigerMaas);

        return Task.CompletedTask;
    }

    private static decimal YuvarlaPara(decimal value)
        => Math.Round(value, 2, MidpointRounding.AwayFromZero);

    private string GetGorevAdi(PersonelGorev gorev)
    {
        return gorev switch
        {
            PersonelGorev.Sofor => "Şoför",
            PersonelGorev.OfisCalisani => "Ofis Çalışanı",
            PersonelGorev.Muhasebe => "Muhasebe",
            PersonelGorev.Yonetici => "Yönetici",
            PersonelGorev.Teknik => "Teknik",
            PersonelGorev.Diger => "Diğer",
            _ => gorev.ToString()
        };
    }

    private string GetCalismaMiktariLabel()
    {
        return sofor.BrutMaasHesaplamaTipi switch
        {
            BrutMaasHesaplamaTipi.Saatlik => "Çalışılan Saat",
            BrutMaasHesaplamaTipi.Gunluk => "Çalışılan Gün",
            BrutMaasHesaplamaTipi.Aylik => "Çalışılan Ay",
            _ => "Miktar"
        };
    }

    private string GetBirimUcretLabel()
    {
        return sofor.BrutMaasHesaplamaTipi switch
        {
            BrutMaasHesaplamaTipi.Saatlik => "Saatlik Ücret (₺)",
            BrutMaasHesaplamaTipi.Gunluk => "Günlük Ücret (₺)",
            BrutMaasHesaplamaTipi.Aylik => "Aylık Ücret (₺)",
            _ => "Birim Ücret (₺)"
        };
    }
}
