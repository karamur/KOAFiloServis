@page "/soforler"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@inject ISoforService SoforService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Şoförler</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-person-badge me-2"></i>Şoförler</h3>
        <button class="btn btn-primary" @onclick="YeniSofor">
            <i class="bi bi-plus-lg me-1"></i>Yeni Şoför
        </button>
    </div>

    @if (soforler == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else if (!soforler.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Henüz şoför kaydı bulunmamaktadır.
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Şoför Kodu</th>
                                <th>Ad Soyad</th>
                                <th>TC Kimlik</th>
                                <th>Telefon</th>
                                <th>Ehliyet</th>
                                <th>Durum</th>
                                <th style="width: 120px;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sofor in soforler)
                            {
                                <tr>
                                    <td><strong>@sofor.SoforKodu</strong></td>
                                    <td>@sofor.TamAd</td>
                                    <td>@sofor.TcKimlikNo</td>
                                    <td>@sofor.Telefon</td>
                                    <td>
                                        @if (sofor.EhliyetGecerlilikTarihi.HasValue)
                                        {
                                            var gunKaldi = (sofor.EhliyetGecerlilikTarihi.Value - DateTime.Today).Days;
                                            <span class="badge @(gunKaldi < 30 ? "bg-danger" : gunKaldi < 60 ? "bg-warning text-dark" : "bg-success")">
                                                @sofor.EhliyetGecerlilikTarihi.Value.ToString("dd.MM.yyyy")
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @if (sofor.Aktif)
                                        {
                                            <span class="badge bg-success">Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Pasif</span>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Duzenle(sofor.Id)" title="Düzenle">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => SilOnay(sofor)" title="Sil">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@if (showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Silme Onayı</h5>
                    <button type="button" class="btn-close" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <p><strong>@silinecekSofor?.TamAd</strong> isimli şoförü silmek istediğinize emin misiniz?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showDeleteModal = false">İptal</button>
                    <button type="button" class="btn btn-danger" @onclick="Sil">Sil</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Sofor>? soforler;
    private bool showDeleteModal = false;
    private Sofor? silinecekSofor;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        soforler = await SoforService.GetAllAsync();
    }

    private void YeniSofor()
    {
        Navigation.NavigateTo("/soforler/yeni");
    }

    private void Duzenle(int id)
    {
        Navigation.NavigateTo($"/soforler/{id}");
    }

    private void SilOnay(Sofor sofor)
    {
        silinecekSofor = sofor;
        showDeleteModal = true;
    }

    private async Task Sil()
    {
        if (silinecekSofor != null)
        {
            await SoforService.DeleteAsync(silinecekSofor.Id);
            await LoadData();
        }
        showDeleteModal = false;
        silinecekSofor = null;
    }
}
