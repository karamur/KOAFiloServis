@page "/soforler"
@page "/personel"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@inject ISoforService SoforService
@inject IPersonelOzlukService OzlukService
@inject IJSRuntime JS
@inject IToastService ToastService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Personel Listesi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-people me-2"></i>Personel Listesi</h3>
        <div class="d-flex gap-2">
            <select class="form-select" style="width: 180px;" @bind="secilenGorev" @bind:after="FiltreleAsync">
                <option value="">Tüm Personel</option>
                @foreach (PersonelGorev gorev in Enum.GetValues(typeof(PersonelGorev)))
                {
                    <option value="@gorev">@GetGorevAdi(gorev)</option>
                }
            </select>
            <div class="btn-group">
                <button class="btn btn-outline-success" @onclick="ImportSablonIndir" title="Import Şablonu İndir">
                    <i class="bi bi-download me-1"></i>Şablon
                </button>
                <button class="btn btn-success" @onclick="() => showImportModal = true" title="Excel'den Personel Yükle">
                    <i class="bi bi-upload me-1"></i>Excel Import
                </button>
                <button class="btn btn-outline-primary" @onclick="ExportToExcel" title="Excel'e Aktar">
                    <i class="bi bi-file-earmark-excel me-1"></i>Excel Export
                </button>
            </div>
            <button class="btn btn-outline-secondary" @onclick="BosPersonelDosyasiIndir">
                <i class="bi bi-file-earmark-text me-1"></i>Boş Personel Dosyası
            </button>
            <button class="btn btn-primary" @onclick="YeniPersonel">
                <i class="bi bi-plus-lg me-1"></i>Yeni Personel
            </button>
        </div>
    </div>

    @if (personeller == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else if (!personeller.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Henüz personel kaydı bulunmamaktadır.
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 70px;">Sıra No</th>
                                <th>Personel Kodu</th>
                                <th>Ad Soyad</th>
                                <th>Görev</th>
                                <th>Telefon</th>
                                <th>İşe Başlama</th>
                                <th>İşten Çıkış</th>
                                <th>SGK Çıkış</th>
                                <th class="text-end">Maaş</th>
                                <th class="text-center">Belgeler</th>
                                <th class="text-center">Durum</th>
                                <th style="width: 120px;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var personel in personeller.OrderBy(p => p.SiralamaNo == 0 ? int.MaxValue : p.SiralamaNo).ThenBy(p => p.Ad))
                            {
                                <tr>
                                    <td>
                                        <input type="number" class="form-control form-control-sm" style="width: 60px;" 
                                               value="@personel.SiralamaNo" 
                                               @onchange="(e) => SiralamaNoGuncelle(personel, e)" />
                                    </td>
                                    <td><strong>@personel.SoforKodu</strong></td>
                                    <td>@personel.TamAd</td>
                                    <td>
                                        <span class="badge @GetGorevBadgeClass(personel.Gorev)">
                                            @GetGorevAdi(personel.Gorev)
                                        </span>
                                    </td>
                                    <td>@personel.Telefon</td>
                                    <td>@personel.IseBaslamaTarihi?.ToString("dd.MM.yyyy")</td>
                                     <td>@personel.IstenAyrilmaTarihi?.ToString("dd.MM.yyyy")</td>
                                     <td>@personel.SgkCikisTarihi?.ToString("dd.MM.yyyy")</td>
                                    <td class="text-end">@personel.NetMaas.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("tr-TR"))</td>
                                    <td class="text-center">
                                        @if (personel.IsSofor)
                                        {
                                            @* Ehliyet durumu *@
                                            @if (personel.EhliyetGecerlilikTarihi.HasValue)
                                            {
                                                var gunKaldi = (personel.EhliyetGecerlilikTarihi.Value - DateTime.Today).Days;
                                                <span class="badge @(gunKaldi < 30 ? "bg-danger" : gunKaldi < 60 ? "bg-warning text-dark" : "bg-success")" 
                                                      title="Ehliyet: @personel.EhliyetGecerlilikTarihi.Value.ToString("dd.MM.yyyy")">
                                                    <i class="bi bi-card-text"></i>
                                                </span>
                                            }
                                            @* SRC durumu *@
                                            @if (personel.SrcBelgesiGecerlilikTarihi.HasValue)
                                            {
                                                var gunKaldi = (personel.SrcBelgesiGecerlilikTarihi.Value - DateTime.Today).Days;
                                                <span class="badge @(gunKaldi < 30 ? "bg-danger" : gunKaldi < 60 ? "bg-warning text-dark" : "bg-success") ms-1" 
                                                      title="SRC: @personel.SrcBelgesiGecerlilikTarihi.Value.ToString("dd.MM.yyyy")">
                                                    <i class="bi bi-file-earmark-check"></i>
                                                </span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (personel.Aktif)
                                        {
                                            <span class="badge bg-success">Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Pasif</span>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-success me-1" @onclick="() => PersonelDosyasiIndir(personel.Id)" title="Dosya Hazırla">
                                            <i class="bi bi-file-earmark-pdf"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Duzenle(personel.Id)" title="Düzenle">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => SilOnay(personel)" title="Sil">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        
        <!-- Özet Bilgiler -->
        <div class="row mt-3">
            <div class="col-md-3">
                <div class="card bg-light">
                    <div class="card-body py-2 text-center">
                        <small class="text-muted">Toplam Personel</small>
                        <h5 class="mb-0">@personeller.Count</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-light">
                    <div class="card-body py-2 text-center">
                        <small class="text-muted">Şoför Sayısı</small>
                        <h5 class="mb-0">@personeller.Count(p => p.Gorev == PersonelGorev.Sofor)</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-light">
                    <div class="card-body py-2 text-center">
                        <small class="text-muted">Aktif Personel</small>
                        <h5 class="mb-0">@personeller.Count(p => p.Aktif)</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-light">
                    <div class="card-body py-2 text-center">
                        <small class="text-muted">Toplam Maaş</small>
                        <h5 class="mb-0">@personeller.Where(p => p.Aktif).Sum(p => p.NetMaas).ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("tr-TR"))</h5>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Silme Onayı</h5>
                    <button type="button" class="btn-close" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <p><strong>@silinecekPersonel?.TamAd</strong> isimli personeli silmek istediğinize emin misiniz?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showDeleteModal = false">İptal</button>
                    <button type="button" class="btn btn-danger" @onclick="Sil">Sil</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showImportModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-upload me-2"></i>Excel'den Personel Import</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseImportModal"></button>
                </div>
                <div class="modal-body">
                    @if (importSonuc == null)
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>
                            <strong>Önemli:</strong> Import şablonunu indirip doldurun. TC Kimlik No ile mevcut personel kontrolü yapılır.
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Excel Dosyası Seçin</label>
                            <InputFile OnChange="OnFileSelected" accept=".xlsx,.xls" class="form-control" />
                        </div>

                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" @bind="mevcutGuncelle" id="mevcutGuncelle">
                            <label class="form-check-label" for="mevcutGuncelle">
                                Mevcut personelleri güncelle (TC eşleşirse)
                            </label>
                        </div>

                        @if (selectedFile != null)
                        {
                            <div class="alert alert-secondary">
                                <i class="bi bi-file-earmark-excel me-2"></i>
                                <strong>Seçilen:</strong> @selectedFile.Name (@(selectedFile.Size / 1024) KB)
                            </div>
                        }

                        @if (importHata != null)
                        {
                            <div class="alert alert-danger">
                                <i class="bi bi-exclamation-triangle me-2"></i>@importHata
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert @(importSonuc.Basarili ? "alert-success" : "alert-warning")">
                            <h5><i class="bi bi-check-circle me-2"></i>Import Tamamlandı</h5>
                        </div>

                        <div class="row text-center mb-3">
                            <div class="col-md-3">
                                <div class="card bg-light">
                                    <div class="card-body py-2">
                                        <small class="text-muted">Toplam Satır</small>
                                        <h4 class="mb-0">@importSonuc.ToplamSatir</h4>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card bg-success text-white">
                                    <div class="card-body py-2">
                                        <small>Eklenen</small>
                                        <h4 class="mb-0">@importSonuc.BasariliEklenen</h4>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card bg-info text-white">
                                    <div class="card-body py-2">
                                        <small>Güncellenen</small>
                                        <h4 class="mb-0">@importSonuc.BasariliGuncellenen</h4>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card bg-warning">
                                    <div class="card-body py-2">
                                        <small>Atlanan</small>
                                        <h4 class="mb-0">@importSonuc.Atlanan</h4>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @if (importSonuc.Hatalar.Any())
                        {
                            <div class="card">
                                <div class="card-header bg-warning">
                                    <i class="bi bi-exclamation-triangle me-2"></i>Uyarılar ve Hatalar
                                </div>
                                <div class="card-body" style="max-height: 200px; overflow-y: auto;">
                                    <ul class="mb-0">
                                        @foreach (var hata in importSonuc.Hatalar.Take(20))
                                        {
                                            <li class="@(hata.Kritik ? "text-danger" : "text-warning")">
                                                <strong>Satır @hata.SatirNo:</strong> [@hata.Kolon] @hata.Mesaj
                                            </li>
                                        }
                                        @if (importSonuc.Hatalar.Count > 20)
                                        {
                                            <li class="text-muted">...ve @(importSonuc.Hatalar.Count - 20) hata daha</li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        }
                    }
                </div>
                <div class="modal-footer">
                    @if (importSonuc == null)
                    {
                        <button type="button" class="btn btn-secondary" @onclick="CloseImportModal">İptal</button>
                        <button type="button" class="btn btn-success" @onclick="ImportBaslat" disabled="@(selectedFile == null || isImporting)">
                            @if (isImporting)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            <i class="bi bi-upload me-1"></i>Import Başlat
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-primary" @onclick="CloseImportModal">Tamam</button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Sofor>? personeller;
    private bool showDeleteModal = false;
    private Sofor? silinecekPersonel;
    private string secilenGorev = "";

    // Import değişkenleri
    private bool showImportModal = false;
    private IBrowserFile? selectedFile;
    private bool mevcutGuncelle = false;
    private bool isImporting = false;
    private string? importHata;
    private PersonelImportSonuc? importSonuc;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        personeller = await SoforService.GetAllAsync();
    }

    private async Task FiltreleAsync()
    {
        if (string.IsNullOrEmpty(secilenGorev))
        {
            personeller = await SoforService.GetAllAsync();
        }
        else if (Enum.TryParse<PersonelGorev>(secilenGorev, out var gorev))
        {
            personeller = await SoforService.GetByGorevAsync(gorev);
        }
    }

    private void YeniPersonel()
    {
        Navigation.NavigateTo("/soforler/yeni");
    }

    private void Duzenle(int id)
    {
        Navigation.NavigateTo($"/soforler/{id}");
    }

    private void SilOnay(Sofor personel)
    {
        silinecekPersonel = personel;
        showDeleteModal = true;
    }

    private async Task Sil()
    {
        if (silinecekPersonel != null)
        {
            await SoforService.DeleteAsync(silinecekPersonel.Id);
            await LoadData();
        }
        showDeleteModal = false;
        silinecekPersonel = null;
    }

    #region Excel Import/Export

    private async Task ImportSablonIndir()
    {
        try
        {
            var bytes = await SoforService.GetImportSablonAsync();
            var dosyaAdi = $"personel_import_sablonu.xlsx";
            await JS.InvokeVoidAsync("downloadFileFromBase64", dosyaAdi, Convert.ToBase64String(bytes));
            ToastService.ShowSuccess("Import şablonu indirildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private async Task ExportToExcel()
    {
        try
        {
            var bytes = await SoforService.ExportToExcelAsync();
            var dosyaAdi = $"personel_listesi_{DateTime.Now:yyyyMMdd}.xlsx";
            await JS.InvokeVoidAsync("downloadFileFromBase64", dosyaAdi, Convert.ToBase64String(bytes));
            ToastService.ShowSuccess("Personel listesi Excel'e aktarıldı.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        importHata = null;
    }

    private async Task ImportBaslat()
    {
        if (selectedFile == null) return;

        isImporting = true;
        importHata = null;
        importSonuc = null;

        try
        {
            // Max 5MB
            if (selectedFile.Size > 5 * 1024 * 1024)
            {
                importHata = "Dosya boyutu 5MB'dan büyük olamaz.";
                return;
            }

            using var stream = selectedFile.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);

            importSonuc = await SoforService.ImportFromExcelAsync(ms.ToArray(), mevcutGuncelle);

            if (importSonuc.BasariliEklenen > 0 || importSonuc.BasariliGuncellenen > 0)
            {
                await LoadData();
                ToastService.ShowSuccess($"{importSonuc.BasariliEklenen} personel eklendi, {importSonuc.BasariliGuncellenen} güncellendi.");
            }
        }
        catch (Exception ex)
        {
            importHata = $"Import hatası: {ex.Message}";
        }
        finally
        {
            isImporting = false;
        }
    }

    private void CloseImportModal()
    {
        showImportModal = false;
        selectedFile = null;
        importHata = null;
        importSonuc = null;
        mevcutGuncelle = false;
    }

    #endregion

    private async Task PersonelDosyasiIndir(int personelId)
    {
        try
        {
            var bytes = await OzlukService.ExportPersonelDosyaPdfAsync(personelId);
            var personel = personeller?.FirstOrDefault(p => p.Id == personelId);
            var dosyaAdi = $"personel_dosyasi_{personel?.SoforKodu ?? personelId.ToString()}_{DateTime.Now:yyyyMMdd}.pdf";
            await JS.InvokeVoidAsync("downloadFileFromBase64", dosyaAdi, Convert.ToBase64String(bytes));
            ToastService.ShowSuccess("Personel dosyası indirildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private async Task BosPersonelDosyasiIndir()
    {
        try
        {
            var bytes = await OzlukService.ExportBosPersonelDosyaPdfAsync();
            var dosyaAdi = $"bos_personel_dosyasi_{DateTime.Now:yyyyMMdd}.pdf";
            await JS.InvokeVoidAsync("downloadFileFromBase64", dosyaAdi, Convert.ToBase64String(bytes));
            ToastService.ShowSuccess("Boş personel dosyası indirildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }
    
    private string GetGorevAdi(PersonelGorev gorev)
    {
        return gorev switch
        {
            PersonelGorev.Sofor => "Şoför",
            PersonelGorev.OfisCalisani => "Ofis Çalışanı",
            PersonelGorev.Muhasebe => "Muhasebe",
            PersonelGorev.Yonetici => "Yönetici",
            PersonelGorev.Teknik => "Teknik",
            PersonelGorev.Diger => "Diğer",
            _ => gorev.ToString()
        };
    }
    
    private string GetGorevBadgeClass(PersonelGorev gorev)
    {
        return gorev switch
        {
            PersonelGorev.Sofor => "bg-primary",
            PersonelGorev.OfisCalisani => "bg-info",
            PersonelGorev.Muhasebe => "bg-success",
            PersonelGorev.Yonetici => "bg-warning text-dark",
            PersonelGorev.Teknik => "bg-secondary",
            _ => "bg-dark"
        };
    }

    private async Task SiralamaNoGuncelle(Sofor personel, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var yeniSiraNo))
        {
            personel.SiralamaNo = yeniSiraNo;
            await SoforService.UpdateAsync(personel);
            ToastService.ShowSuccess($"{personel.TamAd} sıralama no: {yeniSiraNo}");
        }
    }
}
