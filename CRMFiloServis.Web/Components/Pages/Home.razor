@page "/"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@using FaturaEntity = CRMFiloServis.Shared.Entities.Fatura
@inject ICariService CariService
@inject IAracService AracService
@inject ISoforService SoforService
@inject IFaturaService FaturaService
@inject IServisCalismaService ServisCalismaService
@inject IBankaKasaHareketService BankaKasaService
@inject IBelgeUyariService BelgeUyariService
@inject IBudgetService BudgetService
@inject NavigationManager Navigation
@inject ILogger<Home> Logger
@rendermode InteractiveServer

<PageTitle>CRM Filo Servis - Ana Sayfa</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">
            <i class="bi bi-speedometer2 me-2"></i>Dashboard
        </h3>
        <small class="text-muted">Son güncelleme: @DateTime.Now.ToString("dd.MM.yyyy HH:mm")</small>
    </div>

    <!-- Kritik Uyarılar Banner -->
    @if (belgeUyarilar != null && belgeUyarilar.ToplamKritikUyari > 0)
    {
        <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2" style="font-size: 1.5rem;"></i>
            <div class="flex-grow-1">
                <strong>@belgeUyarilar.ToplamKritikUyari kritik belge uyarısı var!</strong>
                Süresi geçmiş veya 7 gün içinde dolacak belgeler bulunuyor.
            </div>
            <button class="btn btn-outline-danger btn-sm" @onclick="() => showBelgeModal = true">
                <i class="bi bi-eye me-1"></i>Görüntüle
            </button>
        </div>
    }

    <!-- Özet Kartlar -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Toplam Cari</h6>
                            <h2>@cariSayisi</h2>
                        </div>
                        <i class="bi bi-people-fill" style="font-size: 3rem; opacity: 0.5;"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="/cariler" class="text-white text-decoration-none">
                        <small>Detaylar <i class="bi bi-arrow-right"></i></small>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-success text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Aktif Araç</h6>
                            <h2>@aracSayisi</h2>
                        </div>
                        <i class="bi bi-truck" style="font-size: 3rem; opacity: 0.5;"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="/araclar" class="text-white text-decoration-none">
                        <small>Detaylar <i class="bi bi-arrow-right"></i></small>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-warning text-dark h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Aktif Şoför</h6>
                            <h2>@soforSayisi</h2>
                        </div>
                        <i class="bi bi-person-badge" style="font-size: 3rem, opacity: 0.5;"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="/soforler" class="text-dark text-decoration-none">
                        <small>Detaylar <i class="bi bi-arrow-right"></i></small>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-danger text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Bekleyen Fatura</h6>
                            <h2>@bekleyenFaturaSayisi</h2>
                        </div>
                        <i class="bi bi-receipt" style="font-size: 3rem, opacity: 0.5;"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="/faturalar" class="text-white text-decoration-none">
                        <small>Detaylar <i class="bi bi-arrow-right"></i></small>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Finansal Özet -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-wallet2 me-2"></i>Bu Ay Özet</h6>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-6 border-end">
                            <small class="text-muted d-block">Toplam Gelir</small>
                            <h5 class="text-success mb-0">@buAyGelir.ToString("N0") ₺</h5>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Toplam Gider</small>
                            <h5 class="text-danger mb-0">@buAyGider.ToString("N0") ₺</h5>
                        </div>
                    </div>
                    <hr />
                    <div class="text-center">
                        <small class="text-muted d-block">Net Kar/Zarar</small>
                        <h4 class="@(buAyGelir - buAyGider >= 0 ? "text-success" : "text-danger") mb-0">
                            @((buAyGelir - buAyGider).ToString("N0")) ₺
                        </h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-bank me-2"></i>Kasa/Banka Durumu</h6>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span>Toplam Kasa:</span>
                        <strong class="text-primary">@toplamKasa.ToString("N2") ₺</strong>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span>Toplam Banka:</span>
                        <strong class="text-primary">@toplamBanka.ToString("N2") ₺</strong>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between align-items-center">
                        <span><strong>Genel Toplam:</strong></span>
                        <strong class="h5 text-success mb-0">@((toplamKasa + toplamBanka).ToString("N2")) ₺</strong>
                    </div>
                </div>
                <div class="card-footer bg-transparent">
                    <a href="/banka-kasa" class="btn btn-outline-primary btn-sm w-100">
                        <i class="bi bi-arrow-right me-1"></i>Detay Görüntüle
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-wallet2 me-2"></i>Bu Ay Bütçe</h6>
                </div>
                <div class="card-body">
                    @if (butceOzet != null)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span>Planlanan Ödeme:</span>
                            <strong class="text-danger">@butceOzet.ToplamOdeme.ToString("N0") ₺</strong>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span>Ödenen:</span>
                            <strong class="text-success">@butceOzet.OdenenToplam.ToString("N0") ₺</strong>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span>Bekleyen:</span>
                            <strong class="text-warning">@butceOzet.BekleyenToplam.ToString("N0") ₺</strong>
                        </div>
                        <hr />
                        <div class="progress" style="height: 20px;">
                            @{
                                var yuzde = butceOzet.ToplamOdeme > 0 ? (butceOzet.OdenenToplam / butceOzet.ToplamOdeme * 100) : 0;
                            }
                            <div class="progress-bar bg-success" style="width: @yuzde.ToString("F0")%">
                                %@yuzde.ToString("F0")
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-3">
                            <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                            <p class="mb-0 mt-2">Bütçe verisi yok</p>
                        </div>
                    }
                </div>
                <div class="card-footer bg-transparent">
                    <a href="/butce" class="btn btn-outline-primary btn-sm w-100">
                        <i class="bi bi-arrow-right me-1"></i>Bütçe Analiz
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Hızlı İşlemler Row -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-lightning me-2"></i>Hızlı İşlemler</h6>
                </div>
                <div class="card-body">
                    <div class="row g-2">
                        <div class="col-md-3">
                            <button class="btn btn-outline-primary w-100" @onclick='@(() => Navigation.NavigateTo("/servis-calismalari/yeni"))'>
                                <i class="bi bi-plus-circle me-2"></i>Yeni Servis Çalışması
                            </button>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-outline-success w-100" @onclick='@(() => Navigation.NavigateTo("/servis-calismalari/toplu-ekle"))'>
                                <i class="bi bi-list-check me-2"></i>Toplu Çalışma Girişi
                            </button>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-outline-warning w-100" @onclick='@(() => Navigation.NavigateTo("/faturalar/yeni"))'>
                                <i class="bi bi-receipt me-2"></i>Yeni Fatura
                            </button>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-outline-info w-100" @onclick='@(() => Navigation.NavigateTo("/butce"))'>
                                <i class="bi bi-wallet2 me-2"></i>Bütçe/Ödeme Girişi
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Grafikler -->
    @if (!isLoading)
    {
        <CRMFiloServis.Web.Components.Shared.DashboardGrafik ParentLoaded="@(!isLoading)" />
    }

    <!-- Gecikmiş ve Yaklaşan -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h6 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Vadesi Geçmiş Faturalar (@vadeGecmisFaturalar.Count)</h6>
                </div>
                <div class="card-body">
                    @if (vadeGecmisFaturalar.Any())
                    {
                        <div class="table-responsive" style="max-height: 200px; overflow-y: auto;">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>Fatura No</th>
                                        <th>Cari</th>
                                        <th>Vade</th>
                                        <th class="text-end">Kalan</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var fatura in vadeGecmisFaturalar.Take(5))
                                    {
                                        var gecikmeGunu = fatura.VadeTarihi.HasValue ? (DateTime.Today - fatura.VadeTarihi.Value).Days : 0;
                                        <tr>
                                            <td>@fatura.FaturaNo</td>
                                            <td>@fatura.Cari?.Unvan</td>
                                            <td>
                                                @fatura.VadeTarihi?.ToString("dd.MM")
                                                <span class="badge bg-danger ms-1">@gecikmeGunu gün</span>
                                            </td>
                                            <td class="text-end"><strong class="text-danger">@fatura.KalanTutar.ToString("N0") ₺</strong></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="text-center mt-2">
                            <small class="text-muted">Toplam Gecikmiş: <strong class="text-danger">@vadeGecmisFaturalar.Sum(f => f.KalanTutar).ToString("N0") ₺</strong></small>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-success py-3">
                            <i class="bi bi-check-circle" style="font-size: 2rem;"></i>
                            <p class="mb-0 mt-2">Vadesi geçmiş fatura bulunmuyor!</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-warning">
                <div class="card-header bg-warning text-dark">
                    <h6 class="mb-0"><i class="bi bi-clock me-2"></i>Vadesi Yaklaşan Faturalar (7 gün içinde)</h6>
                </div>
                <div class="card-body">
                    @if (vadeYaklasanFaturalar.Any())
                    {
                        <div class="table-responsive" style="max-height: 200px; overflow-y: auto;">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>Fatura No</th>
                                        <th>Cari</th>
                                        <th>Vade</th>
                                        <th class="text-end">Kalan</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var fatura in vadeYaklasanFaturalar.Take(5))
                                    {
                                        var kalanGun = fatura.VadeTarihi.HasValue ? (fatura.VadeTarihi.Value - DateTime.Today).Days : 0;
                                        <tr>
                                            <td>@fatura.FaturaNo</td>
                                            <td>@fatura.Cari?.Unvan</td>
                                            <td>
                                                @fatura.VadeTarihi?.ToString("dd.MM")
                                                <span class="badge bg-warning text-dark ms-1">@kalanGun gün</span>
                                            </td>
                                            <td class="text-end"><strong>@fatura.KalanTutar.ToString("N0") ₺</strong></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="text-center mt-2">
                            <small class="text-muted">Toplam: <strong>@vadeYaklasanFaturalar.Sum(f => f.KalanTutar).ToString("N0") ₺</strong></small>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-3">
                            <i class="bi bi-calendar-check" style="font-size: 2rem;"></i>
                            <p class="mb-0 mt-2">7 gün içinde vadesi dolan fatura bulunmuyor.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Son İşlemler -->
    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-calendar-check me-2"></i>Son Servis Çalışmaları</h6>
                </div>
                <div class="card-body">
                    @if (sonCalismalar != null && sonCalismalar.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Tarih</th>
                                        <th>Plaka</th>
                                        <th>Güzergah</th>
                                        <th class="text-end">Tutar</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var calisma in sonCalismalar)
                                    {
                                        <tr>
                                            <td>@calisma.CalismaTarihi.ToString("dd.MM")</td>
                                            <td>@calisma.Arac?.Plaka</td>
                                            <td>@calisma.Guzergah?.GuzergahAdi</td>
                                            <td class="text-end"><strong>@calisma.HesaplananFiyat.ToString("N0") ₺</strong></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="text-center mt-2">
                            <a href="/servis-calismalari" class="btn btn-link btn-sm">Tümünü Görüntüle</a>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0 text-center py-3">Henüz servis çalışması bulunmuyor.</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-cash-stack me-2"></i>Son Tahsilatlar/Ödemeler</h6>
                </div>
                <div class="card-body">
                    @if (sonHareketler != null && sonHareketler.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Tarih</th>
                                        <th>İşlem</th>
                                        <th>Cari</th>
                                        <th class="text-end">Tutar</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var hareket in sonHareketler)
                                    {
                                        <tr>
                                            <td>@hareket.IslemTarihi.ToString("dd.MM")</td>
                                            <td>
                                                <span class="badge @(hareket.HareketTipi == HareketTipi.Giris ? "bg-success" : "bg-danger")">
                                                    @(hareket.HareketTipi == HareketTipi.Giris ? "Tahsilat" : "Ödeme")
                                                </span>
                                            </td>
                                            <td>@hareket.Cari?.Unvan</td>
                                            <td class="text-end">
                                                <strong class="@(hareket.HareketTipi == HareketTipi.Giris ? "text-success" : "text-danger")">
                                                    @hareket.Tutar.ToString("N0") ₺
                                                </strong>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="text-center mt-2">
                            <a href="/banka-kasa" class="btn btn-link btn-sm">Tümünü Görüntüle</a>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0 text-center py-3">Henüz hareket bulunmuyor.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Belge Uyarıları Modal -->
@if (showBelgeModal && belgeUyarilar != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title">
                        <i class="bi bi-file-earmark-medical me-2"></i>Belge Süre Uyarıları
                    </h5>
                    <button type="button" class="btn-close" @onclick="() => showBelgeModal = false"></button>
                </div>
                <div class="modal-body">
                    @if (belgeUyarilar.TumUyarilar.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Durum</th>
                                        <th>Belge Türü</th>
                                        <th>Ad / Plaka</th>
                                        <th>Bitiş Tarihi</th>
                                        <th class="text-center">Kalan Gün</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var uyari in belgeUyarilar.TumUyarilar)
                                    {
                                        <tr>
                                            <td>
                                                <i class="bi @uyari.Icon @(uyari.Seviye == BelgeUyariSeviye.Kritik ? "text-danger" : uyari.Seviye == BelgeUyariSeviye.Acil ? "text-warning" : "text-info")"></i>
                                            </td>
                                            <td>@uyari.BelgeTuru</td>
                                            <td><strong>@uyari.Baslik</strong></td>
                                            <td>@uyari.BitisTarihi.ToString("dd.MM.yyyy")</td>
                                            <td class="text-center">
                                                <span class="badge @uyari.SeviyeClass">
                                                    @if (uyari.KalanGun < 0)
                                                    {
                                                        <text>@Math.Abs(uyari.KalanGun) gün geçti!</text>
                                                    }
                                                    else
                                                    {
                                                        <text>@uyari.KalanGun gün</text>
                                                    }
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-success py-4">
                            <i class="bi bi-check-circle" style="font-size: 3rem;"></i>
                            <p class="mb-0 mt-2">Tüm belgeler güncel!</p>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showBelgeModal = false">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int cariSayisi = 0;
    private int aracSayisi = 0;
    private int soforSayisi = 0;
    private int bekleyenFaturaSayisi = 0;

    private decimal buAyGelir = 0;
    private decimal buAyGider = 0;
    private decimal toplamKasa = 0;
    private decimal toplamBanka = 0;

    private List<ServisCalisma>? sonCalismalar;
    private List<FaturaEntity> vadeGecmisFaturalar = new();
    private List<FaturaEntity> vadeYaklasanFaturalar = new();
    private List<BankaKasaHareket>? sonHareketler;
    
    private BelgeUyariOzet? belgeUyarilar;
    private BudgetOzet? butceOzet;
    private bool showBelgeModal = false;
    private bool isLoading = true;
    private static readonly SemaphoreSlim _semaphore = new(1, 1);

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardDataAsync();
    }

    private async Task LoadDashboardDataAsync()
    {
        // Semaphore ile ayni anda tek islem
        if (!await _semaphore.WaitAsync(0))
            return;

        try
        {
            isLoading = true;
            StateHasChanged();

            // Her cagri arasinda kucuk bir bekleme ekle
            cariSayisi = await CariService.GetCountAsync();
            await Task.Delay(10);
            
            aracSayisi = await AracService.GetActiveCountAsync();
            await Task.Delay(10);
            
            soforSayisi = await SoforService.GetActiveCountAsync();
            await Task.Delay(10);
            
            var faturaStats = await FaturaService.GetDashboardStatsAsync();
            bekleyenFaturaSayisi = faturaStats.BekleyenFaturaSayisi;
            buAyGelir = faturaStats.BuAyGelir;
            buAyGider = faturaStats.BuAyGider;
            vadeGecmisFaturalar = faturaStats.VadeGecmisFaturalar;
            vadeYaklasanFaturalar = faturaStats.VadeYaklasanFaturalar;
            await Task.Delay(10);

            var bankaStats = await BankaKasaService.GetDashboardStatsAsync();
            toplamKasa = bankaStats.ToplamKasa;
            toplamBanka = bankaStats.ToplamBanka;
            await Task.Delay(10);

            sonCalismalar = await ServisCalismaService.GetRecentAsync(5);
            await Task.Delay(10);
            
            sonHareketler = await BankaKasaService.GetRecentAsync(5);
            await Task.Delay(10);
            
            belgeUyarilar = await BelgeUyariService.GetBelgeUyarilarAsync(30);
            await Task.Delay(10);
            
            butceOzet = await BudgetService.GetAylikOzetAsync(DateTime.Today.Year, DateTime.Today.Month);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Dashboard yukleme hatasi");
        }
        finally
        {
            isLoading = false;
            _semaphore.Release();
            StateHasChanged();
        }
    }
}
