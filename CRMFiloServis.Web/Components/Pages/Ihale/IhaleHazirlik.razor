    {
        if (!string.IsNullOrWhiteSpace(kalem.BaslangicNoktasi))
            return kalem.BaslangicNoktasi;
        if (!string.IsNullOrWhiteSpace(kalem.BitisNoktasi))
            return kalem.BitisNoktasi;
        return null;
    }

    private static decimal AracTipineGoreVarsayilanYakit(AracTipi aracTipi, decimal mevcut)
    {
        if (mevcut > 0)
            return mevcut;

        return aracTipi switch
        {
            AracTipi.Minibus => 14,
            AracTipi.Midibus => 18,
            AracTipi.Otobus => 28,
            AracTipi.Otomobil => 8,
            AracTipi.Panelvan => 11,
            _ => 15
        };
    }

    private static decimal? PetrolOfisiMotorinFiyatiBul(string html, string bolge)
    {
        var normalizedBolge = NormalizeBolge(bolge);
        if (string.IsNullOrWhiteSpace(normalizedBolge))
            return null;

        var rowMatches = Regex.Matches(html,
            @"<tr class=""price-row[^""]*""[^>]*data-disctrict-name=""(?<name>[^""]+)""[^>]*>(?<row>.*?)</tr>",
            RegexOptions.Singleline | RegexOptions.IgnoreCase);

        foreach (Match match in rowMatches)
        {
            var name = WebUtility.HtmlDecode(match.Groups["name"].Value);
            var normalizedName = NormalizeBolge(name);
            if (!normalizedName.Contains(normalizedBolge) && !normalizedBolge.Contains(normalizedName))
                continue;

            var priceMatches = Regex.Matches(match.Groups["row"].Value, @"<span class=""with-tax"">(?<price>[0-9]+(?:\.[0-9]+)?)</span>", RegexOptions.IgnoreCase);
            if (priceMatches.Count >= 2 && decimal.TryParse(priceMatches[1].Groups["price"].Value, NumberStyles.Any, CultureInfo.InvariantCulture, out var motorin))
                return motorin;
        }

        return null;
    }

    private static string NormalizeBolge(string value)
    {
        return (value ?? string.Empty)
            .Trim()
            .ToUpperInvariant()
            .Replace("İ", "I")
            .Replace("İ", "I")
            .Replace("Ş", "S")
            .Replace("Ğ", "G")
            .Replace("Ü", "U")
            .Replace("Ö", "O")
            .Replace("Ç", "C");
    }
