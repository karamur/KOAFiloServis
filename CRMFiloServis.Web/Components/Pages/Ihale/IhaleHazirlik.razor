@page "/ihale-hazirlik"
@page "/ihale-hazirlik/{ProjeId:int}"
@rendermode InteractiveServer
@using System.Globalization
@using System.Net
@using System.Text.RegularExpressions
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Models
@using CRMFiloServis.Web.Services
@inject IIhaleHazirlikService IhaleService
@inject IOllamaService OllamaService
@inject ICariService CariService
@inject IGuzergahService GuzergahService
@inject IAracService AracService
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject IToastService ToastService

<PageTitle>İhale Hazırlık</PageTitle>

@if (secilenProje == null)
{
    <!-- PROJE LİSTESİ -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4><i class="bi bi-briefcase me-2"></i>İhale Hazırlık Projeleri</h4>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-success" @onclick="OrnekVeriOlusturAsync" disabled="@yukleniyor">
                <i class="bi bi-magic me-1"></i> Örnek Veri Oluştur
            </button>
            <button class="btn btn-primary" @onclick="YeniProjeModal">
                <i class="bi bi-plus-circle me-1"></i> Yeni Proje
            </button>
        </div>
    </div>

    @if (projeler == null)
    {
        <div class="text-center py-5"><div class="spinner-border"></div></div>
    }
    else if (!projeler.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Henüz ihale projesi oluşturulmamış.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var p in projeler)
            {
                <div class="col-md-6 col-xl-4 mb-3">
                    <div class="card h-100 shadow-sm border-start border-4 @GetDurumBorderColor(p.Durum)">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h6 class="mb-0">@p.ProjeAdi</h6>
                                    <small class="text-muted">@p.ProjeKodu</small>
                                </div>
                                <span class="badge @GetDurumBadge(p.Durum)">@GetDurumMetin(p.Durum)</span>
                            </div>
                            <div class="small text-muted mb-2">
                                @if (p.Cari != null) { <span><i class="bi bi-building me-1"></i>@p.Cari.Unvan</span><br/> }
                                <span><i class="bi bi-calendar me-1"></i>@p.BaslangicTarihi.ToString("dd.MM.yyyy") - @p.BitisTarihi.ToString("dd.MM.yyyy")</span><br/>
                                <span><i class="bi bi-clock me-1"></i>@p.SozlesmeSuresiAy ay</span>
                                <span class="ms-2"><i class="bi bi-signpost me-1"></i>@p.Kalemler.Count(k => !k.IsDeleted) hat</span>
                            </div>
                            <div class="d-flex gap-1 mt-2">
                                <button class="btn btn-sm btn-outline-primary flex-fill" @onclick="() => ProjeSecAsync(p.Id)">
                                    <i class="bi bi-pencil me-1"></i>Düzenle
                                </button>
                                <button class="btn btn-sm btn-outline-success" @onclick="() => KopyalaProjeAsync(p)" title="Kopyala">
                                    <i class="bi bi-copy"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => SilProjeAsync(p.Id)" title="Sil">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}
else
{
    <!-- PROJE DETAY -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <button class="btn btn-sm btn-outline-secondary me-2" @onclick="ListeyeDon">
                <i class="bi bi-arrow-left me-1"></i>Projeler
            </button>
            <span class="h5 mb-0">@secilenProje.ProjeAdi</span>
            <span class="badge @GetDurumBadge(secilenProje.Durum) ms-2">@GetDurumMetin(secilenProje.Durum)</span>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-info" @onclick="ProjeAyarModal">
                <i class="bi bi-gear me-1"></i>Proje Ayarları
            </button>
            @if (aiAktif)
            {
                <button class="btn btn-sm btn-purple" @onclick="AIProjeAnalizAsync" disabled="@yukleniyor">
                    <i class="bi bi-robot me-1"></i>AI Analiz
                </button>
            }
            <button class="btn btn-sm btn-success" @onclick="RaporGosterAsync">
                <i class="bi bi-file-earmark-bar-graph me-1"></i>Rapor
            </button>
        </div>
    </div>

    <!-- Proje Bilgi Kartları -->
    <div class="row mb-3">
        <div class="col-md-3">
            <div class="card bg-light">
                <div class="card-body py-2 text-center">
                    <small class="text-muted">Müşteri</small><br/>
                    <strong>@(secilenProje.Cari?.Unvan ?? secilenProje.Firma?.FirmaAdi ?? "-")</strong>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-light">
                <div class="card-body py-2 text-center">
                    <small class="text-muted">Süre</small><br/>
                    <strong>@secilenProje.SozlesmeSuresiAy ay</strong>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-light">
                <div class="card-body py-2 text-center">
                    <small class="text-muted">Hat Sayısı</small><br/>
                    <strong>@aktifKalemler.Count</strong>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-light">
                <div class="card-body py-2 text-center">
                    <small class="text-muted">Aylık Maliyet</small><br/>
                    <strong class="text-danger">@aktifKalemler.Sum(k => k.AylikMaliyet).ToString("N0") ₺</strong>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-light">
                <div class="card-body py-2 text-center">
                    <small class="text-muted">Aylık Teklif</small><br/>
                    <strong class="text-success">@aktifKalemler.Sum(k => k.AylikTeklifFiyati).ToString("N0") ₺</strong>
                </div>
            </div>
        </div>
    </div>

    <!-- Hat/Güzergah Tablosu -->
    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0"><i class="bi bi-signpost-2 me-2"></i>Güzergah/Hat Kalemleri</h6>
            <button class="btn btn-sm btn-primary" @onclick="YeniKalemModal">
                <i class="bi bi-plus me-1"></i>Hat Ekle
            </button>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Hat Adı</th>
                            <th class="text-center">Mesafe</th>
                            <th class="text-center">Sefer</th>
                            <th class="text-center">Araç</th>
                            <th class="text-center">Sahiplik</th>
                            <th class="text-end">Yakıt</th>
                            <th class="text-end">Masraf</th>
                            <th class="text-end">Şoför</th>
                            <th class="text-end">Aylık Maliyet</th>
                            <th class="text-end">Teklif</th>
                            <th class="text-end">Kâr%</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var k in aktifKalemler)
                        {
                            var topMasraf = k.AylikBakimMasrafi + k.AylikLastikMasrafi + k.AylikSigortaMasrafi +
                                k.AylikKaskoMasrafi + k.AylikMuayeneMasrafi + k.AylikYedekParcaMasrafi + k.AylikDigerMasraf +
                                k.AylikKiraBedeli + k.AylikKomisyonToplam + k.AylikAmortisman;
                            <tr>
                                <td>
                                    <strong>@k.HatAdi</strong>
                                    @if (k.AITahminiKullanildi)
                                    {
                                        <i class="bi bi-robot text-info ms-1" title="AI tahmin kullanıldı"></i>
                                    }
                                </td>
                                <td class="text-center">@k.MesafeKm km</td>
                                <td class="text-center">@k.GunlukSeferSayisi/@k.AylikSeferGunu</td>
                                <td class="text-center small">@(k.AracModelBilgi ?? "-")</td>
                                <td class="text-center">
                                    <span class="badge @GetSahiplikBadge(k.SahiplikDurumu)">@GetSahiplikMetin(k.SahiplikDurumu)</span>
                                </td>
                                <td class="text-end">@k.AylikYakitMaliyeti.ToString("N0")</td>
                                <td class="text-end">@topMasraf.ToString("N0")</td>
                                <td class="text-end">@k.SoforToplamMaliyet.ToString("N0")</td>
                                <td class="text-end fw-bold text-danger">@k.AylikMaliyet.ToString("N0")</td>
                                <td class="text-end fw-bold text-success">@k.AylikTeklifFiyati.ToString("N0")</td>
                                <td class="text-end">%@k.KarMarjiOrani.ToString("N0")</td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-primary" @onclick="() => DuzenleKalemModal(k)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-outline-danger" @onclick="() => SilKalemAsync(k.Id)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                    @if (aktifKalemler.Any())
                    {
                        <tfoot class="table-light fw-bold">
                            <tr>
                                <td colspan="5">TOPLAM</td>
                                <td class="text-end">@aktifKalemler.Sum(k => k.AylikYakitMaliyeti).ToString("N0")</td>
                                <td class="text-end">—</td>
                                <td class="text-end">@aktifKalemler.Sum(k => k.SoforToplamMaliyet).ToString("N0")</td>
                                <td class="text-end text-danger">@aktifKalemler.Sum(k => k.AylikMaliyet).ToString("N0")</td>
                                <td class="text-end text-success">@aktifKalemler.Sum(k => k.AylikTeklifFiyati).ToString("N0")</td>
                                <td class="text-end">%@(aktifKalemler.Any() ? aktifKalemler.Average(k => k.KarMarjiOrani).ToString("N0") : "0")</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>
    </div>

    <!-- Birim Fiyat Özeti -->
    @if (aktifKalemler.Any())
    {
        <div class="row mb-3">
            <div class="col-md-4">
                <div class="card border-primary">
                    <div class="card-body text-center py-2">
                        <small class="text-muted">Ort. Sefer Başı Teklif</small><br/>
                        <h5 class="text-primary mb-0">@aktifKalemler.Average(k => k.SeferBasiTeklifFiyati).ToString("N2") ₺</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-info">
                    <div class="card-body text-center py-2">
                        <small class="text-muted">Ort. Saatlik Teklif</small><br/>
                        <h5 class="text-info mb-0">@aktifKalemler.Average(k => k.SaatlikTeklifFiyati).ToString("N2") ₺</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-warning">
                    <div class="card-body text-center py-2">
                        <small class="text-muted">Ort. Km Başı Maliyet</small><br/>
                        <h5 class="text-warning mb-0">@aktifKalemler.Average(k => k.KmBasiMaliyet).ToString("N2") ₺</h5>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- AI Analiz Sonucu -->
    @if (!string.IsNullOrEmpty(aiAnalizSonuc))
    {
        <div class="card shadow-sm mb-3 border-purple">
            <div class="card-header bg-purple text-white d-flex justify-content-between">
                <span><i class="bi bi-robot me-2"></i>AI Proje Analizi</span>
                <button class="btn btn-sm btn-outline-light" @onclick="() => aiAnalizSonuc = null"><i class="bi bi-x"></i></button>
            </div>
            <div class="card-body" style="white-space: pre-wrap;">@aiAnalizSonuc</div>
        </div>
    }

    <!-- Rapor Modal -->
    @if (projeOzet != null && raporGoster)
    {
        <div class="card shadow-sm mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-file-earmark-bar-graph me-2"></i>Kâr/Zarar/Masraf Tablosu - Enflasyonlu Projeksiyon</h6>
                <button class="btn btn-sm btn-outline-secondary" @onclick="() => raporGoster = false"><i class="bi bi-x"></i></button>
            </div>
            <div class="card-body p-0">
                @if (projeOzet.AylikProjeksiyonlar.Any())
                {
                    var ilkAy = projeOzet.AylikProjeksiyonlar.First();
                    var sonAy = projeOzet.AylikProjeksiyonlar.Last();
                    var artisTutari = sonAy.ToplamMaliyet - ilkAy.ToplamMaliyet;
                    var artisOrani = ilkAy.ToplamMaliyet > 0 ? artisTutari / ilkAy.ToplamMaliyet * 100 : 0;

                    <div class="row g-0 border-bottom">
                        <div class="col-md-4 p-3 text-center border-end">
                            <small class="text-muted d-block">İlk Ay Maliyeti</small>
                            <strong class="text-primary">@ilkAy.ToplamMaliyet.ToString("N0") ₺</strong>
                        </div>
                        <div class="col-md-4 p-3 text-center border-end">
                            <small class="text-muted d-block">Son Ay Tahmini Maliyeti</small>
                            <strong class="text-danger">@sonAy.ToplamMaliyet.ToString("N0") ₺</strong>
                        </div>
                        <div class="col-md-4 p-3 text-center">
                            <small class="text-muted d-block">Süre Sonu Maliyet Artışı</small>
                            <strong class="@(artisTutari >= 0 ? "text-warning" : "text-success")">@artisTutari.ToString("N0") ₺ (%@artisOrani.ToString("N1"))</strong>
                        </div>
                    </div>
                }

                <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                    <table class="table table-sm table-striped mb-0">
                        <thead class="table-dark sticky-top">
                            <tr>
                                <th>Dönem</th>
                                <th class="text-end">Maliyet</th>
                                <th class="text-end">Kâr</th>
                                <th class="text-end">Teklif</th>
                                <th class="text-end">Enflasyon Etkisi</th>
                                <th class="text-end">Küm. Maliyet</th>
                                <th class="text-end">Küm. Kâr</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ay in projeOzet.AylikProjeksiyonlar)
                            {
                                <tr>
                                    <td>@ay.DonemAdi</td>
                                    <td class="text-end text-danger">@ay.ToplamMaliyet.ToString("N0")</td>
                                    <td class="text-end text-success">@ay.ToplamKar.ToString("N0")</td>
                                    <td class="text-end fw-bold">@ay.ToplamTeklif.ToString("N0")</td>
                                    <td class="text-end @(ay.EnflasyonEtkisi > 0 ? "text-danger" : "")">
                                        @(ay.EnflasyonEtkisi > 0 ? "+" : "")@ay.EnflasyonEtkisi.ToString("N0")
                                    </td>
                                    <td class="text-end">@ay.KumulatifMaliyet.ToString("N0")</td>
                                    <td class="text-end text-success">@ay.KumulatifKar.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                        @if (projeOzet.AylikProjeksiyonlar.Any())
                        {
                            <tfoot class="table-dark">
                                <tr class="fw-bold">
                                    <td>TOPLAM</td>
                                    <td class="text-end text-danger">@projeOzet.AylikProjeksiyonlar.Sum(a => a.ToplamMaliyet).ToString("N0")</td>
                                    <td class="text-end text-success">@projeOzet.AylikProjeksiyonlar.Sum(a => a.ToplamKar).ToString("N0")</td>
                                    <td class="text-end">@projeOzet.AylikProjeksiyonlar.Sum(a => a.ToplamTeklif).ToString("N0")</td>
                                    <td class="text-end">@projeOzet.AylikProjeksiyonlar.Sum(a => a.EnflasyonEtkisi).ToString("N0")</td>
                                    <td class="text-end">—</td>
                                    <td class="text-end text-success">@projeOzet.AylikProjeksiyonlar.Last().KumulatifKar.ToString("N0")</td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>
            </div>
        </div>

        <!-- Maliyet Dağılım Kartları -->
        <div class="row mb-3">
            <div class="col-md-3">
                <div class="card border-danger">
                    <div class="card-body text-center py-2">
                        <small class="text-muted">Toplam Proje Maliyeti</small>
                        <h5 class="text-danger mb-0">@projeOzet.AylikProjeksiyonlar.Sum(a => a.ToplamMaliyet).ToString("N0") ₺</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-success">
                    <div class="card-body text-center py-2">
                        <small class="text-muted">Toplam Proje Kârı</small>
                        <h5 class="text-success mb-0">@projeOzet.AylikProjeksiyonlar.Sum(a => a.ToplamKar).ToString("N0") ₺</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-primary">
                    <div class="card-body text-center py-2">
                        <small class="text-muted">Toplam Teklif Bedeli</small>
                        <h5 class="text-primary mb-0">@projeOzet.AylikProjeksiyonlar.Sum(a => a.ToplamTeklif).ToString("N0") ₺</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning">
                    <div class="card-body text-center py-2">
                        <small class="text-muted">Enflasyon Toplam Etkisi</small>
                        <h5 class="text-warning mb-0">@projeOzet.AylikProjeksiyonlar.Sum(a => a.EnflasyonEtkisi).ToString("N0") ₺</h5>
                    </div>
                </div>
            </div>
        </div>
    }
}

<!-- YENİ/DÜZENLE PROJE MODAL -->
@if (projeModalGoster)
{
    <div class="modal show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editProje.Id == 0 ? "Yeni İhale Projesi" : "Proje Düzenle")</h5>
                    <button type="button" class="btn-close" @onclick="() => projeModalGoster = false"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label">Proje Adı</label>
                            <input type="text" class="form-control" @bind="editProje.ProjeAdi" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Durum</label>
                            <select class="form-select" @bind="editProje.Durum">
                                @foreach (var d in Enum.GetValues<IhaleProjeDurum>())
                                {
                                    <option value="@d">@GetDurumMetin(d)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Müşteri (Cari)</label>
                            <select class="form-select" @bind="editProje.CariId">
                                <option value="">-- Seçiniz --</option>
                                @if (tumCariler != null)
                                {
                                    @foreach (var c in tumCariler)
                                    {
                                        <option value="@c.Id">@c.Unvan</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Açıklama</label>
                            <input type="text" class="form-control" @bind="editProje.Aciklama" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Başlangıç</label>
                            <input type="date" class="form-control" @bind="editProje.BaslangicTarihi" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Bitiş</label>
                            <input type="date" class="form-control" @bind="editProje.BitisTarihi" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Sözleşme (ay)</label>
                            <input type="number" class="form-control" @bind="editProje.SozlesmeSuresiAy" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Çalışma Günü/Ay</label>
                            <input type="number" class="form-control" @bind="editProje.AylikCalismGunu" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Günlük Saat</label>
                            <input type="number" class="form-control" @bind="editProje.GunlukCalismaSaati" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Enflasyon (%/yıl)</label>
                            <input type="number" step="0.1" class="form-control" @bind="editProje.EnflasyonOrani" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Yakıt Zam (%/yıl)</label>
                            <input type="number" step="0.1" class="form-control" @bind="editProje.YakitZamOrani" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => projeModalGoster = false">İptal</button>
                    <button class="btn btn-primary" @onclick="KaydetProjeAsync" disabled="@yukleniyor">
                        <i class="bi bi-check me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- YENİ/DÜZENLE KALEM MODAL -->
@if (kalemModalGoster)
{
    <div class="modal show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editKalem.Id == 0 ? "Yeni Hat/Güzergah" : "Hat Düzenle")</h5>
                    <button type="button" class="btn-close" @onclick="() => kalemModalGoster = false"></button>
                </div>
                <div class="modal-body">
                    <!-- Güzergah & Mesafe -->
                    <h6 class="border-bottom pb-1 mb-3"><i class="bi bi-signpost me-1"></i>Güzergah Bilgileri</h6>
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Hazır Güzergah</label>
                            <select class="form-select" @bind="editKalem.GuzergahId">
                                <option value="">-- Seçiniz --</option>
                                @foreach (var guzergah in tumGuzergahlar)
                                {
                                    <option value="@guzergah.Id">@guzergah.GuzergahAdi</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Bölge (yakıt fiyatı için)</label>
                            <input type="text" class="form-control" @bind="editKalemBolge" placeholder="örn: Ankara, İstanbul Avrupa" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end gap-2">
                            <button class="btn btn-outline-primary flex-fill" @onclick="GuzergahtanDoldurAsync">
                                <i class="bi bi-signpost me-1"></i>Güzergahı Doldur
                            </button>
                            <button class="btn btn-outline-success flex-fill" @onclick="GuncelYakitFiyatiGetirAsync">
                                <i class="bi bi-fuel-pump me-1"></i>Motorin Al
                            </button>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Hat Adı</label>
                            <input type="text" class="form-control" @bind="editKalem.HatAdi" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Başlangıç</label>
                            <input type="text" class="form-control" @bind="editKalem.BaslangicNoktasi" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Bitiş</label>
                            <input type="text" class="form-control" @bind="editKalem.BitisNoktasi" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Mesafe (km)</label>
                            <input type="number" step="0.1" class="form-control" @bind="editKalem.MesafeKm" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Süre (dk)</label>
                            <input type="number" class="form-control" @bind="editKalem.TahminiSureDakika" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Sefer Tipi</label>
                            <select class="form-select" @bind="editKalem.SeferTipi">
                                @foreach (var s in Enum.GetValues<SeferTipi>())
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Günlük Sefer</label>
                            <input type="number" class="form-control" @bind="editKalem.GunlukSeferSayisi" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Aylık Gün</label>
                            <input type="number" class="form-control" @bind="editKalem.AylikSeferGunu" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Personel Sayısı</label>
                            <input type="number" class="form-control" @bind="editKalem.PersonelSayisi" />
                        </div>
                    </div>

                    <!-- Araç Bilgisi -->
                    <h6 class="border-bottom pb-1 mb-3"><i class="bi bi-truck me-1"></i>Araç Bilgileri</h6>
                    <div class="row g-3 mb-3">
                        <div class="col-md-3">
                            <label class="form-label">Sahiplik</label>
                            <select class="form-select" @bind="editKalem.SahiplikDurumu">
                                @foreach (var s in Enum.GetValues<AracSahiplikKalem>())
                                {
                                    <option value="@s">@GetSahiplikMetin(s)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3 d-flex align-items-end">
                            <button class="btn btn-outline-info w-100" @onclick="AracOnerAsync">
                                <i class="bi bi-magic me-1"></i>Müsait Araç Öner
                            </button>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Araç Model Bilgisi</label>
                            <input type="text" class="form-control" @bind="editKalem.AracModelBilgi" placeholder="örn: 2022 Mercedes Sprinter" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Koltuk</label>
                            <input type="number" class="form-control" @bind="editKalem.AracKoltukSayisi" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Yakıt (lt/100km)</label>
                            <input type="number" step="0.1" class="form-control" @bind="editKalem.YakitTuketimi" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Yakıt Fiyatı (TL)</label>
                            <input type="number" step="0.01" class="form-control" @bind="editKalem.YakitFiyati" />
                        </div>
                        @if (editKalem.SahiplikDurumu == AracSahiplikKalem.Kiralik)
                        {
                            <div class="col-md-3">
                                <label class="form-label">Aylık Kira (TL)</label>
                                <input type="number" step="0.01" class="form-control" @bind="editKalem.AylikKiraBedeli" />
                            </div>
                        }
                        @if (editKalem.SahiplikDurumu == AracSahiplikKalem.Komisyon)
                        {
                            <div class="col-md-3">
                                <label class="form-label">Sefer Başı Komisyon (TL)</label>
                                <input type="number" step="0.01" class="form-control" @bind="editKalem.SeferBasiKomisyon" />
                            </div>
                        }
                        @if (editKalem.SahiplikDurumu == AracSahiplikKalem.Ozmal)
                        {
                            <div class="col-md-3">
                                <label class="form-label">Araç Değeri (TL)</label>
                                <input type="number" class="form-control" @bind="editKalem.AracDegeri" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Amortisman (yıl)</label>
                                <input type="number" class="form-control" @bind="editKalem.AmortismanYili" />
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(kalemOneriMesaji))
                    {
                        <div class="alert alert-info small">
                            <i class="bi bi-info-circle me-2"></i>@kalemOneriMesaji
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(yakitFiyatMesaji))
                    {
                        <div class="alert alert-warning small">
                            <i class="bi bi-fuel-pump me-2"></i>@yakitFiyatMesaji
                        </div>
                    }

                    <!-- Araç Masrafları -->
                    <h6 class="border-bottom pb-1 mb-3">
                        <i class="bi bi-cash-stack me-1"></i>Aylık Araç Masrafları
                        @if (aiAktif)
                        {
                            <button class="btn btn-sm btn-purple ms-2" @onclick="AITahminMasrafAsync" disabled="@aiYukleniyor">
                                @if (aiYukleniyor)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                <i class="bi bi-robot me-1"></i>AI Tahmin
                            </button>
                        }
                    </h6>
                    <div class="row g-3 mb-3">
                        <div class="col-md-3">
                            <label class="form-label">Bakım/Onarım</label>
                            <input type="number" step="0.01" class="form-control" @bind="editKalem.AylikBakimMasrafi" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Lastik</label>
                            <input type="number" step="0.01" class="form-control" @bind="editKalem.AylikLastikMasrafi" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Sigorta</label>
                            <input type="number" step="0.01" class="form-control" @bind="editKalem.AylikSigortaMasrafi" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Kasko</label>
                            <input type="number" step="0.01" class="form-control" @bind="editKalem.AylikKaskoMasrafi" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Muayene</label>
                            <input type="number" step="0.01" class="form-control" @bind="editKalem.AylikMuayeneMasrafi" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Yedek Parça</label>
                            <input type="number" step="0.01" class="form-control" @bind="editKalem.AylikYedekParcaMasrafi" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Diğer Masraf</label>
                            <input type="number" step="0.01" class="form-control" @bind="editKalem.AylikDigerMasraf" />
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(aiTahminMesaj))
                    {
                        <div class="alert alert-info small">
                            <i class="bi bi-robot me-2"></i>@aiTahminMesaj
                        </div>
                    }

                    <!-- Şoför Maaş -->
                    <h6 class="border-bottom pb-1 mb-3">
                        <i class="bi bi-person me-1"></i>Şoför Maaş Bilgileri
                        @if (aiAktif)
                        {
                            <button class="btn btn-sm btn-purple ms-2" @onclick="AITahminMaasAsync" disabled="@aiYukleniyor">
                                @if (aiYukleniyor)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                <i class="bi bi-robot me-1"></i>AI Tahmin
                            </button>
                        }
                    </h6>
                    <div class="row g-3 mb-3">
                        <div class="col-md-3">
                            <label class="form-label">Brüt Maaş (TL)</label>
                            <input type="number" step="0.01" class="form-control" @bind="editKalem.SoforBrutMaas" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Net Maaş (TL)</label>
                            <input type="number" step="0.01" class="form-control" @bind="editKalem.SoforNetMaas" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">SGK İşveren Payı</label>
                            <input type="number" step="0.01" class="form-control" @bind="editKalem.SoforSGKIsverenPay" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Kâr Marjı (%)</label>
                            <input type="number" step="0.1" class="form-control" @bind="editKalem.KarMarjiOrani" />
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(aiMaasTahminMesaj))
                    {
                        <div class="alert alert-info small">
                            <i class="bi bi-robot me-2"></i>@aiMaasTahminMesaj
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => kalemModalGoster = false">İptal</button>
                    <button class="btn btn-primary" @onclick="KaydetKalemAsync" disabled="@yukleniyor">
                        <i class="bi bi-check me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Loading overlay -->
@if (yukleniyor)
{
    <div class="position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center" style="background: rgba(0,0,0,0.3); z-index: 9999;">
        <div class="text-center text-white">
            <div class="spinner-border spinner-border-lg mb-2"></div>
            <div>İşlem devam ediyor...</div>
        </div>
    </div>
}

<style>
    .btn-purple { background-color: #7c3aed; color: white; border: none; }
    .btn-purple:hover { background-color: #6d28d9; color: white; }
    .bg-purple { background-color: #7c3aed !important; }
    .border-purple { border-color: #7c3aed !important; }
</style>

@code {
    [Parameter] public int? ProjeId { get; set; }

    private List<IhaleProje>? projeler;
    private IhaleProje? secilenProje;
    private List<IhaleGuzergahKalem> aktifKalemler = [];
    private List<Cari>? tumCariler;
    private List<Guzergah> tumGuzergahlar = [];
    private List<Arac> tumAraclar = [];

    private IhaleProje editProje = new();
    private IhaleGuzergahKalem editKalem = new();

    private bool projeModalGoster;
    private bool kalemModalGoster;
    private bool yukleniyor;
    private bool aiAktif;
    private bool aiYukleniyor;
    private bool raporGoster;

    private string? aiAnalizSonuc;
    private string? aiTahminMesaj;
    private string? aiMaasTahminMesaj;
    private string? kalemOneriMesaji;
    private string? yakitFiyatMesaji;
    private string? editKalemBolge;

    private IhaleProjeOzet? projeOzet;

    protected override async Task OnInitializedAsync()
    {
        aiAktif = await OllamaService.BaglantiKontrolAsync();
        tumCariler = await CariService.GetAllAsync();
        tumGuzergahlar = await GuzergahService.GetActiveAsync();
        tumAraclar = await AracService.GetActiveAsync();

        if (ProjeId.HasValue)
            await ProjeSecAsync(ProjeId.Value);
        else
            await LoadProjelerAsync();
    }

    private async Task LoadProjelerAsync()
    {
        projeler = await IhaleService.GetProjelerAsync();
    }

    // ===== Proje İşlemleri =====

    private void YeniProjeModal()
    {
        editProje = new IhaleProje
        {
            BaslangicTarihi = DateTime.Today,
            BitisTarihi = DateTime.Today.AddMonths(12),
            SozlesmeSuresiAy = 12,
            AylikCalismGunu = 22,
            GunlukCalismaSaati = 8,
            EnflasyonOrani = 25,
            YakitZamOrani = 30
        };
        projeModalGoster = true;
    }

    private void ProjeAyarModal()
    {
        if (secilenProje == null) return;
        editProje = secilenProje;
        projeModalGoster = true;
    }

    private async Task KaydetProjeAsync()
    {
        if (string.IsNullOrWhiteSpace(editProje.ProjeAdi)) return;
        yukleniyor = true;

        try
        {
            if (editProje.Id == 0)
            {
                var yeni = await IhaleService.CreateProjeAsync(editProje);
                await ProjeSecAsync(yeni.Id);
            }
            else
            {
                await IhaleService.UpdateProjeAsync(editProje);
                secilenProje = await IhaleService.GetProjeByIdAsync(editProje.Id);
                RefreshKalemler();
            }
            projeModalGoster = false;
            ToastService.ShowSuccess("Proje kaydedildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally { yukleniyor = false; }
    }

    private async Task ProjeSecAsync(int projeId)
    {
        secilenProje = await IhaleService.GetProjeByIdAsync(projeId);
        RefreshKalemler();
    }

    private void RefreshKalemler()
    {
        aktifKalemler = secilenProje?.Kalemler?.Where(k => !k.IsDeleted).ToList() ?? [];
    }

    private async Task ListeyeDon()
    {
        secilenProje = null;
        raporGoster = false;
        aiAnalizSonuc = null;
        projeOzet = null;
        await LoadProjelerAsync();
    }

    private async Task SilProjeAsync(int id)
    {
        await IhaleService.DeleteProjeAsync(id);
        await LoadProjelerAsync();
        ToastService.ShowSuccess("Proje silindi.");
    }

    private async Task KopyalaProjeAsync(IhaleProje p)
    {
        yukleniyor = true;
        try
        {
            await IhaleService.KopyalaProjeAsync(p.Id, $"{p.ProjeAdi} (Kopya)");
            await LoadProjelerAsync();
            ToastService.ShowSuccess("Proje kopyalandı.");
        }
        catch (Exception ex) { ToastService.ShowError(ex.Message); }
        finally { yukleniyor = false; }
    }

    private async Task OrnekVeriOlusturAsync()
    {
        yukleniyor = true;
        StateHasChanged();
        try
        {
            var ornekProje = await IhaleService.OrnekProjeOlusturAsync();
            await ProjeSecAsync(ornekProje.Id);
            ToastService.ShowSuccess("Örnek proje ve güzergah oluşturuldu! Rapor butonuna tıklayarak maliyet analizini görüntüleyebilirsiniz.");
        }
        catch (Exception ex) 
        { 
            ToastService.ShowError($"Örnek veri oluşturma hatası: {ex.Message}"); 
        }
        finally { yukleniyor = false; }
    }

    // ===== Kalem İşlemleri =====

    private void YeniKalemModal()
    {
        if (secilenProje == null) return;
        editKalem = new IhaleGuzergahKalem
        {
            IhaleProjeId = secilenProje.Id,
            GunlukSeferSayisi = 2,
            AylikSeferGunu = secilenProje.AylikCalismGunu,
            SeferTipi = SeferTipi.SabahAksam,
            AracKoltukSayisi = 27,
            YakitTuketimi = 18,
            YakitFiyati = 42,
            KarMarjiOrani = 15,
            AmortismanYili = 5
        };
        aiTahminMesaj = null;
        aiMaasTahminMesaj = null;
        kalemOneriMesaji = null;
        yakitFiyatMesaji = null;
        editKalemBolge = null;
        kalemModalGoster = true;
    }

    private void DuzenleKalemModal(IhaleGuzergahKalem kalem)
    {
        editKalem = kalem;
        aiTahminMesaj = null;
        aiMaasTahminMesaj = null;
        kalemOneriMesaji = null;
        yakitFiyatMesaji = null;
        editKalemBolge = BolgeMetniGetir(kalem);
        kalemModalGoster = true;
    }

    private async Task GuzergahtanDoldurAsync()
    {
        if (!editKalem.GuzergahId.HasValue)
        {
            ToastService.ShowWarning("Önce bir güzergah seçin.");
            return;
        }

        var guzergah = tumGuzergahlar.FirstOrDefault(g => g.Id == editKalem.GuzergahId.Value)
            ?? await GuzergahService.GetByIdAsync(editKalem.GuzergahId.Value);
        if (guzergah == null)
        {
            ToastService.ShowError("Güzergah bulunamadı.");
            return;
        }

        editKalem.HatAdi = string.IsNullOrWhiteSpace(editKalem.HatAdi) ? guzergah.GuzergahAdi : editKalem.HatAdi;
        editKalem.BaslangicNoktasi = string.IsNullOrWhiteSpace(editKalem.BaslangicNoktasi) ? guzergah.BaslangicNoktasi : editKalem.BaslangicNoktasi;
        editKalem.BitisNoktasi = string.IsNullOrWhiteSpace(editKalem.BitisNoktasi) ? guzergah.BitisNoktasi : editKalem.BitisNoktasi;
        if (editKalem.MesafeKm <= 0 && guzergah.Mesafe.HasValue)
            editKalem.MesafeKm = guzergah.Mesafe.Value;
        if (editKalem.TahminiSureDakika <= 0 && guzergah.TahminiSure.HasValue)
            editKalem.TahminiSureDakika = guzergah.TahminiSure.Value;
        if (editKalem.PersonelSayisi <= 0)
            editKalem.PersonelSayisi = guzergah.PersonelSayisi;
        if (editKalem.GunlukSeferSayisi <= 0)
            editKalem.GunlukSeferSayisi = guzergah.SeferTipi == SeferTipi.SabahAksam ? 2 : 1;

        editKalem.SeferTipi = guzergah.SeferTipi;
        editKalemBolge ??= BolgeMetniGetir(editKalem);
        kalemOneriMesaji = $"Güzergah bilgileri '{guzergah.GuzergahAdi}' üzerinden dolduruldu.";
    }

    private Task AracOnerAsync()
    {
        var gerekliKapasite = Math.Max(1, editKalem.PersonelSayisi);
        var adaylar = tumAraclar
            .Where(a => a.Aktif && !a.IsDeleted && a.KoltukSayisi >= gerekliKapasite)
            .Where(a => editKalem.SahiplikDurumu switch
            {
                AracSahiplikKalem.Ozmal => a.SahiplikTipi == AracSahiplikTipi.Ozmal,
                AracSahiplikKalem.Kiralik => a.SahiplikTipi == AracSahiplikTipi.Kiralik,
                AracSahiplikKalem.Komisyon => a.SahiplikTipi == AracSahiplikTipi.Komisyon,
                _ => true
            })
            .OrderBy(a => a.KoltukSayisi - gerekliKapasite)
            .ThenBy(a => a.KmDurumu ?? int.MaxValue)
            .ThenByDescending(a => a.ModelYili ?? 0)
            .ToList();

        if (!adaylar.Any())
        {
            adaylar = tumAraclar
                .Where(a => a.Aktif && !a.IsDeleted && a.KoltukSayisi >= gerekliKapasite)
                .OrderBy(a => a.KoltukSayisi - gerekliKapasite)
                .ThenBy(a => a.KmDurumu ?? int.MaxValue)
                .ThenByDescending(a => a.ModelYili ?? 0)
                .ToList();
        }

        var arac = adaylar.FirstOrDefault();
        if (arac == null)
        {
            kalemOneriMesaji = "Uygun aktif araç bulunamadı.";
            return Task.CompletedTask;
        }

        editKalem.AracId = arac.Id;
        editKalem.AracModelBilgi = string.Join(" ", new[] { arac.ModelYili?.ToString(), arac.Marka, arac.Model }.Where(x => !string.IsNullOrWhiteSpace(x)));
        editKalem.AracKoltukSayisi = arac.KoltukSayisi;
        editKalem.SahiplikDurumu = arac.SahiplikTipi switch
        {
            AracSahiplikTipi.Ozmal => AracSahiplikKalem.Ozmal,
            AracSahiplikTipi.Kiralik => AracSahiplikKalem.Kiralik,
            AracSahiplikTipi.Komisyon => AracSahiplikKalem.Komisyon,
            _ => editKalem.SahiplikDurumu
        };

        if (arac.AylikKiraBedeli.HasValue)
            editKalem.AylikKiraBedeli = arac.AylikKiraBedeli.Value;
        if (arac.KomisyonVar && arac.SabitKomisyonTutari.HasValue)
            editKalem.SeferBasiKomisyon = arac.SabitKomisyonTutari.Value;

        editKalem.YakitTuketimi = AracTipineGoreVarsayilanYakit(arac.AracTipi, editKalem.YakitTuketimi);
        kalemOneriMesaji = $"Önerilen araç: {editKalem.AracModelBilgi} {(string.IsNullOrWhiteSpace(arac.AktifPlaka) ? string.Empty : $"({arac.AktifPlaka})")} - {arac.KoltukSayisi} koltuk.";
        return Task.CompletedTask;
    }

    private async Task GuncelYakitFiyatiGetirAsync()
    {
        var bolge = string.IsNullOrWhiteSpace(editKalemBolge) ? BolgeMetniGetir(editKalem) : editKalemBolge;
        if (string.IsNullOrWhiteSpace(bolge))
        {
            ToastService.ShowWarning("Yakıt fiyatı için önce bölge veya başlangıç bilgisi girin.");
            return;
        }

        try
        {
            yakitFiyatMesaji = "Petrol Ofisi verilerinden güncel motorin fiyatı alınıyor...";
            StateHasChanged();

            var client = HttpClientFactory.CreateClient();
            client.DefaultRequestHeaders.UserAgent.ParseAdd("Mozilla/5.0");
            var html = await client.GetStringAsync("https://www.petrolofisi.com.tr/akaryakit-fiyatlari");
            var fiyat = PetrolOfisiMotorinFiyatiBul(html, bolge);

            if (fiyat.HasValue)
            {
                editKalem.YakitFiyati = fiyat.Value;
                editKalemBolge = bolge;
                yakitFiyatMesaji = $"{bolge} için webden motorin fiyatı alındı: {fiyat.Value:N2} TL/LT.";
            }
            else
            {
                yakitFiyatMesaji = $"{bolge} için web sayfasında eşleşen güncel motorin fiyatı bulunamadı. Mevcut değer korundu.";
            }
        }
        catch (Exception ex)
        {
            yakitFiyatMesaji = $"Yakıt fiyatı alınamadı: {ex.Message}";
        }
    }

    private async Task KaydetKalemAsync()
    {
        if (string.IsNullOrWhiteSpace(editKalem.HatAdi) || secilenProje == null) return;
        yukleniyor = true;

        try
        {
            if (editKalem.Id == 0)
                await IhaleService.AddKalemAsync(editKalem);
            else
                await IhaleService.UpdateKalemAsync(editKalem);

            secilenProje = await IhaleService.GetProjeByIdAsync(secilenProje.Id);
            RefreshKalemler();
            kalemModalGoster = false;
            ToastService.ShowSuccess("Hat kaydedildi.");
        }
        catch (Exception ex) { ToastService.ShowError(ex.Message); }
        finally { yukleniyor = false; }
    }

    private async Task SilKalemAsync(int kalemId)
    {
        await IhaleService.DeleteKalemAsync(kalemId);
        secilenProje = await IhaleService.GetProjeByIdAsync(secilenProje!.Id);
        RefreshKalemler();
        ToastService.ShowSuccess("Hat silindi.");
    }

