@page "/filo-operasyon/plaka-donusum"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@inject IFiloOperasyonService FiloOperasyonService
@inject IAracService AracService
@inject NavigationManager NavigationManager
@inject IToastService ToastService

<PageTitle>Plaka Dönüşüm Takibi | KOA Filo Servis</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="/filo-operasyon">Filo Operasyon</a></li>
                    <li class="breadcrumb-item active">Plaka Dönüşüm</li>
                </ol>
            </nav>
            <h3 class="mb-0">
                <i class="bi bi-card-text me-2"></i>Plaka Dönüşüm Takibi
            </h3>
        </div>
        <button class="btn btn-primary" @onclick="YeniDonusum">
            <i class="bi bi-plus-lg me-1"></i> Yeni Dönüşüm
        </button>
    </div>

    <!-- Özet Kartları -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body text-center">
                    <h6>Başvuru Yapıldı</h6>
                    <h4 class="mb-0">@_donusumler.Count(d => d.Durum == PlakaDonusumDurum.BasvuruYapildi)</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning">
                <div class="card-body text-center">
                    <h6>İncelemede</h6>
                    <h4 class="mb-0">@_donusumler.Count(d => d.Durum == PlakaDonusumDurum.EvrakIncelemede)</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body text-center">
                    <h6>Tamamlandı</h6>
                    <h4 class="mb-0">@_donusumler.Count(d => d.Durum == PlakaDonusumDurum.Tamamlandi)</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body text-center">
                    <h6>Plaka Satışı Bekleyen</h6>
                    <h4 class="mb-0">@_donusumler.Count(d => d.PlakaSatilacakMi && !d.PlakaSatildi)</h4>
                </div>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else if (!_donusumler.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            Kayıtlı plaka dönüşüm işlemi bulunamadı.
        </div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Araç</th>
                            <th>Eski Plaka</th>
                            <th>Yeni Plaka</th>
                            <th>Başvuru</th>
                            <th>Durum</th>
                            <th class="text-end">Masraflar</th>
                            <th>Plaka Satışı</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var donusum in _donusumler)
                        {
                            <tr>
                                <td>
                                    <strong>@(donusum.Arac?.Marka ?? "-") @(donusum.Arac?.Model ?? "")</strong>
                                </td>
                                <td>
                                    <span class="badge @GetPlakaTipiBadge(donusum.EskiPlakaTipi)">
                                        @donusum.EskiPlaka
                                    </span>
                                    <br/>
                                    <small class="text-muted">@GetPlakaTipiText(donusum.EskiPlakaTipi)</small>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(donusum.YeniPlaka))
                                    {
                                        <span class="badge @GetPlakaTipiBadge(donusum.YeniPlakaTipi)">
                                            @donusum.YeniPlaka
                                        </span>
                                        <br/>
                                        <small class="text-muted">@GetPlakaTipiText(donusum.YeniPlakaTipi)</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @donusum.BasvuruTarihi.ToString("dd.MM.yyyy")
                                    @if (donusum.TamamlanmaTarihi.HasValue)
                                    {
                                        <br/>
                                        <small class="text-success">
                                            <i class="bi bi-check"></i> @donusum.TamamlanmaTarihi.Value.ToString("dd.MM.yyyy")
                                        </small>
                                    }
                                </td>
                                <td>
                                    <span class="badge @GetDurumBadge(donusum.Durum)">
                                        @GetDurumText(donusum.Durum)
                                    </span>
                                </td>
                                <td class="text-end">
                                    <strong>@donusum.ToplamMasraf.ToString("N2") ₺</strong>
                                    <br/>
                                    <small class="text-muted">
                                        Plaka: @donusum.PlakaBedeliMasrafi.ToString("N0") ₺
                                    </small>
                                </td>
                                <td>
                                    @if (donusum.PlakaSatilacakMi)
                                    {
                                        @if (donusum.PlakaSatildi)
                                        {
                                            <span class="badge bg-success">
                                                Satıldı: @donusum.PlakaSatisBedeli?.ToString("N0") ₺
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">
                                                Satışta: @donusum.PlakaSatisBedeli?.ToString("N0") ₺
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a href="/filo-operasyon/plaka-donusum/@donusum.Id/duzenle" class="btn btn-outline-primary" title="Düzenle">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button class="btn btn-outline-danger" title="Sil" @onclick="() => SilOnay(donusum)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<!-- Silme Onay Modal -->
@if (_silinecekDonusum != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Silme Onayı</h5>
                    <button type="button" class="btn-close" @onclick="() => _silinecekDonusum = null"></button>
                </div>
                <div class="modal-body">
                    <p><strong>@_silinecekDonusum.EskiPlaka</strong> plakalı aracın dönüşüm kaydını silmek istediğinize emin misiniz?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => _silinecekDonusum = null">İptal</button>
                    <button type="button" class="btn btn-danger" @onclick="Sil">
                        <i class="bi bi-trash me-1"></i> Sil
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private List<PlakaDonusum> _donusumler = new();
    private PlakaDonusum? _silinecekDonusum;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _donusumler = await FiloOperasyonService.GetPlakaDonusumlerAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Veri yüklenirken hata: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private void YeniDonusum()
    {
        NavigationManager.NavigateTo("/filo-operasyon/plaka-donusum/yeni");
    }

    private void SilOnay(PlakaDonusum donusum)
    {
        _silinecekDonusum = donusum;
    }

    private async Task Sil()
    {
        if (_silinecekDonusum == null) return;

        try
        {
            await FiloOperasyonService.DeletePlakaDonusumAsync(_silinecekDonusum.Id);
            _donusumler.Remove(_silinecekDonusum);
            ToastService.ShowSuccess("Kayıt başarıyla silindi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Silme hatası: {ex.Message}");
        }
        finally
        {
            _silinecekDonusum = null;
        }
    }

    private string GetPlakaTipiText(PlakaTipi tip) => tip switch
    {
        PlakaTipi.CPlakaLimonSari => "C Plaka (Sarı)",
        PlakaTipi.CPlakaTurkuaz => "C Plaka (Turkuaz)",
        PlakaTipi.OzelPlaka => "Özel Plaka",
        PlakaTipi.MPlaka => "M Plaka",
        PlakaTipi.SPlaka => "S Plaka",
        _ => tip.ToString()
    };

    private string GetPlakaTipiBadge(PlakaTipi tip) => tip switch
    {
        PlakaTipi.CPlakaLimonSari => "bg-warning text-dark",
        PlakaTipi.CPlakaTurkuaz => "bg-info",
        PlakaTipi.OzelPlaka => "bg-light text-dark border",
        PlakaTipi.MPlaka => "bg-secondary",
        PlakaTipi.SPlaka => "bg-primary",
        _ => "bg-secondary"
    };

    private string GetDurumText(PlakaDonusumDurum durum) => durum switch
    {
        PlakaDonusumDurum.BasvuruYapildi => "Başvuru Yapıldı",
        PlakaDonusumDurum.EvrakIncelemede => "Evrak İncelemede",
        PlakaDonusumDurum.Onaylandi => "Onaylandı",
        PlakaDonusumDurum.YeniPlakaAlindi => "Yeni Plaka Alındı",
        PlakaDonusumDurum.Tamamlandi => "Tamamlandı",
        PlakaDonusumDurum.Reddedildi => "Reddedildi",
        PlakaDonusumDurum.IptalEdildi => "İptal Edildi",
        _ => durum.ToString()
    };

    private string GetDurumBadge(PlakaDonusumDurum durum) => durum switch
    {
        PlakaDonusumDurum.BasvuruYapildi => "bg-info",
        PlakaDonusumDurum.EvrakIncelemede => "bg-warning text-dark",
        PlakaDonusumDurum.Onaylandi => "bg-primary",
        PlakaDonusumDurum.YeniPlakaAlindi => "bg-success",
        PlakaDonusumDurum.Tamamlandi => "bg-success",
        PlakaDonusumDurum.Reddedildi => "bg-danger",
        PlakaDonusumDurum.IptalEdildi => "bg-secondary",
        _ => "bg-secondary"
    };
}
