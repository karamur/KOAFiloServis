@page "/filo-operasyon"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@inject IFiloOperasyonService FiloOperasyonService
@inject NavigationManager NavigationManager

<PageTitle>Filo Operasyon Yönetimi | KOA Filo Servis</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">
            <i class="bi bi-truck me-2"></i>Filo Operasyon Yönetimi
        </h3>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else
    {
        <!-- Özet Kartları -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card border-primary h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-2">Toplam Araç</h6>
                                <h3 class="mb-0">@_ozet.ToplamAracSayisi</h3>
                                <small class="text-muted">
                                    Özmal: @_ozet.OzmalAracSayisi | Kiralık: @_ozet.KiralikAracSayisi
                                </small>
                            </div>
                            <div class="text-primary">
                                <i class="bi bi-car-front fs-1"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-success h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-2">Aktif Komisyonculuk İşleri</h6>
                                <h3 class="mb-0">@_ozet.AktifKomisyonculukIsSayisi</h3>
                            </div>
                            <div class="text-success">
                                <i class="bi bi-briefcase fs-1"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-2">Satışa Bekleyen</h6>
                                <h3 class="mb-0">@_ozet.SatisaBekleyenAracSayisi</h3>
                                <small class="text-warning">
                                    @_ozet.NoterBekleyenSatisSayisi noter bekliyor
                                </small>
                            </div>
                            <div class="text-warning">
                                <i class="bi bi-tag fs-1"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-info h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-2">Plaka Dönüşüm</h6>
                                <h3 class="mb-0">@_ozet.DevamEdenPlakaDonusumSayisi</h3>
                                <small class="text-muted">devam eden</small>
                            </div>
                            <div class="text-info">
                                <i class="bi bi-card-text fs-1"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Hızlı İşlemler -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-light">
                        <h5 class="mb-0"><i class="bi bi-lightning-charge me-2"></i>Hızlı İşlemler</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <button class="btn btn-outline-primary w-100 py-3" @onclick="YeniKomisyonculukIs">
                                    <i class="bi bi-plus-circle fs-4 d-block mb-2"></i>
                                    Yeni Komisyonculuk İşi
                                </button>
                            </div>
                            <div class="col-md-3">
                                <button class="btn btn-outline-success w-100 py-3" @onclick="YeniAracAlim">
                                    <i class="bi bi-box-arrow-in-down fs-4 d-block mb-2"></i>
                                    Araç Alımı
                                </button>
                            </div>
                            <div class="col-md-3">
                                <button class="btn btn-outline-warning w-100 py-3" @onclick="YeniAracSatis">
                                    <i class="bi bi-box-arrow-up fs-4 d-block mb-2"></i>
                                    Araç Satışı
                                </button>
                            </div>
                            <div class="col-md-3">
                                <button class="btn btn-outline-info w-100 py-3" @onclick="YeniPlakaDonusum">
                                    <i class="bi bi-arrow-repeat fs-4 d-block mb-2"></i>
                                    Plaka Dönüşümü
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modül Kartları -->
        <div class="row g-4">
            <!-- Komisyonculuk -->
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-briefcase me-2"></i>Komisyonculuk İş Takibi</h5>
                        <a href="/filo-operasyon/komisyonculuk" class="btn btn-sm btn-light">
                            <i class="bi bi-arrow-right"></i> Tümü
                        </a>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            Firmalardan alınan işler, dışarıdan temin edilen araç/şoför atamaları, 
                            fatura kesimi ve kazanç takibi.
                        </p>
                        <ul class="list-unstyled">
                            <li><i class="bi bi-check-circle text-success me-2"></i>İş alma ve müşteri yönetimi</li>
                            <li><i class="bi bi-check-circle text-success me-2"></i>Özmal/kiralık araç ve şoför atama</li>
                            <li><i class="bi bi-check-circle text-success me-2"></i>Maliyet ve kar/zarar hesaplama</li>
                            <li><i class="bi bi-check-circle text-success me-2"></i>Alınan iş - Verilen iş fatura eşleştirme</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Araç Alım/Satım -->
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-warning d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-cart-plus me-2"></i>Araç Alım/Satım</h5>
                        <a href="/filo-operasyon/alim-satim" class="btn btn-sm btn-light">
                            <i class="bi bi-arrow-right"></i> Tümü
                        </a>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            Özmal ve dışarıdan alınan araçların satışı, yeni araç alımı, 
                            noter evrak takibi ve fatura kontrolü.
                        </p>
                        <ul class="list-unstyled">
                            <li><i class="bi bi-check-circle text-warning me-2"></i>Araç alış/satış kayıtları</li>
                            <li><i class="bi bi-check-circle text-warning me-2"></i>Noter evrak takibi</li>
                            <li><i class="bi bi-check-circle text-warning me-2"></i>Fatura kesim kontrolü</li>
                            <li><i class="bi bi-check-circle text-warning me-2"></i>Belge teslim durumu</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Plaka Dönüşüm -->
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-card-text me-2"></i>Plaka Dönüşüm</h5>
                        <a href="/filo-operasyon/plaka-donusum" class="btn btn-sm btn-light">
                            <i class="bi bi-arrow-right"></i> Tümü
                        </a>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            C plakalı araçların normal plakaya dönüşümü, eski plaka satışı ve 
                            masraf takibi.
                        </p>
                        <ul class="list-unstyled">
                            <li><i class="bi bi-check-circle text-info me-2"></i>C plaka → Normal plaka dönüşüm</li>
                            <li><i class="bi bi-check-circle text-info me-2"></i>Başvuru ve onay takibi</li>
                            <li><i class="bi bi-check-circle text-info me-2"></i>Masraf hesaplama</li>
                            <li><i class="bi bi-check-circle text-info me-2"></i>Eski plaka satış takibi</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Operasyon Durumu -->
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-graph-up me-2"></i>Operasyon & Raporlar</h5>
                        <a href="/filo-operasyon/raporlar" class="btn btn-sm btn-light">
                            <i class="bi bi-arrow-right"></i> Tümü
                        </a>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            Araç bazlı gelir/gider takibi, kar/zarar analizi ve 
                            operasyon performans raporları.
                        </p>
                        <ul class="list-unstyled">
                            <li><i class="bi bi-check-circle text-primary me-2"></i>Araç kar/zarar analizi</li>
                            <li><i class="bi bi-check-circle text-primary me-2"></i>Komisyonculuk kazanç raporu</li>
                            <li><i class="bi bi-check-circle text-primary me-2"></i>Aylık operasyon özeti</li>
                            <li><i class="bi bi-check-circle text-primary me-2"></i>Filo performans karşılaştırma</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private FiloOzetRaporu _ozet = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _ozet = await FiloOperasyonService.GetFiloOzetRaporuAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Filo özet yüklenirken hata: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private void YeniKomisyonculukIs()
    {
        NavigationManager.NavigateTo("/filo-operasyon/komisyonculuk/yeni");
    }

    private void YeniAracAlim()
    {
        NavigationManager.NavigateTo("/filo-operasyon/alim-satim/yeni?tip=alim");
    }

    private void YeniAracSatis()
    {
        NavigationManager.NavigateTo("/filo-operasyon/alim-satim/yeni?tip=satis");
    }

    private void YeniPlakaDonusum()
    {
        NavigationManager.NavigateTo("/filo-operasyon/plaka-donusum/yeni");
    }
}
