        IslemKaynak.Havale => "H",
        IslemKaynak.Eft => "E",
        IslemKaynak.Nakit => "N",
        IslemKaynak.Butce => "B",
        IslemKaynak.EFatura => "EF",
        IslemKaynak.Mahsup => "MH",
        IslemKaynak.CariMahsup => "CM",
        _ => "?"
    };

    private string GetKaynakBadgeClass(IslemKaynak kaynak) => kaynak switch
    {
        IslemKaynak.Manuel => "bg-primary",
