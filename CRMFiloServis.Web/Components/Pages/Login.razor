@page "/login"
@layout EmptyLayout
@attribute [AllowAnonymous]
@using CRMFiloServis.Web.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject IKullaniciService KullaniciService
@inject ILisansService LisansService
@inject NavigationManager Navigation
@inject AppAuthenticationStateProvider AuthProvider
@inject ProtectedLocalStorage LocalStorage
@rendermode InteractiveServer

<PageTitle>Giris - CRM Filo Servis</PageTitle>

<div class="login-container">
    <div class="login-background">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
    </div>

    <div class="login-card">
        <div class="login-header">
            <div class="logo-container">
                <i class="bi bi-truck"></i>
            </div>
            <h1>CRM Filo Servis</h1>
            <p>Filo Yonetim ve Muhasebe Sistemi</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
            </div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@successMessage
                <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
            </div>
        }

        <div class="login-form">
            <div class="form-floating mb-3">
                <input type="text" class="form-control" id="kullaniciAdi" placeholder="Kullanici Adi"
                       @bind="kullaniciAdi" @bind:event="oninput" @onkeypress="HandleKeyPress" autocomplete="username" />
                <label for="kullaniciAdi"><i class="bi bi-person me-2"></i>Kullanici Adi</label>
            </div>

            <div class="form-floating mb-3">
                <input type="@(showPassword ? "text" : "password")" class="form-control" id="sifre" placeholder="Sifre"
                       @bind="sifre" @bind:event="oninput" @onkeypress="HandleKeyPress" autocomplete="current-password" />
                <label for="sifre"><i class="bi bi-lock me-2"></i>Sifre</label>
                <button type="button" class="password-toggle" @onclick="() => showPassword = !showPassword">
                    <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                </button>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="beniHatirla" @bind="beniHatirla" />
                    <label class="form-check-label" for="beniHatirla">Beni Hatirla</label>
                </div>
                <a href="#" class="forgot-password" @onclick="SifremiUnuttum" @onclick:preventDefault>Sifremi Unuttum</a>
            </div>

            <button class="btn btn-primary btn-login w-100" @onclick="GirisYapAsync" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <span>Giris Yapiliyor...</span>
                }
                else
                {
                    <i class="bi bi-box-arrow-in-right me-2"></i>
                    <span>Giris Yap</span>
                }
            </button>
        </div>

        <div class="login-footer">
            @if (lisans != null)
            {
                <div class="license-info">
                    <span class="badge @(lisans.KalanGun <= 7 ? "bg-danger" : "bg-success")">
                        @lisans.Tur - @lisans.KalanGun Gun Kaldi
                    </span>
                </div>
            }
            <div class="github-links mb-2">
                <a href="https://github.com/karamur/CRMFiloServis" target="_blank" class="text-light me-3">
                    <i class="bi bi-github"></i> CRMFiloServis
                </a>
                <a href="https://github.com/karamur/AYDAAnaliz" target="_blank" class="text-light">
                    <i class="bi bi-github"></i> AYDAAnaliz
                </a>
            </div>
            <p class="version mb-1">v1.0.0 © @DateTime.Now.Year Allbatros Global Teknoloji</p>
            <p class="version small">Tum Haklari Saklidir</p>
        </div>
    </div>
</div>

<style>
    .login-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        position: relative;
        overflow: hidden;
        padding: env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left);
    }

    .login-background {
        position: absolute;
        width: 100%;
        height: 100%;
        overflow: hidden;
    }

    .shape {
        position: absolute;
        border-radius: 50%;
        opacity: 0.1;
    }

    .shape-1 {
        width: 400px;
        height: 400px;
        background: white;
        top: -100px;
        left: -100px;
        animation: float 8s ease-in-out infinite;
    }

    .shape-2 {
        width: 300px;
        height: 300px;
        background: white;
        bottom: -50px;
        right: -50px;
        animation: float 6s ease-in-out infinite reverse;
    }

    .shape-3 {
        width: 200px;
        height: 200px;
        background: white;
        top: 50%;
        right: 20%;
        animation: float 10s ease-in-out infinite;
    }

    @@keyframes float {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-30px) rotate(10deg); }
    }

    .login-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        padding: 40px;
        width: 100%;
        max-width: 420px;
        position: relative;
        z-index: 10;
        animation: slideUp 0.5s ease-out;
        margin: 20px;
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .login-header {
        text-align: center;
        margin-bottom: 30px;
    }

    .logo-container {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        box-shadow: 0 10px 30px -5px rgba(30, 60, 114, 0.4);
    }

    .logo-container i {
        font-size: 2.5rem;
        color: white;
    }

    .login-header h1 {
        font-size: 1.75rem;
        font-weight: 700;
        color: #1e3c72;
        margin-bottom: 5px;
    }

    .login-header p {
        color: #6c757d;
        font-size: 0.9rem;
    }

    .form-floating {
        position: relative;
    }

    .form-floating .form-control {
        height: 55px;
        border-radius: 12px;
        border: 2px solid #e9ecef;
        padding-left: 45px;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

    .form-floating .form-control:focus {
        border-color: #1e3c72;
        box-shadow: 0 0 0 4px rgba(30, 60, 114, 0.1);
    }

    .form-floating label {
        padding-left: 45px;
        color: #6c757d;
    }

    .form-floating label i {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: #1e3c72;
    }

    .password-toggle {
        position: absolute;
        right: 15px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #6c757d;
        cursor: pointer;
        z-index: 10;
    }

    .password-toggle:hover {
        color: #1e3c72;
    }

    .form-check-input:checked {
        background-color: #1e3c72;
        border-color: #1e3c72;
    }

    .forgot-password {
        color: #1e3c72;
        text-decoration: none;
        font-size: 0.875rem;
    }

    .forgot-password:hover {
        text-decoration: underline;
    }

    .btn-login {
        height: 55px;
        border-radius: 12px;
        font-size: 1.1rem;
        font-weight: 600;
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        border: none;
        transition: all 0.3s ease;
    }

    .btn-login:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px -5px rgba(30, 60, 114, 0.4);
    }

    .btn-login:disabled {
        opacity: 0.7;
    }

    .login-footer {
        text-align: center;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #e9ecef;
    }

    .license-info {
        margin-bottom: 10px;
    }

    .version {
        color: #adb5bd;
        font-size: 0.8rem;
        margin: 0;
    }

    .alert {
        border-radius: 12px;
        margin-bottom: 20px;
    }

    @@media (max-width: 480px) {
        .login-card {
            padding: 25px;
            margin: 10px;
        }

        .logo-container {
            width: 60px;
            height: 60px;
        }

        .logo-container i {
            font-size: 1.8rem;
        }

        .login-header h1 {
            font-size: 1.4rem;
        }

        .form-floating .form-control {
            height: 50px;
        }

        .btn-login {
            height: 50px;
            font-size: 1rem;
        }
    }
</style>

@code {
    private string kullaniciAdi = "";
    private string sifre = "";
    private bool beniHatirla = false;
    private bool showPassword = false;
    private bool isLoading = false;
    private string? errorMessage;
    private string? successMessage;
    private CRMFiloServis.Shared.Entities.Lisans? lisans;
    
    private const string REMEMBER_KEY = "CRMFiloServis_RememberMe";

    protected override async Task OnInitializedAsync()
    {
        lisans = await LisansService.GetAktifLisansAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // "Beni Hatirla" seciliyse kullanici adini yukle
            try
            {
                var result = await LocalStorage.GetAsync<string>(REMEMBER_KEY);
                if (result.Success && !string.IsNullOrEmpty(result.Value))
                {
                    kullaniciAdi = result.Value;
                    beniHatirla = true;
                    StateHasChanged();
                }
            }
            catch
            {
                // Local storage erisim hatasi - sessizce devam et
            }
        }
    }

    private async Task GirisYapAsync()
    {
        if (string.IsNullOrWhiteSpace(kullaniciAdi) || string.IsNullOrWhiteSpace(sifre))
        {
            errorMessage = "Kullanici adi ve sifre zorunludur!";
            return;
        }

        isLoading = true;
        errorMessage = null;
        successMessage = null;
        StateHasChanged();

        try
        {
            var sonuc = await KullaniciService.GirisYapAsync(kullaniciAdi, sifre);

            if (sonuc.Basarili)
            {
                // "Beni Hatirla" tercihini kaydet
                try
                {
                    if (beniHatirla)
                    {
                        await LocalStorage.SetAsync(REMEMBER_KEY, kullaniciAdi);
                    }
                    else
                    {
                        await LocalStorage.DeleteAsync(REMEMBER_KEY);
                    }
                }
                catch
                {
                    // Local storage hatasi - kritik degil
                }
                
                successMessage = "Giris basarili! Yonlendiriliyorsunuz...";
                StateHasChanged();

                // Ana sayfaya yonlendir
                await Task.Delay(200);
                Navigation.NavigateTo("/", replace: true);
            }
            else
            {
                errorMessage = sonuc.Mesaj ?? "Giris basarisiz!";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Bir hata olustu: " + ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await GirisYapAsync();
        }
    }

    private void SifremiUnuttum()
    {
        errorMessage = null;
        successMessage = "Sifre sifirlama icin sistem yoneticisi ile iletisime gecin.";
    }
}
