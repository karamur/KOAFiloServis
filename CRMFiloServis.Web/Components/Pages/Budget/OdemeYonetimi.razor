    private async Task OdemeSilOnay(BudgetOdeme odeme)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"'{odeme.MasrafKalemi}' odemesini silmek istediginize emin misiniz?");
        if (confirmed)
        {
