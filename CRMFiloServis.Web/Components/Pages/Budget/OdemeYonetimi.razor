    private void TaksitliOdemeAc()
    {
        taksitRequest = new TaksitliOdemeRequest
        {
            BaslangicTarihi = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1),
            TaksitSayisi = 12
        };
        showTaksitModal = true;
    }

    private async Task TaksitliOdemeKaydetAsync()
    {
        if (!TaksitKaydetmeGecerliMi())
        {
            ToastService.ShowWarning("Lütfen taksit planını kontrol edin!");
            return;
        }

        try
        {
            // Kullanicinin duzenledigi taksit planini request'e ekle
            taksitRequest.TaksitPlani = taksitListesi.Select(t => new TaksitDetayRequest
            {
                Sira = t.Sira,
                Tarih = t.Tarih,
                Tutar = t.Tutar
            }).ToList();

            await BudgetService.CreateTaksitliOdemeAsync(taksitRequest);
            ToastService.ShowSuccess(taksitRequest.TaksitSayisi + " taksit olusturuldu.");
            ModalKapat();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private void ModalKapat()
    {
        showOdemeModal = false;
        showOdemeYapModal = false;
        showTaksitModal = false;
        taksitListesi.Clear();
    }

    private string GetAyAdi(int ay) => AyAdlari[ay];
    private string GetDurumAdi(BudgetOdeme o) 
    { 
        if (o.Durum == OdemeDurum.Bekliyor) 
        { 
            var gun = (o.OdemeTarihi.Date - DateTime.Today).Days; 
            if(gun < 0) return $"{-gun} Gün Gecikti"; 
            if(gun == 0) return "Bugün Son"; 
            return $"{gun} Gün Kaldı"; 
        } 
        return o.Durum == OdemeDurum.Odendi ? "Ödendi" : o.Durum == OdemeDurum.Ertelendi ? "Ertelendi" : o.Durum == OdemeDurum.Iptal ? "İptal" : o.Durum.ToString(); 
    }
    
    private string GetDurumClass(BudgetOdeme o) 
    { 
        if (o.Durum == OdemeDurum.Bekliyor) 
        { 
            var gun = (o.OdemeTarihi.Date - DateTime.Today).Days; 
            if(gun < 0) return "bg-danger text-white"; 
            if(gun == 0) return "bg-warning text-dark"; 
            return "bg-info text-white"; 
        } 
        return o.Durum == OdemeDurum.Odendi ? "bg-success text-white" : o.Durum == OdemeDurum.Ertelendi ? "bg-secondary" : o.Durum == OdemeDurum.Iptal ? "bg-danger" : "bg-light text-dark"; 
    }
    private string FormatPara(decimal t) => t.ToString("N2", new System.Globalization.CultureInfo("tr-TR")) + " TL";

    // Taksit Planlama Islemleri
    private List<TaksitBilgisi> taksitListesi = new();

    private void TaksitListesiHesapla()
    {
        taksitListesi.Clear();

        if (taksitRequest.TaksitSayisi <= 1 || taksitRequest.ToplamTutar <= 0)
            return;

        var ilkOdemeTarihi = taksitRequest.BaslangicTarihi;
        var taksitTutari = Math.Round(taksitRequest.ToplamTutar / taksitRequest.TaksitSayisi, 2);

        for (int i = 0; i < taksitRequest.TaksitSayisi; i++)
        {
            taksitListesi.Add(new TaksitBilgisi
            {
                Sira = i + 1,
                Tarih = ilkOdemeTarihi.AddMonths(i),
                Tutar = taksitTutari
            });
        }

        // Son taksitte yuvarlama farkini duzelt (toplam tam tutsun)
        var fark = taksitRequest.ToplamTutar - taksitListesi.Sum(t => t.Tutar);
        if (fark != 0 && taksitListesi.Any())
        {
            taksitListesi.Last().Tutar += fark;
        }
    }

    private void TaksitListesiSifirla()
    {
        taksitListesi.Clear();
        TaksitListesiHesapla();
        StateHasChanged();
    }

    private void TaksitTarihDegistir(TaksitBilgisi taksit, ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var yeniTarih))
        {
            taksit.Tarih = yeniTarih;
            StateHasChanged();
        }
    }

    private void TaksitTutarDegistir(TaksitBilgisi taksit, ChangeEventArgs e)
    {
        var valueStr = e.Value?.ToString() ?? "0";
        if (decimal.TryParse(valueStr, System.Globalization.NumberStyles.Any, 
            new System.Globalization.CultureInfo("tr-TR"), out var yeniTutar) && yeniTutar >= 0)
        {
            taksit.Tutar = yeniTutar;
            StateHasChanged();
        }
    }

    private bool TaksitKaydetmeGecerliMi()
    {
        if (taksitRequest.TaksitSayisi < 1 || taksitRequest.ToplamTutar <= 0)
            return false;

        if (string.IsNullOrWhiteSpace(taksitRequest.MasrafKalemi))
            return false;

        if (!taksitListesi.Any())
            return false;

        // Fark kontrolu - 0.01 TL tolerans
        var taksitToplam = taksitListesi.Sum(t => t.Tutar);
        var fark = Math.Abs(taksitRequest.ToplamTutar - taksitToplam);
        
        return fark < 0.01m;
    }

    private class TaksitBilgisi
    {
        public int Sira { get; set; }
        public DateTime Tarih { get; set; }
        public decimal Tutar { get; set; }
    }
}
