    private string GetGunVadeRenk(DateTime gunTarihi)
    {
        var fark = (gunTarihi.Date - DateTime.Today).Days;

        if (fark < 0)
            return "#dc3545"; // Gecmis - kirmizi
        else if (fark == 0)
            return "#ffc107"; // Bugun - sari
        else
            return "#198754"; // Gelecek (1+ gun) - yesil
    }

    private string GetOdemeVadeRenk(BudgetOdeme odeme)
    {
        var kalanGun = (odeme.OdemeTarihi.Date - DateTime.Today).Days;

        if (kalanGun < 0)
            return "#dc3545"; // Gecmis - kirmizi
        else if (kalanGun == 0)
            return "#ffc107"; // Bugun - sari
        else
            return "#198754"; // Gelecek (1+ gun) - yesil
    }
