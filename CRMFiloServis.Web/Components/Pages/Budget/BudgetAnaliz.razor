<!-- Aylik Liste On Izleme/Yazdir Modal -->
@if (showAylikListeModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-printer me-2"></i>@AktifRaporBaslik</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body p-0" style="max-height: 70vh; overflow-y: auto;">
                    <div id="printArea" class="p-4 bg-white text-dark">
                        @if (aktifListeRaporTuru == "bekleyen")
                        {
                        <!-- 1. SAYFA: TAKVİM -->
                        <div class="print-page print-calendar print-calendar-page">
                            <div class="text-center mb-4">
                                <h4>Bütçe Takvim Önizlemesi</h4>
                                <p class="text-muted">Dönem: @GetAyAdi(aktifTakvimAy) @secilenYil</p>
                            </div>
                            
                            <table class="table table-bordered table-sm mb-0 print-table print-calendar-table" style="table-layout: fixed; width: 100%;">
                                <thead>
                                    <tr class="text-center bg-light">
                                        <th style="width: 14.28%;">Pzt</th>
                                        <th style="width: 14.28%;">Sal</th>
                                        <th style="width: 14.28%;">Çar</th>
                                        <th style="width: 14.28%;">Per</th>
                                        <th style="width: 14.28%;">Cum</th>
                                        <th style="width: 14.28%;">Cmt</th>
                                        <th style="width: 14.28%;">Paz</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var pIlkGun = new DateTime(secilenYil, aktifTakvimAy, 1);
                                        var pIlkGunHafta = ((int)pIlkGun.DayOfWeek + 6) % 7;
                                        var pGunSayisi = DateTime.DaysInMonth(secilenYil, aktifTakvimAy);
                                        var pSatirSayisi = (int)Math.Ceiling((pIlkGunHafta + pGunSayisi) / 7.0);
                                        var pGun = 1;
                                    }
                                    @for (int satir = 0; satir < pSatirSayisi; satir++)
                                    {
                                        <tr>
                                            @for (int sutun = 0; sutun < 7; sutun++)
                                            {
                                                var hucreIndex = satir * 7 + sutun;
                                                if (hucreIndex < pIlkGunHafta || pGun > pGunSayisi)
                                                {
                                                    <td class="bg-light p-1" style="height: 120px;"></td>
                                                }
                                                else
                                                {
                                                    var currentGun = pGun;
                                                    var gunData = takvimData?.FirstOrDefault(t => t.Gun == currentGun);
                                                    <td class="p-0" style="height: 14vh; vertical-align: top; font-size: 0.70rem; overflow: hidden;">
                                                        <div class="d-flex justify-content-between mb-1 bg-light px-1" style="border-bottom: 1px solid #ccc; padding-top: 2px; padding-bottom: 2px;">
                                                            <strong style="font-size: 0.85rem;">@currentGun</strong>
                                                            @if (gunData != null && gunData.BekleyenToplamOdeme > 0)
                                                            {
                                                                <strong class="text-danger" style="font-size: 0.80rem;">@gunData.BekleyenToplamOdeme.ToString("N0") TL</strong>
                                                            }
                                                        </div>
                                                        <div class="px-1" style="overflow: hidden; max-height: calc(14vh - 22px);">
                                                           @if (gunData != null && gunData.Odemeler != null)
                                                           {
                                                               foreach(var o in gunData.Odemeler.Where(x => x.Durum == OdemeDurum.Bekliyor || x.Durum == OdemeDurum.Ertelendi).OrderBy(x => x.Durum))
                                                               {
                                                                   int kalanGun = (o.OdemeTarihi.Date - DateTime.Today).Days;
                                                                   string blockClass = "";
                                                                   string timeText = "";

                                                                   if (kalanGun < 0) {
                                                                       blockClass = "bg-danger text-white"; 
                                                                       timeText = $"{Math.Abs(kalanGun)}g Gecikti";
                                                                   } else if (kalanGun == 0) {
                                                                       blockClass = "bg-warning text-dark fw-bold"; 
                                                                       timeText = "Bugün";
                                                                   } else {
                                                                       blockClass = "bg-success text-white"; 
                                                                       timeText = $"{kalanGun}g Kaldı";
                                                                   }

                                                                   string stringAciklama = string.IsNullOrWhiteSpace(o.Aciklama) ? o.MasrafKalemi : o.Aciklama;
                                                                   stringAciklama = stringAciklama.Replace("[Tekrarlayan]", "").Replace("[tekrarlayan]", "").Trim();

                                                                   <div class="mb-1 px-1 py-1 rounded border-bottom border-light @blockClass" style="line-height: 1.1; font-size: 0.65rem;">
                                                                       <div class="text-truncate" style="max-width: 100%;" title="@stringAciklama">@stringAciklama</div>
                                                                       <div class="d-flex justify-content-between">
                                                                           <span class="fw-bold">@o.Miktar.ToString("N0") TL</span>
                                                                           <span style="font-size: 0.55rem; opacity: 0.9;">@timeText</span>
                                                                       </div>
                                                                   </div>
                                                               }
                                                           }
                                                        </div>
                                                    </td>
                                                    pGun++;
                                                }
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- 2. SAYFA ZORUNLU KESME -->
                        <div style="page-break-before: always; border-top: 2px dashed #ccc; margin: 30px 0;" class="print-page-break d-print-none text-center text-muted">
                            <small><i class="bi bi-scissors me-1"></i> Sayfa Kesimi (Yazdırırken aktif olur) <i class="bi bi-scissors ms-1"></i></small>
                        </div>
                        <div style="page-break-before: always;" class="d-none d-print-block"></div>
                        }

                        <!-- 2. SAYFA: LİSTE -->
                        <div class="print-page print-list-page">
                            <div class="text-center mb-4">
                                <h4>@AktifRaporBaslik</h4>
                                <p class="text-muted">@AktifRaporAltBaslik</p>
                            </div>
                            <table class="table table-bordered table-sm w-100 print-table print-list-table" style="font-size: 0.9rem;">
                                <thead class="table-light">
                                    <tr>
                                        <th>Tarih</th>
                                        <th>Masraf Kalemi</th>
                                        <th class="print-aciklama-col">Açıklama</th>
                                        <th class="text-center">Taksit</th>
                                        <th class="text-end">Tutar</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var odeme in AktifRaporOdemeleri)
                                    {
                                        int kGun2 = (odeme.OdemeTarihi.Date - DateTime.Today).Days;
                                        string trColorClass = "";
                                        string timeText2 = "";
                                        
                                        if (kGun2 < 0) { 
                                            trColorClass = "table-danger text-danger"; 
                                            timeText2 = $"{Math.Abs(kGun2)}g Gecikti";
                                        } 
                                        else if (kGun2 == 0) { 
                                            trColorClass = "table-warning text-dark fw-bold"; 
                                            timeText2 = "Bugün";
                                        } 
                                        else { 
                                            trColorClass = "table-success text-success"; 
                                            timeText2 = $"{kGun2}g Kaldı";
                                        }

                                        <tr class="@($"{trColorClass} print-list-row")">
                                            <td>
                                                @odeme.OdemeTarihi.ToString("dd.MM.yyyy")
                                                <br />
                                                <small class="fw-bold">@timeText2</small>
                                            </td>
                                            <td><strong>@odeme.MasrafKalemi</strong></td>
                                            <td class="print-aciklama-col">@(odeme.Aciklama?.Replace("[Tekrarlayan]", "")?.Replace("[tekrarlayan]", "")?.Trim())</td>
                                            <td class="text-center">
                                                @if (odeme.TaksitliMi)
                                                {
                                                    <span class="badge bg-info">@odeme.KacinciTaksit/@odeme.ToplamTaksitSayisi</span>
                                                }
                                                else
                                                {
                                                    <span>-</span>
                                                }
                                            </td>
                                        <td class="text-end fw-bold">@odeme.Miktar.ToString("N2") TL</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light fw-bold">
                                    <tr>
                                        <td colspan="4" class="text-end">TOPLAM:</td>
                                        <td class="text-end">@AktifRaporOdemeleri.Sum(o => o.Miktar).ToString("N2") TL</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Kapat</button>
                    <button type="button" class="btn btn-primary" @onclick='() => AylikListeExcelAktar(aktifListeRaporTuru)'>
                        <i class="bi bi-file-excel me-1"></i>Excel İndir
                    </button>
                    <button type="button" class="btn btn-success" @onclick='() => AylikListeYazdir(aktifListeRaporTuru)'>
                        <i class="bi bi-printer me-1"></i>Yazdır
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    #printArea .print-list-page {
        display: flex;
        flex-direction: column;
    }

    #printArea .print-list-table {
        table-layout: fixed;
    }

    #printArea .print-list-table th,
    #printArea .print-list-table td {
        padding: 0.2rem 0.35rem !important;
        line-height: 1.15;
        vertical-align: top;
        height: auto;
        white-space: normal;
    }

    #printArea .print-list-table tbody tr {
        page-break-inside: avoid;
    }

    #printArea .print-list-table small {
        line-height: 1.05;
    }

    #printArea .print-list-table .print-aciklama-col {
        font-size: 0.78rem;
        line-height: 1.05;
        word-break: break-word;
    }
</style>

@code {
    private int secilenYil;
    private int secilenAy;
    private int aktifTakvimAy;
    private int secilenFirmaId = 0;
    private string secilenPeriyod = "aylik";

    private int? secilenGun = null;
    private DateTime secilenGunTarih;
    private List<BudgetOdeme> secilenGunOdemeleri = new();
    private List<BudgetOdeme> bekleyenOdemeler = new();
    private List<BudgetOdeme> devirBekleyenOdemeler = new();
    private string aktifListeRaporTuru = "bekleyen";

    private bool isLoading = true;
    private BudgetOzet? ozet;
    private List<BudgetOdeme> odemeler = new();
    private List<BudgetGunlukOzet>? takvimData;
    private List<BudgetMasrafKalemi>? masrafKalemleri;
    private List<BankaHesap>? bankaHesaplari;
    private List<Firma>? firmalar;
    private List<KrediOzet>? aktifKrediler;
    private decimal krediTaksitToplam = 0;
    private int krediTaksitAdet = 0;

    private bool showOdemeModal = false;
    private bool showOdemeYapModal = false;
    private bool showTaksitModal = false;
    private bool showExcelModal = false;
    private bool showAylikListeModal = false;
    private bool showTekrarlayanModal = false;
    private bool showTekrarlayanListeModal = false;

    private BudgetOdeme editOdeme = new();
    private BudgetOdeme? odemeYapilacak;
    private OdemeYapRequest odemeYapRequest = new();
    private TaksitliOdemeRequest taksitRequest = new();
    private IBrowserFile? excelDosya;
    private List<TekrarlayanOdeme>? tekrarlayanOdemeler;
    private TekrarlayanOdeme editTekrarlayan = new();

    private static readonly string[] AyAdlari = { "", "Ocak", "Subat", "Mart", "Nisan", "Mayis", "Haziran", 
                                                   "Temmuz", "Agustos", "Eylul", "Ekim", "Kasim", "Aralik" };

    private List<BudgetOdeme> AktifRaporOdemeleri => aktifListeRaporTuru == "devir" ? devirBekleyenOdemeler : bekleyenOdemeler;
    private string AktifRaporBaslik => aktifListeRaporTuru == "devir"
        ? "Önceki Aylardan Devir Ödenmeyenler"
        : "Aylık Bekleyen Ödeme Listesi";
    private string AktifRaporAltBaslik => aktifListeRaporTuru == "devir"
        ? $"{GetAyAdi(aktifTakvimAy)} {secilenYil} öncesi devreden ödenmeyen kayıtlar"
        : $"Dönem: {GetAyAdi(aktifTakvimAy)} {secilenYil}";

    protected override async Task OnInitializedAsync()
    {
        secilenYil = DateTime.Today.Year;
        secilenAy = DateTime.Today.Month;
        aktifTakvimAy = secilenAy;

        firmalar = await FirmaService.GetAktifFirmalarAsync();
        var aktifFirma = FirmaService.GetAktifFirma();
        if (!aktifFirma.TumFirmalar && aktifFirma.FirmaId > 0)
            secilenFirmaId = aktifFirma.FirmaId;

        masrafKalemleri = await BudgetService.GetMasrafKalemleriAsync();
        bankaHesaplari = await BankaHesapService.GetAllAsync();
        tekrarlayanOdemeler = await BudgetService.GetTekrarlayanOdemelerAsync(secilenFirmaId > 0 ? secilenFirmaId : null);
        await YenileDataAsync();
    }

    private async Task YenileDataAsync()
    {
        isLoading = true;
        var oncekiSecilenGun = secilenGun; // Onceki secimi sakla
        StateHasChanged();

        try
        {
            // Önce seçilen dönem için veya tüm yıl için tekrarlayan ödemeleri oluştur
            if (secilenAy > 0)
            {
                await BudgetService.TekrarlayanOdemelerdenKayitOlusturAsync(secilenYil, secilenAy, secilenFirmaId > 0 ? secilenFirmaId : null);
            }
            else
            {
                for (int m = 1; m <= 12; m++)
                {
                    await BudgetService.TekrarlayanOdemelerdenKayitOlusturAsync(secilenYil, m, secilenFirmaId > 0 ? secilenFirmaId : null);
                }
            }

            // Firma filtresine göre odemeler
            odemeler = await BudgetService.GetOdemelerAsync(secilenYil, secilenAy > 0 ? secilenAy : null, secilenFirmaId > 0 ? secilenFirmaId : null);

            if (secilenAy > 0)
            {
                ozet = await BudgetService.GetAylikOzetAsync(secilenYil, secilenAy, secilenFirmaId > 0 ? secilenFirmaId : null);
                aktifTakvimAy = secilenAy;
            }
            else
            {
                var yillikOzet = await BudgetService.GetYillikOzetAsync(secilenYil, secilenFirmaId > 0 ? secilenFirmaId : null);
                ozet = new BudgetOzet
                {
                    Yil = secilenYil,
                    ToplamOdeme = yillikOzet.ToplamOdeme,
                    OdenenToplam = odemeler.Where(o => o.Durum == OdemeDurum.Odendi).Sum(o => o.Miktar),
                    BekleyenToplam = odemeler.Where(o => o.Durum == OdemeDurum.Bekliyor).Sum(o => o.Miktar),
                    ToplamKayit = odemeler.Count,
                    OdenenKayit = odemeler.Count(o => o.Durum == OdemeDurum.Odendi),
                    BekleyenKayit = odemeler.Count(o => o.Durum == OdemeDurum.Bekliyor)
                };
            }

            takvimData = await BudgetService.GetTakvimDataAsync(secilenYil, aktifTakvimAy, secilenFirmaId > 0 ? secilenFirmaId : null);
            aktifKrediler = await BudgetService.GetAktifKredilerAsync(secilenFirmaId > 0 ? secilenFirmaId : null);
            devirBekleyenOdemeler = await BudgetService.GetDevirBekleyenOdemelerAsync(
                new DateTime(secilenYil, aktifTakvimAy, 1),
                secilenFirmaId > 0 ? secilenFirmaId : null);

            // Bekleyen ödemeler - aktif takvim ayına göre filtrele
            bekleyenOdemeler = odemeler
                .Where(o => o.Durum == OdemeDurum.Bekliyor && o.OdemeAy == aktifTakvimAy)
                .OrderBy(o => o.OdemeTarihi)
                .ToList();

            var krediOdemeler = odemeler.Where(o => o.TaksitliMi && o.Durum == OdemeDurum.Bekliyor).ToList();
            krediTaksitToplam = krediOdemeler.Sum(o => o.Miktar);
            krediTaksitAdet = krediOdemeler.Count;

            // Onceki gun seciliyse, gun verilerini de guncelle
            if (oncekiSecilenGun.HasValue)
            {
                secilenGun = oncekiSecilenGun;
                secilenGunTarih = new DateTime(secilenYil, aktifTakvimAy, oncekiSecilenGun.Value);
                var gunData = takvimData?.FirstOrDefault(t => t.Gun == oncekiSecilenGun.Value);
                secilenGunOdemeleri = gunData?.Odemeler?.Where(o => o.Durum == OdemeDurum.Bekliyor).ToList() ?? new List<BudgetOdeme>();
            }
            else
            {
                secilenGun = null;
                secilenGunOdemeleri.Clear();
            }
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void PeriyodAylikSec() { secilenPeriyod = "aylik"; _ = YenileDataAsync(); }
    private void PeriyodYillikSec() { secilenPeriyod = "yillik"; secilenAy = 0; _ = YenileDataAsync(); }

    private async Task OncekiAy()
    {
        if (aktifTakvimAy > 1)
        {
            aktifTakvimAy--;
            takvimData = await BudgetService.GetTakvimDataAsync(secilenYil, aktifTakvimAy, secilenFirmaId > 0 ? secilenFirmaId : null);
            // Bekleyen ödemeleri de güncelle
            bekleyenOdemeler = odemeler
                .Where(o => o.Durum == OdemeDurum.Bekliyor && o.OdemeAy == aktifTakvimAy)
                .OrderBy(o => o.OdemeTarihi)
                .ToList();
            secilenGun = null;
            StateHasChanged();
        }
    }

    private async Task SonrakiAy()
    {
        if (aktifTakvimAy < 12)
        {
            aktifTakvimAy++;
            takvimData = await BudgetService.GetTakvimDataAsync(secilenYil, aktifTakvimAy, secilenFirmaId > 0 ? secilenFirmaId : null);
            // Bekleyen ödemeleri de güncelle
            bekleyenOdemeler = odemeler
                .Where(o => o.Durum == OdemeDurum.Bekliyor && o.OdemeAy == aktifTakvimAy)
                .OrderBy(o => o.OdemeTarihi)
                .ToList();
            secilenGun = null;
            StateHasChanged();
        }
    }

    private void GunSec(int gun)
    {
        secilenGun = gun;
        secilenGunTarih = new DateTime(secilenYil, aktifTakvimAy, gun);
        var gunData = takvimData?.FirstOrDefault(t => t.Gun == gun);
        // Sadece bekleyen odemeler gosterilsin
        secilenGunOdemeleri = gunData?.Odemeler?.Where(o => o.Durum == OdemeDurum.Bekliyor).ToList() ?? new List<BudgetOdeme>();
        StateHasChanged();
    }

    private void GeriDon()
    {
        secilenGun = null;
        secilenGunOdemeleri.Clear();
        StateHasChanged();
    }

    private void OdemeYapModalAc(BudgetOdeme odeme)
    {
        odemeYapilacak = odeme;
        odemeYapRequest = new OdemeYapRequest
        {
            OdemeTipi = OdemeTipi.Kasa,
            OdemeTarihi = DateTime.Today
        };
        showOdemeYapModal = true;
    }

    private async Task OdemeYap()
    {
        if (odemeYapilacak == null) return;

        if ((odemeYapRequest.OdemeTipi == OdemeTipi.Kasa || odemeYapRequest.OdemeTipi == OdemeTipi.Banka) && !odemeYapRequest.BankaHesapId.HasValue)
        {
            ToastService.ShowWarning("Hesap secin!");
            return;
        }

        try
        {
            await BudgetService.OdemeYapAsync(odemeYapilacak.Id, odemeYapRequest);
            ToastService.ShowSuccess(odemeYapilacak.MasrafKalemi + " odendi!");
            ModalKapat();
            
            // Tum veriyi yenile (gun secimi korunacak)
            await YenileDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private void YeniOdemeAc()
    {
        var aktifFirma = FirmaService.GetAktifFirma();
        editOdeme = new BudgetOdeme
        {
            OdemeTarihi = secilenGun.HasValue ? secilenGunTarih : DateTime.Today,
            Durum = OdemeDurum.Bekliyor,
            FirmaId = aktifFirma.TumFirmalar ? null : aktifFirma.FirmaId
        };
        showOdemeModal = true;
    }

    private void OdemeDuzenle(BudgetOdeme odeme)
    {
        editOdeme = new BudgetOdeme
        {
            Id = odeme.Id,
            OdemeTarihi = odeme.OdemeTarihi,
            MasrafKalemi = odeme.MasrafKalemi,
            Aciklama = odeme.Aciklama,
            Miktar = odeme.Miktar,
            Durum = odeme.Durum,
            FirmaId = odeme.FirmaId,
            // Taksit bilgilerini de kopyala
            TaksitliMi = odeme.TaksitliMi,
            TaksitGrupId = odeme.TaksitGrupId,
            KacinciTaksit = odeme.KacinciTaksit,
            ToplamTaksitSayisi = odeme.ToplamTaksitSayisi
        };
        showOdemeModal = true;
    }

    private async Task OdemeKaydet()
    {
        if (string.IsNullOrWhiteSpace(editOdeme.MasrafKalemi))
        {
            ToastService.ShowWarning("Masraf kalemi zorunlu!");
            return;
        }

        // Miktar 0 veya negatif olabilir - kontrol kaldırıldı

        try
        {
            if (editOdeme.Id > 0)
                await BudgetService.UpdateOdemeAsync(editOdeme);
            else
                await BudgetService.CreateOdemeAsync(editOdeme);

            ToastService.ShowSuccess("Kaydedildi.");
            ModalKapat();
            
            // Kayıt yapılan ödemenin ayına göre takvim ayını güncelle
            aktifTakvimAy = editOdeme.OdemeTarihi.Month;
            
            // Tüm veriyi yenile
            await YenileDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private async Task OdemeSilOnay(BudgetOdeme odeme)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"'{odeme.MasrafKalemi}' odemesini silmek istediginizden emin misiniz?");
        if (confirmed)
        {
            try
            {
                // Kalici silme
                await BudgetService.HardDeleteOdemeAsync(odeme.Id);
                ToastService.ShowSuccess("Odeme silindi.");
                
                // Tum veriyi yenile (gun secimi korunacak)
                await YenileDataAsync();
            }
            catch (Exception ex)
            {
                ToastService.ShowError("Silme hatasi: " + ex.Message);
            }
        }
    }

    private void TaksitliOdemeAc()
    {
        var aktifFirma = FirmaService.GetAktifFirma();
        taksitRequest = new TaksitliOdemeRequest
        {
            BaslangicTarihi = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1),
            TaksitSayisi = 12,
            FirmaId = aktifFirma.TumFirmalar ? null : aktifFirma.FirmaId
        };
        showTaksitModal = true;
    }

    private async Task TaksitliOdemeKaydet()
    {
        if (!TaksitKaydetmeGecerliMi())
        {
            ToastService.ShowWarning("Lütfen taksit planını kontrol edin!");
            return;
        }

        try
        {
            // Kullanicinin duzenledigi taksit planini request'e ekle
            taksitRequest.TaksitPlani = taksitListesi.Select(t => new TaksitDetayRequest
            {
                Sira = t.Sira,
                Tarih = t.Tarih,
                Tutar = t.Tutar
            }).ToList();

            await BudgetService.CreateTaksitliOdemeAsync(taksitRequest);
            ToastService.ShowSuccess(taksitRequest.TaksitSayisi + " taksit olusturuldu.");
            ModalKapat();
            await YenileDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private void ExcelYukleModalAc()
{
        excelDosya = null;
        showExcelModal = true;
    }

    private void ExcelDosyaSecildi(InputFileChangeEventArgs e)
    {
        excelDosya = e.File;
    }

    private async Task SablonIndir()
    {
        try
        {
            var bytes = await BudgetService.GetExcelSablonAsync(firmalar ?? new List<Firma>());
            await JS.InvokeVoidAsync("downloadFileFromBase64", "butce_sablon.xlsx", Convert.ToBase64String(bytes));
            ToastService.ShowSuccess("Sablon indirildi!");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private async Task ExcelYukle()
    {
        if (excelDosya == null) return;

        try
        {
            using var stream = excelDosya.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();

            var sonuc = await BudgetService.ImportFromExcelAsync(bytes);
            ToastService.ShowSuccess($"{sonuc} odeme yuklendi!");
            ModalKapat();
            await YenileDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Yukleme hatasi: " + ex.Message);
        }
    }

    private void ModalKapat()
    {
        showOdemeModal = false;
        showOdemeYapModal = false;
        showTaksitModal = false;
        showExcelModal = false;
        showAylikListeModal = false;
        showTekrarlayanModal = false;
        showTekrarlayanListeModal = false;
    }

    private void AylikListeOnIzleme(string raporTuru = "bekleyen")
    {
        aktifListeRaporTuru = raporTuru;
        showAylikListeModal = true;
    }

    private async Task AylikListeYazdir(string raporTuru = "bekleyen")
    {
        aktifListeRaporTuru = raporTuru;
        // Ensure modal is open so printArea element exists in DOM
        if (!showAylikListeModal)
        {
            showAylikListeModal = true;
