    private async Task AylikListeExcelAktar(string raporTuru = "bekleyen")
    {
        aktifListeRaporTuru = raporTuru;
        var headers = "Tarih,Masraf Kalemi,Aciklama,Taksit,Tutar";
        var rows = "";

        if (AktifRaporOdemeleri.Any())
        {
            rows = string.Join("\n", AktifRaporOdemeleri.Select(o => 
                $"{o.OdemeTarihi:dd.MM.yyyy},{o.MasrafKalemi?.Replace(",", " ")},{o.Aciklama?.Replace(",", " ")},{(o.TaksitliMi ? $"{o.KacinciTaksit}/{o.ToplamTaksitSayisi}" : "")},{o.Miktar}"));
        }
        
        var csv = $"{headers}\n{rows}";
        var fileName = aktifListeRaporTuru == "devir"
            ? $"DevirOdenmeyenler_{GetAyAdi(aktifTakvimAy)}_{secilenYil}.csv"
            : $"AylikOdemeler_{GetAyAdi(aktifTakvimAy)}_{secilenYil}.csv";

        var bytes = System.Text.Encoding.UTF8.GetBytes(csv);
        var base64 = Convert.ToBase64String(bytes);

        await JS.InvokeVoidAsync("eval", $@"
            var a = document.createElement('a');
            a.href = 'data:text/csv;charset=utf-8;base64,{base64}';
            a.download = '{fileName}';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        ");

        ToastService.ShowSuccess("Rapor dosyası indirildi!");
    }

