@page "/butce"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@inject IBudgetService BudgetService
@inject IBankaHesapService BankaHesapService
@inject IToastService ToastService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Butce Analiz</PageTitle>

<div class="container-fluid">
    <!-- Ust Bar -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="d-flex align-items-center gap-2">
            @if (secilenGun.HasValue)
            {
                <button class="btn btn-outline-secondary" @onclick="GeriDon">
                    <i class="bi bi-arrow-left me-1"></i>Geri
                </button>
                <h4 class="mb-0"><i class="bi bi-calendar-day me-2"></i>@secilenGunTarih.ToString("dd MMMM yyyy")</h4>
            }
            else
            {
                <h3 class="mb-0"><i class="bi bi-wallet2 me-2"></i>Butce Analiz</h3>
            }
        </div>
        <div class="d-flex gap-2 flex-wrap align-items-center">
            <!-- Periyod Secimi -->
            <div class="btn-group btn-group-sm">
                <button class="btn @(secilenPeriyod == "gunluk" ? "btn-primary" : "btn-outline-primary")" @onclick="PeriyodGunlukSec">Gunluk</button>
                <button class="btn @(secilenPeriyod == "haftalik" ? "btn-primary" : "btn-outline-primary")" @onclick="PeriyodHaftalikSec">Haftalik</button>
                <button class="btn @(secilenPeriyod == "15gunluk" ? "btn-primary" : "btn-outline-primary")" @onclick="Periyod15GunlukSec">15 Gun</button>
                <button class="btn @(secilenPeriyod == "aylik" ? "btn-primary" : "btn-outline-primary")" @onclick="PeriyodAylikSec">Aylik</button>
                <button class="btn @(secilenPeriyod == "ozel" ? "btn-primary" : "btn-outline-primary")" @onclick="PeriyodOzelSec">Ozel</button>
            </div>
            @if (secilenPeriyod == "ozel")
            {
                <input type="date" class="form-control form-control-sm" style="width:130px;" @bind="ozelBaslangic" />
                <input type="date" class="form-control form-control-sm" style="width:130px;" @bind="ozelBitis" />
                <button class="btn btn-sm btn-primary" @onclick="OzelTarihUygula">Uygula</button>
            }
            else
            {
                <select class="form-select form-select-sm" style="width: 90px;" @bind="secilenYil" @bind:after="YenileDataAsync">
                    @for (int y = DateTime.Today.Year + 2; y >= DateTime.Today.Year - 5; y--)
                    {
                        <option value="@y">@y</option>
                    }
                </select>
                <select class="form-select form-select-sm" style="width: 110px;" @bind="secilenAy" @bind:after="YenileDataAsync">
                    <option value="0">Tum Yil</option>
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m">@GetAyAdi(m)</option>
                    }
                </select>
            }
            <button class="btn btn-primary btn-sm" @onclick="YeniOdemeAc" title="Yeni Odeme"><i class="bi bi-plus-lg"></i></button>
            <button class="btn btn-success btn-sm" @onclick="TaksitliOdemeAc" title="Taksitli Odeme"><i class="bi bi-calendar-plus"></i></button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <!-- Ozet Kartlari -->
        <div class="row mb-3 g-2">
            <div class="col-6 col-md-3">
                <div class="card bg-primary text-white h-100">
                    <div class="card-body py-2 px-3">
                        <small>Toplam</small>
                        <h4 class="mb-0">@FormatPara(ozet?.ToplamOdeme ?? 0)</h4>
                        <small class="opacity-75">@(ozet?.ToplamKayit ?? 0) kayit</small>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card bg-success text-white h-100">
                    <div class="card-body py-2 px-3">
                        <small>Odenen</small>
                        <h4 class="mb-0">@FormatPara(ozet?.OdenenToplam ?? 0)</h4>
                        <small class="opacity-75">@(ozet?.OdenenKayit ?? 0) kayit</small>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card bg-warning text-dark h-100">
                    <div class="card-body py-2 px-3">
                        <small>Bekleyen</small>
                        <h4 class="mb-0">@FormatPara(ozet?.BekleyenToplam ?? 0)</h4>
                        <small>@(ozet?.BekleyenKayit ?? 0) kayit</small>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card bg-danger text-white h-100">
                    <div class="card-body py-2 px-3">
                        <small>Kredi/Taksit</small>
                        <h4 class="mb-0">@FormatPara(krediTaksitToplam)</h4>
                        <small class="opacity-75">@krediTaksitAdet adet</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <!-- Sol: Takvim ve Kredi Listesi -->
            <div class="col-md-5">
                <!-- Takvim -->
                <div class="card mb-3">
                    <div class="card-header d-flex justify-content-between align-items-center py-2">
                        <h6 class="mb-0"><i class="bi bi-calendar3 me-2"></i>@GetAyAdi(aktifTakvimAy) @secilenYil</h6>
                        <div class="btn-group btn-group-sm">
                            <button class="btn btn-outline-primary btn-sm" @onclick="OncekiAy" disabled="@(aktifTakvimAy <= 1)">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                            <button class="btn btn-outline-primary btn-sm" @onclick="SonrakiAy" disabled="@(aktifTakvimAy >= 12)">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-2">
                        <table class="table table-bordered table-sm mb-0" style="table-layout: fixed;">
                            <thead>
                                <tr class="text-center bg-light">
                                    <th>Pzt</th><th>Sal</th><th>Car</th><th>Per</th><th>Cum</th><th>Cmt</th><th>Paz</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var ilkGun = new DateTime(secilenYil, aktifTakvimAy, 1);
                                    var ilkGunHafta = ((int)ilkGun.DayOfWeek + 6) % 7;
                                    var gunSayisi = DateTime.DaysInMonth(secilenYil, aktifTakvimAy);
                                    var satirSayisi = (int)Math.Ceiling((ilkGunHafta + gunSayisi) / 7.0);
                                    var gun = 1;
                                }
                                @for (int satir = 0; satir < satirSayisi; satir++)
                                {
                                    <tr>
                                        @for (int sutun = 0; sutun < 7; sutun++)
                                        {
                                            var hucreIndex = satir * 7 + sutun;
                                            if (hucreIndex < ilkGunHafta || gun > gunSayisi)
                                            {
                                                <td class="bg-light"></td>
                                            }
                                            else
                                            {
                                                var currentGun = gun;
                                                var gunData = takvimData?.FirstOrDefault(t => t.Gun == currentGun);
                                                var bugun = DateTime.Today.Day == currentGun && DateTime.Today.Month == aktifTakvimAy && DateTime.Today.Year == secilenYil;
                                                var seciliMi = secilenGun == currentGun;
                                                <td class="@(seciliMi ? "bg-primary text-white" : bugun ? "bg-info bg-opacity-25" : "") p-1" 
                                                    style="height: 55px; vertical-align: top; cursor: pointer;" 
                                                    @onclick="() => GunSec(currentGun)">
                                                    <div class="d-flex justify-content-between">
                                                        <strong>@currentGun</strong>
                                                        @if (gunData != null && gunData.OdemeSayisi > 0)
                                                        {
                                                            <span class="badge @(seciliMi ? "bg-light text-primary" : "bg-danger") rounded-pill" style="font-size: 0.6rem;">@gunData.OdemeSayisi</span>
                                                        }
                                                    </div>
                                                    @if (gunData != null && gunData.ToplamOdeme > 0)
                                                    {
                                                        <div class="@(seciliMi ? "" : "text-danger")" style="font-size: 0.65rem;">
                                                            @FormatPara(gunData.ToplamOdeme)
                                                        </div>
                                                    }
                                                </td>
                                                gun++;
                                            }
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Kredi Taksit Listesi -->
                <div class="card mb-3">
                    <div class="card-header py-2 d-flex justify-content-between align-items-center">
                        <h6 class="mb-0"><i class="bi bi-credit-card me-2"></i>Kredi/Taksitler</h6>
                        <a href="/butce/kredi-raporu" class="btn btn-outline-info btn-sm py-0">Rapor</a>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush" style="max-height: 180px; overflow-y: auto;">
                            @if (aktifKrediler != null && aktifKrediler.Any())
                            {
                                @foreach (var kredi in aktifKrediler.Take(5))
                                {
                                    <div class="list-group-item list-group-item-action p-2" style="cursor: pointer;" @onclick="() => KrediFiltrele(kredi)">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <small><strong>@kredi.MasrafKalemi</strong></small>
                                            </div>
                                            <div class="text-end">
                                                <span class="badge bg-danger">@FormatPara(kredi.KalanTutar)</span>
                                                <br /><small>@kredi.KalanTaksitSayisi/@kredi.ToplamTaksitSayisi</small>
                                            </div>
                                        </div>
                                        <div class="progress mt-1" style="height: 4px;">
                                            <div class="progress-bar bg-success" style="width: @kredi.TamamlanmaYuzdesi%"></div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="list-group-item text-center text-muted py-3">
                                    <small>Aktif kredi yok</small>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Trend Grafik -->
                <div class="card">
                    <div class="card-header py-2">
                        <h6 class="mb-0"><i class="bi bi-graph-up me-2"></i>Trend</h6>
                    </div>
                    <div class="card-body py-2">
                        <canvas id="trendChart" style="height: 120px;"></canvas>
                    </div>
                </div>
            </div>

            <!-- Sag: Detay ve Listeler -->
            <div class="col-md-7">
                @if (secilenGun.HasValue)
                {
                    <!-- Gun Detay -->
                    <div class="card">
                        <div class="card-header py-2 d-flex justify-content-between align-items-center bg-primary text-white">
                            <h6 class="mb-0"><i class="bi bi-calendar-day me-2"></i>@secilenGunTarih.ToString("dd MMMM yyyy dddd")</h6>
                            <span class="badge bg-light text-primary">@FormatPara(secilenGunOdemeleri.Sum(o => o.Miktar))</span>
                        </div>
                        <div class="card-body p-0">
                            <div class="list-group list-group-flush" style="max-height: 500px; overflow-y: auto;">
                                @foreach (var odeme in secilenGunOdemeleri)
                                {
                                    <div class="list-group-item p-2">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div class="flex-grow-1" style="cursor: pointer;" @onclick="() => OdemeDetayAc(odeme)">
                                                <strong>@odeme.MasrafKalemi</strong>
                                                @if (!string.IsNullOrEmpty(odeme.Aciklama))
                                                {
                                                    <br /><small class="text-muted">@odeme.Aciklama</small>
                                                }
                                                @if (odeme.TaksitliMi)
                                                {
                                                    <span class="badge bg-info ms-1">@odeme.KacinciTaksit/@odeme.ToplamTaksitSayisi</span>
                                                }
                                            </div>
                                            <div class="text-end">
                                                <strong class="text-danger">@FormatPara(odeme.Miktar)</strong>
                                                <br />
                                                @if (odeme.Durum == OdemeDurum.Bekliyor)
                                                {
                                                    <button class="btn btn-success btn-sm py-0 px-1" @onclick="() => OdemeYapModalAc(odeme)">
                                                        <i class="bi bi-cash"></i> Ode
                                                    </button>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success">Odendi</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                                @if (!secilenGunOdemeleri.Any())
                                {
                                    <div class="list-group-item text-center text-muted py-4">
                                        <i class="bi bi-calendar-x" style="font-size: 2rem;"></i>
                                        <p class="mb-0 mt-2">Bu gunde odeme yok</p>
                                        <button class="btn btn-primary btn-sm mt-2" @onclick="YeniOdemeAc">
                                            <i class="bi bi-plus-lg me-1"></i>Odeme Ekle
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <!-- Odeme Listesi -->
                    <div class="card mb-3">
                        <div class="card-header py-2 d-flex justify-content-between align-items-center">
                            <h6 class="mb-0"><i class="bi bi-list-ul me-2"></i>Odemeler</h6>
                            <div class="d-flex gap-2 align-items-center">
                                <select class="form-select form-select-sm" style="width:120px;" @bind="krediFiltre" @bind:after="FiltreUygula">
                                    <option value="tum">Tum</option>
                                    <option value="kredi">Kredi/Taksit</option>
                                    <option value="normal">Normal</option>
                                    <option value="bekleyen">Bekleyen</option>
                                    <option value="odenen">Odenen</option>
                                </select>
                                <span class="badge bg-secondary">@filtrelenmisOdemeler.Count</span>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive" style="max-height: 280px; overflow-y: auto;">
                                <table class="table table-hover table-sm mb-0">
                                    <thead class="table-light sticky-top">
                                        <tr>
                                            <th>Tarih</th>
                                            <th>Masraf</th>
                                            <th class="text-end">Tutar</th>
                                            <th class="text-center">Durum</th>
                                            <th class="text-center">Islem</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var odeme in filtrelenmisOdemeler.Take(50))
                                        {
                                            <tr>
                                                <td style="cursor: pointer;" @onclick="() => OdemeDetayAc(odeme)">
                                                    <small>@odeme.OdemeTarihi.ToString("dd.MM")</small>
                                                    @if (odeme.TaksitliMi)
                                                    {
                                                        <span class="badge bg-info ms-1" style="font-size: 0.55rem;">T</span>
                                                    }
                                                </td>
                                                <td style="cursor: pointer;" @onclick="() => OdemeDetayAc(odeme)">@odeme.MasrafKalemi</td>
                                                <td class="text-end">@FormatPara(odeme.Miktar)</td>
                                                <td class="text-center">
                                                    <span class="badge @GetDurumClass(odeme.Durum)" style="font-size: 0.6rem;">@GetDurumAdi(odeme.Durum)</span>
                                                </td>
                                                <td class="text-center">
                                                    @if (odeme.Durum == OdemeDurum.Bekliyor)
                                                    {
                                                        <button class="btn btn-outline-secondary btn-sm py-0 px-1 me-1" @onclick="() => OdemeDuzenle(odeme)" title="Duzenle">
                                                            <i class="bi bi-pencil" style="font-size: 0.7rem;"></i>
                                                        </button>
                                                        <button class="btn btn-success btn-sm py-0 px-1" @onclick="() => OdemeYapModalAc(odeme)" title="Ode">
                                                            <i class="bi bi-cash" style="font-size: 0.7rem;"></i>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-success"><i class="bi bi-check-circle"></i></span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Kategori Grafik -->
                    <div class="card">
                        <div class="card-header py-2">
                            <h6 class="mb-0"><i class="bi bi-pie-chart me-2"></i>Kategori Dagilimi</h6>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-6">
                                    <canvas id="kategoriChart" style="height: 150px;"></canvas>
                                </div>
                                <div class="col-6">
                                    @if (kategoriOzet != null && kategoriOzet.Any())
                                    {
                                        @foreach (var kat in kategoriOzet.Take(5))
                                        {
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <small>
                                                    <span class="badge me-1" style="background-color: @(kat.Renk ?? "#6c757d"); width: 10px; height: 10px; padding: 0;"></span>
                                                    @kat.MasrafKalemi
                                                </small>
                                                <small><strong>@FormatPara(kat.Toplam)</strong></small>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Odeme Yap Modal -->
@if (showOdemeYapModal && odemeYapilacak != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-cash-coin me-2"></i>Odeme Yap</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info py-2">
                        <strong>@odemeYapilacak.MasrafKalemi</strong><br />
                        <small>@odemeYapilacak.Aciklama</small><br />
                        <strong class="text-danger fs-5">@FormatPara(odemeYapilacak.Miktar)</strong>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Odeme Tipi *</label>
                        <div class="btn-group w-100">
                            <button type="button" class="btn @(odemeYapRequest.OdemeTipi == OdemeTipi.Kasa ? "btn-primary" : "btn-outline-primary")" 
                                    @onclick="() => odemeYapRequest.OdemeTipi = OdemeTipi.Kasa">
                                <i class="bi bi-cash-stack me-1"></i>Kasa
                            </button>
                            <button type="button" class="btn @(odemeYapRequest.OdemeTipi == OdemeTipi.Banka ? "btn-primary" : "btn-outline-primary")" 
                                    @onclick="() => odemeYapRequest.OdemeTipi = OdemeTipi.Banka">
                                <i class="bi bi-bank me-1"></i>Banka
                            </button>
                            <button type="button" class="btn @(odemeYapRequest.OdemeTipi == OdemeTipi.Mahsup ? "btn-primary" : "btn-outline-primary")" 
                                    @onclick="() => odemeYapRequest.OdemeTipi = OdemeTipi.Mahsup">
                                <i class="bi bi-arrow-left-right me-1"></i>Mahsup
                            </button>
                        </div>
                    </div>
                    @if ((odemeYapRequest.OdemeTipi == OdemeTipi.Kasa || odemeYapRequest.OdemeTipi == OdemeTipi.Banka) && bankaHesaplari != null)
                    {
                        <div class="mb-3">
                            <label class="form-label">@(odemeYapRequest.OdemeTipi == OdemeTipi.Kasa ? "Kasa Hesabi" : "Banka Hesabi") *</label>
                            <select class="form-select" @bind="odemeYapRequest.BankaHesapId">
                                <option value="">Secin...</option>
                                @foreach (var hesap in bankaHesaplari.Where(h => odemeYapRequest.OdemeTipi == OdemeTipi.Kasa ? h.HesapTipi == HesapTipi.Kasa : h.HesapTipi != HesapTipi.Kasa))
                                {
                                    <option value="@hesap.Id">@hesap.HesapAdi @(hesap.BankaAdi != null ? $"- {hesap.BankaAdi}" : "")</option>
                                }
                            </select>
                            <small class="text-muted">
                                <i class="bi bi-info-circle me-1"></i>
                                @(odemeYapRequest.OdemeTipi == OdemeTipi.Kasa ? "Kasa = BORC (Para Cikisi)" : "Banka = BORC (Para Cikisi)")
                            </small>
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Odeme Tarihi</label>
                        <input type="date" class="form-control" @bind="odemeYapRequest.OdemeTarihi" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button type="button" class="btn btn-success" @onclick="OdemeYap">
                        <i class="bi bi-check-lg me-1"></i>Odemeyi Tamamla
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Odeme Detay Modal -->
@if (showOdemeDetayModal && detayOdeme != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-receipt me-2"></i>Odeme Detayi</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <table class="table table-borderless mb-0">
                        <tr><th width="120">Tarih:</th><td>@detayOdeme.OdemeTarihi.ToString("dd.MM.yyyy")</td></tr>
                        <tr><th>Masraf:</th><td><strong>@detayOdeme.MasrafKalemi</strong></td></tr>
                        <tr><th>Aciklama:</th><td>@(detayOdeme.Aciklama ?? "-")</td></tr>
                        <tr><th>Tutar:</th><td><strong class="text-danger fs-4">@FormatPara(detayOdeme.Miktar)</strong></td></tr>
                        <tr><th>Durum:</th><td><span class="badge @GetDurumClass(detayOdeme.Durum) fs-6">@GetDurumAdi(detayOdeme.Durum)</span></td></tr>
                        @if (detayOdeme.TaksitliMi)
                        {
                            <tr><th>Taksit:</th><td><span class="badge bg-info fs-6">@detayOdeme.KacinciTaksit / @detayOdeme.ToplamTaksitSayisi</span></td></tr>
                        }
                    </table>
                </div>
                <div class="modal-footer">
                    @if (detayOdeme.Durum == OdemeDurum.Bekliyor)
                    {
                        <button class="btn btn-success" @onclick="DetayOdemeYap">
                            <i class="bi bi-cash me-1"></i>Odeme Yap
                        </button>
                    }
                    <button class="btn btn-primary" @onclick="() => OdemeDuzenle(detayOdeme)">
                        <i class="bi bi-pencil me-1"></i>Duzenle
                    </button>
                    <button class="btn btn-outline-danger" @onclick="() => OdemeSil(detayOdeme)">
                        <i class="bi bi-trash me-1"></i>Sil
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Yeni/Duzenle Odeme Modal -->
@if (showOdemeModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editOdeme.Id > 0 ? "Odeme Duzenle" : "Yeni Odeme")</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Odeme Tarihi *</label>
                        <input type="date" class="form-control" @bind="editOdeme.OdemeTarihi" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Masraf Kalemi *</label>
                        <input type="text" class="form-control" @bind="editOdeme.MasrafKalemi" list="masrafList" />
                        <datalist id="masrafList">
                            @if (masrafKalemleri != null)
                            {
                                @foreach (var k in masrafKalemleri)
                                {
                                    <option value="@k.KalemAdi" />
                                }
                            }
                        </datalist>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Aciklama</label>
                        <input type="text" class="form-control" @bind="editOdeme.Aciklama" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Miktar *</label>
                        <div class="input-group">
                            <input type="number" class="form-control" @bind="editOdeme.Miktar" step="0.01" />
                            <span class="input-group-text">TL</span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Durum</label>
                        <select class="form-select" @bind="editOdeme.Durum">
                            <option value="@OdemeDurum.Bekliyor">Bekliyor</option>
                            <option value="@OdemeDurum.Odendi">Odendi</option>
                            <option value="@OdemeDurum.Ertelendi">Ertelendi</option>
                            <option value="@OdemeDurum.Iptal">Iptal</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button type="button" class="btn btn-primary" @onclick="OdemeKaydet">Kaydet</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Taksitli Odeme Modal -->
@if (showTaksitModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-calendar-plus me-2"></i>Taksitli Odeme</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-6">
                            <div class="mb-3">
                                <label class="form-label">Baslangic *</label>
                                <input type="date" class="form-control" @bind="taksitRequest.BaslangicTarihi" />
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="mb-3">
                                <label class="form-label">Taksit Sayisi *</label>
                                <input type="number" class="form-control" @bind="taksitRequest.TaksitSayisi" min="2" max="60" />
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Masraf Kalemi *</label>
                        <input type="text" class="form-control" @bind="taksitRequest.MasrafKalemi" list="masrafList2" />
                        <datalist id="masrafList2">
                            @if (masrafKalemleri != null)
                            {
                                @foreach (var k in masrafKalemleri)
                                {
                                    <option value="@k.KalemAdi" />
                                }
                            }
                        </datalist>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Aciklama</label>
                        <input type="text" class="form-control" @bind="taksitRequest.Aciklama" />
                    </div>
                    <div class="row">
                        <div class="col-6">
                            <div class="mb-3">
                                <label class="form-label">Toplam Tutar *</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" @bind="taksitRequest.ToplamTutar" step="0.01" />
                                    <span class="input-group-text">TL</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="mb-3">
                                <label class="form-label">Taksit Tutari</label>
                                <div class="input-group">
                                    <input type="text" class="form-control" value="@(taksitRequest.TaksitSayisi > 0 ? (taksitRequest.ToplamTutar / taksitRequest.TaksitSayisi).ToString("N2") : "0")" readonly />
                                    <span class="input-group-text">TL</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button type="button" class="btn btn-primary" @onclick="TaksitliOdemeKaydet">
                        @taksitRequest.TaksitSayisi Taksit Olustur
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int secilenYil;
    private int secilenAy;
    private int aktifTakvimAy;
    private string secilenPeriyod = "aylik";
    private string krediFiltre = "tum";
    private DateTime ozelBaslangic = DateTime.Today.AddDays(-30);
    private DateTime ozelBitis = DateTime.Today;

    private int? secilenGun = null;
    private DateTime secilenGunTarih;
    private List<BudgetOdeme> secilenGunOdemeleri = new();

    private bool isLoading = true;
    private bool chartRendered = false;
    private BudgetOzet? ozet;
    private List<BudgetOdeme> odemeler = new();
    private List<BudgetOdeme> filtrelenmisOdemeler = new();
    private List<BudgetGunlukOzet>? takvimData;
    private List<BudgetKategoriOzet>? kategoriOzet;
    private List<BudgetTrendData>? trendData;
    private List<BudgetMasrafKalemi>? masrafKalemleri;
    private List<BankaHesap>? bankaHesaplari;
    private List<KrediOzet>? aktifKrediler;
    private decimal krediTaksitToplam = 0;
    private int krediTaksitAdet = 0;

    private bool showOdemeModal = false;
    private bool showOdemeDetayModal = false;
    private bool showOdemeYapModal = false;
    private bool showTaksitModal = false;

    private BudgetOdeme editOdeme = new();
    private BudgetOdeme? detayOdeme;
    private BudgetOdeme? odemeYapilacak;
    private OdemeYapRequest odemeYapRequest = new();
    private TaksitliOdemeRequest taksitRequest = new();

    private static readonly string[] AyAdlari = { "", "Ocak", "Subat", "Mart", "Nisan", "Mayis", "Haziran", 
                                                   "Temmuz", "Agustos", "Eylul", "Ekim", "Kasim", "Aralik" };

    protected override async Task OnInitializedAsync()
    {
        secilenYil = DateTime.Today.Year;
        secilenAy = DateTime.Today.Month;
        aktifTakvimAy = secilenAy;

        masrafKalemleri = await BudgetService.GetMasrafKalemleriAsync();
        bankaHesaplari = await BankaHesapService.GetAllAsync();
        await YenileDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!isLoading && !secilenGun.HasValue && !chartRendered)
        {
            chartRendered = true;
            await RenderChartsAsync();
        }
    }

    private async Task YenileDataAsync()
    {
        isLoading = true;
        secilenGun = null;
        chartRendered = false;
        StateHasChanged();

        try
        {
            DateTime baslangic, bitis;

            if (secilenPeriyod == "ozel")
            {
                baslangic = ozelBaslangic;
                bitis = ozelBitis;
                odemeler = await BudgetService.GetOdemelerByDateRangeAsync(baslangic, bitis);
                ozet = await BudgetService.GetPeriyodOzetAsync(baslangic, bitis);
            }
            else
            {
                odemeler = await BudgetService.GetOdemelerAsync(secilenYil, secilenAy > 0 ? secilenAy : null);

                if (secilenAy > 0)
                {
                    ozet = await BudgetService.GetAylikOzetAsync(secilenYil, secilenAy);
                    aktifTakvimAy = secilenAy;
                    baslangic = new DateTime(secilenYil, secilenAy, 1);
                    bitis = baslangic.AddMonths(1).AddDays(-1);
                }
                else
                {
                    var yillikOzet = await BudgetService.GetYillikOzetAsync(secilenYil);
                    ozet = new BudgetOzet
                    {
                        Yil = secilenYil,
                        ToplamOdeme = yillikOzet.ToplamOdeme,
                        OdenenToplam = odemeler.Where(o => o.Durum == OdemeDurum.Odendi).Sum(o => o.Miktar),
                        BekleyenToplam = odemeler.Where(o => o.Durum == OdemeDurum.Bekliyor).Sum(o => o.Miktar),
                        ToplamKayit = odemeler.Count,
                        OdenenKayit = odemeler.Count(o => o.Durum == OdemeDurum.Odendi),
                        BekleyenKayit = odemeler.Count(o => o.Durum == OdemeDurum.Bekliyor)
                    };
                    baslangic = new DateTime(secilenYil, 1, 1);
                    bitis = new DateTime(secilenYil, 12, 31);
                }
            }

            takvimData = await BudgetService.GetTakvimDataAsync(secilenYil, aktifTakvimAy);
            kategoriOzet = await BudgetService.GetKategoriOzetAsync(secilenYil, secilenAy > 0 ? secilenAy : null);
            aktifKrediler = await BudgetService.GetAktifKredilerAsync();

            // Trend data
            if (secilenPeriyod != "ozel")
            {
                var trendBaslangic = secilenAy > 0 ? new DateTime(secilenYil, secilenAy, 1) : new DateTime(secilenYil, 1, 1);
                var trendBitis = secilenAy > 0 ? trendBaslangic.AddMonths(1).AddDays(-1) : new DateTime(secilenYil, 12, 31);
                trendData = await BudgetService.GetTrendDataAsync(trendBaslangic, trendBitis, secilenPeriyod);
            }
            else
            {
                trendData = await BudgetService.GetTrendDataAsync(ozelBaslangic, ozelBitis, secilenPeriyod);
            }

            var krediOdemeler = odemeler.Where(o => o.TaksitliMi).ToList();
            krediTaksitToplam = krediOdemeler.Sum(o => o.Miktar);
            krediTaksitAdet = krediOdemeler.Count;

            FiltreUygula();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task RenderChartsAsync()
    {
        try
        {
            // Trend Chart
            if (trendData != null && trendData.Any())
            {
                var labels = trendData.Select(t => t.Etiket).ToArray();
                var toplam = trendData.Select(t => (double)t.Toplam).ToArray();
                var odenen = trendData.Select(t => (double)t.Odenen).ToArray();
                await JS.InvokeVoidAsync("createLineChart", "trendChart", labels, toplam, odenen);
            }

            // Kategori Chart
            if (kategoriOzet != null && kategoriOzet.Any())
            {
                var labels = kategoriOzet.Take(6).Select(k => k.MasrafKalemi).ToArray();
                var data = kategoriOzet.Take(6).Select(k => (double)k.Toplam).ToArray();
                var colors = kategoriOzet.Take(6).Select(k => k.Renk ?? "#6c757d").ToArray();
                await JS.InvokeVoidAsync("createDoughnutChart", "kategoriChart", labels, data, colors);
            }
        }
        catch { }
    }

    // Periyod secim metodlari
    private void PeriyodGunlukSec() { secilenPeriyod = "gunluk"; _ = YenileDataAsync(); }
    private void PeriyodHaftalikSec() { secilenPeriyod = "haftalik"; _ = YenileDataAsync(); }
    private void Periyod15GunlukSec() { secilenPeriyod = "15gunluk"; _ = YenileDataAsync(); }
    private void PeriyodAylikSec() { secilenPeriyod = "aylik"; _ = YenileDataAsync(); }
    private void PeriyodOzelSec() { secilenPeriyod = "ozel"; StateHasChanged(); }
    private async Task OzelTarihUygula() { await YenileDataAsync(); }

    private void FiltreUygula()
    {
        filtrelenmisOdemeler = krediFiltre switch
        {
            "kredi" => odemeler.Where(o => o.TaksitliMi).OrderBy(o => o.OdemeTarihi).ToList(),
            "normal" => odemeler.Where(o => !o.TaksitliMi).OrderBy(o => o.OdemeTarihi).ToList(),
            "bekleyen" => odemeler.Where(o => o.Durum == OdemeDurum.Bekliyor).OrderBy(o => o.OdemeTarihi).ToList(),
            "odenen" => odemeler.Where(o => o.Durum == OdemeDurum.Odendi).OrderBy(o => o.OdemeTarihi).ToList(),
            _ => odemeler.OrderBy(o => o.OdemeTarihi).ToList()
        };
        StateHasChanged();
    }

    private void KrediFiltrele(KrediOzet kredi)
    {
        krediFiltre = "kredi";
        filtrelenmisOdemeler = odemeler
            .Where(o => o.TaksitGrupId == kredi.TaksitGrupId)
            .OrderBy(o => o.OdemeTarihi)
            .ToList();
        StateHasChanged();
    }

    private async Task OncekiAy()
    {
        if (aktifTakvimAy > 1)
        {
            aktifTakvimAy--;
            takvimData = await BudgetService.GetTakvimDataAsync(secilenYil, aktifTakvimAy);
            secilenGun = null;
            StateHasChanged();
        }
    }

    private async Task SonrakiAy()
    {
        if (aktifTakvimAy < 12)
        {
            aktifTakvimAy++;
            takvimData = await BudgetService.GetTakvimDataAsync(secilenYil, aktifTakvimAy);
            secilenGun = null;
            StateHasChanged();
        }
    }

    private void GunSec(int gun)
    {
        secilenGun = gun;
        secilenGunTarih = new DateTime(secilenYil, aktifTakvimAy, gun);
        var gunData = takvimData?.FirstOrDefault(t => t.Gun == gun);
        secilenGunOdemeleri = gunData?.Odemeler ?? new List<BudgetOdeme>();
        StateHasChanged();
    }

    private void GeriDon()
    {
        secilenGun = null;
        secilenGunOdemeleri.Clear();
        chartRendered = false;
        StateHasChanged();
    }

    private void OdemeDetayAc(BudgetOdeme odeme)
    {
        detayOdeme = odeme;
        showOdemeDetayModal = true;
    }

    private void OdemeYapModalAc(BudgetOdeme odeme)
    {
        odemeYapilacak = odeme;
        odemeYapRequest = new OdemeYapRequest
        {
            OdemeTipi = OdemeTipi.Kasa,
            OdemeTarihi = DateTime.Today
        };
        showOdemeYapModal = true;
    }

    private void DetayOdemeYap()
    {
        if (detayOdeme != null)
        {
            showOdemeDetayModal = false;
            OdemeYapModalAc(detayOdeme);
        }
    }

    private async Task OdemeYap()
    {
        if (odemeYapilacak == null) return;

        if (odemeYapRequest.OdemeTipi == OdemeTipi.Banka && !odemeYapRequest.BankaHesapId.HasValue)
        {
            ToastService.ShowWarning("Banka hesabi secin!");
            return;
        }

        try
        {
            await BudgetService.OdemeYapAsync(odemeYapilacak.Id, odemeYapRequest);
            ToastService.ShowSuccess(odemeYapilacak.MasrafKalemi + " odendi!");
            ModalKapat();
            await YenileDataAsync();
            
            // Eger gun seciliyse, gun odemelerini de guncelle
            if (secilenGun.HasValue)
            {
                takvimData = await BudgetService.GetTakvimDataAsync(secilenYil, aktifTakvimAy);
                var gunData = takvimData?.FirstOrDefault(t => t.Gun == secilenGun.Value);
                secilenGunOdemeleri = gunData?.Odemeler?.Where(o => o.Durum == OdemeDurum.Bekliyor).ToList() ?? new List<BudgetOdeme>();
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private void YeniOdemeAc()
    {
        editOdeme = new BudgetOdeme
        {
            OdemeTarihi = secilenGun.HasValue ? secilenGunTarih : DateTime.Today,
            Durum = OdemeDurum.Bekliyor
        };
        showOdemeModal = true;
    }

    private void OdemeDuzenle(BudgetOdeme odeme)
    {
        editOdeme = new BudgetOdeme
        {
            Id = odeme.Id,
            OdemeTarihi = odeme.OdemeTarihi,
            MasrafKalemi = odeme.MasrafKalemi,
            Aciklama = odeme.Aciklama,
            Miktar = odeme.Miktar,
            Durum = odeme.Durum
        };
        showOdemeDetayModal = false;
        showOdemeModal = true;
    }

    private async Task OdemeKaydet()
    {
        if (string.IsNullOrWhiteSpace(editOdeme.MasrafKalemi) || editOdeme.Miktar <= 0)
        {
            ToastService.ShowWarning("Masraf kalemi ve miktar zorunlu!");
            return;
        }

        try
        {
            if (editOdeme.Id > 0)
                await BudgetService.UpdateOdemeAsync(editOdeme);
            else
                await BudgetService.CreateOdemeAsync(editOdeme);

            ToastService.ShowSuccess("Kaydedildi.");
            ModalKapat();
            await YenileDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private async Task OdemeSil(BudgetOdeme odeme)
    {
        await BudgetService.DeleteOdemeAsync(odeme.Id);
        ToastService.ShowSuccess("Silindi.");
        ModalKapat();
        await YenileDataAsync();
    }

    private void TaksitliOdemeAc()
    {
        taksitRequest = new TaksitliOdemeRequest
        {
            BaslangicTarihi = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1),
            TaksitSayisi = 12
        };
        showTaksitModal = true;
    }

    private async Task TaksitliOdemeKaydet()
    {
        if (string.IsNullOrWhiteSpace(taksitRequest.MasrafKalemi) || taksitRequest.ToplamTutar <= 0 || taksitRequest.TaksitSayisi < 2)
        {
            ToastService.ShowWarning("Alanlari doldurun!");
            return;
        }

        try
        {
            await BudgetService.CreateTaksitliOdemeAsync(taksitRequest);
            ToastService.ShowSuccess(taksitRequest.TaksitSayisi + " taksit olusturuldu.");
            ModalKapat();
            await YenileDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private void ModalKapat()
    {
        showOdemeModal = false;
        showOdemeDetayModal = false;
        showOdemeYapModal = false;
        showTaksitModal = false;
    }

    private string GetAyAdi(int ay) => AyAdlari[ay];
    private string GetDurumAdi(OdemeDurum d) => d switch { OdemeDurum.Bekliyor => "Bekliyor", OdemeDurum.Odendi => "Odendi", OdemeDurum.Ertelendi => "Ertelendi", OdemeDurum.Iptal => "Iptal", _ => d.ToString() };
    private string GetDurumClass(OdemeDurum d) => d switch { OdemeDurum.Bekliyor => "bg-warning text-dark", OdemeDurum.Odendi => "bg-success", OdemeDurum.Ertelendi => "bg-secondary", OdemeDurum.Iptal => "bg-danger", _ => "bg-secondary" };
    private string FormatPara(decimal t) => t.ToString("N0") + " TL";
}
