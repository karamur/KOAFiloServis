<!-- Aylik Liste On Izleme Modal -->
@if (showAylikListeModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.7);" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-eye me-2"></i>Aylik Odeme Listesi - @GetAyAdi(aktifTakvimAy) @secilenYil</h5>
                    <button type="button" class="btn-close" @onclick="() => showAylikListeModal = false"></button>
                </div>
                <div class="modal-body bg-light" style="min-height: 500px;">
                    <div id="printArea" class="bg-white p-4 shadow" style="max-width: 210mm; margin: 0 auto;">
                        <div style="text-align: center; margin-bottom: 20px; border-bottom: 2px solid #000; padding-bottom: 10px;">
                            <h2 style="margin: 0;">AYLIK ODEME LISTESI</h2>
                            <h4 style="margin: 10px 0 0 0;">@GetAyAdi(aktifTakvimAy) @secilenYil</h4>
                            @if (firmalar != null && secilenFirmaId > 0)
                            {
                                var firma = firmalar.FirstOrDefault(f => f.Id == secilenFirmaId);
                                if (firma != null)
                                {
                                    <p style="margin: 5px 0 0 0; color: #666;">@firma.FirmaAdi</p>
                                }
                            }
                        </div>
                        
                        <table style="width: 100%; border-collapse: collapse; font-size: 11px;">
                            <thead>
                                <tr style="background-color: #f0f0f0;">
                                    <th style="border: 1px solid #000; padding: 8px; text-align: left; width: 80px;">Tarih</th>
                                    <th style="border: 1px solid #000; padding: 8px; text-align: left;">Masraf Kalemi</th>
                                    <th style="border: 1px solid #000; padding: 8px; text-align: left;">Aciklama</th>
                                    <th style="border: 1px solid #000; padding: 8px; text-align: center; width: 80px;">Taksit</th>
                                    <th style="border: 1px solid #000; padding: 8px; text-align: right; width: 100px;">Tutar</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (bekleyenOdemeler.Any())
                                {
                                    @foreach (var odeme in bekleyenOdemeler)
                                    {
                                        <tr>
                                            <td style="border: 1px solid #000; padding: 6px;">@odeme.OdemeTarihi.ToString("dd.MM.yyyy")</td>
                                            <td style="border: 1px solid #000; padding: 6px;"><strong>@odeme.MasrafKalemi</strong></td>
                                            <td style="border: 1px solid #000; padding: 6px;">@odeme.Aciklama</td>
                                            <td style="border: 1px solid #000; padding: 6px; text-align: center;">
                                                @if (odeme.TaksitliMi)
                                                {
                                                    <span>@odeme.KacinciTaksit/@odeme.ToplamTaksitSayisi</span>
                                                }
                                            </td>
                                            <td style="border: 1px solid #000; padding: 6px; text-align: right;"><strong>@FormatPara(odeme.Miktar)</strong></td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" style="border: 1px solid #000; padding: 20px; text-align: center; color: #666;">
                                            Bu donem icin bekleyen odeme bulunmamaktadir.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr style="background-color: #d0e0f0; font-weight: bold;">
                                    <td colspan="4" style="border: 1px solid #000; padding: 8px;"><strong>TOPLAM (@bekleyenOdemeler.Count kayit)</strong></td>
                                    <td style="border: 1px solid #000; padding: 8px; text-align: right;"><strong>@FormatPara(bekleyenOdemeler.Sum(o => o.Miktar))</strong></td>
                                </tr>
                            </tfoot>
                        </table>

                        <div style="margin-top: 30px; font-size: 10px; color: #666;">
                            <p>Rapor Tarihi: @DateTime.Now.ToString("dd.MM.yyyy HH:mm")</p>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-success" @onclick="AylikListeExcelAktar">
                        <i class="bi bi-file-earmark-excel me-1"></i>Excel Aktar
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="() => showAylikListeModal = false">Kapat</button>
                    <button type="button" class="btn btn-primary" @onclick="AylikListeYazdir">
                        <i class="bi bi-printer me-1"></i>Yazdir
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int secilenYil;
    private int secilenAy;
    private int aktifTakvimAy;
    private int secilenFirmaId = 0;
    private string secilenPeriyod = "aylik";

    private int? secilenGun = null;
    private DateTime secilenGunTarih;
    private List<BudgetOdeme> secilenGunOdemeleri = new();
    private List<BudgetOdeme> bekleyenOdemeler = new();

    private bool isLoading = true;
    private BudgetOzet? ozet;
    private List<BudgetOdeme> odemeler = new();
    private List<BudgetGunlukOzet>? takvimData;
    private List<BudgetMasrafKalemi>? masrafKalemleri;
    private List<BankaHesap>? bankaHesaplari;
    private List<Firma>? firmalar;
    private List<KrediOzet>? aktifKrediler;
    private decimal krediTaksitToplam = 0;
    private int krediTaksitAdet = 0;

    private bool showOdemeModal = false;
    private bool showOdemeYapModal = false;
    private bool showTaksitModal = false;
    private bool showExcelModal = false;
    private bool showAylikListeModal = false;

    private BudgetOdeme editOdeme = new();
    private BudgetOdeme? odemeYapilacak;
    private OdemeYapRequest odemeYapRequest = new();
    private TaksitliOdemeRequest taksitRequest = new();
    private IBrowserFile? excelDosya;

    private static readonly string[] AyAdlari = { "", "Ocak", "Subat", "Mart", "Nisan", "Mayis", "Haziran", 
                                                   "Temmuz", "Agustos", "Eylul", "Ekim", "Kasim", "Aralik" };

    protected override async Task OnInitializedAsync()
    {
        secilenYil = DateTime.Today.Year;
        secilenAy = DateTime.Today.Month;
        aktifTakvimAy = secilenAy;

        firmalar = await FirmaService.GetAktifFirmalarAsync();
        var aktifFirma = FirmaService.GetAktifFirma();
        if (!aktifFirma.TumFirmalar && aktifFirma.FirmaId > 0)
            secilenFirmaId = aktifFirma.FirmaId;

        masrafKalemleri = await BudgetService.GetMasrafKalemleriAsync();
        bankaHesaplari = await BankaHesapService.GetAllAsync();
        await YenileDataAsync();
    }

    private async Task YenileDataAsync()
    {
        isLoading = true;
        var oncekiSecilenGun = secilenGun; // Onceki secimi sakla
        StateHasChanged();

        try
        {
            // Firma filtresine gore odemeler
            odemeler = await BudgetService.GetOdemelerAsync(secilenYil, secilenAy > 0 ? secilenAy : null, secilenFirmaId > 0 ? secilenFirmaId : null);

            // Sadece bekleyen odemeler - ODENMIS VE SILINMIS OLANLAR HARIC
            bekleyenOdemeler = odemeler.Where(o => o.Durum == OdemeDurum.Bekliyor).OrderBy(o => o.OdemeTarihi).ToList();

            if (secilenAy > 0)
            {
                ozet = await BudgetService.GetAylikOzetAsync(secilenYil, secilenAy, secilenFirmaId > 0 ? secilenFirmaId : null);
                aktifTakvimAy = secilenAy;
            }
            else
            {
                var yillikOzet = await BudgetService.GetYillikOzetAsync(secilenYil, secilenFirmaId > 0 ? secilenFirmaId : null);
                ozet = new BudgetOzet
                {
                    Yil = secilenYil,
                    ToplamOdeme = yillikOzet.ToplamOdeme,
                    OdenenToplam = odemeler.Where(o => o.Durum == OdemeDurum.Odendi).Sum(o => o.Miktar),
                    BekleyenToplam = odemeler.Where(o => o.Durum == OdemeDurum.Bekliyor).Sum(o => o.Miktar),
                    ToplamKayit = odemeler.Count,
                    OdenenKayit = odemeler.Count(o => o.Durum == OdemeDurum.Odendi),
                    BekleyenKayit = odemeler.Count(o => o.Durum == OdemeDurum.Bekliyor)
                };
            }

            takvimData = await BudgetService.GetTakvimDataAsync(secilenYil, aktifTakvimAy, secilenFirmaId > 0 ? secilenFirmaId : null);
            aktifKrediler = await BudgetService.GetAktifKredilerAsync(secilenFirmaId > 0 ? secilenFirmaId : null);

            var krediOdemeler = odemeler.Where(o => o.TaksitliMi && o.Durum == OdemeDurum.Bekliyor).ToList();
            krediTaksitToplam = krediOdemeler.Sum(o => o.Miktar);
            krediTaksitAdet = krediOdemeler.Count;

            // Onceki gun seciliyse, gun verilerini de guncelle
            if (oncekiSecilenGun.HasValue)
            {
                secilenGun = oncekiSecilenGun;
                secilenGunTarih = new DateTime(secilenYil, aktifTakvimAy, oncekiSecilenGun.Value);
                var gunData = takvimData?.FirstOrDefault(t => t.Gun == oncekiSecilenGun.Value);
                secilenGunOdemeleri = gunData?.Odemeler?.Where(o => o.Durum == OdemeDurum.Bekliyor).ToList() ?? new List<BudgetOdeme>();
            }
            else
            {
                secilenGun = null;
                secilenGunOdemeleri.Clear();
            }
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void PeriyodAylikSec() { secilenPeriyod = "aylik"; _ = YenileDataAsync(); }
    private void PeriyodYillikSec() { secilenPeriyod = "yillik"; secilenAy = 0; _ = YenileDataAsync(); }

    private async Task OncekiAy()
    {
        if (aktifTakvimAy > 1)
        {
            aktifTakvimAy--;
            takvimData = await BudgetService.GetTakvimDataAsync(secilenYil, aktifTakvimAy, secilenFirmaId > 0 ? secilenFirmaId : null);
            secilenGun = null;
            StateHasChanged();
        }
    }

    private async Task SonrakiAy()
    {
        if (aktifTakvimAy < 12)
        {
            aktifTakvimAy++;
            takvimData = await BudgetService.GetTakvimDataAsync(secilenYil, aktifTakvimAy, secilenFirmaId > 0 ? secilenFirmaId : null);
            secilenGun = null;
            StateHasChanged();
        }
    }

    private void GunSec(int gun)
    {
        secilenGun = gun;
        secilenGunTarih = new DateTime(secilenYil, aktifTakvimAy, gun);
        var gunData = takvimData?.FirstOrDefault(t => t.Gun == gun);
        // Sadece bekleyen odemeler gosterilsin
        secilenGunOdemeleri = gunData?.Odemeler?.Where(o => o.Durum == OdemeDurum.Bekliyor).ToList() ?? new List<BudgetOdeme>();
        StateHasChanged();
    }

    private void GeriDon()
    {
        secilenGun = null;
        secilenGunOdemeleri.Clear();
        StateHasChanged();
    }

    private void OdemeYapModalAc(BudgetOdeme odeme)
    {
        odemeYapilacak = odeme;
        odemeYapRequest = new OdemeYapRequest
        {
            OdemeTipi = OdemeTipi.Kasa,
            OdemeTarihi = DateTime.Today
        };
        showOdemeYapModal = true;
    }

    private async Task OdemeYap()
    {
        if (odemeYapilacak == null) return;

        if ((odemeYapRequest.OdemeTipi == OdemeTipi.Kasa || odemeYapRequest.OdemeTipi == OdemeTipi.Banka) && !odemeYapRequest.BankaHesapId.HasValue)
        {
            ToastService.ShowWarning("Hesap secin!");
            return;
        }

        try
        {
            await BudgetService.OdemeYapAsync(odemeYapilacak.Id, odemeYapRequest);
            ToastService.ShowSuccess(odemeYapilacak.MasrafKalemi + " odendi!");
            ModalKapat();
            
            // Tum veriyi yenile (gun secimi korunacak)
            await YenileDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private void YeniOdemeAc()
    {
        var aktifFirma = FirmaService.GetAktifFirma();
        editOdeme = new BudgetOdeme
        {
            OdemeTarihi = secilenGun.HasValue ? secilenGunTarih : DateTime.Today,
            Durum = OdemeDurum.Bekliyor,
            FirmaId = aktifFirma.TumFirmalar ? null : aktifFirma.FirmaId
        };
        showOdemeModal = true;
    }

    private void OdemeDuzenle(BudgetOdeme odeme)
    {
        editOdeme = new BudgetOdeme
        {
            Id = odeme.Id,
            OdemeTarihi = odeme.OdemeTarihi,
            MasrafKalemi = odeme.MasrafKalemi,
            Aciklama = odeme.Aciklama,
            Miktar = odeme.Miktar,
            Durum = odeme.Durum,
            FirmaId = odeme.FirmaId
        };
        showOdemeModal = true;
    }

    private async Task OdemeKaydet()
    {
        if (string.IsNullOrWhiteSpace(editOdeme.MasrafKalemi) || editOdeme.Miktar <= 0)
        {
            ToastService.ShowWarning("Masraf kalemi ve miktar zorunlu!");
            return;
        }

        try
        {
            if (editOdeme.Id > 0)
                await BudgetService.UpdateOdemeAsync(editOdeme);
            else
                await BudgetService.CreateOdemeAsync(editOdeme);

            ToastService.ShowSuccess("Kaydedildi.");
            ModalKapat();
            await YenileDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private async Task OdemeSilOnay(BudgetOdeme odeme)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"'{odeme.MasrafKalemi}' odemesini silmek istediginizden emin misiniz?");
        if (confirmed)
        {
            try
            {
                // Kalici silme
                await BudgetService.HardDeleteOdemeAsync(odeme.Id);
                ToastService.ShowSuccess("Odeme silindi.");
                
                // Tum veriyi yenile (gun secimi korunacak)
                await YenileDataAsync();
            }
            catch (Exception ex)
            {
                ToastService.ShowError("Silme hatasi: " + ex.Message);
            }
        }
    }

    private void TaksitliOdemeAc()
    {
        var aktifFirma = FirmaService.GetAktifFirma();
        taksitRequest = new TaksitliOdemeRequest
        {
            BaslangicTarihi = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1),
            TaksitSayisi = 12,
            FirmaId = aktifFirma.TumFirmalar ? null : aktifFirma.FirmaId
        };
        showTaksitModal = true;
    }

    private async Task TaksitliOdemeKaydet()
    {
        if (string.IsNullOrWhiteSpace(taksitRequest.MasrafKalemi) || taksitRequest.ToplamTutar <= 0 || taksitRequest.TaksitSayisi < 2)
        {
            ToastService.ShowWarning("Alanlari doldurun!");
            return;
        }

        try
        {
            await BudgetService.CreateTaksitliOdemeAsync(taksitRequest);
            ToastService.ShowSuccess(taksitRequest.TaksitSayisi + " taksit olusturuldu.");
            ModalKapat();
            await YenileDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private void ExcelYukleModalAc()
    {
        excelDosya = null;
        showExcelModal = true;
    }

    private void ExcelDosyaSecildi(InputFileChangeEventArgs e)
    {
        excelDosya = e.File;
    }

    private async Task SablonIndir()
    {
        try
        {
            var bytes = await BudgetService.GetExcelSablonAsync(firmalar ?? new List<Firma>());
            await JS.InvokeVoidAsync("downloadFileFromBase64", "butce_sablon.xlsx", Convert.ToBase64String(bytes));
            ToastService.ShowSuccess("Sablon indirildi!");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private async Task ExcelYukle()
    {
        if (excelDosya == null) return;

        try
        {
            using var stream = excelDosya.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();

            var sonuc = await BudgetService.ImportFromExcelAsync(bytes);
            ToastService.ShowSuccess($"{sonuc} odeme yuklendi!");
            ModalKapat();
            await YenileDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Yukleme hatasi: " + ex.Message);
        }
    }

    private void ModalKapat()
    {
        showOdemeModal = false;
        showOdemeYapModal = false;
        showTaksitModal = false;
        showExcelModal = false;
        showAylikListeModal = false;
    }

    private void AylikListeOnIzleme()
    {
        showAylikListeModal = true;
    }

    private async Task AylikListeYazdir()
    {
        // Ensure modal is open so printArea element exists in DOM
        if (!showAylikListeModal)
        {
            showAylikListeModal = true;
            StateHasChanged();
            // Wait for Blazor to render the modal and DOM to update
            await Task.Delay(100);
        }

        await JS.InvokeVoidAsync("eval", @"
            var printElement = document.getElementById('printArea');
            if (!printElement) {
                console.error('printArea element not found');
                return;
            }
            var printContent = printElement.innerHTML;
            var printWindow = window.open('', '_blank', 'width=800,height=600');
            printWindow.document.write('<html><head><title>Aylik Odeme Listesi</title>');
            printWindow.document.write('<style>body{font-family:Arial,sans-serif;margin:20px;} table{width:100%;border-collapse:collapse;} th,td{border:1px solid #000;padding:6px;} @media print{body{margin:0;} @page{size:A4;margin:10mm;}}</style>');
            printWindow.document.write('</head><body>');
            printWindow.document.write(printContent);
            printWindow.document.write('</body></html>');
            printWindow.document.close();
            printWindow.focus();
            setTimeout(function(){printWindow.print();},250);
        ");
    }

    private async Task AylikListeExcelAktar()
    {
        var headers = "Tarih,Masraf Kalemi,Aciklama,Taksit,Tutar";
        var rows = "";
        
        if (bekleyenOdemeler.Any())
        {
            rows = string.Join("\n", bekleyenOdemeler.Select(o => 
                $"{o.OdemeTarihi:dd.MM.yyyy},{o.MasrafKalemi?.Replace(",", " ")},{o.Aciklama?.Replace(",", " ")},{(o.TaksitliMi ? $"{o.KacinciTaksit}/{o.ToplamTaksitSayisi}" : "")},{o.Miktar}"));
        }
        
        var csv = $"{headers}\n{rows}";
        var fileName = $"AylikOdemeler_{GetAyAdi(aktifTakvimAy)}_{secilenYil}.csv";

        await JS.InvokeVoidAsync("eval", $@"
            var csvContent = '{csv.Replace("'", "\\'")}';
            var blob = new Blob(['\ufeff' + csvContent], {{ type: 'text/csv;charset=utf-8;' }});
            var link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = '{fileName}';
            link.click();
        ");

        ToastService.ShowSuccess("Excel dosyasý indirildi!");
    }

    private string GetAyAdi(int ay) => AyAdlari[ay];
    private string GetDurumAdi(OdemeDurum d) => d switch { OdemeDurum.Bekliyor => "Bekliyor", OdemeDurum.Odendi => "Odendi", OdemeDurum.Ertelendi => "Ertelendi", OdemeDurum.Iptal => "Iptal", _ => d.ToString() };
    private string GetDurumClass(OdemeDurum d) => d switch { OdemeDurum.Bekliyor => "bg-warning text-dark", OdemeDurum.Odendi => "bg-success", OdemeDurum.Ertelendi => "bg-secondary", OdemeDurum.Iptal => "bg-danger", _ => "bg-secondary" };
    private string FormatPara(decimal t) => t.ToString("N0") + " TL";

    private List<TaksitBilgisi> taksitListesi = new();

    private void TaksitListesiHesapla()
    {
        taksitListesi.Clear();

        if (taksitRequest.TaksitSayisi <= 1 || taksitRequest.ToplamTutar <= 0)
            return;

        var ilkOdemeTarihi = taksitRequest.BaslangicTarihi;
        var taksitTutari = taksitRequest.ToplamTutar / taksitRequest.TaksitSayisi;

        for (int i = 0; i < taksitRequest.TaksitSayisi; i++)
        {
            taksitListesi.Add(new TaksitBilgisi
            {
                Sira = i + 1,
                Tarih = ilkOdemeTarihi.AddMonths(i),
                Tutar = taksitTutari
            });
        }
    }

    private class TaksitBilgisi
    {
        public int Sira { get; set; }
        public DateTime Tarih { get; set; }
        public decimal Tutar { get; set; }
    }
}
