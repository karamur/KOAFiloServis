            Notlar = plan.Notlar
        };
        showTekrarlayanListeModal = false;
        showTekrarlayanModal = true;
    }

    private async Task TekrarlayanOdemeKaydet()
    {
        if (string.IsNullOrWhiteSpace(editTekrarlayan.OdemeAdi) || 
            string.IsNullOrWhiteSpace(editTekrarlayan.MasrafKalemi) || 
            editTekrarlayan.Tutar <= 0)
        {
            ToastService.ShowWarning("Odeme adi, masraf kalemi ve tutar zorunlu!");
            return;
        }

        try
        {
            if (editTekrarlayan.Id > 0)
                await BudgetService.UpdateTekrarlayanOdemeAsync(editTekrarlayan);
            else
                await BudgetService.CreateTekrarlayanOdemeAsync(editTekrarlayan);

            ToastService.ShowSuccess("Tekrarlayan odeme kaydedildi.");
            
            // Modalı kapat, listeyi yenile
            showTekrarlayanModal = false;
            tekrarlayanOdemeler = await BudgetService.GetTekrarlayanOdemelerAsync(secilenFirmaId > 0 ? secilenFirmaId : null);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private async Task TekrarlayanOdemeSilOnay(TekrarlayanOdeme plan)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"'{plan.OdemeAdi}' tekrarlayan odemesini silmek istediginize emin misiniz?");
        if (confirmed)
        {
            try
            {
                await BudgetService.DeleteTekrarlayanOdemeAsync(plan.Id);
                ToastService.ShowSuccess("Tekrarlayan odeme silindi.");
                tekrarlayanOdemeler = await BudgetService.GetTekrarlayanOdemelerAsync(secilenFirmaId > 0 ? secilenFirmaId : null);
                StateHasChanged();
            }
            catch (Exception ex)
            {
                ToastService.ShowError("Silme hatasi: " + ex.Message);
            }
        }
    }

    private async Task TekrarlayanOdemeleriSimdiOlustur()
    {
        try
        {
            var olusturulan = await BudgetService.TekrarlayanOdemelerdenKayitOlusturAsync(
                secilenYil, aktifTakvimAy, secilenFirmaId > 0 ? secilenFirmaId : null);
            
