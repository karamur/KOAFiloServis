    private void TekrarlayanOdemeDuzenle(TekrarlayanOdeme plan)
    {
        editTekrarlayan = new TekrarlayanOdeme
        {
            Id = plan.Id,
            OdemeAdi = plan.OdemeAdi,
            MasrafKalemi = plan.MasrafKalemi,
            Aciklama = plan.Aciklama,
            Tutar = plan.Tutar,
