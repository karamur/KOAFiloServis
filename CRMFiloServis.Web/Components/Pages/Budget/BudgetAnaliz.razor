<!-- Taksitli Odeme Modal -->
@if (showTaksitModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-calendar-plus me-2"></i>Taksitli Odeme / Kredi</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Firma</label>
                                <select class="form-select" @bind="taksitRequest.FirmaId">
                                    <option value="">Firma Secin...</option>
                                    @if (firmalar != null)
                                    {
                                        @foreach (var f in firmalar)
                                        {
                                            <option value="@f.Id">@f.FirmaAdi</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Masraf Kalemi *</label>
                                <input type="text" class="form-control" @bind="taksitRequest.MasrafKalemi" list="masrafList2" />
                                <datalist id="masrafList2">
                                    @if (masrafKalemleri != null)
                                    {
                                        @foreach (var k in masrafKalemleri)
                                        {
                                            <option value="@k.KalemAdi" />
                                        }
                                    }
                                </datalist>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Aciklama</label>
                                <input type="text" class="form-control" @bind="taksitRequest.Aciklama" />
                            </div>
                            <div class="row">
                                <div class="col-6">
                                    <div class="mb-3">
                                        <label class="form-label">Baslangic Tarihi *</label>
                                        <input type="date" class="form-control" @bind="taksitRequest.BaslangicTarihi" @bind:after="TaksitListesiHesapla" />
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="mb-3">
                                        <label class="form-label">Taksit Sayisi *</label>
                                        <input type="number" class="form-control" @bind="taksitRequest.TaksitSayisi" min="1" max="120" @bind:after="TaksitListesiHesapla" />
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-6">
                                    <div class="mb-3">
                                        <label class="form-label">Toplam Tutar *</label>
                                        <div class="input-group">
                                            <input type="number" class="form-control" @bind="taksitRequest.ToplamTutar" step="0.01" @bind:after="TaksitListesiHesapla" />
                                            <span class="input-group-text">TL</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="mb-3">
                                        <label class="form-label">Taksit Tutari</label>
                                        <div class="input-group">
                                            <input type="text" class="form-control fw-bold text-primary" value="@(taksitRequest.TaksitSayisi > 0 ? FormatPara(taksitRequest.ToplamTutar / taksitRequest.TaksitSayisi) : "0 TL")" readonly />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            @if (taksitRequest.TaksitSayisi > 1 && taksitListesi.Any())
                            {
                                var taksitToplam = taksitListesi.Sum(t => t.Tutar);
                                var fark = taksitRequest.ToplamTutar - taksitToplam;
                                var farkSifir = Math.Abs(fark) < 0.01m;
                                
                                <div class="card">
                                    <div class="card-header py-2 bg-info text-white d-flex justify-content-between align-items-center">
                                        <h6 class="mb-0"><i class="bi bi-list-ol me-2"></i>Taksit Plani (@taksitListesi.Count Taksit)</h6>
                                        <button type="button" class="btn btn-sm btn-light" @onclick="TaksitListesiSifirla" title="Taksitleri Sifirla">
                                            <i class="bi bi-arrow-counterclockwise"></i>
                                        </button>
                                    </div>
                                    <div class="card-body p-0" style="max-height: 280px; overflow-y: auto;">
                                        <table class="table table-sm table-striped mb-0">
                                            <thead class="table-light sticky-top">
                                                <tr>
                                                    <th width="40">#</th>
                                                    <th>Tarih</th>
                                                    <th class="text-end">Tutar (TL)</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var taksit in taksitListesi)
                                                {
                                                    <tr>
                                                        <td><span class="badge bg-secondary">@taksit.Sira</span></td>
                                                        <td>
                                                            <input type="date" class="form-control form-control-sm" 
                                                                   value="@taksit.Tarih.ToString("yyyy-MM-dd")" 
                                                                   @onchange="@(e => TaksitTarihDegistir(taksit, e))" />
                                                        </td>
                                                        <td>
                                                            <input type="text" class="form-control form-control-sm text-end" 
                                                                   value="@taksit.Tutar.ToString("N2", new System.Globalization.CultureInfo("tr-TR"))"
                                                                   @onchange="@(e => TaksitTutarDegistir(taksit, e))" 
                                                                   style="width: 120px;" />
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                    <div class="card-footer p-2">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <small class="text-muted">Taksit Toplami:</small>
                                                <strong class="ms-1">@taksitToplam.ToString("N2", new System.Globalization.CultureInfo("tr-TR")) TL</strong>
                                            </div>
                                            <div>
                                                <small class="text-muted">Fark:</small>
                                                <strong class="ms-1 @(farkSifir ? "text-success" : "text-danger")">
                                                    @fark.ToString("N2", new System.Globalization.CultureInfo("tr-TR")) TL
                                                    @if (farkSifir)
                                                    {
                                                        <i class="bi bi-check-circle-fill ms-1"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-exclamation-triangle-fill ms-1"></i>
                                                    }
                                                </strong>
                                            </div>
                                        </div>
                                        @if (!farkSifir)
                                        {
                                            <div class="alert alert-warning py-1 px-2 mt-2 mb-0" style="font-size: 11px;">
                                                <i class="bi bi-info-circle me-1"></i>
                                                Taksit toplamı ile toplam tutar eşit olmalı!
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-info text-center mt-5">
                                    <i class="bi bi-info-circle" style="font-size: 2rem;"></i>
                                    <p class="mb-0 mt-2">Taksit sayisi 2 veya daha fazla olduğunda taksit plani burada gorunecek</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button type="button" class="btn btn-primary" @onclick="TaksitliOdemeKaydet" 
                            disabled="@(!TaksitKaydetmeGecerliMi())">
                        <i class="bi bi-check-lg me-1"></i>@(taksitRequest.TaksitSayisi > 1 ? $"{taksitRequest.TaksitSayisi} Taksit Olustur" : "Kaydet")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

