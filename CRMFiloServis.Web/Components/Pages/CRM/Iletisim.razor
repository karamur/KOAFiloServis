@page "/crm/whatsapp"
@page "/crm/email"
@using System.Text.Json
@using CRMFiloServis.Web.Services
@using CRMFiloServis.Shared.Entities
@inject ICRMService CRMService
@inject ICariService CariService
@inject AppAuthenticationStateProvider AuthProvider
@inject IToastService ToastService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

@{
    var isWhatsApp = NavigationManager.Uri.Contains("/whatsapp");
    var pageTitle = isWhatsApp ? "WhatsApp" : "E-Posta";
    var pageIcon = isWhatsApp ? "bi-whatsapp" : "bi-envelope-fill";
    var iconColor = isWhatsApp ? "text-success" : "text-info";
}

<PageTitle>@pageTitle - CRM</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-0"><i class="bi @pageIcon me-2 @iconColor"></i>@pageTitle</h3>
            <small class="text-muted">@(isWhatsApp ? "WhatsApp mesajlar˝ gˆnderin" : "E-posta gˆnderin")</small>
        </div>
        <button class="btn btn-outline-secondary" @onclick="AyarlariAc">
            <i class="bi bi-gear me-1"></i>Ayarlar
        </button>
    </div>

    <div class="row">
        <!-- Sol Panel - H˝zl˝ Gˆnderim -->
        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h6 class="mb-0"><i class="bi bi-send me-2"></i>Yeni @pageTitle Gˆnder</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Al˝c˝</label>

                        @if (isWhatsApp)
                        {
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" id="topluGonderimCheck" @bind="topluGonderim" />
                                <label class="form-check-label" for="topluGonderimCheck">Ki˛ilere toplu gˆnderim</label>
                            </div>
                        }

                        @if (isWhatsApp && topluGonderim)
                        {
                            <div class="border rounded p-2 bg-light">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <small class="text-muted">Telefonu olan ki˛ilerden seÁim yap˝n</small>
                                    <div class="d-flex gap-1">
                                        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="TumKisileriSec">T¸m¸n¸ SeÁ</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="SecimleriTemizle">Temizle</button>
                                    </div>
                                </div>
                                <div style="max-height: 220px; overflow-y: auto;">
                                    @foreach (var cari in cariler.Where(c => !string.IsNullOrWhiteSpace(c.Telefon)).OrderBy(c => c.Unvan))
                                    {
                                        <div class="form-check">
                                            <input class="form-check-input"
                                                   type="checkbox"
                                                   id="cari_@cari.Id"
                                                   checked="@secilenCariIds.Contains(cari.Id)"
                                                   @onchange="(e => CariSecimDegisti(cari.Id, e.Value))" />
                                            <label class="form-check-label d-flex justify-content-between w-100" for="cari_@cari.Id">
                                                <span>@cari.Unvan</span>
                                                <small class="text-muted">@cari.Telefon</small>
                                            </label>
                                        </div>
                                    }
                                </div>
                                <div class="mt-2 small text-muted">SeÁilen ki˛i: @secilenCariIds.Count</div>
                            </div>
                        }
                        else
                        {
                            <div class="input-group">
                                <select class="form-select" @bind="secilenCariId" @bind:after="CariSecildi">
                                    <option value="0">Cari SeÁin...</option>
                                    @foreach (var cari in cariler.Where(c => isWhatsApp ? !string.IsNullOrEmpty(c.Telefon) : !string.IsNullOrEmpty(c.Email)))
                                    {
                                        <option value="@cari.Id">@cari.Unvan</option>
                                    }
                                </select>
                            </div>
                            <small class="text-muted">veya</small>
                            <input type="text" class="form-control mt-1" 
                                   @bind="aliciAdres" 
                                   placeholder="@(isWhatsApp ? "Telefon numaras˝ (5XX XXX XX XX)" : "E-posta adresi")" />
                        }
                    </div>

                    @if (!isWhatsApp)
                    {
                        <div class="mb-3">
                            <label class="form-label">Konu</label>
                            <input type="text" class="form-control" @bind="konu" placeholder="E-posta konusu" />
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Mesaj</label>
                        <textarea class="form-control" rows="5" @bind="mesajIcerik" placeholder="Mesaj˝n˝z˝ yaz˝n..."></textarea>
                    </div>

                    <!-- H˝zl˝ Şablonlar -->
                    <div class="mb-3">
                        <label class="form-label small text-muted">H˝zl˝ Şablonlar</label>
                        <div class="d-flex flex-wrap gap-1 mb-2">
                            <button class="btn btn-sm btn-outline-secondary" @onclick='() => SablonUygula("Merhaba, sipari˛iniz haz˝rlanm˝˛t˝r.")'>
                                Sipari˛ Haz˝r
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick='() => SablonUygula("÷deme hat˝rlatmas˝: Vadesi geÁmi˛ faturan˝z bulunmaktad˝r.")'>
                                ÷deme Hat˝rlatma
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick='() => SablonUygula("Randevunuz iÁin te˛ekk¸r ederiz. Gˆr¸˛mek ¸zere.")'>
                                Randevu Onay
                            </button>
                        </div>

                        @if (isWhatsApp)
                        {
                            <div class="row g-2 mb-2">
                                <div class="col-md-4">
                                    <input type="text" class="form-control form-control-sm" @bind="yeniSablonBaslik" placeholder="Şablon ad˝" />
                                </div>
                                <div class="col-md-6">
                                    <input type="text" class="form-control form-control-sm" @bind="yeniSablonIcerik" placeholder="Şablon metni" />
                                </div>
                                <div class="col-md-2 d-grid">
                                    <button type="button" class="btn btn-sm btn-success" @onclick="HizliSablonKaydet">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                </div>
                            </div>

                            @if (hizliSablonlar.Any())
                            {
                                <div class="d-flex flex-wrap gap-1">
                                    @foreach (var sablon in hizliSablonlar)
                                    {
                                        <div class="btn-group btn-group-sm">
                                            <button type="button" class="btn btn-outline-success" @onclick="() => SablonUygula(sablon.Icerik)">@sablon.Baslik</button>
                                            <button type="button" class="btn btn-outline-danger" title="Sil" @onclick="() => HizliSablonSil(sablon)">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>

                    <div class="text-end">
                        <button class="btn btn-primary" @onclick="MesajGonder" disabled="@isSending">
                            @if (isSending)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            <i class="bi bi-send me-1"></i>Gˆnder
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sa Panel - Gˆnderim GeÁmi˛i -->
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="bi bi-clock-history me-2"></i>@(isWhatsApp ? "Gˆnderim GeÁmi˛i" : "E-Posta Listesi")</h6>
                    @if (!isWhatsApp)
                    {
                        <button class="btn btn-outline-primary btn-sm" @onclick="EmailListeleriniYenile">
                            <i class="bi bi-arrow-clockwise me-1"></i>Yenile
                        </button>
                    }
                </div>
                @if (!isWhatsApp)
                {
                    <div class="card-header bg-light p-0">
                        <ul class="nav nav-tabs card-header-tabs ms-2 mt-2">
                            <li class="nav-item">
                                <button class="nav-link @(emailListeTab == "gonderilen" ? "active" : "")" @onclick='() => emailListeTab = "gonderilen"'>Gˆnderilen</button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link @(emailListeTab == "gelen" ? "active" : "")" @onclick='() => emailListeTab = "gelen"'>Gelen</button>
                            </li>
                        </ul>
                    </div>
                }
                <div class="card-body p-0">
                    @if (isLoading)
                    {
                        <div class="text-center p-4">
                            <div class="spinner-border text-primary"></div>
                        </div>
                    }
                    else if (isWhatsApp && !gonderilenMesajlar.Any())
                    {
                        <div class="text-center p-5 text-muted">
                            <i class="bi @pageIcon" style="font-size: 3rem;"></i>
                            <p class="mt-2">Hen¸z @pageTitle mesaj˝ gˆnderilmemi˛</p>
                        </div>
                    }
                    else if (!isWhatsApp && !AktifEmailListesi.Any())
                    {
                        <div class="text-center p-5 text-muted">
                            <i class="bi bi-envelope" style="font-size: 3rem;"></i>
                            <p class="mt-2">@(emailListeTab == "gelen" ? "Gelen e-posta bulunamad˝" : "Gˆnderilen e-posta bulunamad˝")</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                            @if (isWhatsApp)
                            {
                                <table class="table table-hover mb-0">
                                    <thead class="table-light sticky-top">
                                        <tr>
                                            <th>Tarih</th>
                                            <th>Al˝c˝</th>
                                            <th>Durum</th>
                                            <th>Mesaj</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var mesaj in gonderilenMesajlar)
                                        {
                                            <tr>
                                                <td><small>@mesaj.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small></td>
                                                <td><strong>@mesaj.DisAlici</strong></td>
                                                <td>
                                                    <span class="badge @GetDurumBadge(mesaj.Durum)">@GetDurumAdi(mesaj.Durum)</span>
                                                </td>
                                                <td><small class="text-muted">@(mesaj.Icerik.Length > 50 ? mesaj.Icerik[..50] + "..." : mesaj.Icerik)</small></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <table class="table table-hover mb-0">
                                    <thead class="table-light sticky-top">
                                        <tr>
                                            <th>Tarih</th>
                                            <th>@(emailListeTab == "gelen" ? "Kimden" : "Kime")</th>
                                            <th>Konu</th>
                                            <th>Durum</th>
                                            <th>÷zet</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var mail in AktifEmailListesi)
                                        {
                                            <tr class="@(!mail.Okundu && emailListeTab == "gelen" ? "table-light" : "")">
                                                <td><small>@mail.Tarih.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small></td>
                                                <td><strong>@(emailListeTab == "gelen" ? mail.Kimden : mail.Kime)</strong></td>
                                                <td>@mail.Baslik</td>
                                                <td>
                                                    <span class="badge @(mail.GelenMi ? (mail.Okundu ? "bg-success" : "bg-warning text-dark") : GetDurumBadge(mail.Durum))">
                                                        @(mail.GelenMi ? (mail.Okundu ? "Okundu" : "Yeni") : GetDurumAdi(mail.Durum))
                                                    </span>
                                                </td>
                                                <td><small class="text-muted">@mail.Ozet</small></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Ayarlar Modal -->
@if (showAyarModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi @pageIcon me-2"></i>@pageTitle Ayarlar˝
                    </h5>
                    <button type="button" class="btn-close" @onclick="AyarModalKapat"></button>
                </div>
                <div class="modal-body">
                    @if (isWhatsApp)
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>
                            WhatsApp Business API entegrasyonu iÁin API anahtar˝ gereklidir.
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Telefon Numaras˝</label>
                            <input type="text" class="form-control" @bind="whatsappAyar!.Telefon" placeholder="5XXXXXXXXX" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">API Anahtar˝</label>
                            <input type="password" class="form-control" @bind="whatsappAyar.ApiKey" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Webhook URL (Opsiyonel)</label>
                            <input type="text" class="form-control" @bind="whatsappAyar.WebhookUrl" />
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" @bind="whatsappAyar.Aktif" />
                            <label class="form-check-label">Aktif</label>
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label">SMTP Sunucu</label>
                            <input type="text" class="form-control" @bind="emailAyar!.SmtpSunucu" placeholder="smtp.gmail.com" />
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">SMTP Port</label>
                                    <input type="number" class="form-control" @bind="emailAyar.SmtpPort" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">SMTP SSL</label>
                                    <div class="form-check mt-2">
                                        <input class="form-check-input" type="checkbox" @bind="emailAyar.SslKullan" />
                                        <label class="form-check-label">SSL Kullan</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">IMAP Sunucu</label>
                                    <input type="text" class="form-control" @bind="emailAyar.ImapSunucu" placeholder="imap.gmail.com" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">IMAP Port</label>
                                    <input type="number" class="form-control" @bind="emailAyar.ImapPort" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Gelen Klasˆr¸</label>
                                    <input type="text" class="form-control" @bind="emailAyar.GelenKlasoru" placeholder="INBOX" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">IMAP SSL</label>
                                    <div class="form-check mt-2">
                                        <input class="form-check-input" type="checkbox" @bind="emailAyar.ImapSslKullan" />
                                        <label class="form-check-label">SSL Kullan</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">E-Posta Adresi</label>
                            <input type="email" class="form-control" @bind="emailAyar.Email" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Şifre / Uygulama Şifresi</label>
                            <input type="password" class="form-control" @bind="emailAyar.Sifre" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Gˆnderen Ad˝</label>
                            <input type="text" class="form-control" @bind="emailAyar.GonderenAdi" placeholder="CRM Filo Servis" />
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="emailAyar.GelenKutusuAktif" />
                            <label class="form-check-label">Gelen kutusu senkronizasyonu aktif</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" @bind="emailAyar.Aktif" />
                            <label class="form-check-label">Aktif</label>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="AyarModalKapat">ıptal</button>
                    <button type="button" class="btn btn-primary" @onclick="AyarlariKaydet" disabled="@isSavingAyar">
                        @if (isSavingAyar)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isSending = false;
    private bool isSavingAyar = false;
    private bool showAyarModal = false;
    private bool topluGonderim = false;
    private List<Cari> cariler = new();
    private List<Mesaj> gonderilenMesajlar = new();
    private List<EmailListeItem> gonderilenEmailListesi = new();
    private List<EmailListeItem> gelenEmailListesi = new();
    private List<int> secilenCariIds = new();
    private List<HizliSablonModel> hizliSablonlar = new();
    private int? aktifKullaniciId;
    private string emailListeTab = "gonderilen";

    // Gˆnderim
    private int secilenCariId = 0;
    private string aliciAdres = "";
    private string konu = "";
    private string mesajIcerik = "";
    private string yeniSablonBaslik = "";
    private string yeniSablonIcerik = "";

    // Ayarlar
    private EmailAyar? emailAyar;
    private WhatsAppAyar? whatsappAyar;

    private bool IsWhatsApp => NavigationManager.Uri.Contains("/whatsapp");
    private List<EmailListeItem> AktifEmailListesi => emailListeTab == "gelen" ? gelenEmailListesi : gonderilenEmailListesi;

    protected override async Task OnInitializedAsync()
    {
        var kullanici = AuthProvider.GetAktifKullanici();
        if (kullanici != null)
        {
            aktifKullaniciId = kullanici.Id;
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            cariler = await CariService.GetAllAsync();

            if (aktifKullaniciId.HasValue)
            {
                if (IsWhatsApp)
                {
                    var tumMesajlar = await CRMService.GetGonderilenMesajlarAsync(aktifKullaniciId.Value);
                    gonderilenMesajlar = tumMesajlar
                        .Where(m => m.Tip == MesajTipi.WhatsApp)
                        .OrderByDescending(m => m.CreatedAt)
                        .Take(50)
                        .ToList();

                    whatsappAyar = await CRMService.GetWhatsAppAyarAsync(aktifKullaniciId) ?? new WhatsAppAyar
                    {
                        KullaniciId = aktifKullaniciId,
                        Aktif = false
                    };
                    HizliSablonlariYukle();
                }
                else
                {
                    emailAyar = await CRMService.GetEmailAyarAsync(aktifKullaniciId) ?? new EmailAyar
                    {
                        KullaniciId = aktifKullaniciId,
                        SmtpPort = 587,
                        SslKullan = true,
                        ImapPort = 993,
                        ImapSslKullan = true,
                        GelenKlasoru = "INBOX",
                        Aktif = false
                    };

                    await EmailListeleriniYenile();
                }
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Veriler y¸klenirken hata: " + ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task EmailListeleriniYenile()
    {
        if (!aktifKullaniciId.HasValue)
        {
            return;
        }

        gonderilenEmailListesi = await CRMService.GetGonderilenEmailListAsync(aktifKullaniciId.Value);
        gelenEmailListesi = await CRMService.GetGelenEmailListAsync(aktifKullaniciId.Value);
    }

    private void CariSecildi()
    {
        if (secilenCariId > 0)
        {
            var cari = cariler.FirstOrDefault(c => c.Id == secilenCariId);
            if (cari != null)
            {
                aliciAdres = IsWhatsApp ? (cari.Telefon ?? "") : (cari.Email ?? "");
            }
        }
    }

    private void CariSecimDegisti(int cariId, object? value)
    {
        var secili = value as bool? == true;
        if (secili)
        {
            if (!secilenCariIds.Contains(cariId))
            {
                secilenCariIds.Add(cariId);
            }
        }
        else
        {
            secilenCariIds.Remove(cariId);
        }
    }

    private void TumKisileriSec()
    {
        secilenCariIds = cariler
            .Where(c => !string.IsNullOrWhiteSpace(c.Telefon))
            .Select(c => c.Id)
            .ToList();
    }

    private void SecimleriTemizle()
    {
        secilenCariIds.Clear();
    }

    private void SablonUygula(string sablon)
    {
        mesajIcerik = sablon;
    }

    private void HizliSablonlariYukle()
    {
        if (string.IsNullOrWhiteSpace(whatsappAyar?.HizliSablonlarJson))
        {
            hizliSablonlar = new();
            return;
        }

        try
        {
            hizliSablonlar = JsonSerializer.Deserialize<List<HizliSablonModel>>(whatsappAyar.HizliSablonlarJson) ?? new();
        }
        catch
        {
            hizliSablonlar = new();
        }
    }

    private async Task HizliSablonKaydet()
    {
        if (!IsWhatsApp)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(yeniSablonBaslik) || string.IsNullOrWhiteSpace(yeniSablonIcerik))
        {
            ToastService.ShowWarning("Şablon ad˝ ve iÁerii zorunludur.");
            return;
        }

        whatsappAyar ??= await CRMService.GetWhatsAppAyarAsync(aktifKullaniciId) ?? new WhatsAppAyar
        {
            KullaniciId = aktifKullaniciId,
            Aktif = false
        };

        hizliSablonlar.Add(new HizliSablonModel
        {
            Baslik = yeniSablonBaslik.Trim(),
            Icerik = yeniSablonIcerik.Trim()
        });

        whatsappAyar.HizliSablonlarJson = JsonSerializer.Serialize(hizliSablonlar);
        await CRMService.SaveWhatsAppAyarAsync(whatsappAyar);

        yeniSablonBaslik = "";
        yeniSablonIcerik = "";
        ToastService.ShowSuccess("H˝zl˝ ˛ablon kaydedildi.");
    }

    private async Task HizliSablonSil(HizliSablonModel sablon)
    {
        if (whatsappAyar == null)
        {
            return;
        }

        hizliSablonlar.Remove(sablon);
        whatsappAyar.HizliSablonlarJson = JsonSerializer.Serialize(hizliSablonlar);
        await CRMService.SaveWhatsAppAyarAsync(whatsappAyar);
        ToastService.ShowSuccess("H˝zl˝ ˛ablon silindi.");
    }

    private async Task MesajGonder()
    {
        if (string.IsNullOrWhiteSpace(mesajIcerik))
        {
            ToastService.ShowWarning("Mesaj iÁerii zorunludur.");
            return;
        }

        isSending = true;
        try
        {
            if (IsWhatsApp && topluGonderim)
            {
                var alicilar = cariler
                    .Where(c => secilenCariIds.Contains(c.Id) && !string.IsNullOrWhiteSpace(c.Telefon))
                    .Select(c => c.Telefon!.Trim())
                    .Distinct()
                    .ToList();

                if (!alicilar.Any())
                {
                    ToastService.ShowWarning("En az bir ki˛i seÁiniz.");
                    return;
                }

                var basariliSayisi = 0;
                foreach (var telefon in alicilar)
                {
                    if (await CRMService.SendWhatsAppAsync(aktifKullaniciId ?? 0, telefon, mesajIcerik))
                    {
                        basariliSayisi++;
                    }
                }

                if (basariliSayisi == alicilar.Count)
                {
                    ToastService.ShowSuccess($"WhatsApp mesaj˝ {basariliSayisi} ki˛iye gˆnderildi.");
                }
                else
                {
                    ToastService.ShowWarning($"{basariliSayisi}/{alicilar.Count} ki˛iye gˆnderim ba˛ar˝l˝ oldu.");
                }

                mesajIcerik = "";
                secilenCariIds.Clear();
                await LoadData();
                return;
            }

            if (string.IsNullOrWhiteSpace(aliciAdres))
            {
                ToastService.ShowWarning("Al˝c˝ bilgisi zorunludur.");
                return;
            }

            bool basarili;
            if (IsWhatsApp)
            {
                basarili = await CRMService.SendWhatsAppAsync(aktifKullaniciId ?? 0, aliciAdres, mesajIcerik);
            }
            else
            {
                if (string.IsNullOrWhiteSpace(konu))
                {
                    ToastService.ShowWarning("E-posta konusu zorunludur.");
                    return;
                }
                basarili = await CRMService.SendEmailAsync(aktifKullaniciId ?? 0, aliciAdres, konu, mesajIcerik);
            }

            if (basarili)
            {
                ToastService.ShowSuccess($"{(IsWhatsApp ? "WhatsApp" : "E-posta")} gˆnderildi.");
                aliciAdres = "";
                konu = "";
                mesajIcerik = "";
                secilenCariId = 0;
                await LoadData();
            }
            else
            {
                ToastService.ShowError("Gˆnderim ba˛ar˝s˝z. Ayarlar˝ kontrol edin.");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
        finally
        {
            isSending = false;
        }
    }

    private async Task AyarlariAc()
    {
        if (IsWhatsApp)
        {
            whatsappAyar = await CRMService.GetWhatsAppAyarAsync(aktifKullaniciId) ?? new WhatsAppAyar
            {
                KullaniciId = aktifKullaniciId,
                Aktif = false
            };
        }
        else
        {
            emailAyar = await CRMService.GetEmailAyarAsync(aktifKullaniciId) ?? new EmailAyar
            {
                KullaniciId = aktifKullaniciId,
                SmtpPort = 587,
                SslKullan = true,
                ImapPort = 993,
                ImapSslKullan = true,
                GelenKlasoru = "INBOX",
                Aktif = false
            };
        }
        showAyarModal = true;
    }

    private void AyarModalKapat()
    {
        showAyarModal = false;
    }

    private async Task AyarlariKaydet()
    {
        isSavingAyar = true;
        try
        {
            if (IsWhatsApp && whatsappAyar != null)
            {
                whatsappAyar.HizliSablonlarJson = JsonSerializer.Serialize(hizliSablonlar);
                await CRMService.SaveWhatsAppAyarAsync(whatsappAyar);
            }
            else if (!IsWhatsApp && emailAyar != null)
            {
                await CRMService.SaveEmailAyarAsync(emailAyar);
                await EmailListeleriniYenile();
            }

            ToastService.ShowSuccess("Ayarlar kaydedildi.");
            AyarModalKapat();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
        finally
        {
            isSavingAyar = false;
        }
    }

