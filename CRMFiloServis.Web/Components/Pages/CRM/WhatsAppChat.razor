@page "/crm/whatsapp-chat"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@using CRMFiloServis.Web.Services.Interfaces
@inject IWhatsAppService WhatsAppService
@inject ICariService CariService
@inject AppAuthenticationStateProvider AuthProvider
@inject IToastService ToastService
@rendermode InteractiveServer

<PageTitle>WhatsApp Chat - CRM</PageTitle>

<div class="container-fluid h-100 py-3" style="min-height: 80vh;">
    <div class="row h-100 g-0 border rounded bg-white shadow-sm" style="min-height: 700px;">

        <!-- Sol Panel: Kiţiler ve Gruplar -->
        <div class="col-md-4 border-end d-flex flex-column h-100">
            <div class="p-3 border-bottom bg-light d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text-success"><i class="bi bi-whatsapp me-2"></i>Sohbetler</h5>
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="dropdown">
                        <i class="bi bi-three-dots-vertical"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><button class="dropdown-item" @onclick="() => showYeniKisiModal = true"><i class="bi bi-person-plus me-2"></i>Yeni Kiţi</button></li>
                        <li><button class="dropdown-item" @onclick="() => showYeniGrupModal = true"><i class="bi bi-people me-2"></i>Yeni Grup</button></li>
                        <li><button class="dropdown-item" @onclick="CariAktar"><i class="bi bi-person-lines-fill me-2"></i>Carilerden Aktar</button></li>
                    </ul>
                </div>
            </div>

            <div class="p-2 border-bottom">
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" placeholder="Kiţi veya grup ara..." @bind="aramaMetni" @bind:event="oninput" />
                </div>
            </div>

            <ul class="nav nav-tabs nav-fill border-bottom-0 pt-2 px-2">
                <li class="nav-item">
                    <button class="nav-link w-100 py-1 @(aktifTab == "kisiler" ? "active border-bottom-0 bg-white" : "bg-light")" @onclick='() => aktifTab = "kisiler"'>Kiţiler</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link w-100 py-1 @(aktifTab == "gruplar" ? "active border-bottom-0 bg-white" : "bg-light")" @onclick='() => aktifTab = "gruplar"'>Gruplar</button>
                </li>
            </ul>

            <div class="flex-grow-1 overflow-auto bg-white">
                @if (isLoading)
                {
                    <div class="d-flex justify-content-center p-4">
                        <div class="spinner-border text-success" role="status"></div>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @if (aktifTab == "kisiler")
                        {
                            @foreach (var kisi in FiltreliKisiler())
                            {
                                <button class="list-group-item list-group-item-action d-flex align-items-center py-3 @(seciliKisi?.Id == kisi.Id && !grupModu ? "active bg-light" : "")"
                                        @onclick="() => KisiSec(kisi)">
                                    <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center fw-bold me-3" style="width: 45px; height: 45px; font-size: 1.2rem;">
                                        @(kisi.AdSoyad.FirstOrDefault().ToString().ToUpper())
                                    </div>
                                    <div class="flex-grow-1 overflow-hidden">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <strong class="text-truncate">@kisi.AdSoyad</strong>
                                        </div>
                                        <div class="small text-muted text-truncate">@kisi.Telefon</div>
                                    </div>
                                </button>
                            }
                        }
                        else
                        {
                            @foreach (var grup in FiltreliGruplar())
                            {
                                <button class="list-group-item list-group-item-action d-flex align-items-center py-3 @(seciliGrup?.Id == grup.Id && grupModu ? "active bg-light" : "")"
                                        @onclick="() => GrupSec(grup)">
                                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold me-3" style="width: 45px; height: 45px; font-size: 1.2rem;">
                                        <i class="bi bi-people-fill"></i>
                                    </div>
                                    <div class="flex-grow-1 overflow-hidden">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <strong class="text-truncate">@grup.GrupAdi</strong>
                                            <span class="badge bg-secondary rounded-pill">@grup.Uyeler.Count</span>
                                        </div>
                                        <div class="small text-muted text-truncate">@(grup.Aciklama ?? "Grup Mesajý")</div>
                                    </div>
                                </button>
                            }
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Sađ Panel: Sohbet Ekraný -->
        <div class="col-md-8 d-flex flex-column h-100" style="background-color: #efeae2; position: relative;">
            <!-- Wallpaper / background image simulation -->
            <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; opacity: 0.05; background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23000000\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zM36 0V4h4v2h-4v4h-2V6h-4V4h4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E'); z-index: 0; pointer-events: none;"></div>

            @if (grupModu ? seciliGrup != null : seciliKisi != null)
            {
                <!-- Sohbet Baţlýđý -->
                <div class="d-flex align-items-center p-3 bg-light border-bottom" style="z-index: 1;">
                    @if (grupModu)
                    {
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold me-3" style="width: 40px; height: 40px;">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <div class="flex-grow-1">
                            <h6 class="mb-0 fw-bold">@seciliGrup!.GrupAdi</h6>
                            <small class="text-muted">@seciliGrup.Uyeler.Count üye</small>
                        </div>
                        <button class="btn btn-light btn-sm" @onclick="() => showGrupUyeleriModal = true" title="Üyeleri Yönet">
                            <i class="bi bi-person-lines-fill"></i>
                        </button>
                    }
                    else
                    {
                        <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center fw-bold me-3" style="width: 40px; height: 40px;">
                            @(seciliKisi!.AdSoyad.FirstOrDefault().ToString().ToUpper())
                        </div>
                        <div>
                            <h6 class="mb-0 fw-bold">@seciliKisi.AdSoyad</h6>
                            <small class="text-muted">@seciliKisi.Telefon</small>
                        </div>
                    }
                </div>

                <!-- Mesajlar -->
                <div class="flex-grow-1 p-4 overflow-auto" id="chatContainer" style="z-index: 1;">
                    @if (isMessagesLoading)
                    {
                        <div class="text-center p-4">
                            <div class="spinner-border text-success" role="status"></div>
                        </div>
                    }
                    else if (!aktifMesajlar.Any())
                    {
                        <div class="text-center d-flex justify-content-center align-items-center h-100">
                            <div class="bg-info bg-opacity-10 text-dark px-4 py-2 rounded-pill small shadow-sm">
                                Buraya gönderilen mesajlar uçtan uca ţifrelenmiţtir.
                            </div>
                        </div>
                    }
                    else
                    {
                        var groupedMessages = aktifMesajlar.GroupBy(m => m.MesajTarihi.ToLocalTime().Date);
                        foreach (var dayGroup in groupedMessages)
                        {
                            <div class="text-center mb-3">
                                <span class="badge bg-white text-muted shadow-sm px-3 py-2 rounded-pill">
                                    @(dayGroup.Key == DateTime.Today ? "Bugün" : (dayGroup.Key == DateTime.Today.AddDays(-1) ? "Dün" : dayGroup.Key.ToString("dd MMMM yyyy")))
                                </span>
                            </div>

                            foreach (var msg in dayGroup)
                            {
                                var isGiden = msg.Tipi == WhatsAppMesaj.Yon.Giden;
                                <div class="d-flex mb-3 @(isGiden ? "justify-content-end" : "justify-content-start")">
                                    <div class="p-2 px-3 shadow-sm" style="max-width: 75%; border-radius: 12px; @(isGiden ? "background-color: #d9fdd3; border-top-right-radius: 0;" : "background-color: #ffffff; border-top-left-radius: 0;")">
                                        <div class="text-break" style="white-space: pre-wrap; font-size: 0.95rem;">@msg.Icerik</div>
                                        <div class="d-flex justify-content-end align-items-center mt-1" style="font-size: 0.7rem;">
                                            <span class="text-muted me-1">@msg.MesajTarihi.ToLocalTime().ToString("HH:mm")</span>
                                            @if (isGiden)
                                            {
                                                <i class="bi bi-check-all text-info" style="font-size: 1rem;"></i>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    }
                </div>

                <!-- Hýzlý Ţablonlar -->
                @if (sablonlar.Any())
                {
                    <div class="px-3 py-2 bg-white" style="z-index: 1;">
                        <small class="text-muted d-block mb-1">Hýzlý Ţablonlar:</small>
                        <div class="d-flex flex-nowrap overflow-auto gap-2 pb-1" style="-ms-overflow-style: none; scrollbar-width: none;">
                            @foreach (var s in sablonlar)
                            {
                                <button class="btn btn-outline-secondary btn-sm text-nowrap rounded-pill" @onclick="() => yazilanMesaj = s.Icerik">@s.Baslik</button>
                            }
                        </div>
                    </div>
                }

                <!-- Mesaj Yazma Alaný -->
                <div class="p-3 bg-light d-flex align-items-center gap-2 border-top" style="z-index: 1;">
                    <div class="dropdown dropup">
                        <button class="btn btn-light btn-lg text-muted rounded-circle" type="button" @onclick="() => showSablonYonetimModal = true" title="Ţablon Yönetimi">
                            <i class="bi bi-journal-text"></i>
                        </button>
                    </div>
                    <textarea class="form-control rounded-pill px-4 py-2" rows="1" placeholder="Mesaj yazýn..." 
                              style="resize: none; overflow-y: hidden;"
                              @bind="yazilanMesaj" @bind:event="oninput" @onkeydown="KlavyeGonder" id="chatInput"></textarea>

                    @if (string.IsNullOrWhiteSpace(yazilanMesaj))
                    {
                        <button class="btn btn-success btn-lg rounded-circle" disabled>
                            <i class="bi bi-mic-fill"></i>
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-success btn-lg rounded-circle" @onclick="MesajGonder" disabled="@isSending">
                            @if (isSending)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                            }
                            else
                            {
                                <i class="bi bi-send-fill" style="margin-left: -2px;"></i>
                            }
                        </button>
                    }
                </div>
            }
            else
            {
                <!-- Seçimsiz Boţ Durum -->
                <div class="h-100 d-flex flex-column justify-content-center align-items-center text-muted" style="z-index: 1;">
                    <i class="bi bi-whatsapp opacity-25" style="font-size: 8rem;"></i>
                    <h4 class="mt-4 fw-light text-dark">Filo CRM WhatsApp</h4>
                    <p>Sohbet baţlatmak için sol taraftan bir kiţi veya grup seçin.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- ================= MODALS ================= -->

<!-- Yeni Kiţi Modal -->
@if (showYeniKisiModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">Yeni Kiţi Ekle</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showYeniKisiModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Ad Soyad</label>
                        <input type="text" class="form-control" @bind="yeniKisi.AdSoyad" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Telefon (Örn: 905XXXXXXXXX)</label>
                        <input type="text" class="form-control" @bind="yeniKisi.Telefon" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notlar</label>
                        <textarea class="form-control" @bind="yeniKisi.Notlar"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showYeniKisiModal = false">Ýptal</button>
                    <button type="button" class="btn btn-success" @onclick="KisiKaydet">Kaydet</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Yeni Grup Modal -->
@if (showYeniGrupModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Yeni Grup Ekle</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showYeniGrupModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Grup Adý</label>
                        <input type="text" class="form-control" @bind="yeniGrup.GrupAdi" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Açýklama</label>
                        <input type="text" class="form-control" @bind="yeniGrup.Aciklama" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showYeniGrupModal = false">Ýptal</button>
                    <button type="button" class="btn btn-primary" @onclick="GrupKaydet">Oluţtur</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Grup Üyeleri Yönetim Modal -->
@if (showGrupUyeleriModal && seciliGrup != null)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title">@seciliGrup.GrupAdi - Üyeler</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showGrupUyeleriModal = false"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="p-3 border-bottom bg-light">
                        <label class="form-label small fw-bold">Yeni Üye Ekle</label>
                        <div class="input-group">
                            <select class="form-select" @bind="eklenecekKisiId">
                                <option value="0">Kiţi Seçin...</option>
                                @foreach (var k in kisiler.Where(k => !seciliGrup.Uyeler.Any(u => u.KisiId == k.Id)))
                                {
                                    <option value="@k.Id">@k.AdSoyad</option>
                                }
                            </select>
                            <button class="btn btn-success" @onclick="GrubaKisiEkle"><i class="bi bi-plus-lg"></i> Ekle</button>
                        </div>
                    </div>
                    <ul class="list-group list-group-flush">
                        @if (!seciliGrup.Uyeler.Any())
                        {
                            <li class="list-group-item text-center text-muted py-4">Grupta henüz üye yok.</li>
                        }
                        @foreach (var uye in seciliGrup.Uyeler)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-0">@uye.Kisi?.AdSoyad</h6>
                                    <small class="text-muted">@uye.Kisi?.Telefon</small>
                                </div>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => GruptanKisiCikar(uye.KisiId)">
                                    Çýkar
                                </button>
                            </li>
                        }
                    </ul>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showGrupUyeleriModal = false">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

<script>
    // Scroll chat to bottom
    window.scrollToBottom = (elementId) => {
        var element = document.getElementById(elementId);
        if (element) {
            element.scrollTop = element.scrollHeight;
        }
    }
</script>

@code {
    private List<WhatsAppKisi> kisiler = new();
    private List<WhatsAppGrup> gruplar = new();
    private List<WhatsAppSablon> sablonlar = new();
    private List<WhatsAppMesaj> aktifMesajlar = new();

    private bool isLoading = true;
    private bool isMessagesLoading = false;
    private bool isSending = false;

    private string aktifTab = "kisiler";
    private string aramaMetni = "";
    private string yazilanMesaj = "";

    private bool grupModu => aktifTab == "gruplar";
    private WhatsAppKisi? seciliKisi;
    private WhatsAppGrup? seciliGrup;

    // Modals
    private bool showYeniKisiModal = false;
    private WhatsAppKisi yeniKisi = new();

    private bool showYeniGrupModal = false;
    private WhatsAppGrup yeniGrup = new();

    private bool showGrupUyeleriModal = false;
    private int eklenecekKisiId = 0;

    private bool showSablonYonetimModal = false; //TODO: tam CRUD

    private int? aktifKullaniciId;

    protected override async Task OnInitializedAsync()
    {
        var kullanici = AuthProvider.GetAktifKullanici();
        aktifKullaniciId = kullanici?.Id;

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        try
        {
            kisiler = await WhatsAppService.GetKisilerAsync();
            gruplar = await WhatsAppService.GetGruplarAsync();
            sablonlar = await WhatsAppService.GetSablonlarAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Veriler yüklenemedi: " + ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private IEnumerable<WhatsAppKisi> FiltreliKisiler()
    {
        if (string.IsNullOrWhiteSpace(aramaMetni)) return kisiler;
        return kisiler.Where(k => 
            k.AdSoyad.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) || 
            (k.Telefon != null && k.Telefon.Contains(aramaMetni)));
    }

    private IEnumerable<WhatsAppGrup> FiltreliGruplar()
    {
        if (string.IsNullOrWhiteSpace(aramaMetni)) return gruplar;
        return gruplar.Where(g => g.GrupAdi.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase));
    }

    private async Task KisiSec(WhatsAppKisi kisi)
    {
        seciliKisi = kisi;
        seciliGrup = null;
        await MesajlariYukle();
    }

    private async Task GrupSec(WhatsAppGrup grup)
    {
        seciliGrup = grup;
        seciliKisi = null;
        await MesajlariYukle();
    }

    private async Task MesajlariYukle()
    {
        isMessagesLoading = true;
        try
        {
            if (seciliKisi != null)
            {
                aktifMesajlar = await WhatsAppService.GetMesajlarByKisiAsync(seciliKisi.Id);
                await WhatsAppService.MesajlariOkunduIsaretleAsync(kisiId: seciliKisi.Id);
            }
            else if (seciliGrup != null)
            {
                aktifMesajlar = await WhatsAppService.GetMesajlarByGrupAsync(seciliGrup.Id);
                await WhatsAppService.MesajlariOkunduIsaretleAsync(grupId: seciliGrup.Id);
            }
        }
        finally
        {
            isMessagesLoading = false;
            // ScrollToBottom is handled via JS
        }
    }

    private async Task MesajGonder()
    {
        if (string.IsNullOrWhiteSpace(yazilanMesaj)) return;

        isSending = true;
        try
        {
            if (seciliKisi != null)
            {
                var yeni = await WhatsAppService.SendMesajToKisiAsync(seciliKisi.Id, yazilanMesaj, aktifKullaniciId);
                aktifMesajlar.Add(yeni);
            }
            else if (seciliGrup != null)
            {
                var yeni = await WhatsAppService.SendMesajToGrupAsync(seciliGrup.Id, yazilanMesaj, aktifKullaniciId);
                aktifMesajlar.Add(yeni);
            }
            yazilanMesaj = "";
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
        finally
        {
            isSending = false;
        }
    }

    private async Task KlavyeGonder(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await MesajGonder();
        }
    }

    private async Task KisiKaydet()
    {
        try
        {
            await WhatsAppService.CreateKisiAsync(yeniKisi);
            showYeniKisiModal = false;
            yeniKisi = new();
            await LoadDataAsync();
            ToastService.ShowSuccess("Kiţi eklendi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message);
        }
    }

    private async Task GrupKaydet()
    {
        try
        {
            await WhatsAppService.CreateGrupAsync(yeniGrup);
            showYeniGrupModal = false;
            yeniGrup = new();
            await LoadDataAsync();
            ToastService.ShowSuccess("Grup oluţturuldu.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message);
        }
    }

    private async Task GrubaKisiEkle()
    {
        if (seciliGrup != null && eklenecekKisiId > 0)
        {
            await WhatsAppService.GrubaKisiEkleAsync(seciliGrup.Id, eklenecekKisiId);
            seciliGrup = await WhatsAppService.GetGrupByIdAsync(seciliGrup.Id);
            eklenecekKisiId = 0;
            ToastService.ShowSuccess("Kiţi gruba eklendi.");
        }
    }

    private async Task GruptanKisiCikar(int kisiId)
    {
        if (seciliGrup != null)
        {
            await WhatsAppService.GruptanKisiCikarAsync(seciliGrup.Id, kisiId);
            seciliGrup = await WhatsAppService.GetGrupByIdAsync(seciliGrup.Id);
            ToastService.ShowSuccess("Kiţi gruptan çýkarýldý.");
        }
    }

    private async Task CariAktar()
    {
        try
        {
            var cariler = await CariService.GetAllAsync();
            var telefonluCariler = cariler.Where(c => !string.IsNullOrWhiteSpace(c.Telefon)).Select(c => c.Id).ToList();

            if (!telefonluCariler.Any())
            {
                ToastService.ShowWarning("Telefon numarasý kayýtlý cari bulunamadý.");
                return;
            }

            await WhatsAppService.SeciliCarilerdenKisiOlustur(telefonluCariler);
            await LoadDataAsync(); // Listeyi yenile
            ToastService.ShowSuccess($"{telefonluCariler.Count} cari WhatsApp kiţilerine aktarýldý.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Aktarým sýrasýnda hata oluţtu: " + ex.Message);
        }
    }
}