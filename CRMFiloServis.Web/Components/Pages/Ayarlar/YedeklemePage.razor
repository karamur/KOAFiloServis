@page "/yedekleme"
@using CRMFiloServis.Web.Services
@inject IBackupService BackupService
@inject IToastService ToastService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Veritabaný Yedekleme</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-database-fill-gear me-2"></i>Veritabaný Yedekleme</h3>
        <button class="btn btn-primary" @onclick="YedekAl" disabled="@isBackingUp">
            @if (isBackingUp)
            {
                <span class="spinner-border spinner-border-sm me-1"></span>
                <text>Yedekleniyor...</text>
            }
            else
            {
                <i class="bi bi-download me-1"></i>
                <text>Yeni Yedek Al</text>
            }
        </button>
    </div>

    <div class="row mb-4">
        <!-- Ayarlar Kartý -->
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-gear me-2"></i>Otomatik Yedekleme Ayarlarý</h6>
                </div>
                <div class="card-body">
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" id="autoBackup" 
                               @bind="settings.AutoBackupEnabled" @bind:after="SaveSettings" />
                        <label class="form-check-label" for="autoBackup">Otomatik Yedekleme Aktif</label>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Yedekleme Aralýđý</label>
                        <select class="form-select" @bind="settings.AutoBackupIntervalHours" @bind:after="SaveSettings">
                            <option value="6">Her 6 Saatte</option>
                            <option value="12">Her 12 Saatte</option>
                            <option value="24">Günde Bir</option>
                            <option value="48">2 Günde Bir</option>
                            <option value="168">Haftada Bir</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Saklanacak Yedek Sayýsý</label>
                        <select class="form-select" @bind="settings.KeepBackupCount" @bind:after="SaveSettings">
                            <option value="5">5 Yedek</option>
                            <option value="10">10 Yedek</option>
                            <option value="20">20 Yedek</option>
                            <option value="30">30 Yedek</option>
                        </select>
                    </div>

                    @if (settings.LastBackupTime.HasValue)
                    {
                        <div class="alert alert-info py-2 mb-0">
                            <small>
                                <i class="bi bi-clock me-1"></i>
                                Son Yedekleme: @settings.LastBackupTime.Value.ToString("dd.MM.yyyy HH:mm")
                            </small>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Durum Kartý -->
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-info-circle me-2"></i>Yedekleme Durumu</h6>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-6 border-end">
                            <h3 class="text-primary mb-0">@backups.Count</h3>
                            <small class="text-muted">Toplam Yedek</small>
                        </div>
                        <div class="col-6">
                            <h3 class="text-success mb-0">@GetTotalSize()</h3>
                            <small class="text-muted">Toplam Boyut</small>
                        </div>
                    </div>
                    <hr />
                    <div class="text-center">
                        @if (settings.AutoBackupEnabled)
                        {
                            <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Otomatik Yedekleme Aktif</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark"><i class="bi bi-pause-circle me-1"></i>Otomatik Yedekleme Kapalý</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Son Yedek Kartý -->
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-clock-history me-2"></i>Son Yedek</h6>
                </div>
                <div class="card-body">
                    @if (backups.Any())
                    {
                        var lastBackup = backups.First();
                        <div class="text-center">
                            <i class="bi bi-file-earmark-zip text-primary" style="font-size: 3rem;"></i>
                            <h6 class="mt-2 mb-1">@lastBackup.FileName</h6>
                            <p class="text-muted mb-1">@lastBackup.FileSizeFormatted</p>
                            <small class="text-muted">@lastBackup.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                        </div>
                        <div class="d-grid gap-2 mt-3">
                            <button class="btn btn-outline-primary btn-sm" @onclick="() => DownloadBackup(lastBackup)">
                                <i class="bi bi-download me-1"></i>Ýndir
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                            <p class="mb-0 mt-2">Henüz yedek yok</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Yedek Listesi -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0"><i class="bi bi-list-ul me-2"></i>Yedek Listesi</h6>
            @if (backups.Count > settings.KeepBackupCount)
            {
                <button class="btn btn-outline-warning btn-sm" @onclick="CleanupBackups">
                    <i class="bi bi-trash me-1"></i>Eski Yedekleri Temizle
                </button>
            }
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Dosya Adý</th>
                            <th>Boyut</th>
                            <th>Oluţturulma Tarihi</th>
                            <th class="text-center" style="width: 200px;">Ýţlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var backup in backups)
                        {
                            <tr>
                                <td>
                                    <i class="bi bi-file-earmark-zip text-primary me-2"></i>
                                    @backup.FileName
                                </td>
                                <td>@backup.FileSizeFormatted</td>
                                <td>@backup.CreatedAt.ToString("dd.MM.yyyy HH:mm:ss")</td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-primary" title="Ýndir" @onclick="() => DownloadBackup(backup)">
                                            <i class="bi bi-download"></i>
                                        </button>
                                        <button class="btn btn-outline-success" title="Geri Yükle" @onclick="() => RestoreBackup(backup)">
                                            <i class="bi bi-arrow-counterclockwise"></i>
                                        </button>
                                        <button class="btn btn-outline-danger" title="Sil" @onclick="() => DeleteBackup(backup)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!backups.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                                    <p class="mb-0 mt-2">Henüz yedek bulunmuyor. "Yeni Yedek Al" butonuna týklayarak ilk yedeđinizi oluţturun.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Geri Yükleme Onay Modal -->
@if (showRestoreModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Geri Yükleme Onayý</h5>
                    <button type="button" class="btn-close" @onclick="() => showRestoreModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-danger">
                        <strong>Dikkat!</strong> Bu iţlem mevcut veritabanýný silecek ve seçilen yedekten geri yükleyecektir. 
                        Bu iţlem geri alýnamaz!
                    </div>
                    <p>Geri yüklenecek yedek: <strong>@selectedBackup?.FileName</strong></p>
                    <p>Tarih: @selectedBackup?.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showRestoreModal = false">Ýptal</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmRestore" disabled="@isRestoring">
                        @if (isRestoring)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                            <text>Geri Yükleniyor...</text>
                        }
                        else
                        {
                            <i class="bi bi-arrow-counterclockwise me-1"></i>
                            <text>Geri Yükle</text>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<BackupInfo> backups = new();
    private BackupSettings settings = new();
    private bool isBackingUp = false;
    private bool isRestoring = false;
    private bool showRestoreModal = false;
    private BackupInfo? selectedBackup;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        settings = BackupService.GetSettings();
        backups = await BackupService.GetBackupListAsync();
    }

    private async Task YedekAl()
    {
        isBackingUp = true;
        StateHasChanged();

        try
        {
            var result = await BackupService.CreateBackupAsync();

            if (result.Success)
            {
                ToastService.ShowSuccess($"Yedek baţarýyla oluţturuldu: {result.FileName}");
                await LoadData();
            }
            else
            {
                ToastService.ShowError($"Yedekleme hatasý: {result.ErrorMessage}");
            }
        }
        finally
        {
            isBackingUp = false;
            StateHasChanged();
        }
    }

    private async Task SaveSettings()
    {
        await BackupService.SaveSettingsAsync(settings);
        ToastService.ShowSuccess("Ayarlar kaydedildi.");
    }

    private async Task DownloadBackup(BackupInfo backup)
    {
        try
        {
            if (File.Exists(backup.FilePath))
            {
                var bytes = await File.ReadAllBytesAsync(backup.FilePath);
                var base64 = Convert.ToBase64String(bytes);
                await JS.InvokeVoidAsync("downloadFile", backup.FileName, base64, "application/octet-stream");
                ToastService.ShowSuccess("Yedek indiriliyor...");
            }
            else
            {
                ToastService.ShowError("Dosya bulunamadý!");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Ýndirme hatasý: {ex.Message}");
        }
    }

    private void RestoreBackup(BackupInfo backup)
    {
        selectedBackup = backup;
        showRestoreModal = true;
    }

    private async Task ConfirmRestore()
    {
        if (selectedBackup == null) return;

        isRestoring = true;
        StateHasChanged();

        try
        {
            var success = await BackupService.RestoreBackupAsync(selectedBackup.FileName);

            if (success)
            {
                ToastService.ShowSuccess("Veritabaný baţarýyla geri yüklendi. Sayfa yenileniyor...");
                showRestoreModal = false;

                // Sayfayý yenile
                await Task.Delay(2000);
                await JS.InvokeVoidAsync("location.reload");
            }
            else
            {
                ToastService.ShowError("Geri yükleme baţarýsýz!");
            }
        }
        finally
        {
            isRestoring = false;
            showRestoreModal = false;
            StateHasChanged();
        }
    }

    private async Task DeleteBackup(BackupInfo backup)
    {
        var success = await BackupService.DeleteBackupAsync(backup.FileName);

        if (success)
        {
            ToastService.ShowSuccess("Yedek silindi.");
            await LoadData();
        }
        else
        {
            ToastService.ShowError("Silme iţlemi baţarýsýz!");
        }
    }

    private async Task CleanupBackups()
    {
        await BackupService.CleanupOldBackupsAsync(settings.KeepBackupCount);
        ToastService.ShowSuccess("Eski yedekler temizlendi.");
        await LoadData();
    }

    private string GetTotalSize()
    {
        var total = backups.Sum(b => b.FileSizeBytes);
        if (total < 1024) return $"{total} B";
        if (total < 1024 * 1024) return $"{total / 1024.0:F1} KB";
        return $"{total / (1024.0 * 1024.0):F2} MB";
    }
}
