@page "/ayarlar/firmalar"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@inject IFirmaService FirmaService
@inject IToastService ToastService
@rendermode InteractiveServer

<PageTitle>Firma Yonetimi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-building me-2"></i>Firma Yonetimi</h3>
        <button class="btn btn-primary" @onclick="YeniFirmaAc">
            <i class="bi bi-plus-lg me-1"></i>Yeni Firma
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var firma in firmalar)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 @(firma.VarsayilanFirma ? "border-primary" : "")">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-0">
                                    @firma.FirmaAdi
                                    @if (firma.VarsayilanFirma)
                                    {
                                        <span class="badge bg-primary ms-1">Varsayilan</span>
                                    }
                                </h5>
                            </div>
                            <span class="badge @(firma.Aktif ? "bg-success" : "bg-secondary")">
                                @(firma.Aktif ? "Aktif" : "Pasif")
                            </span>
                        </div>
                        <div class="card-body">
                            <table class="table table-borderless table-sm mb-0">
                                @if (!string.IsNullOrEmpty(firma.UnvanTam))
                                {
                                    <tr>
                                        <th width="100"><i class="bi bi-building me-1"></i>Unvan:</th>
                                        <td>@firma.UnvanTam</td>
                                    </tr>
                                }
                                <tr>
                                    <th><i class="bi bi-hash me-1"></i>Vergi No:</th>
                                    <td>@firma.VergiNo</td>
                                </tr>
                                <tr>
                                    <th><i class="bi bi-geo-alt me-1"></i>Vergi D.:</th>
                                    <td>@firma.VergiDairesi</td>
                                </tr>
                                @if (!string.IsNullOrEmpty(firma.Telefon))
                                {
                                    <tr>
                                        <th><i class="bi bi-telephone me-1"></i>Telefon:</th>
                                        <td>@firma.Telefon</td>
                                    </tr>
                                }
                                @if (!string.IsNullOrEmpty(firma.Email))
                                {
                                    <tr>
                                        <th><i class="bi bi-envelope me-1"></i>Email:</th>
                                        <td>@firma.Email</td>
                                    </tr>
                                }
                            </table>
                        </div>
                        <div class="card-footer bg-transparent">
                            <div class="btn-group btn-group-sm w-100">
                                <button class="btn btn-outline-primary" @onclick="() => FirmaDuzenle(firma)">
                                    <i class="bi bi-pencil me-1"></i>Duzenle
                                </button>
                                @if (!firma.VarsayilanFirma)
                                {
                                    <button class="btn btn-outline-success" @onclick="() => VarsayilanYap(firma)">
                                        <i class="bi bi-star me-1"></i>Varsayilan Yap
                                    </button>
                                }
                                <button class="btn btn-outline-danger" @onclick="() => FirmaSil(firma)" disabled="@firma.VarsayilanFirma">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (!firmalar.Any())
            {
                <div class="col-12">
                    <div class="alert alert-info text-center py-4">
                        <i class="bi bi-info-circle" style="font-size: 2rem;"></i>
                        <p class="mb-2 mt-2">Henuz firma tanimlanmamis.</p>
                        <button class="btn btn-primary" @onclick="YeniFirmaAc">
                            <i class="bi bi-plus-lg me-1"></i>Ilk Firmayi Ekle
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Firma Modal -->
@if (showModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editFirma.Id > 0 ? "Firma Duzenle" : "Yeni Firma")</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Firma Kodu *</label>
                            <input type="text" class="form-control" @bind="editFirma.FirmaKodu" placeholder="F001" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">Firma Adi *</label>
                            <input type="text" class="form-control" @bind="editFirma.FirmaAdi" placeholder="Kisa isim (Menu'de gorunecek)" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Tam Unvan</label>
                            <input type="text" class="form-control" @bind="editFirma.UnvanTam" placeholder="Resmi unvan" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Vergi No</label>
                            <input type="text" class="form-control" @bind="editFirma.VergiNo" maxlength="11" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Vergi Dairesi</label>
                            <input type="text" class="form-control" @bind="editFirma.VergiDairesi" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Telefon</label>
                            <input type="text" class="form-control" @bind="editFirma.Telefon" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" @bind="editFirma.Email" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Web Sitesi</label>
                            <input type="text" class="form-control" @bind="editFirma.WebSite" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Il</label>
                            <input type="text" class="form-control" @bind="editFirma.Il" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Ilce</label>
                            <input type="text" class="form-control" @bind="editFirma.Ilce" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Adres</label>
                            <textarea class="form-control" @bind="editFirma.Adres" rows="2"></textarea>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" @bind="editFirma.Aktif" id="chkAktif" />
                                <label class="form-check-label" for="chkAktif">Aktif</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button type="button" class="btn btn-primary" @onclick="FirmaKaydet">
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Firma> firmalar = new();
    private bool isLoading = true;
    private bool showModal = false;
    private Firma editFirma = new();

    protected override async Task OnInitializedAsync()
    {
        await YenileAsync();
    }

    private async Task YenileAsync()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            firmalar = await FirmaService.GetAllAsync();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void YeniFirmaAc()
    {
        var nextCode = firmalar.Any() ? $"F{firmalar.Count + 1:000}" : "F001";
        editFirma = new Firma
        {
            FirmaKodu = nextCode,
            Aktif = true,
            VarsayilanFirma = !firmalar.Any()
        };
        showModal = true;
    }

    private void FirmaDuzenle(Firma firma)
    {
        editFirma = new Firma
        {
            Id = firma.Id,
            FirmaKodu = firma.FirmaKodu,
            FirmaAdi = firma.FirmaAdi,
            UnvanTam = firma.UnvanTam,
            VergiNo = firma.VergiNo,
            VergiDairesi = firma.VergiDairesi,
            Telefon = firma.Telefon,
            Email = firma.Email,
            WebSite = firma.WebSite,
            Adres = firma.Adres,
            Il = firma.Il,
            Ilce = firma.Ilce,
            Aktif = firma.Aktif,
            VarsayilanFirma = firma.VarsayilanFirma
        };
        showModal = true;
    }

    private async Task FirmaKaydet()
    {
        if (string.IsNullOrWhiteSpace(editFirma.FirmaKodu) || string.IsNullOrWhiteSpace(editFirma.FirmaAdi))
        {
            ToastService.ShowWarning("Firma kodu ve adi zorunludur!");
            return;
        }

        try
        {
            if (editFirma.Id > 0)
                await FirmaService.UpdateAsync(editFirma);
            else
                await FirmaService.CreateAsync(editFirma);

            ToastService.ShowSuccess("Firma kaydedildi.");
            ModalKapat();
            await YenileAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private async Task VarsayilanYap(Firma firma)
    {
        try
        {
            await FirmaService.SetVarsayilanAsync(firma.Id);
            ToastService.ShowSuccess(firma.FirmaAdi + " varsayilan firma olarak ayarlandi.");
            await YenileAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private async Task FirmaSil(Firma firma)
    {
        if (firma.VarsayilanFirma)
        {
            ToastService.ShowWarning("Varsayilan firma silinemez!");
            return;
        }

        try
        {
            await FirmaService.DeleteAsync(firma.Id);
            ToastService.ShowSuccess("Firma silindi.");
            await YenileAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private void ModalKapat()
    {
        showModal = false;
    }
}
