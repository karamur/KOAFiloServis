@page "/servis-calismalari/toplu-ekle"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@inject IServisCalismaService ServisCalismaService
@inject IAracService AracService
@inject ISoforService SoforService
@inject IGuzergahService GuzergahService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Toplu Servis Çalýţmasý Giriţi</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-list-check me-2"></i>Toplu Servis Çalýţmasý Giriţi</h3>
        <button class="btn btn-secondary" @onclick="Geri">
            <i class="bi bi-arrow-left me-1"></i>Geri
        </button>
    </div>

    @if (!string.IsNullOrEmpty(mesaj))
    {
        <div class="alert @(basarili ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mesaj
            <button type="button" class="btn-close" @onclick="@(() => mesaj = null)"></button>
        </div>
    }

    <div class="row">
        <div class="col-lg-4">
            <div class="card mb-3">
                <div class="card-header">
                    <h6 class="mb-0">Ortak Bilgiler</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Araç Seçimi <span class="text-danger">*</span></label>
                        <select class="form-select" @bind="secilenAracId">
                            <option value="0">-- Araç Seçin --</option>
                            @foreach (var arac in araclar)
                            {
                                <option value="@arac.Id">@arac.Plaka - @arac.Marka @arac.Model</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ţoför Seçimi <span class="text-danger">*</span></label>
                        <select class="form-select" @bind="secilenSoforId">
                            <option value="0">-- Ţoför Seçin --</option>
                            @foreach (var sofor in soforler)
                            {
                                <option value="@sofor.Id">@sofor.TamAd</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Güzergah Seçimi <span class="text-danger">*</span></label>
                        <select class="form-select" @bind="secilenGuzergahId" @bind:after="GuzergahDegisti">
                            <option value="0">-- Güzergah Seçin --</option>
                            @foreach (var guzergah in guzergahlar)
                            {
                                <option value="@guzergah.Id">@guzergah.GuzergahAdi (@guzergah.BirimFiyat.ToString("N0") ?)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Servis Türü</label>
                        <select class="form-select" @bind="secilenServisTuru">
                            <option value="@ServisTuru.Sabah">Sabah</option>
                            <option value="@ServisTuru.Aksam">Akţam</option>
                            <option value="@ServisTuru.SabahAksam">Sabah + Akţam</option>
                            <option value="@ServisTuru.Ozel">Özel</option>
                        </select>
                    </div>

                    <hr />

                    <div class="mb-3">
                        <label class="form-label">Baţlangýç Tarihi</label>
                        <input type="date" class="form-control" @bind="baslangicTarihi" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Bitiţ Tarihi</label>
                        <input type="date" class="form-control" @bind="bitisTarihi" />
                    </div>

                    <button class="btn btn-primary w-100" @onclick="TarihleriOlustur" 
                            disabled="@(secilenAracId == 0 || secilenSoforId == 0 || secilenGuzergahId == 0)">
                        <i class="bi bi-calendar-plus me-1"></i>Tarihleri Oluţtur
                    </button>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">Hýzlý Seçim</h6>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <button class="btn btn-outline-primary btn-sm" @onclick="@(() => HizliSecim(7))">Son 7 Gün</button>
                        <button class="btn btn-outline-primary btn-sm" @onclick="@(() => HizliSecim(30))">Son 30 Gün</button>
                        <button class="btn btn-outline-primary btn-sm" @onclick="BuAy">Bu Ay</button>
                        <button class="btn btn-outline-primary btn-sm" @onclick="GecenAy">Geçen Ay</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Çalýţma Günleri</h6>
                    @if (calismalar.Any())
                    {
                        <div>
                            <button class="btn btn-outline-secondary btn-sm me-2" @onclick="TumunuSec">
                                <i class="bi bi-check-all me-1"></i>Tümünü Seç
                            </button>
                            <button class="btn btn-outline-secondary btn-sm me-2" @onclick="HaftaIciSec">
                                <i class="bi bi-calendar-week me-1"></i>Hafta Ýçi
                            </button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="SecimileriKaldir">
                                <i class="bi bi-x me-1"></i>Seçimleri Kaldýr
                            </button>
                        </div>
                    }
                </div>
                <div class="card-body">
                    @if (!calismalar.Any())
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-calendar-x" style="font-size: 3rem;"></i>
                            <p class="mt-2">Tarih aralýđý seçip "Tarihleri Oluţtur" butonuna týklayýn.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                            <table class="table table-hover">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th style="width: 50px;">Seç</th>
                                        <th>Tarih</th>
                                        <th>Gün</th>
                                        <th style="width: 150px;">Notlar</th>
                                        <th class="text-end" style="width: 120px;">Tutar</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var calisma in calismalar)
                                    {
                                        var isWeekend = calisma.Tarih.DayOfWeek == DayOfWeek.Saturday || calisma.Tarih.DayOfWeek == DayOfWeek.Sunday;
                                        <tr class="@(isWeekend ? "table-light" : "")">
                                            <td>
                                                <input type="checkbox" class="form-check-input" @bind="calisma.Secili" />
                                            </td>
                                            <td>@calisma.Tarih.ToString("dd.MM.yyyy")</td>
                                            <td>
                                                @GetGunAdi(calisma.Tarih.DayOfWeek)
                                                @if (isWeekend)
                                                {
                                                    <span class="badge bg-secondary ms-1">Hafta Sonu</span>
                                                }
                                            </td>
                                            <td>
                                                <input type="text" class="form-control form-control-sm" 
                                                       @bind="calisma.Notlar" placeholder="Opsiyonel"
                                                       disabled="@(!calisma.Secili)" />
                                            </td>
                                            <td class="text-end">
                                                @if (calisma.Secili)
                                                {
                                                    <strong>@birimFiyat.ToString("N2") ?</strong>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light">
                                    <tr>
                                        <td colspan="4" class="text-end"><strong>Toplam:</strong></td>
                                        <td class="text-end"><strong class="text-primary">@(calismalar.Count(c => c.Secili) * birimFiyat).ToString("N2") ?</strong></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span class="text-muted">Seçilen: <strong>@calismalar.Count(c => c.Secili)</strong> gün</span>
                            </div>
                            <button class="btn btn-success btn-lg" @onclick="Kaydet" disabled="@(kayitYapiliyor || !calismalar.Any(c => c.Secili))">
                                @if (kayitYapiliyor)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                <i class="bi bi-check-lg me-1"></i>Tümünü Kaydet
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Arac> araclar = new();
    private List<Sofor> soforler = new();
    private List<Guzergah> guzergahlar = new();
    private List<TopluCalismaModel> calismalar = new();

    private int secilenAracId;
    private int secilenSoforId;
    private int secilenGuzergahId;
    private ServisTuru secilenServisTuru = ServisTuru.Sabah;
    private DateTime baslangicTarihi = DateTime.Today.AddDays(-7);
    private DateTime bitisTarihi = DateTime.Today;
    private decimal birimFiyat = 0;

    private string? mesaj;
    private bool basarili;
    private bool kayitYapiliyor;

    protected override async Task OnInitializedAsync()
    {
        araclar = (await AracService.GetActiveAsync()).ToList();
        soforler = (await SoforService.GetActiveSoforlerAsync()).ToList(); // Sadece ţoför görevli personeller
        guzergahlar = (await GuzergahService.GetActiveAsync()).ToList();
    }

    private void GuzergahDegisti()
    {
        if (secilenGuzergahId > 0)
        {
            var guzergah = guzergahlar.FirstOrDefault(g => g.Id == secilenGuzergahId);
            birimFiyat = guzergah?.BirimFiyat ?? 0;
        }
        else
        {
            birimFiyat = 0;
        }
    }

    private void TarihleriOlustur()
    {
        calismalar.Clear();

        for (var tarih = baslangicTarihi; tarih <= bitisTarihi; tarih = tarih.AddDays(1))
        {
            calismalar.Add(new TopluCalismaModel
            {
                Tarih = tarih,
                Secili = tarih.DayOfWeek != DayOfWeek.Saturday && tarih.DayOfWeek != DayOfWeek.Sunday
            });
        }
    }

    private void HizliSecim(int gun)
    {
        bitisTarihi = DateTime.Today;
        baslangicTarihi = DateTime.Today.AddDays(-gun + 1);
        TarihleriOlustur();
    }

    private void BuAy()
    {
        var bugun = DateTime.Today;
        baslangicTarihi = new DateTime(bugun.Year, bugun.Month, 1);
        bitisTarihi = bugun;
        TarihleriOlustur();
    }

    private void GecenAy()
    {
        var bugun = DateTime.Today;
        var gecenAy = bugun.AddMonths(-1);
        baslangicTarihi = new DateTime(gecenAy.Year, gecenAy.Month, 1);
        bitisTarihi = new DateTime(gecenAy.Year, gecenAy.Month, DateTime.DaysInMonth(gecenAy.Year, gecenAy.Month));
        TarihleriOlustur();
    }

    private void TumunuSec()
    {
        foreach (var c in calismalar) c.Secili = true;
    }

    private void HaftaIciSec()
    {
        foreach (var c in calismalar)
        {
            c.Secili = c.Tarih.DayOfWeek != DayOfWeek.Saturday && c.Tarih.DayOfWeek != DayOfWeek.Sunday;
        }
    }

    private void SecimileriKaldir()
    {
        foreach (var c in calismalar) c.Secili = false;
    }

    private async Task Kaydet()
    {
        if (secilenAracId == 0 || secilenSoforId == 0 || secilenGuzergahId == 0)
        {
            mesaj = "Araç, ţoför ve güzergah seçimi zorunludur!";
            basarili = false;
            return;
        }

        var secilenler = calismalar.Where(c => c.Secili).ToList();
        if (!secilenler.Any())
        {
            mesaj = "En az bir gün seçilmelidir!";
            basarili = false;
            return;
        }

        kayitYapiliyor = true;
        StateHasChanged();

        try
        {
            int basariliKayit = 0;

            foreach (var calisma in secilenler)
            {
                var entity = new ServisCalisma
                {
                    AracId = secilenAracId,
                    SoforId = secilenSoforId,
                    GuzergahId = secilenGuzergahId,
                    CalismaTarihi = calisma.Tarih,
                    ServisTuru = secilenServisTuru,
                    Fiyat = birimFiyat,
                    Notlar = calisma.Notlar,
                    Durum = CalismaDurum.Tamamlandi
                };

                await ServisCalismaService.CreateAsync(entity);
                basariliKayit++;
            }

            mesaj = $"{basariliKayit} adet servis çalýţmasý baţarýyla kaydedildi!";
            basarili = true;
            calismalar.Clear();
        }
        catch (Exception ex)
        {
            mesaj = $"Hata: {ex.Message}";
            basarili = false;
        }
        finally
        {
            kayitYapiliyor = false;
        }
    }

    private void Geri()
    {
        Navigation.NavigateTo("/servis-calismalari");
    }

    private string GetGunAdi(DayOfWeek gun) => gun switch
    {
        DayOfWeek.Monday => "Pazartesi",
        DayOfWeek.Tuesday => "Salý",
        DayOfWeek.Wednesday => "Çarţamba",
        DayOfWeek.Thursday => "Perţembe",
        DayOfWeek.Friday => "Cuma",
        DayOfWeek.Saturday => "Cumartesi",
        DayOfWeek.Sunday => "Pazar",
        _ => gun.ToString()
    };

    private class TopluCalismaModel
    {
        public DateTime Tarih { get; set; }
        public bool Secili { get; set; }
        public string? Notlar { get; set; }
    }
}
