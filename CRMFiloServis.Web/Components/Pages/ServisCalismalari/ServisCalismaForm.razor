@page "/servis-calismalari/yeni"
@page "/servis-calismalari/{Id:int}"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@inject IServisCalismaService ServisCalismaService
@inject IAracService AracService
@inject ISoforService SoforService
@inject IGuzergahService GuzergahService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>@(IsEdit ? "Servis Çalýţmasý Düzenle" : "Yeni Servis Çalýţmasý")</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-calendar-check me-2"></i>@(IsEdit ? "Servis Çalýţmasý Düzenle" : "Yeni Servis Çalýţmasý")</h3>
        <button class="btn btn-secondary" @onclick="Geri">
            <i class="bi bi-arrow-left me-1"></i>Geri
        </button>
    </div>

    <div class="card">
        <div class="card-body">
            <EditForm Model="calisma" OnValidSubmit="Kaydet">
                <DataAnnotationsValidator />

                <div class="row">
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Çalýţma Tarihi *</label>
                            <InputDate @bind-Value="calisma.CalismaTarihi" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Servis Türü *</label>
                            <InputSelect @bind-Value="calisma.ServisTuru" class="form-select">
                                @foreach (ServisTuru tur in Enum.GetValues(typeof(ServisTuru)))
                                {
                                    <option value="@tur">@GetServisTuruText(tur)</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Durum</label>
                            <InputSelect @bind-Value="calisma.Durum" class="form-select">
                                @foreach (CalismaDurum durum in Enum.GetValues(typeof(CalismaDurum)))
                                {
                                    <option value="@durum">@GetDurumText(durum)</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Araç (Plaka) *</label>
                            <InputSelect @bind-Value="calisma.AracId" class="form-select">
                                <option value="0">-- Araç Seçiniz --</option>
                                @foreach (var arac in araclar)
                                {
                                    <option value="@arac.Id">@arac.Plaka - @arac.Marka @arac.Model</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Ţoför *</label>
                            <InputSelect @bind-Value="calisma.SoforId" class="form-select">
                                <option value="0">-- Ţoför Seçiniz --</option>
                                @foreach (var sofor in soforler)
                                {
                                    <option value="@sofor.Id">@sofor.TamAd</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Güzergah *</label>
                            <InputSelect @bind-Value="calisma.GuzergahId" class="form-select" @onchange="GuzergahDegisti">
                                <option value="0">-- Güzergah Seçiniz --</option>
                                @foreach (var guzergah in guzergahlar)
                                {
                                    <option value="@guzergah.Id">@guzergah.GuzergahAdi (@guzergah.Cari?.Unvan) - @guzergah.BirimFiyat.ToString("N2")?</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Fiyat (?)</label>
                            <InputNumber @bind-Value="calisma.Fiyat" class="form-control" />
                            <small class="text-muted">Boţ býrakýlýrsa güzergah fiyatý kullanýlýr</small>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Km Baţlangýç</label>
                            <InputNumber @bind-Value="calisma.KmBaslangic" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Km Bitiţ</label>
                            <InputNumber @bind-Value="calisma.KmBitis" class="form-control" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Baţlangýç Saati</label>
                            <InputText @bind-Value="baslangicSaati" class="form-control" type="time" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Bitiţ Saati</label>
                            <InputText @bind-Value="bitisSaati" class="form-control" type="time" />
                        </div>
                    </div>
                </div>

                <div class="card bg-light mb-3">
                    <div class="card-body">
                        <h6 class="card-title text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Arýza Bilgileri</h6>
                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-check">
                                    <InputCheckbox @bind-Value="calisma.ArizaOlduMu" class="form-check-input" id="arizaOldu" />
                                    <label class="form-check-label" for="arizaOldu">Arýza Oldu</label>
                                </div>
                            </div>
                            <div class="col-md-9">
                                @if (calisma.ArizaOlduMu)
                                {
                                    <div class="mb-3">
                                        <label class="form-label">Arýza Açýklamasý</label>
                                        <InputTextArea @bind-Value="calisma.ArizaAciklamasi" class="form-control" rows="2" />
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Notlar</label>
                    <InputTextArea @bind-Value="calisma.Notlar" class="form-control" rows="2" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="Geri">
                        <i class="bi bi-x-lg me-1"></i>Ýptal
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int? Id { get; set; }

    private ServisCalisma calisma = new();
    private List<Arac> araclar = new();
    private List<Sofor> soforler = new();
    private List<Guzergah> guzergahlar = new();
    private string? baslangicSaati;
    private string? bitisSaati;
    private bool IsEdit => Id.HasValue;

    protected override async Task OnInitializedAsync()
    {
        araclar = await AracService.GetActiveAsync();
        soforler = await SoforService.GetActiveSoforlerAsync(); // Sadece ţoför görevli personeller
        guzergahlar = await GuzergahService.GetActiveAsync();

        if (IsEdit)
        {
            var existing = await ServisCalismaService.GetByIdAsync(Id!.Value);
            if (existing != null)
            {
                calisma = existing;
                baslangicSaati = calisma.BaslangicSaati?.ToString(@"hh\:mm");
                bitisSaati = calisma.BitisSaati?.ToString(@"hh\:mm");
            }
            else
            {
                Navigation.NavigateTo("/servis-calismalari");
            }
        }
        else
        {
            calisma.CalismaTarihi = DateTime.Today;
            calisma.ServisTuru = ServisTuru.Sabah;
            calisma.Durum = CalismaDurum.Tamamlandi;
        }
    }

    private void GuzergahDegisti(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int guzergahId))
        {
            calisma.GuzergahId = guzergahId;
            var guzergah = guzergahlar.FirstOrDefault(g => g.Id == guzergahId);
            if (guzergah != null && !calisma.Fiyat.HasValue)
            {
                calisma.Fiyat = guzergah.BirimFiyat;
            }
        }
    }

    private async Task Kaydet()
    {
        if (calisma.AracId == 0 || calisma.SoforId == 0 || calisma.GuzergahId == 0)
            return;

        if (TimeSpan.TryParse(baslangicSaati, out var bs))
            calisma.BaslangicSaati = bs;

        if (TimeSpan.TryParse(bitisSaati, out var bts))
            calisma.BitisSaati = bts;

        if (calisma.ArizaOlduMu)
        {
            calisma.Durum = CalismaDurum.ArizaNedeniyleYapilamadi;
        }

        if (IsEdit)
        {
            await ServisCalismaService.UpdateAsync(calisma);
        }
        else
        {
            await ServisCalismaService.CreateAsync(calisma);
        }
        Navigation.NavigateTo("/servis-calismalari");
    }

    private void Geri()
    {
        Navigation.NavigateTo("/servis-calismalari");
    }

    private string GetServisTuruText(ServisTuru tur) => tur switch
    {
        ServisTuru.Sabah => "Sabah",
        ServisTuru.Aksam => "Akţam",
        ServisTuru.SabahAksam => "Sabah+Akţam",
        ServisTuru.Ozel => "Özel",
        _ => tur.ToString()
    };

    private string GetDurumText(CalismaDurum durum) => durum switch
    {
        CalismaDurum.Planli => "Planlý",
        CalismaDurum.Tamamlandi => "Tamamlandý",
        CalismaDurum.IptalEdildi => "Ýptal Edildi",
        CalismaDurum.ArizaNedeniyleYapilamadi => "Arýza Nedeniyle Yapýlamadý",
        _ => durum.ToString()
    };
}
