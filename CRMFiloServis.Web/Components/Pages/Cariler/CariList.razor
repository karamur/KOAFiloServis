@page "/cariler"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@inject ICariService CariService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Cariler</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-people-fill me-2"></i>Cariler</h3>
        <button class="btn btn-primary" @onclick="YeniCari">
            <i class="bi bi-plus-lg me-1"></i>Yeni Cari
        </button>
    </div>

    @if (cariler == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else if (!cariler.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Henüz cari kaydý bulunmamaktadýr.
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Cari Kodu</th>
                                <th>Ünvan</th>
                                <th>Tip</th>
                                <th>Telefon</th>
                                <th>Email</th>
                                <th>Yetkili</th>
                                <th style="width: 120px;">Ýţlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cari in cariler)
                            {
                                <tr>
                                    <td><strong>@cari.CariKodu</strong></td>
                                    <td>@cari.Unvan</td>
                                    <td>
                                        <span class="badge @GetTipBadgeClass(cari.CariTipi)">
                                            @GetTipText(cari.CariTipi)
                                        </span>
                                    </td>
                                    <td>@cari.Telefon</td>
                                    <td>@cari.Email</td>
                                    <td>@cari.YetkiliKisi</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Duzenle(cari.Id)" title="Düzenle">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => SilOnay(cari)" title="Sil">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@if (showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Silme Onayý</h5>
                    <button type="button" class="btn-close" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <p><strong>@silinecekCari?.Unvan</strong> isimli cariyi silmek istediđinize emin misiniz?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showDeleteModal = false">Ýptal</button>
                    <button type="button" class="btn btn-danger" @onclick="Sil">Sil</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Cari>? cariler;
    private bool showDeleteModal = false;
    private Cari? silinecekCari;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        cariler = await CariService.GetAllAsync();
    }

    private void YeniCari()
    {
        Navigation.NavigateTo("/cariler/yeni");
    }

    private void Duzenle(int id)
    {
        Navigation.NavigateTo($"/cariler/{id}");
    }

    private void SilOnay(Cari cari)
    {
        silinecekCari = cari;
        showDeleteModal = true;
    }

    private async Task Sil()
    {
        if (silinecekCari != null)
        {
            await CariService.DeleteAsync(silinecekCari.Id);
            await LoadData();
        }
        showDeleteModal = false;
        silinecekCari = null;
    }

    private string GetTipBadgeClass(CariTipi tip) => tip switch
    {
        CariTipi.Musteri => "bg-success",
        CariTipi.Tedarikci => "bg-warning text-dark",
        CariTipi.MusteriTedarikci => "bg-info",
        _ => "bg-secondary"
    };

    private string GetTipText(CariTipi tip) => tip switch
    {
        CariTipi.Musteri => "Müţteri",
        CariTipi.Tedarikci => "Tedarikçi",
        CariTipi.MusteriTedarikci => "Müţteri/Tedarikçi",
        _ => tip.ToString()
    };
}
