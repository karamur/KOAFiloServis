@page "/araclar/yeni"
@page "/araclar/{Id:int}"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@inject IAracService AracService
@inject ICariService CariService
@inject IToastService ToastService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>@(IsEdit ? "Araç Düzenle" : "Yeni Araç")</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-truck me-2"></i>@(IsEdit ? "Araç Düzenle" : "Yeni Araç")</h3>
        <button class="btn btn-secondary" @onclick="Geri">
            <i class="bi bi-arrow-left me-1"></i>Geri
        </button>
    </div>

    <div class="card">
        <div class="card-body">
            <EditForm Model="arac" OnValidSubmit="Kaydet">
                <DataAnnotationsValidator />

                <!-- Temel Bilgiler -->
                <h5 class="border-bottom pb-2 mb-3"><i class="bi bi-info-circle me-2"></i>Temel Bilgiler</h5>
                
                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Şase No * <small class="text-muted">(Tekil)</small></label>
                            <InputText @bind-Value="arac.SaseNo" class="form-control" style="text-transform: uppercase;" disabled="@IsEdit" />
                            <ValidationMessage For="@(() => arac.SaseNo)" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">@(IsEdit ? "Aktif Plaka" : "Plaka *")</label>
                            <InputText @bind-Value="plaka" class="form-control" style="text-transform: uppercase;" disabled="@IsEdit" />
                            @if (IsEdit)
                            {
                                <small class="text-info">
                                    <i class="bi bi-info-circle"></i> Plaka değişikliği için "Plaka Geçmişi" sekmesini kullanın
                                </small>
                            }
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Araç Tipi *</label>
                            <InputSelect @bind-Value="arac.AracTipi" class="form-select">
                                @foreach (AracTipi tip in Enum.GetValues(typeof(AracTipi)))
                                {
                                    <option value="@tip">@GetTipText(tip)</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Marka</label>
                            <InputText @bind-Value="arac.Marka" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label">Model</label>
                            <InputText @bind-Value="arac.Model" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="mb-3">
                            <label class="form-label">Model Yılı</label>
                            <InputNumber @bind-Value="arac.ModelYili" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="mb-3">
                            <label class="form-label">Koltuk Sayısı</label>
                            <InputNumber @bind-Value="arac.KoltukSayisi" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="mb-3">
                            <label class="form-label">Renk</label>
                            <InputText @bind-Value="arac.Renk" class="form-control" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Motor No</label>
                            <InputText @bind-Value="arac.MotorNo" class="form-control" />
                        </div>
                    </div>
                </div>

                <!-- Sahiplik ve Kiralama Bilgileri -->
                <h5 class="border-bottom pb-2 mb-3 mt-4"><i class="bi bi-building me-2"></i>Sahiplik & Kiralama Bilgileri</h5>
                
                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Sahiplik Tipi *</label>
                            <InputSelect @bind-Value="arac.SahiplikTipi" class="form-select" @oninput="OnSahiplikTipiChanged">
                                @foreach (AracSahiplikTipi tip in Enum.GetValues(typeof(AracSahiplikTipi)))
                                {
                                    <option value="@tip">@GetSahiplikText(tip)</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                    @if (arac.SahiplikTipi == AracSahiplikTipi.Kiralik)
                    {
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Araç Sahibi (Kiralayan) *</label>
                                <InputSelect @bind-Value="arac.KiralikCariId" class="form-select">
                                    <option value="">-- Seçiniz --</option>
                                    @foreach (var cari in tedarikciCariler)
                                    {
                                        <option value="@cari.Id">@cari.Unvan</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Kira Hesaplama Tipi</label>
                                <InputSelect @bind-Value="arac.KiraHesaplamaTipi" class="form-select">
                                    <option value="">-- Seçiniz --</option>
                                    @foreach (KiraHesaplamaTipi tip in Enum.GetValues(typeof(KiraHesaplamaTipi)))
                                    {
                                        <option value="@tip">@GetKiraHesaplamaText(tip)</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>
                    }
                </div>

                @if (arac.SahiplikTipi == AracSahiplikTipi.Kiralik)
                {
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Günlük Kira Bedeli (?)</label>
                                <InputNumber @bind-Value="arac.GunlukKiraBedeli" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Aylık Kira Bedeli (?)</label>
                                <InputNumber @bind-Value="arac.AylikKiraBedeli" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Sefer Başına Kira Bedeli (?)</label>
                                <InputNumber @bind-Value="arac.SeferBasinaKiraBedeli" class="form-control" />
                            </div>
                        </div>
                    </div>
                }

                <!-- Komisyon Bilgileri -->
                <h5 class="border-bottom pb-2 mb-3 mt-4"><i class="bi bi-percent me-2"></i>Komisyon Bilgileri</h5>
                
                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3 pt-4">
                            <div class="form-check">
                                <InputCheckbox @bind-Value="arac.KomisyonVar" class="form-check-input" id="komisyonVar" />
                                <label class="form-check-label" for="komisyonVar">Komisyon Var</label>
                            </div>
                        </div>
                    </div>
                    @if (arac.KomisyonVar)
                    {
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Komisyoncu *</label>
                                <InputSelect @bind-Value="arac.KomisyoncuCariId" class="form-select">
                                    <option value="">-- Seçiniz --</option>
                                    @foreach (var cari in tedarikciCariler)
                                    {
                                        <option value="@cari.Id">@cari.Unvan</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Komisyon Hesaplama Tipi</label>
                                <InputSelect @bind-Value="arac.KomisyonHesaplamaTipi" class="form-select">
                                    <option value="">-- Seçiniz --</option>
                                    @foreach (KomisyonHesaplamaTipi tip in Enum.GetValues(typeof(KomisyonHesaplamaTipi)))
                                    {
                                        <option value="@tip">@GetKomisyonHesaplamaText(tip)</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>
                    }
                </div>

                @if (arac.KomisyonVar)
                {
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Komisyon Oranı (%)</label>
                                <InputNumber @bind-Value="arac.KomisyonOrani" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Sabit Komisyon Tutarı (?)</label>
                                <InputNumber @bind-Value="arac.SabitKomisyonTutari" class="form-control" />
                            </div>
                        </div>
                    </div>
                }

                <!-- Sigorta ve Muayene Bilgileri -->
                <h5 class="border-bottom pb-2 mb-3 mt-4"><i class="bi bi-calendar-check me-2"></i>Sigorta & Muayene</h5>
                
                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Trafik Sigortası Bitiş</label>
                            <InputDate @bind-Value="arac.TrafikSigortaBitisTarihi" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Kasko Bitiş</label>
                            <InputDate @bind-Value="arac.KaskoBitisTarihi" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Muayene Bitiş</label>
                            <InputDate @bind-Value="arac.MuayeneBitisTarihi" class="form-control" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Km Durumu</label>
                            <InputNumber @bind-Value="arac.KmDurumu" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="mb-3 pt-4">
                            <div class="form-check">
                                <InputCheckbox @bind-Value="arac.Aktif" class="form-check-input" id="aktif" />
                                <label class="form-check-label" for="aktif">Aktif</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3 pt-4">
                            <div class="form-check">
                                <InputCheckbox @bind-Value="arac.SatisaAcik" class="form-check-input" id="satisaAcik" />
                                <label class="form-check-label text-danger fw-bold" for="satisaAcik">Satışa Aktar</label>
                            </div>
                        </div>
                    </div>
                    @if (arac.SatisaAcik)
                    {
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Satış Fiyatı</label>
                                <InputNumber @bind-Value="arac.SatisFiyati" class="form-control text-end text-danger fw-bold" />
                            </div>
                        </div>
                    }
                </div>

                <div class="mb-3">
                    <label class="form-label">Notlar</label>
                    <InputTextArea @bind-Value="arac.Notlar" class="form-control" rows="2" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="Geri">
                        <i class="bi bi-x-lg me-1"></i>İptal
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int? Id { get; set; }

    private Arac arac = new();
    private List<Cari> tedarikciCariler = new();
    private bool IsEdit => Id.HasValue;
    private string plaka = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        // Tüm carileri yükle (Araç sahibi, kiralayan ve komisyoncular için)
        tedarikciCariler = await CariService.GetAllAsync();

        if (IsEdit)
        {
            var existing = await AracService.GetByIdAsync(Id!.Value);
            if (existing != null)
            {
                arac = existing;
                plaka = arac.AktifPlaka ?? string.Empty;
            }
            else
            {
                Navigation.NavigateTo("/araclar");
            }
        }
        else
        {
            arac.Aktif = true;
            arac.AracTipi = AracTipi.Minibus;
            arac.SahiplikTipi = AracSahiplikTipi.Ozmal;
        }
    }

    private void OnSahiplikTipiChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<AracSahiplikTipi>(e.Value?.ToString(), out var tip))
        {
            arac.SahiplikTipi = tip;
            if (tip == AracSahiplikTipi.Ozmal)
            {
                arac.KiralikCariId = null;
                arac.GunlukKiraBedeli = null;
                arac.AylikKiraBedeli = null;
                arac.SeferBasinaKiraBedeli = null;
                arac.KiraHesaplamaTipi = null;
            }
        }
    }

    private async Task Kaydet()
    {
        // Şase no zorunlu
        if (string.IsNullOrWhiteSpace(arac.SaseNo))
        {
            ToastService.ShowError("Şase numarası zorunludur!");
            return;
        }
        
        // Yeni araç ekleme için plaka zorunlu
        if (!IsEdit && string.IsNullOrWhiteSpace(plaka))
        {
            ToastService.ShowError("Plaka zorunludur!");
            return;
        }

        arac.SaseNo = arac.SaseNo.ToUpper().Trim();
        if (!string.IsNullOrWhiteSpace(plaka))
            plaka = plaka.ToUpper().Trim();

        // Özmal araçlarda kira bilgilerimini temizle
        if (arac.SahiplikTipi == AracSahiplikTipi.Ozmal)
        {
            arac.KiralikCariId = null;
            arac.GunlukKiraBedeli = null;
            arac.AylikKiraBedeli = null;
            arac.SeferBasinaKiraBedeli = null;
            arac.KiraHesaplamaTipi = null;
        }

        // Komisyon yoksa bilgileri temizle
        if (!arac.KomisyonVar)
        {
            arac.KomisyoncuCariId = null;
            arac.KomisyonOrani = null;
            arac.SabitKomisyonTutari = null;
            arac.KomisyonHesaplamaTipi = null;
        }

        // Satışa aktarılırsa aracı pasif yap ve tarihini kaydet
        if (arac.SatisaAcik)
        {
            arac.Aktif = false;
            if (arac.SatisaAcilmaTarihi == null)
            {
                arac.SatisaAcilmaTarihi = DateTime.Now;
            }
        }
        else
        {
            arac.SatisaAcilmaTarihi = null;
            arac.SatisFiyati = null;
        }

        try
        {
            if (IsEdit)
            {
                await AracService.UpdateAsync(arac);
                ToastService.ShowSuccess($"{arac.AktifPlaka ?? arac.SaseNo} başarıyla güncellendi.");
            }
            else
            {
                await AracService.CreateAsync(arac, plaka!, PlakaIslemTipi.Alis);
                ToastService.ShowSuccess($"{plaka} plakalı araç başarıyla eklendi.");
            }
            Navigation.NavigateTo("/araclar");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Kayıt sırasında hata oluştu: {ex.Message}");
        }
    }

    private void Geri()
    {
        Navigation.NavigateTo("/araclar");
    }

    private string GetTipText(AracTipi tip) => tip switch
    {
        AracTipi.Minibus => "Minibüs",
        AracTipi.Midibus => "Midibüs",
        AracTipi.Otobus => "Otobüs",
        AracTipi.Otomobil => "Otomobil",
        AracTipi.Panelvan => "Panelvan",
        _ => tip.ToString()
    };

    private string GetSahiplikText(AracSahiplikTipi tip) => tip switch
    {
        AracSahiplikTipi.Ozmal => "Özmal",
        AracSahiplikTipi.Kiralik => "Kiralık",
        AracSahiplikTipi.Komisyon => "Komisyon",
        AracSahiplikTipi.Diger => "Diğer",
        _ => tip.ToString()
    };

    private string GetKiraHesaplamaText(KiraHesaplamaTipi tip) => tip switch
    {
        KiraHesaplamaTipi.Gunluk => "Günlük",
        KiraHesaplamaTipi.Aylik => "Aylık",
        KiraHesaplamaTipi.SeferBasina => "Sefer Başına",
        _ => tip.ToString()
    };

    private string GetKomisyonHesaplamaText(KomisyonHesaplamaTipi tip) => tip switch
    {
        KomisyonHesaplamaTipi.YuzdeOrani => "Yüzde Oranı",
        KomisyonHesaplamaTipi.SabitTutar => "Sabit Tutar",
        _ => tip.ToString()
    };
}
