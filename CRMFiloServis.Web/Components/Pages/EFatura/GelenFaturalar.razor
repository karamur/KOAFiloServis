        }
    }

    private void DosyaSecildi(InputFileChangeEventArgs e)
    {
        importFile = e.File;
        importResult = null;
    }

    private async Task ImportYap()
    {
        if (importFile == null) return;

        isImporting = true;
        importResult = null;
        StateHasChanged();

        try
        {
            using var stream = new MemoryStream();
            await importFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(stream);
            var fileContent = stream.ToArray();

            // Secili firmaya gore import
            var firmaId = filtreFirmaId > 0 ? filtreFirmaId : (int?)null;
            importResult = await FaturaService.ImportFromExcelAsync(fileContent, FaturaYonu.Gelen, firmaId);

            if (importResult.Success)
            {
                ToastService.ShowSuccess($"{importResult.ImportedCount} fatura aktarildi.");
                await YenileAsync();
            }
            else if (importResult.ImportedCount == 0 && importResult.SkippedCount > 0)
            {
                ToastService.ShowWarning($"{importResult.SkippedCount} fatura zaten mevcut.");
            }
            else if (importResult.Errors.Any())
            {
                ToastService.ShowError($"Hata: {importResult.Errors.FirstOrDefault()}");
            }
        }
        catch (Exception ex)
        {
            importResult = new EFaturaImportResult 
            { 
                Success = false, 
                Errors = new List<string> { $"Import hatasi: {ex.Message}" } 
            };
            ToastService.ShowError($"Import hatasi: {ex.Message}");
        }
        finally
        {
            isImporting = false;
            StateHasChanged();
        }
    }

    private async Task ExcelExport()
    {
        if (!filtreliFaturalar.Any())
        {
            ToastService.ShowWarning("Indirilecek fatura yok!");
            return;
        }

        try
        {
            var bytes = await FaturaService.ExportToExcelAsync(filtreliFaturalar);
            await JS.InvokeVoidAsync("downloadFileFromBase64", $"gelen_faturalar_{DateTime.Now:yyyyMMdd}.xlsx", Convert.ToBase64String(bytes));
            ToastService.ShowSuccess("Excel indirildi!");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private void ModalKapat()
    {
        showFaturaModal = false;
        showImportModal = false;
        showDetayModal = false;
        showOdemeModal = false;
        showOdemeTarihiModal = false;
    }

    private string GetDurumAdi(FaturaDurum d) => d switch
    {
        FaturaDurum.Beklemede => "Odenmedi",
        FaturaDurum.KismiOdendi => "Kismi Odendi",
        FaturaDurum.Odendi => "Odendi",
        FaturaDurum.IptalEdildi => "Iptal",
        _ => d.ToString()
    };

    private string GetDurumClass(FaturaDurum d) => d switch
    {
        FaturaDurum.Beklemede => "bg-danger",
        FaturaDurum.KismiOdendi => "bg-warning text-dark",
        FaturaDurum.Odendi => "bg-success",
        FaturaDurum.IptalEdildi => "bg-secondary",
        _ => "bg-secondary"
    };

    private string FormatPara(decimal t) => t.ToString("N2") + " TL";
