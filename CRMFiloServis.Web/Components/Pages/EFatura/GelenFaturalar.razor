    private void FaturaDetayAc(Fatura fatura)
    {
        detayFatura = fatura;
        showDetayModal = true;
    }

    private void OdemeYapAc(Fatura fatura)
    {
        odemeFatura = fatura;
        odemeTarihi = DateTime.Today;
        odemeTutar = fatura.KalanTutar;
        odemeHesapId = bankaHesaplari.FirstOrDefault()?.Id ?? 0;
        odemeAciklama = $"{fatura.FaturaNo} fatura odemesi";
        showOdemeModal = true;
    }

    private void OdemeTarihiDegistirAc(Fatura fatura)
    {
        odemeTarihiFatura = fatura;
        yeniOdemeTarihi = fatura.VadeTarihi ?? DateTime.Today.AddDays(30);
        showOdemeTarihiModal = true;
    }

    private async Task FaturaKaydet()
    {
        if (string.IsNullOrWhiteSpace(editFatura.FaturaNo) || editFatura.CariId <= 0 || editFatura.GenelToplam <= 0)
        {
            ToastService.ShowWarning("Zorunlu alanlari doldurun!");
            return;
        }

        try
        {
            editFatura.FaturaYonu = FaturaYonu.Gelen;
            editFatura.FaturaTipi = FaturaTipi.AlisFaturasi;
            editFatura.FaturaTarihi = DateTime.SpecifyKind(editFatura.FaturaTarihi, DateTimeKind.Utc);
            if (editFatura.VadeTarihi.HasValue)
                editFatura.VadeTarihi = DateTime.SpecifyKind(editFatura.VadeTarihi.Value, DateTimeKind.Utc);

            if (editFatura.Id > 0)
                await FaturaService.UpdateAsync(editFatura);
            else
                await FaturaService.CreateAsync(editFatura);

            ToastService.ShowSuccess("Fatura kaydedildi.");
            ModalKapat();
            await YenileAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private async Task OdemeKaydetAsync()
    {
        if (odemeFatura == null || odemeTutar <= 0 || odemeHesapId <= 0)
        {
            ToastService.ShowWarning("Lutfen tum alanlari doldurun!");
            return;
        }

        try
        {
            // Banka/Kasa hareket olustur
            var hareket = new BankaKasaHareket
            {
                BankaHesapId = odemeHesapId,
                IslemTarihi = DateTime.SpecifyKind(odemeTarihi, DateTimeKind.Utc),
                HareketTipi = HareketTipi.Cikis,
                IslemKaynak = IslemKaynak.FaturaOdeme,
                Tutar = odemeTutar,
                Aciklama = odemeAciklama,
                CariId = odemeFatura.CariId
            };
            await BankaKasaService.CreateAsync(hareket);

            // Fatura odenen tutari guncelle
            await FaturaService.UpdateOdenenTutarAsync(odemeFatura.Id);

            ToastService.ShowSuccess("Odeme kaydedildi.");
            ModalKapat();
            await YenileAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private async Task OdemeTarihiKaydetAsync()
    {
        if (odemeTarihiFatura == null) return;

        try
        {
            odemeTarihiFatura.VadeTarihi = DateTime.SpecifyKind(yeniOdemeTarihi, DateTimeKind.Utc);
            await FaturaService.UpdateAsync(odemeTarihiFatura);

            ToastService.ShowSuccess("Odeme tarihi guncellendi.");
            ModalKapat();
            await YenileAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private void ExcelImportAc()
    {
        importFile = null;
        importResult = null;
        showImportModal = true;
    }

    private async Task SablonIndir()
    {
        try
        {
            var bytes = await FaturaService.GetExcelSablonAsync(FaturaYonu.Gelen);
            await JS.InvokeVoidAsync("downloadFileFromBase64", "gelen_fatura_sablon.xlsx", Convert.ToBase64String(bytes));
            ToastService.ShowSuccess("Sablon indirildi!");
