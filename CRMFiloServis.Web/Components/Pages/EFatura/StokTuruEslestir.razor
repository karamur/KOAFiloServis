@page "/efatura/stok-turu-eslestir"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@inject IFaturaService FaturaService
@inject IStokService StokService
@inject IToastService ToastService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Stok Türü Eşleştirme</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-tags me-2"></i>Stok Türü Eşleştirme</h3>
        <div class="d-flex gap-2">
            @if (aktifTab == "eslesmemis")
            {
                <div class="form-check form-switch d-flex align-items-center me-2">
                    <input class="form-check-input" type="checkbox" id="stokKartiOlustur" @bind="stokKartiOlustur" />
                    <label class="form-check-label ms-2 small" for="stokKartiOlustur">Stok Kartı Oluştur</label>
                </div>
                <button class="btn btn-success" @onclick="TumunuKaydet" disabled="@(!degisiklikVar || isKaydediliyor)">
                    @if (isKaydediliyor)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    <i class="bi bi-check-all me-1"></i>Tümünü Kaydet
                </button>
            }
            <button class="btn btn-outline-secondary" @onclick="YenileAsync">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
    </div>

    <!-- Tabs -->
    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <button class="nav-link @(aktifTab == "eslesmemis" ? "active" : "")" @onclick='() => TabDegistir("eslesmemis")'>
                <i class="bi bi-x-circle me-1 text-danger"></i>Eşleşmemiş
                <span class="badge bg-danger ms-1">@eslesmemisKalemler.Count</span>
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(aktifTab == "eslesmis" ? "active" : "")" @onclick='() => TabDegistir("eslesmis")'>
                <i class="bi bi-check-circle me-1 text-success"></i>Eşleşmiş
                <span class="badge bg-success ms-1">@eslesmisKalemler.Count</span>
            </button>
        </li>
    </ul>

    <!-- Filtreler -->
    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small">Tarih Aralığı</label>
                    <input type="date" class="form-control form-control-sm" @bind="filtreBaslangic" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">&nbsp;</label>
                    <input type="date" class="form-control form-control-sm" @bind="filtreBitis" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Fatura Yönü</label>
                    <select class="form-select form-select-sm" @bind="filtreYon">
                        <option value="">Tümü</option>
                        <option value="Gelen">Gelen (Alış)</option>
                        <option value="Giden">Giden (Satış)</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Kalem Tipi</label>
                    <select class="form-select form-select-sm" @bind="filtreKalemTipi">
                        <option value="">Tümü</option>
                        @foreach (FaturaKalemTipi tip in Enum.GetValues<FaturaKalemTipi>())
                        {
                            <option value="@((int)tip)">@GetKalemTipiAdi(tip)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Arama</label>
                    <input type="text" class="form-control form-control-sm" @bind="aramaMetni" placeholder="Açıklama, kod..." />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary btn-sm w-100" @onclick="FiltreleAsync">
                        <i class="bi bi-search me-1"></i>Filtrele
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (aktifTab == "eslesmemis")
    {
        <!-- Toplu İşlem Toolbar -->
        <div class="card mb-3 bg-light">
            <div class="card-body py-2">
                <div class="row g-2 align-items-center">
                    <div class="col-auto">
                        <div class="btn-group btn-group-sm">
                            <button class="btn btn-outline-primary" @onclick="HepsiniIsaretle">
                                <i class="bi bi-check-all me-1"></i>Hepsini Seç (@filtrelenmisKalemler.Count)
                            </button>
                            <button class="btn btn-outline-secondary" @onclick="SecimleriTemizle" disabled="@(!seciliKalemler.Any())">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                    </div>
                    <div class="col-auto">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text">Toplu Tür:</span>
                            <select class="form-select" style="width: 130px;" @bind="topluKalemTipi" @bind:after="TopluKalemTipiDegisti">
                                <option value="">Seç...</option>
                                @foreach (FaturaKalemTipi tip in Enum.GetValues<FaturaKalemTipi>())
                                {
                                    <option value="@((int)tip)">@GetKalemTipiAdi(tip)</option>
                                }
                            </select>
                            <span class="input-group-text">Alt Tip:</span>
                            <select class="form-select" style="width: 170px;" @bind="topluAltTipi"
                                    disabled="@(string.IsNullOrEmpty(topluKalemTipi) || !SeciliTipIcinAltTipVar())">
                                <option value="">Seç...</option>
                                @if (!string.IsNullOrEmpty(topluKalemTipi) && int.TryParse(topluKalemTipi, out var topluTipInt))
                                {
                                    foreach (var altTip in GetAltTipler((FaturaKalemTipi)topluTipInt))
                                    {
                                        <option value="@((int)altTip)">@GetAltTipAdi(altTip)</option>
                                    }
                                }
                            </select>
                            <button class="btn btn-primary" @onclick="TopluTurDegistir" 
                                    disabled="@(string.IsNullOrEmpty(topluKalemTipi) || !seciliKalemler.Any())">
                                <i class="bi bi-check me-1"></i>Uygula
                            </button>
                        </div>
                    </div>
                    <div class="col-auto">
                        <button class="btn btn-success btn-sm" @onclick="TopluEslestirVeStokKartiOlustur" 
                                disabled="@(!seciliKalemler.Any() || string.IsNullOrEmpty(topluKalemTipi) || isKaydediliyor)">
                            @if (isKaydediliyor)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            <i class="bi bi-box-seam me-1"></i>Eşleştir + Stok Kartı
                        </button>
                    </div>
                    @if (seciliKalemler.Any())
                    {
                        <div class="col-auto">
                            <span class="badge bg-info fs-6">@seciliKalemler.Count seçili</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Tablo -->
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive" style="max-height: 500px;">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                @if (aktifTab == "eslesmemis")
                                {
                                    <th style="width: 40px;">
                                        <input type="checkbox" class="form-check-input" 
                                               checked="@tumunuSecildiMi"
                                               @onchange="TumunuSecHandler" />
                                    </th>
                                }
                                <th style="width: 100px;">Fatura No</th>
                                <th style="width: 90px;">Tarih</th>
                                <th style="width: 60px;">Yön</th>
                                <th style="width: 240px;">Stok Kodu</th>
                                <th>Açıklama</th>
                                <th class="text-end" style="width: 100px;">Tutar</th>
                                <th style="width: 150px;">Kalem Tipi</th>
                                <th style="width: 150px;">Alt Tipi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var kalem in filtrelenmisKalemler)
                            {
                                <tr class="@(seciliKalemler.Contains(kalem.Id) ? "table-active" : "") @(degistirilmisKalemler.Contains(kalem.Id) ? "table-warning" : "")">
                                    @if (aktifTab == "eslesmemis")
                                    {
                                        <td>
                                            <input type="checkbox" class="form-check-input" 
                                                   checked="@seciliKalemler.Contains(kalem.Id)"
                                                   @onchange="(e) => KalemSecildi(kalem.Id, (bool)e.Value!)" />
                                        </td>
                                    }
                                    <td><small>@kalem.Fatura?.FaturaNo</small></td>
                                    <td><small>@kalem.Fatura?.FaturaTarihi.ToString("dd.MM.yy")</small></td>
                                    <td>
                                        <span class="badge @(kalem.Fatura?.FaturaYonu == FaturaYonu.Gelen ? "bg-danger" : "bg-success")">
                                            @(kalem.Fatura?.FaturaYonu == FaturaYonu.Gelen ? "Alış" : "Satış")
                                        </span>
                                    </td>
                                    <td>
                                        @if (aktifTab == "eslesmemis")
                                        {
                                            <div>
                                                <input class="form-control form-control-sm mb-1" list="stokKodlariListesi"
                                                       value="@GetStokKoduInputValue(kalem)"
                                                       @onchange="e => StokKoduDegistiHandler(e, kalem)"
                                                       placeholder="Stok kodu ara / seç / manuel yaz" />
                                                @if (!string.IsNullOrWhiteSpace(kalem.UrunKodu))
                                                {
                                                    <small class="text-muted">Kayıtlı kod: @kalem.UrunKodu</small>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <small class="text-muted">@(string.IsNullOrWhiteSpace(kalem.UrunKodu) ? "-" : kalem.UrunKodu)</small>
                                        }
                                    </td>
                                    <td><span title="@kalem.Aciklama">@TruncateText(kalem.Aciklama, 50)</span></td>
                                    <td class="text-end"><strong>@FormatPara(kalem.ToplamTutar)</strong></td>
                                    <td>
                                        @if (aktifTab == "eslesmemis")
                                        {
                                            <select class="form-select form-select-sm" 
                                                    value="@((int)kalem.KalemTipi)"
                                                    @onchange="e => KalemTipiDegistiHandler(e, kalem)">
                                                @foreach (FaturaKalemTipi tip in Enum.GetValues<FaturaKalemTipi>())
                                                {
                                                    <option value="@((int)tip)">@GetKalemTipiAdi(tip)</option>
                                                }
                                            </select>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@GetKalemTipiAdi(kalem.KalemTipi)</span>
                                        }
                                    </td>
                                    <td>
                                        @if (aktifTab == "eslesmemis")
                                        {
                                            <select class="form-select form-select-sm" 
                                                    value="@((int?)kalem.AltTipi ?? 0)"
                                                    @onchange="e => AltTipiDegistiHandler(e, kalem)">
                                                <option value="0">-</option>
                                                @foreach (var altTip in GetAltTipler(kalem.KalemTipi))
                                                {
                                                    <option value="@((int)altTip)">@GetAltTipAdi(altTip)</option>
                                                }
                                            </select>
                                        }
                                        else
                                        {
                                            <span class="text-muted">@(kalem.AltTipi.HasValue ? GetAltTipAdi(kalem.AltTipi.Value) : "-")</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer d-flex justify-content-between">
                <small class="text-muted">@filtrelenmisKalemler.Count kalem gösteriliyor</small>
                @if (degisiklikVar)
                {
                    <span class="badge bg-warning text-dark">@degistirilmisKalemler.Count değişiklik kaydedilmedi</span>
                }
            </div>
        </div>
    }
</div>

<datalist id="stokKodlariListesi">
    @foreach (var stok in stokKartlari)
    {
        <option value="@GetStokKoduOptionValue(stok)"></option>
    }
</datalist>

@code {
    private List<FaturaKalem> eslesmemisKalemler = new();
    private List<FaturaKalem> eslesmisKalemler = new();
    private List<FaturaKalem> filtrelenmisKalemler = new();
    private List<StokKarti> stokKartlari = new();
    private HashSet<int> seciliKalemler = new();
    private HashSet<int> degistirilmisKalemler = new();
    private bool isLoading = true;
    private bool isKaydediliyor = false;
    private string aktifTab = "eslesmemis";

    private DateTime? filtreBaslangic;
    private DateTime? filtreBitis;
    private string filtreYon = "";
    private string filtreKalemTipi = "";
    private string aramaMetni = "";
    private string topluKalemTipi = "";
    private string topluAltTipi = "";
    private bool stokKartiOlustur = false;

    private bool degisiklikVar => degistirilmisKalemler.Any();
    private bool tumunuSecildiMi => filtrelenmisKalemler.Any() && filtrelenmisKalemler.All(k => seciliKalemler.Contains(k.Id));

    protected override async Task OnInitializedAsync()
    {
        filtreBaslangic = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        filtreBitis = DateTime.Today;
        stokKartlari = await StokService.GetStokKartlariAsync();
        await YenileAsync();
    }

    private void TabDegistir(string tab)
    {
        aktifTab = tab;
        seciliKalemler.Clear();
        degistirilmisKalemler.Clear();
        Filtrele();
    }

    private async Task YenileAsync()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            eslesmemisKalemler = await FaturaService.GetEslesmemisKalemleriAsync(filtreBaslangic, filtreBitis);
            eslesmisKalemler = await FaturaService.GetEslesmisKalemleriAsync(filtreBaslangic, filtreBitis);
            Filtrele();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task FiltreleAsync() => await YenileAsync();

    private void Filtrele()
    {
        var kaynakListe = aktifTab == "eslesmemis" ? eslesmemisKalemler : eslesmisKalemler;
        var query = kaynakListe.AsEnumerable();

        if (!string.IsNullOrEmpty(filtreYon))
        {
            var yon = filtreYon == "Gelen" ? FaturaYonu.Gelen : FaturaYonu.Giden;
            query = query.Where(k => k.Fatura?.FaturaYonu == yon);
        }

        if (!string.IsNullOrEmpty(filtreKalemTipi) && int.TryParse(filtreKalemTipi, out var tip))
            query = query.Where(k => (int)k.KalemTipi == tip);

        if (!string.IsNullOrWhiteSpace(aramaMetni))
        {
            var lower = aramaMetni.ToLowerInvariant();
            query = query.Where(k => 
                (k.Aciklama?.ToLowerInvariant().Contains(lower) ?? false) ||
                (k.UrunKodu?.ToLowerInvariant().Contains(lower) ?? false) ||
                (k.Fatura?.FaturaNo?.ToLowerInvariant().Contains(lower) ?? false));
        }

        filtrelenmisKalemler = query.OrderByDescending(k => k.Fatura?.FaturaTarihi).ThenBy(k => k.SiraNo).ToList();
        seciliKalemler.Clear();
    }

    private void KalemSecildi(int kalemId, bool secili)
    {
        if (secili) seciliKalemler.Add(kalemId);
        else seciliKalemler.Remove(kalemId);
    }

    private void TumunuSecHandler(ChangeEventArgs e)
    {
        if ((bool)e.Value!) foreach (var k in filtrelenmisKalemler) seciliKalemler.Add(k.Id);
        else seciliKalemler.Clear();
    }

    private void HepsiniIsaretle()
    {
        seciliKalemler.Clear();
        foreach (var k in filtrelenmisKalemler) seciliKalemler.Add(k.Id);
    }

    private void SecimleriTemizle()
    {
        seciliKalemler.Clear();
        topluKalemTipi = "";
        topluAltTipi = "";
    }

    private Task TopluKalemTipiDegisti()
    {
        topluAltTipi = "";
        return Task.CompletedTask;
    }

    private bool SeciliTipIcinAltTipVar()
    {
        if (string.IsNullOrEmpty(topluKalemTipi) || !int.TryParse(topluKalemTipi, out var tipInt))
            return false;

        return GetAltTipler((FaturaKalemTipi)tipInt).Any();
    }

    private void KalemTipiDegistiHandler(ChangeEventArgs e, FaturaKalem kalem)
    {
        if (int.TryParse(e.Value?.ToString(), out var yeniTip))
        {
            kalem.KalemTipi = (FaturaKalemTipi)yeniTip;
            kalem.AltTipi = null;
            degistirilmisKalemler.Add(kalem.Id);
        }
    }

    private void AltTipiDegistiHandler(ChangeEventArgs e, FaturaKalem kalem)
    {
        if (int.TryParse(e.Value?.ToString(), out var yeniAltTip))
        {
            kalem.AltTipi = yeniAltTip == 0 ? null : (FaturaKalemAltTipi)yeniAltTip;
            degistirilmisKalemler.Add(kalem.Id);
        }
    }

    private void StokKoduDegistiHandler(ChangeEventArgs e, FaturaKalem kalem)
    {
        var rawValue = e.Value?.ToString()?.Trim() ?? string.Empty;
        var yeniKod = rawValue.Contains(" | ", StringComparison.Ordinal)
            ? rawValue.Split(" | ", 2, StringSplitOptions.None)[0].Trim()
            : rawValue;

        kalem.UrunKodu = string.IsNullOrWhiteSpace(yeniKod) ? null : yeniKod;
        degistirilmisKalemler.Add(kalem.Id);
    }

    private void TopluTurDegistir()
    {
        if (string.IsNullOrEmpty(topluKalemTipi) || !seciliKalemler.Any()) return;

        var yeniTip = (FaturaKalemTipi)int.Parse(topluKalemTipi);
        var yeniAltTip = !string.IsNullOrEmpty(topluAltTipi) && int.TryParse(topluAltTipi, out var altTipInt)
            ? (FaturaKalemAltTipi?)altTipInt
            : null;
        var sayac = 0;

        var secilenKalemler = GetSeciliKalemlerVeTekrarlari();

        foreach (var kalem in secilenKalemler)
        {
            kalem.KalemTipi = yeniTip;
            kalem.AltTipi = yeniAltTip;
            degistirilmisKalemler.Add(kalem.Id);
            sayac++;
        }

        var mesaj = $"{sayac} kalemin türü '{GetKalemTipiAdi(yeniTip)}' olarak değiştirildi.";
        if (yeniAltTip.HasValue)
            mesaj += $" Alt tipi '{GetAltTipAdi(yeniAltTip.Value)}' olarak ayarlandı.";

        ToastService.ShowSuccess(mesaj);
    }

    private async Task TopluEslestirVeStokKartiOlustur()
    {
        if (!seciliKalemler.Any() || string.IsNullOrEmpty(topluKalemTipi)) return;

        var onay = await JS.InvokeAsync<bool>("confirm", $"{seciliKalemler.Count} kalem için stok kartı oluşturulacak. Devam?");
        if (!onay) return;

        isKaydediliyor = true;
        StateHasChanged();

        try
        {
            var yeniTip = (FaturaKalemTipi)int.Parse(topluKalemTipi);
            var yeniAltTip = !string.IsNullOrEmpty(topluAltTipi) && int.TryParse(topluAltTipi, out var altTipInt)
                ? (FaturaKalemAltTipi?)altTipInt
                : null;
            var secilenKalemler = GetSeciliKalemlerVeTekrarlari();

            foreach (var kalem in secilenKalemler)
            {
                kalem.KalemTipi = yeniTip;
                kalem.AltTipi = yeniAltTip;
                degistirilmisKalemler.Add(kalem.Id);
            }

            var sonuc = await FaturaService.UpdateFaturaKalemleriVeStokKartiOlusturAsync(secilenKalemler, true);

            var mesaj = $"{sonuc.GuncellenenKalemSayisi} kalem güncellendi.";
            if (sonuc.OlusturulanStokKartiSayisi > 0) mesaj += $" {sonuc.OlusturulanStokKartiSayisi} stok kartı oluşturuldu.";
            if (sonuc.AtlananStokKartiSayisi > 0) mesaj += $" {sonuc.AtlananStokKartiSayisi} zaten mevcut.";
            if (sonuc.OlusturulanStokHareketSayisi > 0) mesaj += $" {sonuc.OlusturulanStokHareketSayisi} stok hareketi.";
            if (sonuc.OlusturulanGiderKayitSayisi > 0) mesaj += $" {sonuc.OlusturulanGiderKayitSayisi} gider kaydı (770.99.999).";

            ToastService.ShowSuccess(mesaj);
            foreach (var hata in sonuc.Hatalar.Take(3)) ToastService.ShowWarning(hata);

            degistirilmisKalemler.Clear();
            seciliKalemler.Clear();
            topluKalemTipi = "";
            topluAltTipi = "";
            await YenileAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isKaydediliyor = false;
            StateHasChanged();
        }
    }

    private async Task TumunuKaydet()
    {
        if (!degistirilmisKalemler.Any()) return;

        isKaydediliyor = true;
        StateHasChanged();

        try
        {
            var degistirilmisler = GetDegistirilmisKalemlerVeTekrarlari();

            if (stokKartiOlustur)
            {
                var sonuc = await FaturaService.UpdateFaturaKalemleriVeStokKartiOlusturAsync(degistirilmisler, true);
                var mesaj = $"{sonuc.GuncellenenKalemSayisi} kalem güncellendi.";
                if (sonuc.OlusturulanStokKartiSayisi > 0) mesaj += $" {sonuc.OlusturulanStokKartiSayisi} stok kartı oluşturuldu.";
                if (sonuc.OlusturulanStokHareketSayisi > 0) mesaj += $" {sonuc.OlusturulanStokHareketSayisi} stok hareketi.";
                if (sonuc.OlusturulanGiderKayitSayisi > 0) mesaj += $" {sonuc.OlusturulanGiderKayitSayisi} gider kaydı (770.99.999).";
                ToastService.ShowSuccess(mesaj);
                foreach (var hata in sonuc.Hatalar.Take(3)) ToastService.ShowWarning(hata);
            }
            else
            {
                await FaturaService.UpdateFaturaKalemleriAsync(degistirilmisler);
                ToastService.ShowSuccess($"{degistirilmisKalemler.Count} kalem güncellendi.");
            }

            degistirilmisKalemler.Clear();
            await YenileAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isKaydediliyor = false;
            StateHasChanged();
        }
    }

    private string GetKalemTipiAdi(FaturaKalemTipi tip) => tip switch
    {
        FaturaKalemTipi.Hizmet => "Hizmet", FaturaKalemTipi.Mal => "Mal", FaturaKalemTipi.Demirbas => "Demirbaş",
        FaturaKalemTipi.Arac => "Araç", FaturaKalemTipi.Servis => "Servis", FaturaKalemTipi.Diger => "Diğer", _ => tip.ToString()
    };

    private IEnumerable<FaturaKalemAltTipi> GetAltTipler(FaturaKalemTipi tip) => tip switch
    {
        FaturaKalemTipi.Hizmet => new[] { FaturaKalemAltTipi.TasimaHizmeti, FaturaKalemAltTipi.KiralamaHizmeti, FaturaKalemAltTipi.DanismanlikHizmeti },
        FaturaKalemTipi.Mal => new[] { FaturaKalemAltTipi.TicariMal, FaturaKalemAltTipi.YedekParca, FaturaKalemAltTipi.SarfMalzeme },
        FaturaKalemTipi.Demirbas => new[] { FaturaKalemAltTipi.AracDemirbas, FaturaKalemAltTipi.OfisEkipmani, FaturaKalemAltTipi.MakinaTechizat },
        FaturaKalemTipi.Arac => new[] { FaturaKalemAltTipi.AracSatis, FaturaKalemAltTipi.AracAlis },
        FaturaKalemTipi.Servis => new[] { FaturaKalemAltTipi.BakimOnarim, FaturaKalemAltTipi.Kasko, FaturaKalemAltTipi.Sigorta, FaturaKalemAltTipi.Muayene },
        _ => Array.Empty<FaturaKalemAltTipi>()
    };

    private string GetAltTipAdi(FaturaKalemAltTipi altTip) => altTip switch
    {
        FaturaKalemAltTipi.TasimaHizmeti => "Taşıma", FaturaKalemAltTipi.KiralamaHizmeti => "Kiralama",
        FaturaKalemAltTipi.DanismanlikHizmeti => "Danışmanlık", FaturaKalemAltTipi.TicariMal => "Ticari Mal",
        FaturaKalemAltTipi.YedekParca => "Yedek Parça", FaturaKalemAltTipi.SarfMalzeme => "Sarf Malzeme",
        FaturaKalemAltTipi.AracDemirbas => "Araç", FaturaKalemAltTipi.OfisEkipmani => "Ofis",
        FaturaKalemAltTipi.MakinaTechizat => "Makine", FaturaKalemAltTipi.AracSatis => "Satış",
        FaturaKalemAltTipi.AracAlis => "Alış", FaturaKalemAltTipi.BakimOnarim => "Bakım/Onarım",
        FaturaKalemAltTipi.Kasko => "Kasko", FaturaKalemAltTipi.Sigorta => "Sigorta", FaturaKalemAltTipi.Muayene => "Muayene",
        _ => altTip.ToString()
    };

    private string TruncateText(string? text, int maxLength) => string.IsNullOrEmpty(text) ? "" : text.Length <= maxLength ? text : text.Substring(0, maxLength) + "...";
    private string FormatPara(decimal tutar) => tutar.ToString("N2", new System.Globalization.CultureInfo("tr-TR"));

    private List<FaturaKalem> GetSeciliKalemlerVeTekrarlari()
    {
        var secilenler = eslesmemisKalemler.Where(k => seciliKalemler.Contains(k.Id)).ToList();
        return GetKalemlerVeTekrarlari(secilenler);
    }

    private List<FaturaKalem> GetDegistirilmisKalemlerVeTekrarlari()
    {
        var degistirilenler = eslesmemisKalemler.Where(k => degistirilmisKalemler.Contains(k.Id)).ToList();
        return GetKalemlerVeTekrarlari(degistirilenler);
    }

    private List<FaturaKalem> GetKalemlerVeTekrarlari(List<FaturaKalem> kaynakKalemler)
    {
        if (!kaynakKalemler.Any())
            return new List<FaturaKalem>();

        var sonuc = new Dictionary<int, FaturaKalem>();

        foreach (var secilen in kaynakKalemler)
        {
            var ayniKalemler = eslesmemisKalemler.Where(k =>
                NormalizeMatchValue(k.Aciklama) == NormalizeMatchValue(secilen.Aciklama) &&
                NormalizeMatchValue(k.UrunKodu) == NormalizeMatchValue(secilen.UrunKodu));

            foreach (var kalem in ayniKalemler)
                sonuc[kalem.Id] = kalem;
        }

        return sonuc.Values.ToList();
    }

    private static string NormalizeMatchValue(string? value) => string.IsNullOrWhiteSpace(value) ? string.Empty : value.Trim().ToLowerInvariant();

    private string GetStokKoduInputValue(FaturaKalem kalem)
    {
        if (string.IsNullOrWhiteSpace(kalem.UrunKodu))
            return string.Empty;

        var stok = stokKartlari.FirstOrDefault(s => string.Equals(s.StokKodu, kalem.UrunKodu, StringComparison.OrdinalIgnoreCase));
        return stok == null ? kalem.UrunKodu : GetStokKoduOptionValue(stok);
    }

    private static string GetStokKoduOptionValue(StokKarti stok) => $"{stok.StokKodu} | {stok.StokAdi}";
}
