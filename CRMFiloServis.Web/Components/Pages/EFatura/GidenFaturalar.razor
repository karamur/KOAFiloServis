@page "/efatura/giden"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@inject IFaturaService FaturaService
@inject ICariService CariService
@inject IBankaKasaHareketService BankaKasaService
@inject IFirmaService FirmaService
@inject IMuhasebeService MuhasebeService
@inject IToastService ToastService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Kesilen Faturalar</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-file-earmark-arrow-up text-success me-2"></i>Kesilen Faturalar (Giden)</h3>
        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="YeniFaturaAc">
                <i class="bi bi-plus-lg me-1"></i>Yeni Fatura
            </button>
            <button class="btn btn-outline-info" @onclick="SablonIndir" title="Excel Sablon Indir">
                <i class="bi bi-download"></i>
            </button>
            <button class="btn btn-outline-success" @onclick="ExcelImportAc" title="Excel Yukle">
                <i class="bi bi-upload"></i>
            </button>
            <button class="btn btn-success" @onclick="ExcelExport" disabled="@(!filtreliFaturalar.Any())" title="Excel Indir">
                <i class="bi bi-file-earmark-excel"></i>
            </button>
        </div>
    </div>

    <!-- Gelismis Filtreler -->
    <div class="card mb-3">
        <div class="card-header bg-primary text-white py-2">
            <i class="bi bi-funnel me-2"></i>Filtreler
        </div>
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small mb-1">Yil</label>
                    <select class="form-select form-select-sm" @bind="filtreYil" @bind:after="YilAyDegisti">
                        @for (int y = DateTime.Today.Year; y >= DateTime.Today.Year - 5; y--)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Ay</label>
                    <select class="form-select form-select-sm" @bind="filtreAy" @bind:after="YilAyDegisti">
                        <option value="0">Tum Yil</option>
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m">@GetAyAdi(m)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Baslangic</label>
                    <input type="date" class="form-control form-control-sm" @bind="filtreBaslangic" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Bitis</label>
                    <input type="date" class="form-control form-control-sm" @bind="filtreBitis" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Durum</label>
                    <select class="form-select form-select-sm" @bind="filtreDurum">
                        <option value="">Tumu</option>
                        <option value="1">Tahsil Edilmedi</option>
                        <option value="2">Kismi Tahsilat</option>
                        <option value="3">Tahsil Edildi</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Ara (Fatura/Cari)</label>
                    <input type="text" class="form-control form-control-sm" placeholder="Fatura No / Cari" @bind="aramaMetni" />
                </div>
            </div>
            <div class="row g-2 mt-1 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small mb-1">Firma</label>
                    <select class="form-select form-select-sm" @bind="filtreFirmaId">
                        <option value="0">Tum Firmalar</option>
                        @foreach (var firma in firmalar)
                        {
                            <option value="@firma.Id">@firma.FirmaAdi</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Vergi No / TC</label>
                    <input type="text" class="form-control form-control-sm" placeholder="Vergi/TC No" @bind="filtreVergiNo" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Vergi Dairesi</label>
                    <input type="text" class="form-control form-control-sm" placeholder="Vergi Dairesi" @bind="filtreVergiDairesi" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">E-Fatura Tipi</label>
                    <select class="form-select form-select-sm" @bind="filtreEFaturaTipi">
                        <option value="">Tumu</option>
                        <option value="1">E-Fatura</option>
                        <option value="2">E-Arsiv</option>
                    </select>
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button class="btn btn-primary btn-sm" @onclick="Filtrele"><i class="bi bi-search me-1"></i>Ara</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="FiltreTemizle"><i class="bi bi-x-lg me-1"></i>Temizle</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Ozet Kartlari -->
    <div class="row mb-3 g-2">
        <div class="col-6 col-md-3">
            <div class="card bg-primary text-white h-100">
                <div class="card-body py-2 text-center">
                    <small>Toplam Fatura</small>
                    <h4 class="mb-0">@filtreliFaturalar.Count</h4>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card bg-success text-white h-100">
                <div class="card-body py-2 text-center">
                    <small>Toplam Tutar</small>
                    <h4 class="mb-0">@FormatPara(filtreliFaturalar.Sum(f => f.GenelToplam))</h4>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card bg-info text-white h-100">
                <div class="card-body py-2 text-center">
                    <small>Tahsil Edilen</small>
                    <h4 class="mb-0">@FormatPara(filtreliFaturalar.Sum(f => f.OdenenTutar))</h4>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card bg-warning text-dark h-100">
                <div class="card-body py-2 text-center">
                    <small>Tahsil Bekleyen</small>
                    <h4 class="mb-0">@FormatPara(filtreliFaturalar.Sum(f => f.KalanTutar))</h4>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Fatura No</th>
                                <th>Tarih</th>
                                <th>Cari</th>
                                <th>Vergi No</th>
                                <th>Vade</th>
                                <th class="text-end">Tutar</th>
                                <th class="text-end">Tahsil</th>
                                <th class="text-end">Kalan</th>
                                <th class="text-center">Durum</th>
                                <th class="text-center">Islem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var fatura in filtreliFaturalar)
                            {
                                var vadeGecmis = fatura.VadeTarihi.HasValue && fatura.VadeTarihi.Value < DateTime.Today && fatura.KalanTutar > 0;
                                <tr class="@(vadeGecmis ? "table-warning" : "")" @ondblclick="() => FaturaDuzenle(fatura)" style="cursor: pointer;">
                                    <td>
                                        <strong>@fatura.FaturaNo</strong>
                                        <span class="badge @(fatura.EFaturaTipi == EFaturaTipi.EFatura ? "bg-primary" : "bg-secondary") ms-1">
                                            @(fatura.EFaturaTipi == EFaturaTipi.EFatura ? "E-F" : "E-A")
                                        </span>
                                    </td>
                                    <td>@fatura.FaturaTarihi.ToString("dd.MM.yyyy")</td>
                                    <td>@fatura.Cari?.Unvan</td>
                                    <td><small>@fatura.Cari?.VergiNo</small></td>
                                    <td>
                                        @if (fatura.VadeTarihi.HasValue)
                                        {
                                            <span class="@(vadeGecmis ? "text-danger fw-bold" : "")">
                                                @fatura.VadeTarihi.Value.ToString("dd.MM.yyyy")
                                            </span>
                                        }
                                    </td>
                                    <td class="text-end">@FormatPara(fatura.GenelToplam)</td>
                                    <td class="text-end text-success">@FormatPara(fatura.OdenenTutar)</td>
                                    <td class="text-end text-danger"><strong>@FormatPara(fatura.KalanTutar)</strong></td>
                                    <td class="text-center">
                                        <span class="badge @GetDurumClass(fatura.Durum)">@GetDurumAdi(fatura.Durum)</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            @if (fatura.KalanTutar > 0)
                                            {
                                                <button class="btn btn-success" @onclick="() => TahsilatYapAc(fatura)" title="Tahsilat Yap">
                                                    <i class="bi bi-cash-coin"></i>
                                                </button>
                                            }
                                            <button class="btn btn-outline-primary" @onclick="() => FaturaDetayAc(fatura)" title="Detay">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button class="btn btn-outline-secondary" @onclick="() => FaturaDuzenle(fatura)" title="Duzenle">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-outline-danger" @onclick="() => FaturaSilOnay(fatura)" title="Sil">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<!-- Yeni/Duzenle Fatura Modal -->
@if (showFaturaModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editFatura.Id > 0 ? "Fatura Duzenle" : "Yeni Fatura")</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Fatura No *</label>
                                <input type="text" class="form-control" @bind="editFatura.FaturaNo" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Fatura Tarihi *</label>
                                <input type="date" class="form-control" @bind="editFatura.FaturaTarihi" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Vade Tarihi</label>
                                <input type="date" class="form-control" @bind="editFatura.VadeTarihi" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-5">
                            <div class="mb-3">
                                <label class="form-label">Cari * <button class="btn btn-sm btn-outline-primary ms-2" @onclick="YeniCariAc"><i class="bi bi-plus"></i> Yeni</button></label>
                                <select class="form-select" @bind="editFatura.CariId">
                                    <option value="0">Secin...</option>
                                    @foreach (var cari in cariler.Where(c => c.CariTipi == CariTipi.Musteri || c.CariTipi == CariTipi.MusteriTedarikci))
                                    {
                                        <option value="@cari.Id">@cari.Unvan</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">E-Fatura Tipi</label>
                                <select class="form-select" @bind="editFatura.EFaturaTipi">
                                    <option value="@EFaturaTipi.EFatura">E-Fatura</option>
                                    <option value="@EFaturaTipi.EArsiv">E-Arsiv</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Durum</label>
                                <select class="form-select" @bind="editFatura.Durum">
                                    <option value="@FaturaDurum.Beklemede">Beklemede</option>
                                    <option value="@FaturaDurum.KismiOdendi">Kismi Tahsilat</option>
                                    <option value="@FaturaDurum.Odendi">Tahsil Edildi</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Ara Toplam</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" @bind="editFatura.AraToplam" step="0.01" />
                                    <span class="input-group-text">?</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">KDV Tutar</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" @bind="editFatura.KdvTutar" step="0.01" />
                                    <span class="input-group-text">?</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Genel Toplam *</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" @bind="editFatura.GenelToplam" step="0.01" />
                                    <span class="input-group-text">?</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">ETTN No</label>
                                <input type="text" class="form-control" @bind="editFatura.EttnNo" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Aciklama</label>
                                <input type="text" class="form-control" @bind="editFatura.Aciklama" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button type="button" class="btn btn-primary" @onclick="FaturaKaydet">Kaydet</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Yeni Cari Modal -->
@if (showCariModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-person-plus me-2"></i>Yeni Musteri Ekle</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showCariModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Unvan / Ad Soyad *</label>
                            <input type="text" class="form-control" @bind="yeniCari.Unvan" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Vergi No</label>
                            <input type="text" class="form-control" @bind="yeniCari.VergiNo" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">TC Kimlik No</label>
                            <input type="text" class="form-control" @bind="yeniCari.TcKimlikNo" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Vergi Dairesi</label>
                            <input type="text" class="form-control" @bind="yeniCari.VergiDairesi" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Telefon</label>
                            <input type="text" class="form-control" @bind="yeniCari.Telefon" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" @bind="yeniCari.Email" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Adres</label>
                            <textarea class="form-control" rows="2" @bind="yeniCari.Adres"></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Muhasebe Hesabi</label>
                            <select class="form-select" @bind="secilenHesapId">
                                <option value="0">-- Hesap Sec veya Otomatik Olustur --</option>
                                @foreach (var hesap in musteriHesaplari)
                                {
                                    <option value="@hesap.Id">@hesap.HesapKodu - @hesap.HesapAdi</option>
                                }
                            </select>
                            <small class="text-muted">Bos birakirsaniz 120.xxx altinda otomatik hesap olusturulur</small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showCariModal = false">Iptal</button>
                    <button type="button" class="btn btn-success" @onclick="CariKaydet" disabled="@isSavingCari">
                        @if (isSavingCari)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Hesap Olusturma Onay Modal -->
@if (showHesapOnayModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title"><i class="bi bi-question-circle me-2"></i>Hesap Olustur</h5>
                </div>
                <div class="modal-body">
                    <p>Musteri icin muhasebe hesabi olusturulsun mu?</p>
                    <p class="mb-0"><strong>@yeniHesapKodu</strong> - @yeniCari.Unvan</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="HesapOlusturmaReddet">Hayir</button>
                    <button type="button" class="btn btn-primary" @onclick="HesapOlusturmaOnayla">Evet, Olustur</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Silme Onay Modal -->
@if (showSilModal && silinecekFatura != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Fatura Sil</h5>
                </div>
                <div class="modal-body">
                    <p>Bu faturayi silmek istediginize emin misiniz?</p>
                    <p class="mb-0"><strong>@silinecekFatura.FaturaNo</strong> - @silinecekFatura.Cari?.Unvan</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showSilModal = false">Iptal</button>
                    <button type="button" class="btn btn-danger" @onclick="FaturaSil">Sil</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Tahsilat Modal -->
@if (showTahsilatModal && tahsilatFatura != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-cash-coin me-2"></i>Tahsilat Yap</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info py-2">
                        <strong>@tahsilatFatura.FaturaNo</strong> - @tahsilatFatura.Cari?.Unvan<br/>
                        <span class="text-danger">Kalan: @FormatPara(tahsilatFatura.KalanTutar)</span>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Tahsilat Tarihi *</label>
                            <input type="date" class="form-control" @bind="tahsilatTarihi" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Tahsilat Tutari *</label>
                            <div class="input-group">
                                <input type="number" class="form-control" @bind="tahsilatTutar" step="0.01" />
                                <span class="input-group-text">?</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Hesap *</label>
                            <select class="form-select" @bind="tahsilatHesapId">
                                <option value="0">Secin...</option>
                                @foreach (var hesap in bankaHesaplari)
                                {
                                    <option value="@hesap.Id">@hesap.HesapAdi</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Aciklama</label>
                            <input type="text" class="form-control" @bind="tahsilatAciklama" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button type="button" class="btn btn-success" @onclick="TahsilatKaydetAsync">
                        <i class="bi bi-check-lg me-1"></i>Tahsilati Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Detay Modal -->
@if (showDetayModal && detayFatura != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-receipt me-2"></i>Fatura Detayi</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-borderless table-sm">
                                <tr><th width="120">Fatura No:</th><td><strong>@detayFatura.FaturaNo</strong></td></tr>
                                <tr><th>Tarih:</th><td>@detayFatura.FaturaTarihi.ToString("dd.MM.yyyy")</td></tr>
                                <tr><th>Vade:</th><td>@detayFatura.VadeTarihi?.ToString("dd.MM.yyyy")</td></tr>
                                <tr><th>Cari:</th><td>@detayFatura.Cari?.Unvan</td></tr>
                                <tr><th>Vergi No:</th><td>@detayFatura.Cari?.VergiNo</td></tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-borderless table-sm">
                                <tr><th>Ara Toplam:</th><td class="text-end">@FormatPara(detayFatura.AraToplam)</td></tr>
                                <tr><th>KDV:</th><td class="text-end">@FormatPara(detayFatura.KdvTutar)</td></tr>
                                <tr><th>Genel Toplam:</th><td class="text-end"><strong class="text-success fs-5">@FormatPara(detayFatura.GenelToplam)</strong></td></tr>
                                <tr><th>Tahsil Edilen:</th><td class="text-end text-info">@FormatPara(detayFatura.OdenenTutar)</td></tr>
                                <tr><th>Kalan:</th><td class="text-end text-danger"><strong>@FormatPara(detayFatura.KalanTutar)</strong></td></tr>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Import Modal -->
@if (showImportModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-file-earmark-excel me-2"></i>Excel'den Fatura Yukle</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info py-2">
                        <i class="bi bi-info-circle me-1"></i>
                        Sablon dosyasini indirip doldurduktan sonra yukleyin.
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">E-Fatura Tipi *</label>
                            <select class="form-select" @bind="importEFaturaTipi">
                                <option value="1">E-Fatura</option>
                                <option value="2">E-Arsiv Fatura</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Excel Dosyasi *</label>
                            <InputFile class="form-control" OnChange="DosyaSecildi" accept=".xlsx,.xls" />
                        </div>
                    </div>
                    @if (importResult != null)
                    {
                        <div class="row g-2 mb-3">
                            <div class="col-4">
                                <div class="card bg-success text-white text-center py-2">
                                    <h4 class="mb-0">@importResult.ImportedCount</h4>
                                    <small>Aktarilan</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="card bg-warning text-dark text-center py-2">
                                    <h4 class="mb-0">@importResult.SkippedCount</h4>
                                    <small>Atlanan</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="card bg-danger text-white text-center py-2">
                                    <h4 class="mb-0">@importResult.ErrorCount</h4>
                                    <small>Hata</small>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-info" @onclick="SablonIndir">
                        <i class="bi bi-download me-1"></i>Sablon Indir
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Kapat</button>
                    <button type="button" class="btn btn-primary" @onclick="ImportYap" disabled="@(importFile == null || isImporting)">
                        @if (isImporting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Yukle
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Fatura> faturalar = new();
    private List<Fatura> filtreliFaturalar = new();
    private List<Cari> cariler = new();
    private List<BankaHesap> bankaHesaplari = new();
    private List<Firma> firmalar = new();
    private List<MuhasebeHesap> musteriHesaplari = new();
    private bool isLoading = false;

    // Filtreler
    private DateTime? filtreBaslangic;
    private DateTime? filtreBitis;
    private string filtreEFaturaTipi = "";
    private string filtreDurum = "";
    private string aramaMetni = "";
    private int filtreFirmaId = 0;
    private string filtreVergiNo = "";
    private string filtreVergiDairesi = "";
    private int filtreYil = DateTime.Today.Year;
    private int filtreAy = DateTime.Today.Month;

    // Modal state
    private bool showFaturaModal = false;
    private bool showImportModal = false;
    private bool showDetayModal = false;
    private bool showTahsilatModal = false;
    private bool showCariModal = false;
    private bool showHesapOnayModal = false;
    private bool showSilModal = false;

    // Fatura
    private Fatura editFatura = new();
    private Fatura? detayFatura;
    private Fatura? silinecekFatura;

    // Tahsilat
    private Fatura? tahsilatFatura;
    private DateTime tahsilatTarihi = DateTime.Today;
    private decimal tahsilatTutar;
    private int tahsilatHesapId;
    private string tahsilatAciklama = "";

    // Yeni Cari
    private Cari yeniCari = new();
    private int secilenHesapId = 0;
    private bool isSavingCari = false;
    private string yeniHesapKodu = "";
    private bool hesapOlusturulacakMi = false;

    // Import
    private IBrowserFile? importFile;
    private EFaturaImportResult? importResult;
    private bool isImporting = false;
    private int importEFaturaTipi = 1;

    protected override async Task OnInitializedAsync()
    {
        cariler = await CariService.GetAllAsync();
        bankaHesaplari = await BankaKasaService.GetAktifHesaplarAsync();
        firmalar = await FirmaService.GetAllAsync();
        await LoadMusteriHesaplariAsync();
        YilAyDegisti();
        await YenileAsync();
    }

    private async Task LoadMusteriHesaplariAsync()
    {
        var tumHesaplar = await MuhasebeService.GetHesapPlaniAsync();
        musteriHesaplari = tumHesaplar.Where(h => h.HesapKodu.StartsWith("120")).ToList();
    }

    private async Task YenileAsync()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            faturalar = await FaturaService.GetByYonAsync(FaturaYonu.Giden);
            Filtrele();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void YilAyDegisti()
    {
        if (filtreAy > 0)
        {
            filtreBaslangic = new DateTime(filtreYil, filtreAy, 1);
            filtreBitis = filtreBaslangic.Value.AddMonths(1).AddDays(-1);
        }
        else
        {
            filtreBaslangic = new DateTime(filtreYil, 1, 1);
            filtreBitis = new DateTime(filtreYil, 12, 31);
        }
    }

    private void Filtrele()
    {
        var filtered = faturalar.AsEnumerable();
        
        if (filtreBaslangic.HasValue)
            filtered = filtered.Where(f => f.FaturaTarihi >= filtreBaslangic.Value);
        
        if (filtreBitis.HasValue)
            filtered = filtered.Where(f => f.FaturaTarihi <= filtreBitis.Value);
        
        if (!string.IsNullOrEmpty(filtreEFaturaTipi) && int.TryParse(filtreEFaturaTipi, out var efTip))
            filtered = filtered.Where(f => (int)f.EFaturaTipi == efTip);
        
        if (!string.IsNullOrEmpty(filtreDurum) && int.TryParse(filtreDurum, out var durum))
            filtered = filtered.Where(f => (int)f.Durum == durum);
        
        if (filtreFirmaId > 0)
            filtered = filtered.Where(f => f.FirmaId == filtreFirmaId || (f.Cari != null && f.Cari.FirmaId == filtreFirmaId));
        
        if (!string.IsNullOrEmpty(aramaMetni))
            filtered = filtered.Where(f => 
                f.FaturaNo.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ||
                (f.Cari?.Unvan?.Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ?? false));

        if (!string.IsNullOrEmpty(filtreVergiNo))
            filtered = filtered.Where(f =>
                (f.Cari?.VergiNo?.Contains(filtreVergiNo, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (f.Cari?.TcKimlikNo?.Contains(filtreVergiNo, StringComparison.OrdinalIgnoreCase) ?? false));

        if (!string.IsNullOrEmpty(filtreVergiDairesi))
            filtered = filtered.Where(f =>
                f.Cari?.VergiDairesi?.Contains(filtreVergiDairesi, StringComparison.OrdinalIgnoreCase) ?? false);
        
        filtreliFaturalar = filtered
            .OrderByDescending(f => f.FaturaTarihi)
            .ThenByDescending(f => f.FaturaNo)
            .ToList();
        StateHasChanged();
    }

    private void FiltreTemizle()
    {
        filtreYil = DateTime.Today.Year;
        filtreAy = DateTime.Today.Month;
        filtreEFaturaTipi = "";
        filtreDurum = "";
        aramaMetni = "";
        filtreFirmaId = 0;
        filtreVergiNo = "";
        filtreVergiDairesi = "";
        YilAyDegisti();
        Filtrele();
    }

    private void YeniFaturaAc()
    {
        editFatura = new Fatura
        {
            FaturaTarihi = DateTime.Today,
            FaturaYonu = FaturaYonu.Giden,
            FaturaTipi = FaturaTipi.SatisFaturasi,
            EFaturaTipi = EFaturaTipi.EFatura,
            Durum = FaturaDurum.Beklemede
        };
        showFaturaModal = true;
    }

    private void FaturaDuzenle(Fatura fatura)
    {
        editFatura = new Fatura
        {
            Id = fatura.Id,
            FaturaNo = fatura.FaturaNo,
            FaturaTarihi = fatura.FaturaTarihi,
            VadeTarihi = fatura.VadeTarihi,
            CariId = fatura.CariId,
            EFaturaTipi = fatura.EFaturaTipi,
            AraToplam = fatura.AraToplam,
            KdvTutar = fatura.KdvTutar,
            GenelToplam = fatura.GenelToplam,
            EttnNo = fatura.EttnNo,
            Aciklama = fatura.Aciklama,
            Durum = fatura.Durum,
            FaturaYonu = FaturaYonu.Giden,
            FaturaTipi = FaturaTipi.SatisFaturasi
        };
        showFaturaModal = true;
    }

    private void FaturaDetayAc(Fatura fatura)
    {
        detayFatura = fatura;
        showDetayModal = true;
    }

    private void TahsilatYapAc(Fatura fatura)
    {
        tahsilatFatura = fatura;
        tahsilatTutar = fatura.KalanTutar;
        tahsilatTarihi = DateTime.Today;
        tahsilatHesapId = bankaHesaplari.FirstOrDefault()?.Id ?? 0;
        tahsilatAciklama = $"{fatura.FaturaNo} fatura tahsilati";
        showTahsilatModal = true;
    }

    private void FaturaSilOnay(Fatura fatura)
    {
        silinecekFatura = fatura;
        showSilModal = true;
    }

    private async Task FaturaSil()
    {
        if (silinecekFatura == null) return;

        try
        {
            await FaturaService.DeleteAsync(silinecekFatura.Id);
            ToastService.ShowSuccess("Fatura silindi.");
            showSilModal = false;
            silinecekFatura = null;
            await YenileAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private async Task YeniCariAc()
    {
        yeniCari = new Cari
        {
            CariTipi = CariTipi.Musteri,
            Aktif = true
        };
        secilenHesapId = 0;
        await LoadMusteriHesaplariAsync();
        showCariModal = true;
    }

    private async Task CariKaydet()
    {
        if (string.IsNullOrWhiteSpace(yeniCari.Unvan))
        {
            ToastService.ShowWarning("Unvan zorunludur!");
            return;
        }

        isSavingCari = true;
        StateHasChanged();

        try
        {
            // Hesap secilmemisse otomatik olusturma sor
            if (secilenHesapId == 0)
            {
                // Yeni hesap kodu olustur
                var sonHesap = musteriHesaplari
                    .Where(h => h.HesapKodu.StartsWith("120.") && h.HesapKodu.Length > 4)
                    .OrderByDescending(h => h.HesapKodu)
                    .FirstOrDefault();

                if (sonHesap != null)
                {
                    var sonNumara = int.Parse(sonHesap.HesapKodu.Split('.').Last());
                    yeniHesapKodu = $"120.{(sonNumara + 1):D3}";
                }
                else
                {
                    yeniHesapKodu = "120.001";
                }

                showCariModal = false;
                showHesapOnayModal = true;
                isSavingCari = false;
                return;
            }

            // Hesap secilmis, direkt kaydet
            yeniCari.MuhasebeHesapId = secilenHesapId;
            await CariKaydetDevam();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
            isSavingCari = false;
        }
    }

    private async Task HesapOlusturmaOnayla()
    {
        hesapOlusturulacakMi = true;
        showHesapOnayModal = false;
        isSavingCari = true;
        StateHasChanged();

        try
        {
            // Muhasebe hesabi olustur
            var yeniHesap = new MuhasebeHesap
            {
                HesapKodu = yeniHesapKodu,
                HesapAdi = yeniCari.Unvan,
                HesapTuru = HesapTuru.Aktif,
                HesapGrubu = HesapGrubu.DonenVarliklar,
                Aktif = true
            };
            var olusturulanHesap = await MuhasebeService.CreateHesapAsync(yeniHesap);
            yeniCari.MuhasebeHesapId = olusturulanHesap.Id;

            await CariKaydetDevam();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
            isSavingCari = false;
        }
    }

    private async Task HesapOlusturmaReddet()
    {
        hesapOlusturulacakMi = false;
        showHesapOnayModal = false;
        isSavingCari = true;
        StateHasChanged();

        try
        {
            yeniCari.MuhasebeHesapId = null;
            await CariKaydetDevam();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
            isSavingCari = false;
        }
    }

    private async Task CariKaydetDevam()
    {
        // Cari kodu olustur
        yeniCari.CariKodu = $"M{DateTime.Now:yyyyMMddHHmmss}";
        
        var kaydedilen = await CariService.CreateAsync(yeniCari);
        cariler = await CariService.GetAllAsync();
        editFatura.CariId = kaydedilen.Id;

        ToastService.ShowSuccess($"Musteri eklendi: {yeniCari.Unvan}");
        showCariModal = false;
        isSavingCari = false;
        StateHasChanged();
    }

    private async Task FaturaKaydet()
    {
        if (string.IsNullOrWhiteSpace(editFatura.FaturaNo) || editFatura.CariId <= 0 || editFatura.GenelToplam <= 0)
        {
            ToastService.ShowWarning("Zorunlu alanlari doldurun!");
            return;
        }

        try
        {
            editFatura.FaturaYonu = FaturaYonu.Giden;
            editFatura.FaturaTipi = FaturaTipi.SatisFaturasi;
            editFatura.FaturaTarihi = DateTime.SpecifyKind(editFatura.FaturaTarihi, DateTimeKind.Utc);
            if (editFatura.VadeTarihi.HasValue)
                editFatura.VadeTarihi = DateTime.SpecifyKind(editFatura.VadeTarihi.Value, DateTimeKind.Utc);

            if (editFatura.Id > 0)
                await FaturaService.UpdateAsync(editFatura);
            else
                await FaturaService.CreateAsync(editFatura);

            ToastService.ShowSuccess("Fatura kaydedildi.");
            ModalKapat();
            await YenileAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private async Task TahsilatKaydetAsync()
    {
        if (tahsilatFatura == null || tahsilatHesapId <= 0 || tahsilatTutar <= 0)
        {
            ToastService.ShowWarning("Lutfen tum alanlari doldurun!");
            return;
        }

        try
        {
            var hareket = new BankaKasaHareket
            {
                BankaHesapId = tahsilatHesapId,
                IslemTarihi = DateTime.SpecifyKind(tahsilatTarihi, DateTimeKind.Utc),
                HareketTipi = HareketTipi.Giris,
                IslemKaynak = IslemKaynak.FaturaTahsilat,
                Tutar = tahsilatTutar,
                Aciklama = tahsilatAciklama,
                CariId = tahsilatFatura.CariId
            };
            await BankaKasaService.CreateAsync(hareket);
            await FaturaService.UpdateOdenenTutarAsync(tahsilatFatura.Id);

            ToastService.ShowSuccess("Tahsilat kaydedildi.");
            ModalKapat();
            await YenileAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private void ExcelImportAc()
    {
        importFile = null;
        importResult = null;
        showImportModal = true;
    }

    private void DosyaSecildi(InputFileChangeEventArgs e)
    {
        importFile = e.File;
        importResult = null;
    }

    private async Task ImportYap()
    {
        if (importFile == null) return;

        isImporting = true;
        importResult = null;
        StateHasChanged();

        try
        {
            using var stream = new MemoryStream();
            await importFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(stream);
            var fileContent = stream.ToArray();

            var firmaId = filtreFirmaId > 0 ? filtreFirmaId : (int?)null;
            var eFaturaTip = (EFaturaTipi)importEFaturaTipi;
            importResult = await FaturaService.ImportFromExcelAsync(fileContent, FaturaYonu.Giden, firmaId, eFaturaTip);

            if (importResult.Success)
            {
                ToastService.ShowSuccess($"{importResult.ImportedCount} fatura aktarildi.");
                await YenileAsync();
            }
        }
        catch (Exception ex)
        {
            importResult = new EFaturaImportResult { Success = false, Errors = new List<string> { ex.Message } };
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isImporting = false;
            StateHasChanged();
        }
    }

    private async Task SablonIndir()
    {
        try
        {
            var bytes = await FaturaService.GetExcelSablonAsync(FaturaYonu.Giden);
            await JS.InvokeVoidAsync("downloadFileFromBase64", "kesilen_fatura_sablon.xlsx", Convert.ToBase64String(bytes));
            ToastService.ShowSuccess("Sablon indirildi!");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private async Task ExcelExport()
    {
        if (!filtreliFaturalar.Any())
        {
            ToastService.ShowWarning("Indirilecek fatura yok!");
            return;
        }

        try
        {
            var bytes = await FaturaService.ExportToExcelAsync(filtreliFaturalar);
            await JS.InvokeVoidAsync("downloadFileFromBase64", $"kesilen_faturalar_{DateTime.Now:yyyyMMdd}.xlsx", Convert.ToBase64String(bytes));
            ToastService.ShowSuccess("Excel indirildi!");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata: " + ex.Message);
        }
    }

    private void ModalKapat()
    {
        showFaturaModal = false;
        showImportModal = false;
        showDetayModal = false;
        showTahsilatModal = false;
        showCariModal = false;
        showHesapOnayModal = false;
        showSilModal = false;
    }

    private string GetAyAdi(int ay) => ay switch
    {
        1 => "Ocak", 2 => "Subat", 3 => "Mart", 4 => "Nisan",
        5 => "Mayis", 6 => "Haziran", 7 => "Temmuz", 8 => "Agustos",
        9 => "Eylul", 10 => "Ekim", 11 => "Kasim", 12 => "Aralik",
        _ => ""
    };

    private string GetDurumAdi(FaturaDurum d) => d switch
    {
        FaturaDurum.Beklemede => "Tahsil Edilmedi",
        FaturaDurum.KismiOdendi => "Kismi Tahsilat",
        FaturaDurum.Odendi => "Tahsil Edildi",
        FaturaDurum.IptalEdildi => "Iptal",
        _ => d.ToString()
    };

    private string GetDurumClass(FaturaDurum d) => d switch
    {
        FaturaDurum.Beklemede => "bg-danger",
        FaturaDurum.KismiOdendi => "bg-warning text-dark",
        FaturaDurum.Odendi => "bg-success",
        FaturaDurum.IptalEdildi => "bg-secondary",
        _ => "bg-secondary"
    };

    private string FormatPara(decimal t) => t.ToString("N2", new System.Globalization.CultureInfo("tr-TR")) + " ?";
}
