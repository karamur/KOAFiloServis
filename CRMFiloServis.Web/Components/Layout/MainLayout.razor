@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject CRMFiloServis.Web.Services.IKullaniciService KullaniciService
@inject CRMFiloServis.Web.Services.ILisansService LisansService
@inject CRMFiloServis.Web.Services.IFirmaService FirmaService
@inject CRMFiloServis.Web.Services.AppAuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation

<AuthorizeView>
    <Authorized>
        @if (!isInitialized)
        {
            <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Yukleniyor...</span>
                </div>
            </div>
        }
        else if (!lisansGecerli)
        {
            <div class="d-flex justify-content-center align-items-center flex-column" style="height: 100vh; background: #f8f9fa;">
                <div class="card shadow-lg" style="max-width: 500px;">
                    <div class="card-body text-center p-5">
                        <i class="bi bi-shield-exclamation text-danger" style="font-size: 4rem;"></i>
                        <h3 class="mt-3 text-danger">Lisans Gecersiz</h3>
                        <p class="text-muted">@lisansHataMesaji</p>
                        <hr />
                        <div class="alert alert-warning">
                            <strong>Makine Kodu:</strong><br/>
                            <code class="fs-5">@makineKodu</code>
                        </div>
                        <p class="small text-muted">Bu kodu yetkili kisiye gondererek lisans alabilirsiniz.</p>
                        <div class="d-grid gap-2">
                            <a href="/ayarlar/lisans" class="btn btn-primary">
                                <i class="bi bi-key me-2"></i>Lisans Gir
                            </a>
                            <button type="button" class="btn btn-outline-danger" onclick="location.href='/login'">
                                <i class="bi bi-box-arrow-right me-2"></i>Cikis Yap
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="page">
                <div class="sidebar">
                    <NavMenu />
                </div>

                <main>
                    <div class="top-row px-4 d-flex justify-content-between align-items-center bg-white border-bottom">
                        <div class="d-flex align-items-center gap-3">
                            <div class="d-flex align-items-center text-muted">
                                <i class="bi bi-person-circle me-2 fs-5"></i>
                                <div>
                                    <div class="fw-bold">@aktifKullanici?.AdSoyad</div>
                                    <small class="text-muted">@aktifKullanici?.Rol?.RolAdi</small>
                                </div>
                            </div>
                            <div class="vr d-none d-md-block"></div>
                            <div class="text-muted d-none d-md-block">
                                <i class="bi bi-calendar3 me-2"></i>
                                @DateTime.Now.ToString("dd MMMM yyyy, dddd", new System.Globalization.CultureInfo("tr-TR"))
                            </div>
                            @if (kalanLisansGunu <= 30)
                            {
                                <div class="vr d-none d-md-block"></div>
                                <div class="badge bg-warning text-dark">
                                    <i class="bi bi-clock-history me-1"></i>
                                    Lisans: @kalanLisansGunu gun kaldi
                                </div>
                            }
                        </div>

                        <div class="d-flex align-items-center gap-2">
                            <CRMFiloServis.Web.Components.Shared.BildirimDropdown />

                            <div class="dropdown">
                                <button class="btn btn-outline-primary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-building me-1"></i><span class="d-none d-md-inline">@aktifFirmaAdi</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end" style="min-width: 250px;">
                                    @foreach (var firma in firmalar)
                                    {
                                        <li>
                                            <button class="dropdown-item @(firma.Id == aktifFirmaId ? "active" : "")" 
                                                    @onclick="() => FirmaSecildi(firma)">
                                                <i class="bi bi-building me-2"></i>@firma.FirmaAdi
                                                @if (firma.VarsayilanFirma)
                                                {
                                                    <i class="bi bi-star-fill text-warning ms-2"></i>
                                                }
                                            </button>
                                        </li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item text-primary" href="/ayarlar/firma">
                                            <i class="bi bi-gear me-2"></i>Firma Ayarlari
                                        </a>
                                    </li>
                                </ul>
                            </div>

                            <div class="dropdown">
                                <button class="btn btn-light btn-sm dropdown-toggle border" type="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-gear me-1"></i><span class="d-none d-md-inline">Ayarlar</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" href="/ayarlar/profil">
                                            <i class="bi bi-person me-2"></i>Profil Ayarlari
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="/ayarlar/lisans">
                                            <i class="bi bi-key me-2"></i>Lisans Bilgileri
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="/ayarlar/veritabani">
                                            <i class="bi bi-database me-2"></i>Veritabani Ayarlari
                                        </a>
                                    </li>
                                </ul>
                            </div>

                            <!-- Cikis Butonu - JavaScript ile tam sayfa yenileme -->
                            <button type="button" class="btn btn-danger btn-sm" onclick="window.location.href='/login'" title="Cikis Yap">
                                <i class="bi bi-box-arrow-right me-1"></i><span class="d-none d-md-inline">Cikis</span>
                            </button>
                        </div>
                    </div>

                    <article class="content px-4">
                        @Body
                    </article>
                </main>
            </div>

            <CRMFiloServis.Web.Components.Shared.ToastContainer />
        }
    </Authorized>
    <NotAuthorized>
        @{
            Navigation.NavigateTo("/login", true);
        }
        <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yonlendiriliyor...</span>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">X</span>
</div>

@code {
    private CRMFiloServis.Shared.Entities.Kullanici? aktifKullanici;
    private bool isInitialized = false;
    private bool lisansGecerli = false;
    private string lisansHataMesaji = "";
    private string makineKodu = "";
    private int kalanLisansGunu = 0;

    private List<CRMFiloServis.Shared.Entities.Firma> firmalar = new();
    private int aktifFirmaId;
    private string aktifFirmaAdi = "Firma";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var currentUri = Navigation.Uri;
            if (currentUri.Contains("/login") || currentUri.Contains("/ayarlar/lisans"))
            {
                isInitialized = true;
                return;
            }

            aktifKullanici = AuthProvider.GetAktifKullanici();
            isInitialized = true;

            if (aktifKullanici == null)
            {
                return;
            }

            await LisansKontrol();

            if (lisansGecerli)
            {
                await FirmalariYukle();
            }
        }
        catch (Exception)
        {
            isInitialized = true;
            aktifKullanici = null;
        }
    }

    private async Task LisansKontrol()
    {
        try
        {
            var lisans = await LisansService.GetAktifLisansAsync();
            makineKodu = await LisansService.GetMakineKoduAsync();

            if (lisans == null)
            {
                lisansGecerli = false;
                lisansHataMesaji = "Lisans bulunamadi. Lutfen gecerli bir lisans anahtari girin.";
                return;
            }

            if (DateTime.UtcNow > lisans.BitisTarihi)
            {
                lisansGecerli = false;
                lisansHataMesaji = $"Lisans suresi {lisans.BitisTarihi:dd.MM.yyyy} tarihinde dolmus.";
                return;
            }

            if (!string.IsNullOrEmpty(lisans.MakineKodu) && lisans.MakineKodu != makineKodu)
            {
                lisansGecerli = false;
                lisansHataMesaji = "Bu lisans baska bir bilgisayar icin gecerlidir.";
                return;
            }

            lisansGecerli = true;
            kalanLisansGunu = lisans.KalanGun;
        }
        catch (Exception ex)
        {
            lisansGecerli = false;
            lisansHataMesaji = $"Lisans kontrolu sirasinda hata: {ex.Message}";
        }
    }

    private async Task FirmalariYukle()
    {
        try
        {
            var aktifFirma = FirmaService.GetAktifFirma();
            aktifFirmaId = aktifFirma.FirmaId;
            aktifFirmaAdi = aktifFirma.FirmaAdi;
        }
        catch { }
    }

    private void FirmaSecildi(CRMFiloServis.Shared.Entities.Firma firma)
    {
        FirmaService.SetAktifFirma(firma.Id);
        aktifFirmaId = firma.Id;
        aktifFirmaAdi = firma.FirmaAdi;
        StateHasChanged();
        Navigation.NavigateTo(Navigation.Uri, false);
    }
}
