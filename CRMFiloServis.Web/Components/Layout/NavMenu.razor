@code {
    private bool[] expandedSections = new bool[15];
    private HashSet<string> kullaniciYetkileri = new();
    private bool yetkilerYuklendi = false;
    private bool isAdmin = false;

    protected override async Task OnInitializedAsync()
    {
        await YetkileriYukle();
    }

    private async Task YetkileriYukle()
    {
        try
        {
            var aktifKullanici = AuthProvider.GetAktifKullanici();
            if (aktifKullanici != null)
            {
                // Admin kontrolu
                isAdmin = aktifKullanici.Rol?.RolAdi == "Admin";
                
                if (!isAdmin)
                {
                    // Kullanici yetkilerini yukle
                    var yetkiler = await KullaniciService.GetKullaniciYetkileriAsync(aktifKullanici.Id);
                    kullaniciYetkileri = yetkiler.ToHashSet();
                }
                
                yetkilerYuklendi = true;
            }
        }
        catch
        {
            // Hata durumunda bos yetkiler
            kullaniciYetkileri = new HashSet<string>();
        }
    }

    private bool HasYetki(string yetkiKodu)
    {
        // Admin her seyi gorebilir
        if (isAdmin) return true;
        
        // Yetkiler henuz yuklenmediyse gosterme
        if (!yetkilerYuklendi) return false;
        
        return kullaniciYetkileri.Contains(yetkiKodu);
    }

    private bool HasMenuYetki(string menuKodu)
    {
        // Admin her seyi gorebilir
        if (isAdmin) return true;
        
        // Yetkiler henuz yuklenmediyse gosterme
        if (!yetkilerYuklendi) return false;
        
        // Ana menu yetkisi veya altindaki herhangi bir yetki varsa goster
        return kullaniciYetkileri.Contains(menuKodu) || 
               kullaniciYetkileri.Any(y => y.StartsWith(menuKodu.Replace("menu.", "") + ".") ||
                                           y.StartsWith(GetMenuPrefix(menuKodu)));
    }

    private string GetMenuPrefix(string menuKodu)
    {
        // menu.cari -> cariler, kesilenfatura, gelenfatura
        // menu.filoservis -> araclar, guzergahlar, serviscalisma vs.
        return menuKodu switch
        {
            "menu.crm" => "bildirim",
            "menu.cari" => "cari",
            "menu.filoservis" => "arac",
            "menu.muhasebe" => "muhasebe",
            "menu.personel" => "personel",
            "menu.fatura" => "fatura",
            "menu.bankakasa" => "banka",
            "menu.butce" => "butce",
            "menu.checklist" => "checklist",
            "menu.raporlar" => "rapor",
            "menu.satis" => "satis",
            "menu.ayarlar" => "firma",
            _ => ""
        };
    }

    private void ToggleSection(int index)
    {
        if (index < expandedSections.Length)
        {
            expandedSections[index] = !expandedSections[index];
        }
    }
}

