@rendermode InteractiveServer

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <a class="navbar-brand" href="">
            <i class="bi bi-truck me-2"></i>CRM Filo Servis
        </a>
    </div>
</div>

<!-- Global Arama -->
<div class="px-3 py-2">
    <CRMFiloServis.Web.Components.Shared.GlobalSearch />
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable">
    <nav class="nav flex-column">
        <!-- Ana Sayfa -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <i class="bi bi-house-door-fill me-2"></i> Ana Sayfa
            </NavLink>
        </div>
        
        <!-- Belge Uyarilari -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="belge-uyarilari">
                <i class="bi bi-exclamation-triangle-fill me-2 text-warning"></i> Belge Uyarilari
            </NavLink>
        </div>

        <!-- CARI MODULU -->
        <div class="nav-section">
            <div class="nav-section-header" @onclick="() => ToggleSection(0)" style="cursor: pointer;">
                <span><i class="bi bi-people-fill me-2"></i>CARI MODULU</span>
                <i class="bi @(expandedSections[0] ? "bi-chevron-up" : "bi-chevron-down")"></i>
            </div>
            @if (expandedSections[0])
            {
                <div class="nav-section-content">
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="cariler">
                            <i class="bi bi-person-lines-fill me-2"></i> Cariler
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="efatura/giden">
                            <i class="bi bi-file-earmark-arrow-up me-2 text-success"></i> Kesilen Faturalar
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="efatura/gelen">
                            <i class="bi bi-file-earmark-arrow-down me-2 text-danger"></i> Gelen Faturalar
                        </NavLink>
                    </div>
                </div>
            }
        </div>

        <!-- FILO SERVIS -->
        <div class="nav-section">
            <div class="nav-section-header" @onclick="() => ToggleSection(1)" style="cursor: pointer;">
                <span><i class="bi bi-truck me-2"></i>FILO SERVIS</span>
                <i class="bi @(expandedSections[1] ? "bi-chevron-up" : "bi-chevron-down")"></i>
            </div>
            @if (expandedSections[1])
            {
                <div class="nav-section-content">
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="araclar">
                            <i class="bi bi-car-front-fill me-2"></i> Araclar
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="guzergahlar">
                            <i class="bi bi-signpost-split-fill me-2"></i> Guzergahlar
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="servis-calismalari">
                            <i class="bi bi-calendar-check-fill me-2"></i> Servis Çalışmaları
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="servis-calismalari/toplu-ekle">
                            <i class="bi bi-list-check me-2"></i> Toplu Çalışma Girişi
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="masraf-kalemleri">
                            <i class="bi bi-list-task me-2"></i> Masraf Kalemleri
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="arac-masraflari">
                            <i class="bi bi-receipt me-2"></i> Araç Masrafları
                        </NavLink>
                    </div>
                </div>
            }
        </div>

        <!-- MUHASEBE -->
        <div class="nav-section">
            <div class="nav-section-header" @onclick="() => ToggleSection(7)" style="cursor: pointer;">
                <span><i class="bi bi-journal-text me-2"></i>MUHASEBE</span>
                <i class="bi @(expandedSections.Length > 7 && expandedSections[7] ? "bi-chevron-up" : "bi-chevron-down")"></i>
            </div>
            @if (expandedSections.Length > 7 && expandedSections[7])
            {
                <div class="nav-section-content">
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="muhasebe">
                            <i class="bi bi-speedometer2 me-2"></i> Muhasebe Dashboard
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="muhasebe/hesap-plani">
                            <i class="bi bi-list-nested me-2"></i> Hesap Plani
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="muhasebe/fisler">
                            <i class="bi bi-receipt me-2"></i> Muhasebe Fisleri
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="muhasebe/raporlar">
                            <i class="bi bi-file-earmark-bar-graph me-2"></i> Muhasebe Raporlari
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="muhasebe/analiz">
                            <i class="bi bi-graph-up me-2"></i> Mali Analiz
                        </NavLink>
                    </div>
                </div>
            }
        </div>

        <!-- PERSONEL YÖNETİMİ -->
        <div class="nav-section">
            <div class="nav-section-header" @onclick="() => ToggleSection(5)" style="cursor: pointer;">
                <span><i class="bi bi-people-fill me-2"></i>PERSONEL</span>
                <i class="bi @(expandedSections.Length > 5 && expandedSections[5] ? "bi-chevron-up" : "bi-chevron-down")"></i>
            </div>
            @if (expandedSections.Length > 5 && expandedSections[5])
            {
                <div class="nav-section-content">
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="personel">
                            <i class="bi bi-people me-2"></i> Personel Listesi
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="personel/maas">
                            <i class="bi bi-cash-stack me-2"></i> Maaş Yönetimi
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="personel/izin">
                            <i class="bi bi-calendar-check me-2"></i> İzin Yönetimi
                        </NavLink>
                    </div>
                </div>
            }
        </div>

        <!-- FATURA MODÜLÜ -->
        <div class="nav-section">
            <div class="nav-section-header" @onclick="() => ToggleSection(2)" style="cursor: pointer;">
                <span><i class="bi bi-receipt me-2"></i>FATURA MODÜLÜ</span>
                <i class="bi @(expandedSections[2] ? "bi-chevron-up" : "bi-chevron-down")"></i>
            </div>
            @if (expandedSections[2])
            {
                <div class="nav-section-content">
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="faturalar">
                            <i class="bi bi-file-earmark-text-fill me-2"></i> Faturalar
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="fatura-hazirlik">
                            <i class="bi bi-clipboard-check me-2"></i> Fatura Hazırlık
                        </NavLink>
                    </div>
                </div>
            }
        </div>

        <!-- BANKA / KASA -->
        <div class="nav-section">
            <div class="nav-section-header" @onclick="() => ToggleSection(3)" style="cursor: pointer;">
                <span><i class="bi bi-bank me-2"></i>BANKA / KASA</span>
                <i class="bi @(expandedSections[3] ? "bi-chevron-up" : "bi-chevron-down")"></i>
            </div>
            @if (expandedSections[3])
            {
                <div class="nav-section-content">
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="banka-hesaplari">
                            <i class="bi bi-bank2 me-2"></i> Banka Hesapları
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="banka-hareketleri">
                            <i class="bi bi-arrow-left-right me-2"></i> Hareketler
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="odeme-eslestirme">
                            <i class="bi bi-link-45deg me-2"></i> Ödeme Eşleştirme
                        </NavLink>
                    </div>
                </div>
            }
        </div>

        <!-- RAPORLAR -->
        <div class="nav-section">
            <div class="nav-section-header" @onclick="() => ToggleSection(4)" style="cursor: pointer;">
                <span><i class="bi bi-bar-chart-fill me-2"></i>RAPORLAR</span>
                <i class="bi @(expandedSections[4] ? "bi-chevron-up" : "bi-chevron-down")"></i>
            </div>
            @if (expandedSections[4])
            {
                <div class="nav-section-content">
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="butce">
                            <i class="bi bi-wallet2 me-2 text-success"></i> Bütçe Analiz
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="mali-analiz">
                            <i class="bi bi-graph-up-arrow me-2"></i> Mali Analiz
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="rapor/checklist">
                            <i class="bi bi-clipboard-check me-2"></i> Aylık Checklist
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="rapor/ozmal-arac">
                            <i class="bi bi-truck me-2"></i> Özmal Araç Raporu
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="rapor/kiralik-arac">
                            <i class="bi bi-building me-2"></i> Kiralık Araç Raporu
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="rapor/komisyon">
                            <i class="bi bi-percent me-2"></i> Komisyon Raporu
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="rapor/servis-calisma">
                            <i class="bi bi-file-earmark-bar-graph me-2"></i> Servis Raporu
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="rapor/fatura-odeme">
                            <i class="bi bi-file-earmark-text me-2"></i> Fatura Ödeme
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="rapor/arac-masraf">
                            <i class="bi bi-file-earmark-spreadsheet me-2"></i> Araç Masraf
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="raporlar/cari-ekstre">
                            <i class="bi bi-file-earmark-ruled me-2"></i> Cari Ekstre
                        </NavLink>
                    </div>
                </div>
            }
        </div>

        <!-- SATIS MODULU -->
        <div class="nav-section">
            <div class="nav-section-header" @onclick="() => ToggleSection(8)" style="cursor: pointer;">
                <span><i class="bi bi-car-front-fill me-2"></i>SATIS MODULU</span>
                <i class="bi @(expandedSections.Length > 8 && expandedSections[8] ? "bi-chevron-up" : "bi-chevron-down")"></i>
            </div>
            @if (expandedSections.Length > 8 && expandedSections[8])
            {
                <div class="nav-section-content">
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="satis">
                            <i class="bi bi-speedometer2 me-2"></i> Satis Dashboard
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="satis/ilan/yeni">
                            <i class="bi bi-plus-circle me-2"></i> Yeni Ilan
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="satis/personel">
                            <i class="bi bi-people me-2"></i> Satis Personeli
                        </NavLink>
                    </div>
                </div>
            }
        </div>

        <!-- AYARLAR -->
        <div class="nav-section">
            <div class="nav-section-header" @onclick="() => ToggleSection(6)" style="cursor: pointer;">
                <span><i class="bi bi-gear-fill me-2"></i>AYARLAR</span>
                <i class="bi @(expandedSections.Length > 6 && expandedSections[6] ? "bi-chevron-up" : "bi-chevron-down")"></i>
            </div>
            @if (expandedSections.Length > 6 && expandedSections[6])
            {
                <div class="nav-section-content">
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="ayarlar/veritabani">
                            <i class="bi bi-database-gear me-2 text-primary"></i> Veritabani Ayarlari
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="ayarlar/raporlar">
                            <i class="bi bi-file-earmark-bar-graph me-2 text-success"></i> Servis Raporlari
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="ayarlar/lisans">
                            <i class="bi bi-key me-2 text-warning"></i> Lisans Bilgileri
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="ayarlar/kullanicilar">
                            <i class="bi bi-person-badge me-2 text-info"></i> Kullanici Yonetimi
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="sistem-durumu">
                            <i class="bi bi-heart-pulse me-2"></i> Sistem Durumu
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="aktivite-log">
                            <i class="bi bi-clock-history me-2"></i> Aktivite Logu
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="yedekleme">
                            <i class="bi bi-database-fill-gear me-2"></i> Yedekleme
                        </NavLink>
                    </div>
                </div>
            }
        </div>
    </nav>
</div>

@code {
    private bool[] expandedSections = [false, false, false, false, false, false, false, false, false];

    private void ToggleSection(int index)
    {
        expandedSections[index] = !expandedSections[index];
    }
}

