# ============================================================
# 🔐 KOAFiloServis — Environment değişkenleri (örnek)
# ------------------------------------------------------------
# 1) Bu dosyayı `.env` olarak kopyalayın
# 2) Tüm değerleri kendi ortamınız için DEĞİŞTİRİN
# 3) `.env` ASLA git'e commit edilmemelidir (.gitignore'da)
# ============================================================

# ── Web ──────────────────────────────────────────────────────
WEB_PORT=8080

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=koafiloservis
POSTGRES_USER=koafilo
POSTGRES_PASSWORD=ChangeMe!2025
POSTGRES_PORT=5432

# ── JWT (en az 32 karakter, üretim için mutlaka değiştirin) ──
JWT_SECRET=please-generate-a-strong-random-secret-of-min-32-chars
JWT_ISSUER=KOAFiloServis
JWT_AUDIENCE=KOAFiloServis-Users

# ── Ollama (opsiyonel — `docker compose --profile ai up`) ────
OLLAMA_PORT=11434
