@page "/ayarlar"
@using CRMFiloServis.Mobile.Services
@inject IApiService ApiService
@inject NavigationManager Navigation

<div class="container-fluid p-3">
    <div class="d-flex align-items-center mb-4">
        <button class="btn btn-link text-dark p-0 me-3" @onclick="GeriGit">
            <i class="bi bi-arrow-left fs-4"></i>
        </button>
        <h5 class="mb-0">Ayarlar</h5>
    </div>

    @if (_kullanici != null)
    {
        <!-- Kullanıcı Bilgileri -->
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-person-circle me-2"></i> Profil Bilgileri
            </div>
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="rounded-circle bg-primary text-white p-3 me-3" style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-person-fill fs-3"></i>
                    </div>
                    <div>
                        <h6 class="mb-0">@_kullanici.AdSoyad</h6>
                        <small class="text-muted">@(_kullanici.Rol ?? "Şoför")</small>
                    </div>
                </div>
                <hr />
                <p class="mb-1"><i class="bi bi-envelope me-2 text-muted"></i> @_kullanici.Email</p>
                @if (!string.IsNullOrEmpty(_kullanici.Telefon))
                {
                    <p class="mb-0"><i class="bi bi-telephone me-2 text-muted"></i> @_kullanici.Telefon</p>
                }
            </div>
        </div>
    }

    <!-- Uygulama Ayarları -->
    <div class="card mb-4">
        <div class="card-header bg-white">
            <i class="bi bi-gear me-2 text-secondary"></i> Uygulama Ayarları
        </div>
        <div class="list-group list-group-flush">
            <div class="list-group-item d-flex justify-content-between align-items-center">
                <span><i class="bi bi-geo-alt me-2 text-success"></i> Konum Takibi</span>
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" @bind="_konumTakibiAktif" />
                </div>
            </div>
            <div class="list-group-item d-flex justify-content-between align-items-center">
                <span><i class="bi bi-bell me-2 text-warning"></i> Bildirimler</span>
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" @bind="_bildirimlerAktif" />
                </div>
            </div>
            <div class="list-group-item d-flex justify-content-between align-items-center">
                <span><i class="bi bi-moon me-2 text-info"></i> Karanlık Mod</span>
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" @bind="_karanlikMod" />
                </div>
            </div>
        </div>
    </div>

    <!-- Sunucu Ayarları -->
    <div class="card mb-4">
        <div class="card-header bg-white">
            <i class="bi bi-server me-2 text-primary"></i> Sunucu Bağlantısı
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label small text-muted">Sunucu Adresi</label>
                <input type="text" class="form-control" @bind="_sunucuAdresi" placeholder="https://api.filoservis.com" />
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-outline-secondary btn-sm" @onclick="VarsayilanSunucuyuUygula">
                    <i class="bi bi-router me-1"></i> 192.168.1.10:5190 kullan
                </button>
                <button class="btn btn-primary btn-sm" @onclick="SunucuAdresiniKaydetAsync">
                    <i class="bi bi-floppy me-1"></i> Kaydet
                </button>
                <button class="btn btn-outline-primary btn-sm" @onclick="BaglantiyiTestEtAsync">
                <i class="bi bi-wifi me-1"></i> Bağlantıyı Test Et
                </button>
            </div>
            @if (_baglantiDurumu != null)
            {
                <span class="ms-2 @(_baglantiBasarili ? "text-success" : "text-danger")">
                    <i class="bi @(_baglantiBasarili ? "bi-check-circle" : "bi-x-circle") me-1"></i>
                    @_baglantiDurumu
                </span>
            }
        </div>
    </div>

    <!-- Hakkında -->
    <div class="card mb-4">
        <div class="card-header bg-white">
            <i class="bi bi-info-circle me-2 text-info"></i> Uygulama Hakkında
        </div>
        <div class="list-group list-group-flush">
            <div class="list-group-item d-flex justify-content-between">
                <span>Versiyon</span>
                <span class="text-muted">1.0.0</span>
            </div>
            <div class="list-group-item d-flex justify-content-between">
                <span>Son Güncelleme</span>
                <span class="text-muted">@DateTime.Now.ToString("dd.MM.yyyy")</span>
            </div>
        </div>
    </div>

    <!-- Çıkış Butonu -->
    <button class="btn btn-outline-danger w-100 py-3" @onclick="CikisYapAsync">
        <i class="bi bi-box-arrow-right me-2"></i>
        Çıkış Yap
    </button>
</div>

@code {
    private KullaniciBilgisi? _kullanici;
    private bool _konumTakibiAktif = true;
    private bool _bildirimlerAktif = true;
    private bool _karanlikMod = false;
    private string _sunucuAdresi = "";
    private string? _baglantiDurumu;
    private bool _baglantiBasarili;

    protected override async Task OnInitializedAsync()
    {
        if (ApiService.TokenGecerliMi)
        {
            _kullanici = await ApiService.KullaniciBilgisiGetirAsync();
        }
        
        // Ayarları yükle (localStorage'dan)
        await AyarlariYukleAsync();
    }

    private async Task AyarlariYukleAsync()
    {
        _sunucuAdresi = await ApiService.GetSunucuAdresiAsync();
    }

    private async Task BaglantiyiTestEtAsync()
    {
        _baglantiDurumu = "Test ediliyor...";
        _baglantiBasarili = false;
        StateHasChanged();

        try
        {
            await ApiService.SetSunucuAdresiAsync(_sunucuAdresi);
            var sonuc = await ApiService.BaglantiyiTestEtAsync();
            _baglantiBasarili = sonuc;
            _baglantiDurumu = sonuc ? "Bağlantı başarılı" : "Bağlantı başarısız";
        }
        catch
        {
            _baglantiBasarili = false;
            _baglantiDurumu = "Bağlantı hatası";
        }
    }

    private async Task SunucuAdresiniKaydetAsync()
    {
        await ApiService.SetSunucuAdresiAsync(_sunucuAdresi);
        _sunucuAdresi = await ApiService.GetSunucuAdresiAsync();
        _baglantiBasarili = true;
        _baglantiDurumu = "Sunucu adresi kaydedildi";
    }

    private void VarsayilanSunucuyuUygula()
    {
        _sunucuAdresi = "192.168.1.10:5190";
        _baglantiDurumu = null;
    }

    private async Task CikisYapAsync()
    {
        await ApiService.CikisYapAsync();
        Navigation.NavigateTo("/", forceLoad: true);
    }

    private void GeriGit() => Navigation.NavigateTo("/");
}
